@page "/admision"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Visal.Application.Tenancy
@inject IPacienteService Svc
@inject IAseguradoraService AseSvc
@inject ISucursalService SucSvc
@inject ICatalogoPacienteService CatSvc
@inject IGeografiaService GeoSvc
@inject ICie11Service Cie11Svc
@inject INotaMedicaService NotaSvc
@inject IJSRuntime JS

<PageTitle>Admision de Pacientes - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Operacion Clinica</div>
        <h1 class="ase-title">Admision de Pacientes</h1>
    </div>
    <div style="display:flex; gap:8px;">
        <button class="btn btn-outline-primary btn-sm" @onclick="OpenImport" title="Importar pacientes desde Excel">&#128229; Importar Excel</button>
        <button class="btn btn-primary btn-sm" @onclick="New">+ Nuevo paciente</button>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-grid">
    <div class="ase-card ase-list">
        <div class="ase-card-h">Pacientes (@_lista.Count)</div>
        <input class="form-control form-control-sm mb-2" placeholder="Buscar por nombre o documento..." value="@_filtro" @oninput="OnFiltro" />
        @foreach (var p in _lista)
        {
            <button class="ase-li @(p.Id == _id ? "sel" : "")" @onclick="() => Select(p.Id)">
                <div class="ase-li-name">@p.NombreCompleto</div>
                <div class="ase-li-sub">@p.NumeroDocumento &middot; @(p.Ciudad ?? "-") &middot; @(p.Aseguradora ?? "Sin aseguradora")</div>
                <div class="ase-li-sub">@(p.Sede ?? "Sin sede") &middot; @(p.Estado ?? "Sin estado")</div>
            </button>
        }
        @if (_lista.Count == 0) { <div class="ase-empty">Sin pacientes.</div> }
    </div>

    <div class="ase-detail">
        @if (!_showForm)
        {
            <div class="ase-card"><div class="ase-empty">Selecciona o registra un paciente.</div></div>
        }
        else
        {
            <div class="ase-card">
                <div class="pac-tabs">
                    <button class="pac-tab @(_tab == "generales" ? "active" : "")" @onclick="@(() => _tab = "generales")">Datos Generales</button>
                    <button class="pac-tab @(_tab == "adicionales" ? "active" : "")" @onclick="@(() => _tab = "adicionales")">Datos Adicionales</button>
                    <button class="pac-tab @(_tab == "detalle" ? "active" : "")" @onclick="@(() => _tab = "detalle")">Detalle</button>
                    <button class="pac-tab @(_tab == "documentos" ? "active" : "")" @onclick="OnAbrirDocumentosTab" disabled="@(_id is null)">Documentos@(_docs.Count > 0 ? $" ({_docs.Count})" : "")</button>
                </div>

                @* ===== TAB DATOS GENERALES ===== *@
                @if (_tab == "generales")
                {
                    <div class="ase-card-h">Identificacion</div>
                    <div class="ase-form">
                        <div class="ase-f"><label>Numero Documento *</label><input class="form-control form-control-sm" @bind="_doc" /></div>
                        <div class="ase-f"><label>Tipo Documento</label>
                            <select class="form-select form-select-sm" @bind="_tipoDoc">
                                <option>CC</option><option>CE</option><option>TI</option><option>RC</option><option>PA</option><option>MS</option>
                            </select>
                        </div>
                        <div class="ase-f"><label>Primer Nombre</label><input class="form-control form-control-sm" @bind="_pNombre" /></div>
                        <div class="ase-f"><label>Segundo Nombre</label><input class="form-control form-control-sm" @bind="_sNombre" /></div>
                        <div class="ase-f"><label>Primer Apellido</label><input class="form-control form-control-sm" @bind="_pApellido" /></div>
                        <div class="ase-f"><label>Segundo Apellido</label><input class="form-control form-control-sm" @bind="_sApellido" /></div>
                        <div class="ase-f"><label>Fecha Nacimiento</label><input type="date" class="form-control form-control-sm" @bind="_fnac" @bind:after="RecalcularEdad" /></div>
                        <div class="ase-f"><label>Edad <small class="text-muted">(auto)</small></label><input type="number" class="form-control form-control-sm" @bind="_edad" readonly /></div>
                    </div>

                    <div class="ase-card-h" style="margin-top:14px;">Datos administrativos PAD</div>
                    <div class="ase-form">
                        <div class="ase-f"><label>IPS Que Comenta</label>
                            <select class="form-select form-select-sm" value="@_ipsComenta" @onchange="OnIpsComentaChanged">
                                <option value="">Seleccione Elemento</option>
                                @foreach (var a in _aseguradoras) { <option value="@a.Id">@a.Nombre (@a.Codigo)</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Codigo de Aceptacion</label><input class="form-control form-control-sm" @bind="_codAcept" /></div>
                        <div class="ase-f"><label>Fecha Comentan</label><input type="date" class="form-control form-control-sm" @bind="_fComenta" /></div>
                        <div class="ase-f"><label>Entidad Aseguradora</label>
                            <select class="form-select form-select-sm" @bind="_aseId">
                                <option value="">Seleccione Elemento</option>
                                @foreach (var a in _aseguradoras) { <option value="@a.Id">@a.Nombre (@a.Codigo)</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>FECHA INGRESO PAD</label><input type="date" class="form-control form-control-sm" @bind="_fIngreso" /></div>
                        <div class="ase-f"><label>FECHA EGRESO PAD</label><input type="date" class="form-control form-control-sm" @bind="_fEgreso" /></div>
                        <div class="ase-f"><label>Dias Estancia</label><input type="number" class="form-control form-control-sm" @bind="_diasEst" /></div>
                        <div class="ase-f"><label>Op. de Ingreso (dias)</label><input type="number" class="form-control form-control-sm" @bind="_opIngreso" /></div>
                    </div>

                    <div class="ase-card-h" style="margin-top:14px;">Clasificacion</div>
                    <div class="ase-form">
                        <div class="ase-f"><label>Incapacidad</label>
                            <select class="form-select form-select-sm" @bind="_incapacidad">
                                <option value="">--</option><option>SI</option><option>NO</option>
                            </select>
                        </div>
                        <div class="ase-f"><label>Grupo RH</label>
                            <select class="form-select form-select-sm" @bind="_grupoRh">
                                <option value="">--</option><option>O+</option><option>O-</option><option>A+</option><option>A-</option><option>B+</option><option>B-</option><option>AB+</option><option>AB-</option>
                            </select>
                        </div>
                        <div class="ase-f"><label>Tipo Usuario</label>
                            <select class="form-select form-select-sm" @bind="_tipoUsuario">
                                <option value="">--</option>
                                @foreach (var c in CatItems(CatalogoPacienteTipo.TipoUsuario)) { <option value="@c.Id">@c.Nombre</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Estado</label>
                            <select class="form-select form-select-sm" @bind="_estado">
                                <option value="">Seleccione Elemento</option><option>ACTIVO</option><option>INACTIVO</option>
                            </select>
                        </div>
                        <div class="ase-f"><label>Clasificacion Paciente</label>
                            <select class="form-select form-select-sm" @bind="_clasifPaciente">
                                <option value="">--</option>
                                @foreach (var c in CatItems(CatalogoPacienteTipo.ClasificacionPaciente)) { <option value="@c.Id">@c.Nombre</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Clasificacion Grupo de Patologia</label>
                            <select class="form-select form-select-sm" @bind="_clasifGrupo">
                                <option value="">--</option>
                                @foreach (var c in CatItems(CatalogoPacienteTipo.ClasificacionGrupoPatologia)) { <option value="@c.Id">@c.Nombre</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Contrato 1</label>
                            <select class="form-select form-select-sm" @bind="_contrato1" disabled="@(_contratosAse.Count == 0)">
                                <option value="">@(_contratosAse.Count == 0 ? "Selecciona IPS que comenta" : "Seleccione Elemento")</option>
                                @foreach (var c in _contratosAse) { <option value="@c.Id">@c.CodigoContrato</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Contrato 2</label>
                            <select class="form-select form-select-sm" @bind="_contrato2" disabled="@(_contratosAse.Count == 0)">
                                <option value="">@(_contratosAse.Count == 0 ? "Selecciona IPS que comenta" : "Seleccione Elemento")</option>
                                @foreach (var c in _contratosAse) { <option value="@c.Id">@c.CodigoContrato</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Contrato 3</label>
                            <select class="form-select form-select-sm" @bind="_contrato3" disabled="@(_contratosAse.Count == 0)">
                                <option value="">@(_contratosAse.Count == 0 ? "Selecciona IPS que comenta" : "Seleccione Elemento")</option>
                                @foreach (var c in _contratosAse) { <option value="@c.Id">@c.CodigoContrato</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Estrato Social</label>
                            <select class="form-select form-select-sm" @bind="_estrato">
                                <option value="">--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option><option>6</option><option>NO REFIERE</option>
                            </select>
                        </div>
                        <div class="ase-f"><label>Sexo</label>
                            <select class="form-select form-select-sm" @bind="_sexo">
                                <option value="">--</option><option>MASCULINO</option><option>FEMENINO</option><option>INDETERMINADO</option>
                            </select>
                        </div>
                        <div class="ase-f"><label>Zona</label>
                            <select class="form-select form-select-sm" @bind="_zona">
                                <option value="">--</option><option>URBANA</option><option>RURAL</option>
                            </select>
                        </div>
                    </div>

                    <div class="ase-card-h" style="margin-top:14px;">Diagnostico</div>
                    <div class="ase-form">
                        <div class="ase-f">
                            <label>CIE10 / CIE-11</label>
                            <div class="cie-input-row">
                                <input class="form-control form-control-sm mono" @bind="_cie10Codigo" placeholder="Codigo" />
                                <button class="btn btn-danger btn-sm" title="Buscar diagnostico" @onclick="OpenCieModal">Buscar</button>
                            </div>
                        </div>
                        <div class="ase-f ase-f-wide"><label>Diagnostico Principal</label><input class="form-control form-control-sm" @bind="_dxPrincipal" /></div>
                        <div class="ase-f"><label>Tutela</label>
                            <select class="form-select form-select-sm" @bind="_tutela">
                                <option value="">--</option><option>SI</option><option>NO</option>
                            </select>
                        </div>
                        <div class="ase-f"><label>Tipo Tutela</label>
                            <select class="form-select form-select-sm" @bind="_tipoTutela">
                                <option value="">--</option>
                                @foreach (var c in CatItems(CatalogoPacienteTipo.TipoTutela)) { <option value="@c.Id">@c.Nombre</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Med Contratado</label>
                            <select class="form-select form-select-sm" @bind="_medContratado">
                                <option value="">Seleccione Elemento</option>
                                @foreach (var c in CatItems(CatalogoPacienteTipo.MedContratado)) { <option value="@c.Id">@c.Nombre</option> }
                            </select>
                        </div>
                    </div>

                    <div class="ase-card-h" style="margin-top:14px;">Geografia y contacto</div>
                    <div class="ase-form">
                        <div class="ase-f"><label>Pais Residencia</label>
                            <select class="form-select form-select-sm" value="@_paisResidencia" @onchange="OnPaisResidenciaChanged">
                                <option value="">--</option>
                                @foreach (var p in _paises) { <option value="@p.Id">@p.Nombre</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Pais Origen</label>
                            <select class="form-select form-select-sm" @bind="_paisOrigen">
                                <option value="">--</option>
                                @foreach (var p in _paises) { <option value="@p.Id">@p.Nombre</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Departamento</label>
                            <select class="form-select form-select-sm" value="@_departamento" @onchange="OnDepartamentoChanged" disabled="@(_departamentos.Count == 0)">
                                <option value="">--</option>
                                @foreach (var d in _departamentos) { <option value="@d.Id">@d.Nombre</option> }
                            </select>
                        </div>
                        <div class="ase-f"><label>Municipio</label>
                            <select class="form-select form-select-sm" @bind="_municipio" disabled="@(_municipios.Count == 0)">
                                <option value="">--</option>
                                @foreach (var m in _municipios) { <option value="@m.Id">@m.Nombre</option> }
                            </select>
                        </div>
                        <div class="ase-f ase-f-wide"><label>Direccion</label><input class="form-control form-control-sm" @bind="_dir" /></div>
                        <div class="ase-f"><label>Barrio</label><input class="form-control form-control-sm" @bind="_barrio" /></div>
                        <div class="ase-f"><label>Ciudad</label><input class="form-control form-control-sm" @bind="_ciudad" /></div>
                        <div class="ase-f"><label>Telefono</label>
                            <div style="display:flex;gap:6px;">
                                <select class="form-select form-select-sm" style="max-width:110px;" @bind="_codPaisTel">
                                    @foreach (var cp in _codigosPais) { <option value="@cp.Codigo">@cp.Codigo @cp.Pais</option> }
                                </select>
                                <input class="form-control form-control-sm" @bind="_tel" placeholder="Solo numero" />
                            </div>
                        </div>
                        <div class="ase-f"><label>Correo Electronico</label><input class="form-control form-control-sm" @bind="_email" /></div>
                        <div class="ase-f"><label>Sede Atencion</label>
                            <select class="form-select form-select-sm" @bind="_sedeId">
                                <option value="">--</option>
                                @foreach (var s in _sedes) { <option value="@s.Id">@s.Nombre</option> }
                            </select>
                        </div>
                    </div>
                }

                @* ===== TAB DATOS ADICIONALES ===== *@
                @if (_tab == "adicionales")
                {
                    <div class="ase-card-h">Estado civil, ocupacion, regimen</div>
                    <div class="ase-form">
                        <div class="ase-f"><label>Estado civil</label>
                            <select class="form-select form-select-sm" @bind="_estadoCivil"><option value="">--</option><option>SOLTERO</option><option>CASADO</option><option>UNION LIBRE</option><option>VIUDO</option><option>DIVORCIADO</option><option>NO REFIERE</option></select>
                        </div>
                        <div class="ase-f"><label>Ocupacion</label>
                            <input class="form-control form-control-sm" @bind="_ocupacion" list="ocupaciones-sug" placeholder="Escribe o selecciona..." />
                            <datalist id="ocupaciones-sug">
                                <option value="NO APLICA"></option>
                                <option value="NO REFIERE"></option>
                            </datalist>
                        </div>
                        <div class="ase-f"><label>Regimen</label>
                            <select class="form-select form-select-sm" @bind="_regimen"><option value="">--</option><option>CONTRIBUTIVO</option><option>SUBSIDIADO</option><option>PARTICULAR</option><option>ESPECIAL</option></select>
                        </div>
                    </div>

                    <div class="ase-card-h" style="margin-top:14px;display:flex;justify-content:space-between;align-items:center;">
                        <span>Contactos de emergencia</span>
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AgregarContactoEmergencia">+ Agregar contacto</button>
                    </div>
                    @if (_contactos.Count == 0)
                    {
                        <div class="ase-empty" style="padding:14px;">Sin contactos. Pulsa "+ Agregar contacto" para registrar uno.</div>
                    }
                    @for (var i = 0; i < _contactos.Count; i++)
                    {
                        var idx = i;
                        var c = _contactos[idx];
                        <div class="ase-form" style="border:1px solid #e2e8f0;border-radius:8px;padding:10px;margin-bottom:8px;">
                            <div class="ase-f ase-f-wide"><label>Nombre (#@(idx + 1))</label>
                                <input class="form-control form-control-sm" @bind="c.Nombre" />
                            </div>
                            <div class="ase-f"><label>Parentesco</label>
                                <input class="form-control form-control-sm" @bind="c.Parentesco" placeholder="Madre, padre, conyuge..." />
                            </div>
                            <div class="ase-f ase-f-wide"><label>Telefono</label>
                                <div style="display:flex;gap:6px;">
                                    <select class="form-select form-select-sm" style="max-width:110px;" @bind="c.CodigoPais">
                                        @foreach (var cp in _codigosPais) { <option value="@cp.Codigo">@cp.Codigo @cp.Pais</option> }
                                    </select>
                                    <input class="form-control form-control-sm" @bind="c.Telefono" placeholder="Solo numero" />
                                </div>
                            </div>
                            <button type="button" class="btn btn-link text-danger btn-sm" style="align-self:end;" @onclick="() => QuitarContactoEmergencia(idx)" title="Quitar contacto">&#128465; Quitar</button>
                        </div>
                    }

                    <label class="ase-chk" style="margin-top:8px;"><input type="checkbox" @bind="_activo" /> <span>Activo</span></label>
                }

                @* ===== TAB DETALLE ===== *@
                @if (_tab == "detalle")
                {
                    <div class="ase-card-h">Detalle clinico (proximo modulo)</div>
                    <div class="ase-empty">
                        Aqui ira la HC del paciente, historial de ingresos, ordenes clinicas, notas medicas y formularios diligenciados.
                        Por ahora se reservan los cimientos del paciente.
                    </div>
                }

                @* ===== TAB DOCUMENTOS DEL PACIENTE ===== *@
                @if (_tab == "documentos")
                {
                    <div class="ase-card-h" style="display:flex;justify-content:space-between;align-items:center;">
                        <span>Documentos adjuntos del paciente</span>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="RecargarDocsPacienteAsync" disabled="@_docsBusy" title="Refrescar lista">&#128260; Refrescar</button>
                    </div>
                    <div class="text-muted" style="font-size:11.5px;margin-bottom:10px;">
                        Todos los archivos cargados a notas medicas (firmas, ordenes, anexos) aparecen aqui. Usa "Refrescar" si acabas de capturar una firma por WhatsApp.
                    </div>
                    @if (_docsError is not null)
                    {
                        <div class="ase-alert">Error al cargar documentos: @_docsError</div>
                    }
                    @if (_docsBusy)
                    {
                        <div class="ase-empty"><em>Cargando documentos...</em></div>
                    }
                    else if (_docs.Count == 0)
                    {
                        <div class="ase-empty">Aun no hay documentos adjuntos para este paciente.</div>
                    }
                    else
                    {
                        <div class="ase-table-wrap">
                            <table class="table table-sm pac-docs-tbl">
                                <thead>
                                    <tr>
                                        <th>Categoria</th>
                                        <th>Nombre del archivo</th>
                                        <th>Nota</th>
                                        <th>Fecha nota</th>
                                        <th>Subido</th>
                                        <th>Tamano</th>
                                        <th style="width:120px;">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in _docs)
                                    {
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(d.Categoria))
                                                {
                                                    <span class="pac-doc-cat">@d.Categoria</span>
                                                }
                                                else { <span class="text-muted">-</span> }
                                            </td>
                                            <td title="@d.Anotaciones">@d.NombreOriginal</td>
                                            <td><span class="text-muted">@(d.CodigoNota ?? d.NotaMedicaId.ToString()[..8])</span></td>
                                            <td>@(d.FechaNota?.ToString("dd/MM/yyyy") ?? "-")</td>
                                            <td>@d.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@FormatTam(d.Tamano)</td>
                                            <td>
                                                <a class="btn btn-outline-secondary btn-sm" href="@d.RutaArchivo" target="_blank" title="Abrir / descargar">&#128190; Ver</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }

                <div class="ase-actions" style="margin-top:18px;">
                    <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@_busy">@(_busy ? "Guardando..." : "Guardar paciente")</button>
                    @if (_id is not null)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="Desactivar" disabled="@_busy" title="Marcar como inactivo sin borrar el historial clinico">Desactivar</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="Delete" disabled="@_busy" title="Eliminar definitivamente. Solo se puede si el paciente no tiene HC, notas ni asignaciones.">Eliminar</button>
                    }
                </div>
            </div>
        }
    </div>
</div>

@* ===== Modal de busqueda CIE-11 (WHO ICD-11 API) ===== *@
@if (_cieModal)
{
    <div class="cie-backdrop" @onclick="CloseCieModal"></div>
    <div class="cie-modal">
        <div class="cie-modal-h">
            <h3>Buscar Diagnostico o Codigo</h3>
            <button class="cie-modal-close" @onclick="CloseCieModal">&times;</button>
        </div>
        <div class="cie-modal-body">
            <div class="cie-search-row">
                <input class="form-control form-control-sm" placeholder="Ej.: diabetes, covid, 5A11..."
                       @bind="_cieQuery" @bind:event="oninput"
                       @onkeyup="OnCieKeyUp" />
                <button class="btn btn-danger btn-sm" @onclick="SearchCie" disabled="@_cieBusy">@(_cieBusy ? "..." : "Buscar")</button>
            </div>
            @if (_cieError is not null) { <div class="ase-alert" style="margin-top:10px;">@_cieError</div> }
            <div class="cie-result-h">Resultados de la Busqueda</div>
            <div class="cie-result-list">
                @if (_cieBusy) { <div class="cie-empty">Buscando en WHO ICD-11...</div> }
                else if (_cieResults.Count == 0) { <div class="cie-empty">Escribe un termino y pulsa Buscar.</div> }
                else
                {
                    @foreach (var r in _cieResults)
                    {
                        <button class="cie-result-item" @onclick="() => SelectCieAsync(r)">
                            @if (!string.IsNullOrWhiteSpace(r.Code))
                            {
                                <span class="cie-code">@r.Code</span>
                            }
                            <span class="cie-title">@r.Title</span>
                        </button>
                    }
                }
            </div>
        </div>
    </div>
}

<style>
    .pac-tabs { display: flex; gap: 4px; border-bottom: 1.5px solid #e2e8f0; margin-bottom: 18px; padding-bottom: 0; }
    .pac-tab:disabled { opacity: .5; cursor: not-allowed; }
    .pac-docs-tbl { font-size: 12.5px; }
    .pac-docs-tbl thead th { font-size: 11px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: .04em; background: #f1f5f9; }
    .pac-doc-cat { display: inline-block; padding: 2px 8px; border-radius: 999px; background: #ecfdf5; color: #047857; font-size: 11px; font-weight: 700; }
    .ase-table-wrap { overflow: auto; border: 1px solid #e2e8f0; border-radius: 8px; background: #fff; }
