            {
                Nombre = d.ContactoEmergencia!,
                Parentesco = d.Parentesco,
                CodigoPais = "+57",
                Telefono = d.TelefonoEmergencia,
                Orden = 1
            });
        }
        _showForm = true; _tab = "generales"; _error = _ok = null;
    }

    private async Task Save()
    {
        _error = _ok = null; _busy = true;
        try
        {
            Guid? ase = Guid.TryParse(_aseId, out var ag) ? ag : null;
            Guid? sede = Guid.TryParse(_sedeId, out var sg) ? sg : null;
            Guid? Try(string s) => Guid.TryParse(s, out var g) ? g : null;
            var req = new SavePacienteRequest(
                _id,
                _doc, _tipoDoc, _pNombre, _sNombre, _pApellido, _sApellido, null,
                _fnac, _edad,
                Try(_ipsComenta), _codAcept, _fComenta,
                ase, _fIngreso, _fEgreso, _diasEst, _opIngreso,
                _incapacidad, _grupoRh, Try(_tipoUsuario), _estado,
                Try(_clasifPaciente), Try(_clasifGrupo),
                _estrato, _sexo, _estadoCivil, _zona, _ocupacion, _regimen,
                Try(_contrato1), Try(_contrato2), Try(_contrato3),
                null, _cie10Codigo, _dxPrincipal,
                _tutela, Try(_tipoTutela), Try(_medContratado),
                Try(_paisResidencia), Try(_paisOrigen), Try(_departamento), Try(_municipio),
                _dir, _barrio, _ciudad,
                _codPaisTel, _tel, _email,
                sede,
                _emerNombre, _emerParentesco, _emerTel,
                _contactos
                    .Where(c => !string.IsNullOrWhiteSpace(c.Nombre))
                    .Select((c, i) => new PacienteContactoEmergenciaDto(
                        c.Id, c.Nombre.Trim(), c.Parentesco?.Trim(),
                        string.IsNullOrWhiteSpace(c.CodigoPais) ? "+57" : c.CodigoPais.Trim(),
                        c.Telefono?.Trim(),
                        c.Orden > 0 ? c.Orden : i + 1))
                    .ToList(),
                _activo);
            var saved = await Svc.SaveAsync(req, await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            await Select(saved.Id); await LoadLista(); _ok = $"Paciente \"{saved.NombreCompleto}\" guardado.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task Delete()
    {
        if (_id is not Guid id) { return; }
        _busy = true; _error = null; _ok = null;
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm",
                "Eliminar definitivamente este paciente? Esta accion no se puede deshacer.");
            if (!ok) { return; }
            await Svc.DeleteAsync(id, await Actor());
            _showForm = false; _id = null; await LoadLista(); _ok = "Paciente eliminado.";
        }
        catch (InvalidOperationException ex)
        {
            // Mensaje legible del servicio (paciente con HC/notas/asignaciones).
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            // Error inesperado (incluye violaciones de FK no anticipadas).
            _error = "No se pudo eliminar el paciente: " + ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task Desactivar()
    {
        if (_id is not Guid id) { return; }
        _busy = true; _error = null; _ok = null;
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm",
                "Marcar este paciente como inactivo? El historial clinico se conserva. Podras reactivarlo despues editando.");
            if (!ok) { return; }
            await Svc.DesactivarAsync(id, await Actor());
            await LoadLista();
            _ok = "Paciente desactivado.";
            // Reflejar el cambio en el form sin cerrar.
            _activo = false;
        }
        catch (Exception ex) { _error = "No se pudo desactivar: " + ex.Message; }
        finally { _busy = false; }
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    // ===== Import desde Excel =====

    private bool _showImportModal;
    private bool _importing;
    private string? _importError;
    private int _importTotal, _importCurrent, _importOk, _importErr;
    private double _importProgress;
    private readonly List<string> _importLog = new();

    private void OpenImport()
    {
        _showImportModal = true;
        _importError = null;
        _importLog.Clear();
        _importTotal = _importCurrent = _importOk = _importErr = 0;
        _importProgress = 0;
    }

    private void CloseImport()
    {
        if (_importing) { return; }
        _showImportModal = false;
    }

    private async Task OnExcelSelected(InputFileChangeEventArgs e)
    {
        _importError = null;
        _importLog.Clear();
        _importTotal = _importCurrent = _importOk = _importErr = 0;
        _importProgress = 0;
        _importing = true;
        try
        {
            const long max = 25L * 1024 * 1024;
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(max).CopyToAsync(ms);
            ms.Position = 0;

            using var wb = new ClosedXML.Excel.XLWorkbook(ms);
            var ws = wb.Worksheets.First();
            var lastRow = ws.LastRowUsed()?.RowNumber() ?? 1;
            _importTotal = Math.Max(0, lastRow - 1);

            // Lookup de pacientes existentes para upsert por documento.
            var existentes = await Svc.ListAsync(null);
            var byDoc = new Dictionary<string, PacienteDto>(StringComparer.OrdinalIgnoreCase);
            foreach (var p in existentes) { byDoc[p.NumeroDocumento.Trim()] = p; }

            // Cargar TODOS los catalogos una vez para resolver los nombres del
            // Excel a IDs sin hacer queries por fila.
            var sedesAll = await SucSvc.ListAsync(soloActivas: true);
            var sedesByNombre = new Dictionary<string, Guid>(StringComparer.OrdinalIgnoreCase);
            foreach (var s in sedesAll)
            {
                if (!string.IsNullOrWhiteSpace(s.Nombre)) { sedesByNombre[s.Nombre.Trim()] = s.Id; }
                if (!string.IsNullOrWhiteSpace(s.Codigo) && !sedesByNombre.ContainsKey(s.Codigo!.Trim())) { sedesByNombre[s.Codigo.Trim()] = s.Id; }
            }

            var aseguradorasAll = await AseSvc.ListAseguradorasAsync();
            var aseByNombre = new Dictionary<string, Guid>(StringComparer.OrdinalIgnoreCase);
            foreach (var a in aseguradorasAll)
            {
                if (!string.IsNullOrWhiteSpace(a.Nombre)) { aseByNombre[a.Nombre.Trim()] = a.Id; }
                if (!string.IsNullOrWhiteSpace(a.Codigo) && !aseByNombre.ContainsKey(a.Codigo!.Trim())) { aseByNombre[a.Codigo.Trim()] = a.Id; }
            }

            Dictionary<string, Guid> CatPorTipo(IReadOnlyList<CatalogoPacienteDto> items)
            {
                var d = new Dictionary<string, Guid>(StringComparer.OrdinalIgnoreCase);
                foreach (var c in items)
                {
                    if (!string.IsNullOrWhiteSpace(c.Nombre)) { d[c.Nombre.Trim()] = c.Id; }
                    if (!string.IsNullOrWhiteSpace(c.Codigo) && !d.ContainsKey(c.Codigo!.Trim())) { d[c.Codigo.Trim()] = c.Id; }
                }
                return d;
            }
            var tiposUsuario = CatPorTipo(await CatSvc.ListAsync(Visal.Domain.Enums.CatalogoPacienteTipo.TipoUsuario));
            var clasifPaciente = CatPorTipo(await CatSvc.ListAsync(Visal.Domain.Enums.CatalogoPacienteTipo.ClasificacionPaciente));
            var clasifGrupo = CatPorTipo(await CatSvc.ListAsync(Visal.Domain.Enums.CatalogoPacienteTipo.ClasificacionGrupoPatologia));
            var tiposTutela = CatPorTipo(await CatSvc.ListAsync(Visal.Domain.Enums.CatalogoPacienteTipo.TipoTutela));
            var medContratado = CatPorTipo(await CatSvc.ListAsync(Visal.Domain.Enums.CatalogoPacienteTipo.MedContratado));

            // Geografia. Solo paises arriba; departamentos/municipios se
            // resuelven on-demand por fila (cascada).
            var paisesAll = await GeoSvc.ListPaisesAsync();
            var paisByNombre = new Dictionary<string, Guid>(StringComparer.OrdinalIgnoreCase);
            foreach (var p in paisesAll)
            {
                if (!string.IsNullOrWhiteSpace(p.Nombre)) { paisByNombre[p.Nombre.Trim()] = p.Id; }
                if (!string.IsNullOrWhiteSpace(p.Codigo) && !paisByNombre.ContainsKey(p.Codigo!.Trim())) { paisByNombre[p.Codigo.Trim()] = p.Id; }
            }

            // Cache departamentos/municipios por pais para no traerlos N veces.
            var deptosCache = new Dictionary<Guid, Dictionary<string, Guid>>();
            var mpiosCache = new Dictionary<Guid, Dictionary<string, Guid>>();

            // Cache contratos por aseguradora.
            var contratosCache = new Dictionary<Guid, Dictionary<string, Guid>>();

            var actor = await Actor();

            for (var r = 2; r <= lastRow; r++)
            {
                _importCurrent = r - 1;
                _importProgress = (double)_importCurrent / Math.Max(1, _importTotal) * 100;
                try
                {
                    // Helpers de lectura tolerantes a celdas raras: si la celda tiene
                    // un error #N/A, formato inesperado, o tipo no convertible, NO
                    // tira excepcion — devuelve "" o null. Asi una sola celda mala
                    // no rompe la fila entera ni el import completo.
                    string T(int col)
                    {
                        try { return (ws.Cell(r, col).GetString() ?? string.Empty).Trim(); }
                        catch { return string.Empty; }
                    }
                    string? TN(int col) { var v = T(col); return string.IsNullOrWhiteSpace(v) ? null : v; }
                    // Truncado defensivo: si el Excel tiene un valor mas largo que el
                    // limite de la columna en BD (varchar(40), varchar(120), etc.),
                    // recortamos en vez de fallar la fila entera. La perdida visible
                    // es minima (un telefono o codigo recortado) frente a perder al
                    // paciente completo.
                    static string? Trunc(string? s, int max)
                        => s is null ? null : (s.Length <= max ? s : s.Substring(0, max));
                    int? TI(int col)
                    {
                        var v = T(col);
                        if (string.IsNullOrWhiteSpace(v)) { return null; }
                        if (int.TryParse(v, out var n)) { return n; }
                        // "3.0" o "3,0" => 3 (toleramos celdas exportadas como decimal).
                        if (double.TryParse(v, System.Globalization.NumberStyles.Any,
                                System.Globalization.CultureInfo.InvariantCulture, out var d)) { return (int)d; }
                        if (double.TryParse(v.Replace(',', '.'), System.Globalization.NumberStyles.Any,
                                System.Globalization.CultureInfo.InvariantCulture, out var d2)) { return (int)d2; }
                        return null;
                    }
                    DateOnly? TFecha(int col)
                    {
                        try
                        {
                            if (ws.Cell(r, col).TryGetValue<DateTime>(out var dtv)) { return DateOnly.FromDateTime(dtv); }
                        }
                        catch { /* sigue con texto */ }
                        var s = T(col);
                        if (string.IsNullOrWhiteSpace(s)) { return null; }
                        // Aceptamos los formatos mas comunes que vimos en archivos
                        // exportados desde Excel/Sheets en Colombia + ISO.
                        var fmts = new[] {
                            "dd/MM/yyyy", "d/M/yyyy", "dd-MM-yyyy", "d-M-yyyy",
                            "yyyy-MM-dd", "yyyy/MM/dd", "yyyyMMdd",
                            "MM/dd/yyyy", "M/d/yyyy", "dd/MM/yy"
                        };
                        if (DateTime.TryParseExact(s, fmts,
                                System.Globalization.CultureInfo.InvariantCulture,
                                System.Globalization.DateTimeStyles.None, out var dt)) { return DateOnly.FromDateTime(dt); }
                        // Como ultimo recurso, intentamos parse flexible.
                        if (DateTime.TryParse(s, new System.Globalization.CultureInfo("es-CO"),
                                System.Globalization.DateTimeStyles.None, out var dt2)) { return DateOnly.FromDateTime(dt2); }
                        return null;
                    }
                    Guid? Lookup(Dictionary<string, Guid> dic, int col, string nombre)
                    {
                        var v = T(col);
                        if (string.IsNullOrWhiteSpace(v)) { return null; }
                        if (dic.TryGetValue(v, out var id)) { return id; }
                        _importLog.Add($"[..]  Fila {r}: {nombre} '{v}' no existe en el tenant — se deja vacio.");
                        return null;
                    }
                    bool SiNo(int col) => string.Equals(T(col), "SI", StringComparison.OrdinalIgnoreCase);

                    var doc = T(1);
                    if (string.IsNullOrWhiteSpace(doc)) { continue; }

                    var tipoDoc = (T(2) is { Length: > 0 } td) ? td.ToUpperInvariant() : "CC";
                    var pn = T(3); var sn = T(4); var pa = T(5); var sa = T(6);
                    var fechaNac = TFecha(7);
                    var edad = TI(8);

                    var sexo = TN(9); var estadoCivil = TN(10); var grupoRh = TN(11);
                    var zona = TN(12); var regimen = TN(13); var estrato = TN(14); var ocupacion = TN(15);

                    var codPais = TN(16) ?? "+57";
                    var telefono = TN(17); var email = TN(18); var direccion = TN(19); var barrio = TN(20);

                    var paisResId = Lookup(paisByNombre, 21, "Pais residencia");
                    var paisOrigenId = Lookup(paisByNombre, 22, "Pais origen");

                    // Departamento + Municipio: cascada desde pais residencia.
                    Guid? deptoId = null;
                    Guid? mpioId = null;
                    var deptoNombre = T(23);
                    var mpioNombre = T(24);
                    if (paisResId is Guid prid && !string.IsNullOrWhiteSpace(deptoNombre))
                    {
                        if (!deptosCache.TryGetValue(prid, out var dDic))
                        {
                            dDic = new Dictionary<string, Guid>(StringComparer.OrdinalIgnoreCase);
                            foreach (var d in await GeoSvc.ListDepartamentosAsync(prid))
                            {
                                if (!string.IsNullOrWhiteSpace(d.Nombre)) { dDic[d.Nombre.Trim()] = d.Id; }
                            }
                            deptosCache[prid] = dDic;
                        }
                        if (dDic.TryGetValue(deptoNombre, out var did)) { deptoId = did; }
                        else { _importLog.Add($"[..]  Fila {r}: Departamento '{deptoNombre}' no existe en el pais elegido — se deja vacio."); }

                        if (deptoId is Guid didOk && !string.IsNullOrWhiteSpace(mpioNombre))
                        {
                            if (!mpiosCache.TryGetValue(didOk, out var mDic))
                            {
                                mDic = new Dictionary<string, Guid>(StringComparer.OrdinalIgnoreCase);
                                foreach (var m in await GeoSvc.ListMunicipiosAsync(didOk))
                                {
                                    if (!string.IsNullOrWhiteSpace(m.Nombre)) { mDic[m.Nombre.Trim()] = m.Id; }
                                }
                                mpiosCache[didOk] = mDic;
                            }
                            if (mDic.TryGetValue(mpioNombre, out var mid)) { mpioId = mid; }
                            else { _importLog.Add($"[..]  Fila {r}: Municipio '{mpioNombre}' no existe en el departamento — se deja vacio."); }
                        }
                    }
                    var ciudad = TN(25);

                    var aseId = Lookup(aseByNombre, 26, "Aseguradora");
                    // IPS Que Comenta apunta tambien a aseguradoras.
                    var ipsId = Lookup(aseByNombre, 27, "IPS Que Comenta");
                    var codAcept = TN(28);
                    var fComenta = TFecha(29);
                    var fIngreso = TFecha(30);
                    var fEgreso = TFecha(31);
                    var diasEst = TI(32);
                    var opIngreso = TI(33);

                    var incapacidad = SiNo(34) ? "SI" : (string.IsNullOrWhiteSpace(T(34)) ? null : "NO");
                    var tipoUsuarioId = Lookup(tiposUsuario, 35, "Tipo usuario");
                    var estado = TN(36);
                    var clasifPacId = Lookup(clasifPaciente, 37, "Clasificacion paciente");
                    var clasifGrpId = Lookup(clasifGrupo, 38, "Clasificacion grupo patologia");
                    var medContId = Lookup(medContratado, 39, "Med contratado");

                    var cieCodigo = TN(40);
                    var diag = TN(41);

                    var tutela = SiNo(42) ? "SI" : (string.IsNullOrWhiteSpace(T(42)) ? null : "NO");
                    var tipoTutelaId = Lookup(tiposTutela, 43, "Tipo tutela");

                    // Contratos: cascada desde aseId.
                    Guid? c1 = null; Guid? c2 = null; Guid? c3 = null;
                    if (aseId is Guid aseGid)
                    {
                        if (!contratosCache.TryGetValue(aseGid, out var cDic))
                        {
                            cDic = new Dictionary<string, Guid>(StringComparer.OrdinalIgnoreCase);
                            foreach (var c in await AseSvc.ListContratosAsync(aseGid))
                            {
                                if (!string.IsNullOrWhiteSpace(c.CodigoContrato)) { cDic[c.CodigoContrato.Trim()] = c.Id; }
                            }
                            contratosCache[aseGid] = cDic;
                        }
                        Guid? ResolveContrato(int col, int idx)
                        {
                            var v = T(col);
                            if (string.IsNullOrWhiteSpace(v)) { return null; }
                            if (cDic.TryGetValue(v, out var cid)) { return cid; }
                            _importLog.Add($"[..]  Fila {r}: Contrato {idx} '{v}' no existe en la aseguradora — se deja vacio.");
                            return null;
                        }
                        c1 = ResolveContrato(44, 1);
                        c2 = ResolveContrato(45, 2);
                        c3 = ResolveContrato(46, 3);
                    }

                    Guid? sedeId = null;
                    var sedeNombre = T(47);
                    if (!string.IsNullOrWhiteSpace(sedeNombre) && sedesByNombre.TryGetValue(sedeNombre, out var sid)) { sedeId = sid; }
                    else if (!string.IsNullOrWhiteSpace(sedeNombre)) { _importLog.Add($"[..]  Fila {r}: sede '{sedeNombre}' no existe en el tenant — se deja vacia."); }

                    var emNombre = TN(48); var emPar = TN(49); var emTel = TN(50);
                    var contactosEm = new List<PacienteContactoEmergenciaDto>();
                    if (!string.IsNullOrWhiteSpace(emNombre))
                    {
                        contactosEm.Add(new PacienteContactoEmergenciaDto(
                            Id: null, Nombre: emNombre,
                            Parentesco: emPar, CodigoPais: "+57", Telefono: emTel, Orden: 1));
                    }

                    // Activo: si el Excel no trae nada, asumimos que el usuario quiere
                    // mantener el estado actual (true para nuevos, el existente para upsert).
                    var activoCell = T(51);
                    bool activo;
                    bool activoExplicito = !string.IsNullOrWhiteSpace(activoCell);

                    var nombreCompleto = string.Join(' ', new[] { pn, sn, pa, sa }.Where(s => !string.IsNullOrWhiteSpace(s)));

                    Guid? id = null;
                    if (byDoc.TryGetValue(doc, out var existing)) { id = existing.Id; }

                    // MERGE: si el paciente ya existe, traemos el detalle actual y
                    // usamos sus valores como fallback cuando una celda del Excel viene
                    // vacia. Asi al recargar el archivo solo se ACTUALIZAN los campos
                    // nuevos, sin borrar los que ya estaban llenos en la BD.
                    PacienteDetailDto? prev = null;
                    if (id is Guid pid)
                    {
                        try { prev = await Svc.GetAsync(pid); } catch { prev = null; }
                    }
                    // string | actualExcel | (prev?.X)  -> aplica.
                    string? Pick(string? excel, string? actual) => string.IsNullOrWhiteSpace(excel) ? actual : excel;
                    int? PickI(int? excel, int? actual) => excel ?? actual;
                    DateOnly? PickD(DateOnly? excel, DateOnly? actual) => excel ?? actual;
                    Guid? PickG(Guid? excel, Guid? actual) => excel ?? actual;

                    activo = activoExplicito
                        ? string.Equals(activoCell, "SI", StringComparison.OrdinalIgnoreCase)
                        : (prev?.Activo ?? true);

                    var req = new SavePacienteRequest(
                        Id: id,
                        NumeroDocumento: Trunc(doc, 30) ?? doc,
                        TipoDocumento: Trunc(!string.IsNullOrWhiteSpace(tipoDoc) ? tipoDoc : (prev?.TipoDocumento ?? "CC"), 10) ?? "CC",
                        PrimerNombre: Trunc(Pick(pn, prev?.PrimerNombre), 80),
                        SegundoNombre: Trunc(Pick(sn, prev?.SegundoNombre), 80),
                        PrimerApellido: Trunc(Pick(pa, prev?.PrimerApellido), 80),
                        SegundoApellido: Trunc(Pick(sa, prev?.SegundoApellido), 80),
                        NombreCompleto: Trunc(string.IsNullOrWhiteSpace(nombreCompleto) ? (prev?.NombreCompleto ?? doc) : nombreCompleto, 250) ?? doc,
                        FechaNacimiento: PickD(fechaNac, prev?.FechaNacimiento),
                        Edad: PickI(edad, prev?.Edad),
                        IpsComentaId: PickG(ipsId, prev?.IpsComentaId),
                        CodigoAceptacion: Trunc(Pick(codAcept, prev?.CodigoAceptacion), 120),
                        FechaComentan: PickD(fComenta, prev?.FechaComentan),
                        AseguradoraId: PickG(aseId, prev?.AseguradoraId),
                        FechaIngresoPad: PickD(fIngreso, prev?.FechaIngresoPad),
                        FechaEgresoPad: PickD(fEgreso, prev?.FechaEgresoPad),
                        DiasEstancia: PickI(diasEst, prev?.DiasEstancia),
                        OpIngresoDias: PickI(opIngreso, prev?.OpIngresoDias),
                        Incapacidad: Trunc(Pick(incapacidad, prev?.Incapacidad), 60),
                        GrupoRh: Trunc(Pick(grupoRh, prev?.GrupoRh), 10),
                        TipoUsuarioId: PickG(tipoUsuarioId, prev?.TipoUsuarioId),
                        Estado: Trunc(Pick(estado, prev?.Estado), 120),
                        ClasificacionPacienteId: PickG(clasifPacId, prev?.ClasificacionPacienteId),
                        ClasificacionGrupoPatologiaId: PickG(clasifGrpId, prev?.ClasificacionGrupoPatologiaId),
                        EstratoSocial: Trunc(Pick(estrato, prev?.EstratoSocial), 20),
                        Sexo: Trunc(Pick(sexo, prev?.Sexo), 20),
                        EstadoCivil: Trunc(Pick(estadoCivil, prev?.EstadoCivil), 120),
                        Zona: Trunc(Pick(zona, prev?.Zona), 120),
                        Ocupacion: Trunc(Pick(ocupacion, prev?.Ocupacion), 120),
                        Regimen: Trunc(Pick(regimen, prev?.Regimen), 120),
                        Contrato1Id: PickG(c1, prev?.Contrato1Id),
                        Contrato2Id: PickG(c2, prev?.Contrato2Id),
                        Contrato3Id: PickG(c3, prev?.Contrato3Id),
                        Cie10Id: prev?.Cie10Id,
                        Cie10Codigo: Trunc(Pick(cieCodigo, prev?.Cie10Codigo), 30),
                        DiagnosticoPrincipal: Trunc(Pick(diag, prev?.DiagnosticoPrincipal), 500),
                        Tutela: Trunc(Pick(tutela, prev?.Tutela), 120),
                        TipoTutelaId: PickG(tipoTutelaId, prev?.TipoTutelaId),
                        MedContratadoId: PickG(medContId, prev?.MedContratadoId),
                        PaisResidenciaId: PickG(paisResId, prev?.PaisResidenciaId),
                        PaisOrigenId: PickG(paisOrigenId, prev?.PaisOrigenId),
                        DepartamentoId: PickG(deptoId, prev?.DepartamentoId),
                        MunicipioId: PickG(mpioId, prev?.MunicipioId),
                        Direccion: Trunc(Pick(direccion, prev?.Direccion), 300),
                        Barrio: Trunc(Pick(barrio, prev?.Barrio), 120),
                        Ciudad: Trunc(Pick(ciudad, prev?.Ciudad), 120),
                        CodigoPaisTelefono: Trunc(Pick(codPais, prev?.CodigoPaisTelefono) ?? "+57", 5) ?? "+57",
                        Telefono: Trunc(Pick(telefono, prev?.Telefono), 120),
                        Email: Trunc(Pick(email, prev?.Email), 160),
                        SedeAtencionId: PickG(sedeId, prev?.SedeAtencionId),
                        ContactoEmergencia: Trunc(Pick(emNombre, prev?.ContactoEmergencia), 200),
                        Parentesco: Trunc(Pick(emPar, prev?.Parentesco), 80),
                        TelefonoEmergencia: Trunc(Pick(emTel, prev?.TelefonoEmergencia), 120),
                        // Contactos: si el Excel no trae uno nuevo, conservamos los existentes.
                        ContactosEmergencia: contactosEm.Count > 0
                            ? contactosEm
                            : (prev?.ContactosEmergencia ?? Array.Empty<PacienteContactoEmergenciaDto>()),
                        Activo: activo);

                    var saved = await Svc.SaveAsync(req, actor);
                    if (saved is null)
                    {
                        _importErr++;
                        _importLog.Add($"[ERR] Fila {r} ({doc}): SaveAsync retorno null.");
                        continue;
                    }
                    _importOk++;
                    _importLog.Add($"[OK]  Fila {r} ({doc}): {nombreCompleto}{(id is not null ? " [upsert]" : " [nuevo]")}.");
                }
                catch (Exception ex)
                {
                    _importErr++;
                    _importLog.Add($"[ERR] Fila {r}: {ex.Message}");
                }
                if (r % 5 == 0) { StateHasChanged(); await Task.Yield(); }
            }
            _importProgress = 100;
            await LoadLista();
            _ok = $"Import terminado: {_importOk} OK, {_importErr} errores.";
        }
        catch (Exception ex)
        {
            _importError = $"Error fatal: {ex.Message}";
        }
        finally
        {
            _importing = false;
            StateHasChanged();
        }
    }
}
