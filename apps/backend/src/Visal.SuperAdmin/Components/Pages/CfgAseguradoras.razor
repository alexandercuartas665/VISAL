@page "/cfg-aseguradoras"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using System.Security.Claims
@using ClosedXML.Excel
@using Visal.Application.Tenancy
@inject IAseguradoraService Svc
@inject IPaqueteService PaqSvc
@inject IServicioBulkUpdateService BulkSvc
@inject IJSRuntime JS

<PageTitle>Entidades Aseguradoras - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion del Sistema</div>
        <h1 class="ase-title">Entidades Aseguradoras</h1>
    </div>
    <div class="ase-head-actions">
        <button class="btn btn-outline-secondary btn-sm" title="Actualizar en masa MODALIDAD, GRUPO SERVICIO y SERVICIO FACTURACION de todos los servicios que coincidan con la busqueda por Descripcion. Guarda snapshot para deshacer." @onclick="AbrirBulk">&#128736; Actualizar en masa</button>
        <button class="btn btn-primary btn-sm" @onclick="NewAseguradora">+ Nueva aseguradora</button>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-grid">
    <!-- Lista de aseguradoras -->
    <div class="ase-card ase-list">
        @{
            var _filtroNorm = (_filtro ?? string.Empty).Trim();
            var _lista = string.IsNullOrEmpty(_filtroNorm)
                ? _aseguradoras
                : _aseguradoras.Where(x =>
                        (x.Nombre ?? "").Contains(_filtroNorm, StringComparison.OrdinalIgnoreCase)
                     || (x.Codigo ?? "").Contains(_filtroNorm, StringComparison.OrdinalIgnoreCase)
                     || (x.Tipo ?? "").Contains(_filtroNorm, StringComparison.OrdinalIgnoreCase)
                     || (x.Nit ?? "").Contains(_filtroNorm, StringComparison.OrdinalIgnoreCase)
                  ).ToList();
        }
        <div class="ase-card-h">
            Aseguradoras (@_lista.Count@(_lista.Count != _aseguradoras.Count ? $" / {_aseguradoras.Count}" : ""))
        </div>
        <div style="padding:6px 10px;position:sticky;top:0;background:#fff;z-index:1;border-bottom:1px solid #f1f5f9;">
            <div style="position:relative;">
                <input class="form-control form-control-sm" style="padding-right:26px;"
                       placeholder="Buscar por nombre, codigo, tipo o NIT..."
                       @bind="_filtro" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(_filtroNorm))
                {
                    <button type="button"
                            @onclick="() => _filtro = string.Empty"
                            style="position:absolute;right:6px;top:50%;transform:translateY(-50%);border:none;background:transparent;color:#94a3b8;font-size:16px;line-height:1;cursor:pointer;"
                            title="Limpiar filtro">&times;</button>
                }
            </div>
        </div>
        @foreach (var a in _lista)
        {
            <button class="ase-li @(a.Id == _aseId ? "sel" : "")" @onclick="() => SelectAseguradora(a.Id)">
                <div class="ase-li-name">@a.Nombre</div>
                <div class="ase-li-sub">@a.Codigo &middot; @a.Tipo &middot; @a.Contratos contrato(s)</div>
            </button>
        }
        @if (_aseguradoras.Count == 0)
        {
            <div class="ase-empty">Sin aseguradoras. Crea una nueva.</div>
        }
        else if (_lista.Count == 0)
        {
            <div class="ase-empty">Sin coincidencias para "@_filtroNorm".</div>
        }
    </div>

    <!-- Detalle -->
    <div class="ase-detail">
        @if (!_showForm)
        {
            <div class="ase-card"><div class="ase-empty">Selecciona o crea una aseguradora.</div></div>
        }
        else
        {
            <div class="ase-card">
                <div class="ase-card-h">Datos de la entidad</div>
                <div class="ase-form">
                    <div class="ase-f"><label>Codigo *</label><input class="form-control form-control-sm" @bind="_aCodigo" /></div>
                    <div class="ase-f"><label>Tipo</label>
                        <select class="form-select form-select-sm" @bind="_aTipo">
                            <option>EPS</option><option>IPS</option><option>ARL</option><option>EAPB</option><option>PARTICULAR</option><option>OTRO</option>
                        </select>
                    </div>
                    <div class="ase-f ase-f-wide"><label>Nombre *</label><input class="form-control form-control-sm" @bind="_aNombre" /></div>
                    <div class="ase-f"><label>Codigo Movilidad</label><input class="form-control form-control-sm" @bind="_aMov" /></div>
                    <div class="ase-f"><label>NIT</label><input class="form-control form-control-sm" @bind="_aNit" /></div>
                    <div class="ase-f"><label>Regimen</label>
                        <select class="form-select form-select-sm" @bind="_aRegimen">
                            <option value="">--</option><option>CONTRIBUTIVO</option><option>SUBSIDIADO</option><option>PARTICULAR</option><option>ESPECIAL</option>
                        </select>
                    </div>
                    <div class="ase-f"><label>CodInt</label><input class="form-control form-control-sm" @bind="_aCodInt" /></div>
                    <div class="ase-f ase-f-wide"><label title="Correo destino para radicar la factura (Fase 4 Facturacion).">Correo facturacion</label>
                        <input class="form-control form-control-sm" type="email" @bind="_aCorreoFac" placeholder="facturacion@eps.com" />
                    </div>
                    <div class="ase-f ase-f-full"><label>Descripcion</label><textarea class="form-control form-control-sm" rows="2" @bind="_aDesc"></textarea></div>
                </div>
                <div class="ase-actions">
                    <button class="btn btn-primary btn-sm" @onclick="SaveAseguradora" disabled="@_busy">Guardar entidad</button>
                    @if (_aseId is not null)
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick="DeleteAseguradora">Eliminar</button>
                    }
                </div>
            </div>

            @if (_aseId is not null)
            {
                @* ============ Tabs: Contratos / Cuenta medica ============ *@
                <div class="ase-tabs">
                    <button class="ase-tab @(_aseTab == "contratos" ? "sel" : "")" @onclick='() => _aseTab = "contratos"'>Contratos y servicios</button>
                    <button class="ase-tab @(_aseTab == "cuentaMedica" ? "sel" : "")" @onclick='() => _aseTab = "cuentaMedica"'>Cuenta medica</button>
                </div>

                @if (_aseTab == "cuentaMedica")
                {
                    <Visal.SuperAdmin.Components.Forms.CuentaMedicaConfigPanel AseguradoraId="@_aseId" />
                }
                else
                {
                <!-- Contratos -->
                <div class="ase-card">
                    <div class="ase-card-h">Contratos <button class="btn btn-outline-primary btn-sm ms-2" @onclick="AddContrato">+ Contrato</button></div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle ase-table">
                            <thead><tr><th>Codigo</th><th>Fecha inicial</th><th>Fecha final</th><th>Estado</th><th>Prorroga</th><th title="Si se activa, la asignacion contra este contrato exige adjuntar el PDF de autorizacion.">PDF autorizacion</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var c in _contratos)
                                {
                                    <tr class="@(c.Id == _contratoId ? "sel" : "")">
                                        <td><input class="form-control form-control-sm mono" @bind="c.CodigoContrato" /></td>
                                        <td><input type="date" class="form-control form-control-sm" @bind="c.FechaInicial" /></td>
                                        <td><input type="date" class="form-control form-control-sm" @bind="c.FechaFinal" /></td>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="c.Estado">
                                                <option>ACTIVO</option><option>INACTIVO</option><option>SUSPENDIDO</option><option>VENCIDO</option>
                                            </select>
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="c.Prorroga">
                                                <option value="false">NO</option><option value="true">SI</option>
                                            </select>
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input" @bind="c.RequierePdfAutorizacion"
                                                   title="Si se activa, la asignacion contra este contrato exige adjuntar el PDF de autorizacion." />
                                        </td>
                                        <td class="ase-row-actions">
                                            <button class="btn btn-primary btn-sm" title="Guardar" @onclick="() => SaveContrato(c)">&#10003;</button>
                                            @if (c.Id is not null)
                                            {
                                                <button class="btn @(c.Id == _contratoId ? "btn-primary" : "btn-outline-secondary") btn-sm" title="Ver servicios" @onclick="() => SelectContrato(c.Id!.Value)">Servicios</button>
                                                <button class="btn btn-outline-danger btn-sm" title="Eliminar" @onclick="() => DeleteContrato(c)">&times;</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (_contratos.Count == 0) { <div class="ase-empty">Sin contratos. Agrega uno.</div> }
                    </div>
                </div>

                <!-- Servicios -->
                @if (_contratoId is not null)
                {
                    <div class="ase-card">
                        <div class="ase-card-h">
                            Servicios del contrato
                            <span class="ase-tools">
                                <input class="form-control form-control-sm ase-filter" placeholder="Filtrar servicios..." value="@_filtro" @oninput="OnFiltroInput" />
                                <button class="btn btn-outline-primary btn-sm" @onclick="AddServicio">+ Servicio</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="DescargarPlantilla" disabled="@_busy" title="Descarga un Excel con las columnas esperadas y un ejemplo.">&#11015; Plantilla</button>
                                <label class="btn btn-primary btn-sm mb-0">
                                    Importar Excel
                                    <InputFile OnChange="OnImportExcel" accept=".xlsx" style="display:none" />
                                </label>
                                <button class="btn btn-outline-danger btn-sm" @onclick="BorrarTodosLosServicios" disabled="@(_busy || _contratoId is null)" title="Borra TODOS los servicios de este contrato. Util cuando hiciste un import incorrecto.">&#128465; Borrar todos</button>
                            </span>
                        </div>
                        <div class="ase-serv-wrap">
                            <table class="table table-sm align-middle ase-table ase-serv ase-serv-wide">
                                <thead><tr>
                                    <th style="min-width:90px;">Historia</th>
                                    <th style="min-width:110px;">Paquete</th>
                                    <th style="min-width:120px;">Cod. Servicio</th>
                                    <th style="min-width:120px;">Cod. Interno</th>
                                    <th style="min-width:340px;">Descripcion</th>
                                    <th style="min-width:100px;">Tarifa</th>
                                    <th style="min-width:130px;">Modulo</th>
                                    <th style="min-width:150px;">Especialidad</th>
                                    <th style="min-width:130px;">Modalidad</th>
                                    <th style="min-width:110px;">Sede</th>
                                    <th style="min-width:150px;" class="ase-th-fact">Modalidad Fact.</th>
                                    <th style="min-width:170px;" class="ase-th-fact">Grupo Servicio Fact.</th>
                                    <th style="min-width:200px;" class="ase-th-fact">Servicio Facturacion</th>
                                    <th style="min-width:140px;"></th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var s in FilteredServicios())
                                    {
                                        <tr>
                                            <td><input class="form-control form-control-sm mono" @bind="s.Historia" /></td>
                                            <td>
                                                <select class="form-select form-select-sm mono" @bind="s.PaqueteId">
                                                    <option value="">(opcional)</option>
                                                    @foreach (var p in _paquetes)
                                                    {
                                                        <option value="@p.Id">@p.Codigo</option>
                                                    }
                                                </select>
                                            </td>
                                            <td><input class="form-control form-control-sm mono" @bind="s.CodigoServicio" /></td>
                                            <td><input class="form-control form-control-sm mono" @bind="s.CodigoInterno" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Descripcion" /></td>
                                            <td><input class="form-control form-control-sm" type="number" step="0.01" @bind="s.Tarifa" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Modulo" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Especialidad" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Modalidad" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Sede" /></td>
                                            <td><input class="form-control form-control-sm ase-td-fact" @bind="s.ModalidadFacturacion" /></td>
                                            <td><input class="form-control form-control-sm ase-td-fact" @bind="s.GrupoServicioFacturacion" /></td>
                                            <td><input class="form-control form-control-sm ase-td-fact" @bind="s.ServicioFacturacion" /></td>
                                            <td class="ase-row-actions">
                                                <button class="btn btn-primary btn-sm" title="Guardar" @onclick="() => SaveServicio(s)">&#10003;</button>
                                                <button class="btn @(TieneRips(s) ? "btn-info" : "btn-outline-info") btn-sm"
                                                        title="RIPS Res 2275 + Valor Total (Facturacion)"
                                                        @onclick="() => AbrirRips(s)">RIPS</button>
                                                @if (s.Id is not null)
                                                {
                                                    <button class="btn btn-outline-danger btn-sm" title="Eliminar" @onclick="() => DeleteServicio(s)">&times;</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (_servicios.Count == 0) { <div class="ase-empty">Sin servicios. Importa el Excel o agrega manualmente.</div> }
                        </div>
                    </div>
                }
                } @* fin else (tab contratos) *@
            }
        }
    </div>
</div>

@* ============ Modal RIPS Res 2275 + Valor Total (Fase 4 Facturacion) ============ *@
@if (_ripsOpen && _ripsEdit is not null)
{
    <div class="sn-modal-back" @onclick="CerrarRips">
        <div class="sn-modal sn-modal-md" @onclick:stopPropagation>
            <div class="sn-modal-h">
                <div>
                    <div class="sn-modal-eyebrow">Servicio del contrato</div>
                    <h3>Codigos RIPS (Res 2275) + Valor Total</h3>
                    <div style="font-size:12px;color:var(--muted);margin-top:4px;">
                        Usados por el snapshot Relacion de Facturas al radicar ante la EPS.
                    </div>
                </div>
                <button class="sn-modal-x" @onclick="CerrarRips">&times;</button>
            </div>
            <div class="sn-modal-body">
                <div class="rips-grid">
                    <div><label>Finalidad</label><input class="form-control form-control-sm mono" maxlength="10" @bind="_ripsEdit.Finalidad" placeholder="17" /></div>
                    <div><label>Causa Externa</label><input class="form-control form-control-sm mono" maxlength="10" @bind="_ripsEdit.CausaExterna" placeholder="38" /></div>
                    <div><label>Modalidad Atencion</label><input class="form-control form-control-sm mono" maxlength="10" @bind="_ripsEdit.ModalidadAtencion" placeholder="02" /></div>
                    <div><label>Via Ingreso</label><input class="form-control form-control-sm mono" maxlength="10" @bind="_ripsEdit.ViaIngreso" placeholder="03" /></div>
                    <div><label>Grupo Servicios</label><input class="form-control form-control-sm mono" maxlength="10" @bind="_ripsEdit.GrupoServicios" placeholder="07" /></div>
                    <div><label>Servicios (REPS)</label><input class="form-control form-control-sm mono" maxlength="10" @bind="_ripsEdit.Servicios" placeholder="312" /></div>
                    <div class="rips-span2"><label>Valor Total (pactado con la aseguradora)</label>
                        <input class="form-control form-control-sm" type="number" step="0.01" @bind="_ripsEdit.ValorTotal" placeholder="Deja vacio para usar Tarifa" />
                    </div>
                </div>
            </div>
            <div class="sn-modal-f">
                <small class="text-muted">Los codigos son strings MinSalud — spec §5.10.</small>
                <div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarRips">Cancelar</button>
                    <button class="btn btn-primary btn-sm ms-2" @onclick="GuardarRips">Guardar RIPS</button>
                </div>
            </div>
        </div>
    </div>
}

@* ================== Modal: Actualizar en masa ================== *@
@if (_bulkOpen)
{
    <div class="sn-modal-back" @onclick="CerrarBulk">
        <div class="sn-modal sn-modal-lg bulk-modal" @onclick:stopPropagation>
            <div class="sn-modal-h">
                <div>
                    <div class="sn-modal-eyebrow">Facturacion</div>
                    <h3>Actualizar en masa <small class="text-muted">— aplica a servicios de todos los contratos</small></h3>
                </div>
                <button class="sn-modal-x" @onclick="CerrarBulk">&times;</button>
            </div>
            <div class="sn-modal-b">
                <div class="bulk-tabs">
                    <button class="bulk-tab @(_bulkTab == "buscar" ? "sel" : "")" @onclick='() => _bulkTab = "buscar"'>Buscar y aplicar</button>
                    <button class="bulk-tab @(_bulkTab == "historial" ? "sel" : "")" @onclick='async () => { _bulkTab = "historial"; await LoadHistorialBulk(); }'>Historial (max 20)</button>
                </div>

                @if (_bulkTab == "buscar")
                {
                    <div class="bulk-row">
                        <div style="min-width:170px;">
                            <label class="bulk-lbl">Operador</label>
                            <select class="form-select form-select-sm" @bind="_bulkOperador">
                                <option value="Contiene">Contiene</option>
                                <option value="EmpiezaCon">Empieza con</option>
                                <option value="TerminaCon">Termina con</option>
                                <option value="Exacto">Exacto</option>
                            </select>
                        </div>
                        <div class="bulk-grow">
                            <label class="bulk-lbl">Buscar en Descripcion</label>
                            <input class="form-control form-control-sm" placeholder="Ej: TERAPIA FISICA..." @bind="_bulkTexto" @onkeyup="OnBulkTextoKeyup" />
                        </div>
                        <div>
                            <label class="bulk-lbl">&nbsp;</label>
                            <button class="btn btn-outline-primary btn-sm" @onclick="BuscarBulk" disabled="@_bulkBusy">@(_bulkBusy ? "Buscando..." : "Buscar")</button>
                        </div>
                    </div>

                    @if (_bulkBusqueda is not null)
                    {
                        <div class="bulk-count">
                            <b>@_bulkBusqueda.TotalCoincidencias</b> servicios coinciden.
                            @if (_bulkBusqueda.TotalCoincidencias > 0)
                            {
                                <span class="text-muted"> Mostrando @_bulkBusqueda.Preview.Count preview.</span>
                            }
                        </div>
                        @if (_bulkBusqueda.Preview.Count > 0)
                        {
                            <div class="bulk-preview-wrap">
                                <table class="table table-sm bulk-preview">
                                    <thead><tr>
                                        <th>Aseguradora</th><th>Contrato</th><th>Descripcion</th>
                                        <th>Modalidad Fact.</th><th>Grupo Serv. Fact.</th><th>Servicio Fact.</th>
                                    </tr></thead>
                                    <tbody>
                                        @foreach (var f in _bulkBusqueda.Preview)
                                        {
                                            <tr>
                                                <td>@f.Aseguradora</td>
                                                <td class="mono">@f.CodigoContrato</td>
                                                <td>@f.Descripcion</td>
                                                <td>@(f.ModalidadFacturacionActual ?? "-")</td>
                                                <td>@(f.GrupoServicioFacturacionActual ?? "-")</td>
                                                <td>@(f.ServicioFacturacionActual ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }

                    <div class="bulk-sep">Nuevos valores <small class="text-muted">(deja vacio los campos que no quieres cambiar)</small></div>
                    <div class="bulk-row">
                        <div class="bulk-grow"><label class="bulk-lbl">Modalidad Fact.</label>
                            <input class="form-control form-control-sm" placeholder="Ej: PGP" @bind="_bulkNuevaModalidad" /></div>
                        <div class="bulk-grow"><label class="bulk-lbl">Grupo Servicio Fact.</label>
                            <input class="form-control form-control-sm" placeholder="Ej: TERAPIAS" @bind="_bulkNuevoGrupo" /></div>
                        <div class="bulk-grow"><label class="bulk-lbl">Servicio Facturacion</label>
                            <input class="form-control form-control-sm" placeholder="Ej: TERAPIA FISICA POR SESION" @bind="_bulkNuevoServicio" /></div>
                    </div>
                    <div class="bulk-row">
                        <div class="bulk-grow"><label class="bulk-lbl">Motivo <span style="color:#dc2626;">*</span></label>
                            <input class="form-control form-control-sm" placeholder="Ej: Actualizacion contratos ASMET Julio 2026" @bind="_bulkMotivo" /></div>
                    </div>
                    @if (_bulkError is not null) { <div class="ase-alert">@_bulkError</div> }
                    @if (_bulkOk is not null) { <div class="ase-ok">@_bulkOk</div> }
                }
                else
                {
                    <div class="bulk-historial">
                        @if (_bulkHistorial.Count == 0) { <div class="ase-empty">Sin ejecuciones registradas.</div> }
                        else
                        {
                            <table class="table table-sm">
                                <thead><tr>
                                    <th>Fecha</th><th>Filtro</th><th>Cambios</th><th>Motivo</th><th>Afectados</th><th>Estado</th><th></th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var h in _bulkHistorial)
                                    {
                                        <tr>
                                            <td class="mono">@h.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                            <td><span class="mono">@h.OperadorBusqueda</span> "@h.TextoBusqueda"</td>
                                            <td>
                                                @if (h.NuevaModalidad is not null) { <span class="bulk-chip">Mod=@h.NuevaModalidad</span> }
                                                @if (h.NuevoGrupo is not null) { <span class="bulk-chip">Grupo=@h.NuevoGrupo</span> }
                                                @if (h.NuevoServicio is not null) { <span class="bulk-chip">Serv=@h.NuevoServicio</span> }
                                            </td>
                                            <td>@h.Motivo</td>
                                            <td>@h.TotalAfectados</td>
                                            <td><span class="bulk-estado bulk-estado-@h.Estado.ToLower()">@h.Estado</span></td>
                                            <td>
                                                @if (h.Estado == "Aplicada")
                                                {
                                                    <button class="btn btn-outline-warning btn-sm" title="Revertir esta ejecucion (restaura los valores anteriores)"
                                                            @onclick="() => RevertirBulk(h.Id)">Revertir</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                }
            </div>
            <div class="sn-modal-f">
                <small class="text-muted">Retencion: se guardan las ultimas 20 ejecuciones para permitir rollback.</small>
                <div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarBulk">Cerrar</button>
                    @if (_bulkTab == "buscar")
                    {
                        <button class="btn btn-primary btn-sm ms-2" @onclick="AplicarBulk"
                                disabled="@(_bulkBusy || _bulkBusqueda is null || _bulkBusqueda.TotalCoincidencias == 0 || string.IsNullOrWhiteSpace(_bulkMotivo))">
                            Aplicar a @(_bulkBusqueda?.TotalCoincidencias ?? 0) servicios
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<style>
    .rips-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px 16px; }
    .rips-grid label { display:block; font-size:12px; color:var(--muted); margin-bottom:4px; }
    .rips-span2 { grid-column:1 / -1; }

