    private async Task OnExcelSelected(InputFileChangeEventArgs e)
    {
        _importError = null;
        _importLog.Clear();
        _importTotal = _importCurrent = _importOk = _importErr = 0;
        _importProgress = 0;
        _importing = true;
        try
        {
            // Volcar el upload a memoria. 50 MB tope (los Excel con muchas firmas
            // pesan ~7 MB en TERAPIAS, dejamos margen amplio).
            const long max = 50L * 1024 * 1024;
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(max).CopyToAsync(ms);
            var xlsxBytes = ms.ToArray();
            ms.Position = 0;

            using var wb = new ClosedXML.Excel.XLWorkbook(ms);
            var ws = wb.Worksheets.First();
            var lastRow = ws.LastRowUsed()?.RowNumber() ?? 1;

            // Detectar fila inicial de datos. En la plantilla estandar los datos
            // empiezan en la fila 2 (fila 1 = encabezado). Algunos Excel reales
            // traen filas de logo/metadata arriba y el encabezado esta mas abajo
            // (p.ej. plantillas de Excel modernas). Detectamos el encabezado
            // buscando la primera fila donde la col 1 diga "documento"/"cedula"/etc.
            // y arrancamos una fila despues. Si no encontramos header, arrancamos
            // en la 2 (comportamiento por defecto).
            var startRow = 2;
            for (var probe = 1; probe <= Math.Min(lastRow, 20); probe++)
            {
                var v = ws.Cell(probe, 1).GetString().Trim();
                if (string.IsNullOrEmpty(v)) { continue; }
                var vLower = v.ToLowerInvariant();
                if (vLower.Contains("documento") || vLower.Contains("cedula") || vLower.Contains("cédula")
                    || vLower.Contains("identifica") || vLower.Contains("n°") || vLower.StartsWith("no ") || vLower == "no")
                {
                    startRow = probe + 1;
                    _importLog.Add($"Cabecera detectada en fila {probe}: datos empiezan en fila {startRow}.");
                    break;
                }
                // Si encontramos algo que parece un documento numerico en la col 1,
                // asumimos que ese es el inicio de datos (no hay header).
                if (v.Length >= 4 && v.Any(char.IsDigit) && !v.Contains(' '))
                {
                    startRow = probe;
                    break;
                }
            }
            _importTotal = Math.Max(0, lastRow - startRow + 1);

            // Catalogos (resueltos una vez para no hacer 200 lookups).
            var tipos = await Svc.ListTiposAsync(false);
            var subs = await Svc.ListSubcategoriasAsync(false);
            // Listado actual de profesionales para detectar upserts por documento.
            var existentes = await Svc.ListProfesionalesAsync(null);
            var byDoc = new Dictionary<string, ProfesionalDto>(StringComparer.OrdinalIgnoreCase);
            foreach (var p in existentes) { byDoc[p.NumeroDocumento.Trim()] = p; }

            // Indice de pictures por fila (formato clasico: drawings ancladas a celda).
            var picsByRow = new Dictionary<int, ClosedXML.Excel.Drawings.IXLPicture>();
            foreach (var pic in ws.Pictures)
            {
                try
                {
                    var row = pic.TopLeftCell.Address.RowNumber;
                    if (!picsByRow.ContainsKey(row)) { picsByRow[row] = pic; }
                }
                catch { /* picture mal anclada — skip */ }
            }
            // Mapa de imagenes "insertadas en celda" (rich data, formato moderno
            // de Excel que ClosedXML no soporta). Se prefiere sobre picsByRow si
            // ambos existen para la misma fila.
            Dictionary<(int Row, int Col), byte[]> cellImages;
            try { cellImages = XlsxCellImageReader.ReadFirstSheet(xlsxBytes); }
            catch (Exception exImg)
            {
                cellImages = new();
                _importLog.Add($"[WARN] No se pudo leer imagenes en celda (rich data): {exImg.Message}");
            }
            var cellImagesByRow = new Dictionary<int, byte[]>();
            foreach (var kv in cellImages)
            {
                // La firma se espera en col 12 (columna L). Si viene en otra, la aceptamos igual.
                if (!cellImagesByRow.ContainsKey(kv.Key.Row)) { cellImagesByRow[kv.Key.Row] = kv.Value; }
            }
            _importLog.Add($"Firmas detectadas: {picsByRow.Count} ancladas + {cellImagesByRow.Count} en celda.");

            var actor = await Actor();
            var firmaDir = Path.Combine(Env.WebRootPath, "uploads", "firmas");
            Directory.CreateDirectory(firmaDir);

            for (var r = startRow; r <= lastRow; r++)
            {
                _importCurrent = r - startRow + 1;
                _importProgress = (double)_importCurrent / Math.Max(1, _importTotal) * 100;
                try
                {
                    var doc = ws.Cell(r, 1).GetString().Trim();
                    if (string.IsNullOrWhiteSpace(doc)) { continue; }
                    var tipoDoc = (ws.Cell(r, 2).GetString().Trim() is { Length: > 0 } td) ? td.ToUpperInvariant() : "CC";
                    var pn = ws.Cell(r, 3).GetString().Trim();
                    var sn = ws.Cell(r, 4).GetString().Trim();
                    var pa = ws.Cell(r, 5).GetString().Trim();
                    var sa = ws.Cell(r, 6).GetString().Trim();
                    var tipoProfNombre = ws.Cell(r, 7).GetString().Trim();
                    var registro = ws.Cell(r, 8).GetString().Trim();
                    var ciudad = ws.Cell(r, 9).GetString().Trim();
                    var celular = ws.Cell(r, 10).GetString().Trim();
                    var subcatNombre = ws.Cell(r, 11).GetString().Trim();
                    // Columna 12 = Firma (imagen embebida). Columna 13 = Rol (nombre).
                    // Si el rol no existe entre los roles definidos, NO se crea usuario
                    // pero el profesional si se guarda — asi el import no aborta la fila.
                    var rolNombre = ws.Cell(r, 13).GetString().Trim();

                    var tipo = tipos.FirstOrDefault(t => string.Equals(t.Nombre.Trim(), tipoProfNombre, StringComparison.OrdinalIgnoreCase));
                    if (tipo is null)
                    {
                        _importErr++;
                        _importLog.Add($"[ERR] Fila {r} ({doc}): tipo profesional '{tipoProfNombre}' no existe en catalogo. Salta.");
                        continue;
                    }

                    var subcatIds = new List<Guid>();
                    if (!string.IsNullOrWhiteSpace(subcatNombre))
                    {
                        var sc = subs.FirstOrDefault(s => string.Equals(s.Nombre.Trim(), subcatNombre, StringComparison.OrdinalIgnoreCase));
                        if (sc is not null) { subcatIds.Add(sc.Id); }
                    }

                    // Firma: preferimos "insertada en celda" (formato moderno)
                    // sobre "picture anclada" clasica. Ambas se persisten a
                    // /uploads/firmas. Si la fila es upsert y no trae firma nueva,
                    // mantenemos la existente (mas abajo, al armar la request).
                    string? firmaUrl = null;
                    if (cellImagesByRow.TryGetValue(r, out var imgBytes))
                    {
                        var ext = SniffImageExt(imgBytes);
                        var name = $"firma-{Guid.NewGuid():N}{ext}";
                        var path = Path.Combine(firmaDir, name);
                        await File.WriteAllBytesAsync(path, imgBytes);
                        firmaUrl = $"/uploads/firmas/{name}";
                    }
                    else if (picsByRow.TryGetValue(r, out var pic))
                    {
                        var ext = pic.Format switch
                        {
                            ClosedXML.Excel.Drawings.XLPictureFormat.Jpeg => ".jpg",
                            ClosedXML.Excel.Drawings.XLPictureFormat.Gif => ".gif",
                            ClosedXML.Excel.Drawings.XLPictureFormat.Bmp => ".bmp",
                            _ => ".png"
                        };
                        var name = $"firma-{Guid.NewGuid():N}{ext}";
                        var path = Path.Combine(firmaDir, name);
                        await using (var fs = File.Create(path))
                        {
                            pic.ImageStream.Position = 0;
                            await pic.ImageStream.CopyToAsync(fs);
                        }
                        firmaUrl = $"/uploads/firmas/{name}";
                    }

                    // Resolver rol del Excel (si viene y matchea). Si no, se
                    // usara como fallback el rol persistido del profesional
                    // existente — asi el import no pisa a null al hacer upsert.
                    Guid? rolIdImportRow = null;
                    if (!string.IsNullOrWhiteSpace(rolNombre))
                    {
                        var rolMatch = _roles.FirstOrDefault(x => string.Equals(x.Nombre.Trim(), rolNombre, StringComparison.OrdinalIgnoreCase));
                        if (rolMatch is not null) { rolIdImportRow = rolMatch.Id; }
                    }

                    Guid? id = null;
                    // Upsert: cargar detalle actual para preservar campos que el
                    // Excel deje vacios (regla acordada: import no pisa datos
                    // existentes cuando la celda viene vacia).
                    ProfesionalDetailDto? detExistente = null;
                    if (byDoc.TryGetValue(doc, out var existing))
                    {
                        id = existing.Id;
                        detExistente = await Svc.GetProfesionalAsync(existing.Id);
                        if (firmaUrl is null) { firmaUrl = detExistente?.FirmaUrl; }
                    }

                    var nombreCompleto = string.Join(' ', new[] { pn, sn, pa, sa }.Where(s => !string.IsNullOrWhiteSpace(s)));
                    // Sedes: si el Excel no trae sede seleccionada y el profesional
                    // ya existia con sedes asignadas, las preservamos.
                    List<string> agencias;
                    if (!string.IsNullOrWhiteSpace(_importSede))
                    {
                        agencias = new List<string> { _importSede.Trim() };
                    }
                    else if (detExistente is not null && detExistente.Agencias.Count > 0)
                    {
                        agencias = detExistente.Agencias.ToList();
                    }
                    else
                    {
                        agencias = new List<string>();
                    }

                    // Rol: si no viene o no matchea, preservamos el rol persistido.
                    var rolIdParaGuardar = rolIdImportRow ?? detExistente?.RolPredeterminadoId;

                    var req = new SaveProfesionalRequest(id, doc, tipoDoc,
                        pn, sn, pa, sa, nombreCompleto, tipo.Id, registro, ciudad, celular, firmaUrl,
                        subcatIds, agencias, rolIdParaGuardar);
                    var saved = await Svc.SaveProfesionalAsync(req, actor);
                    if (saved is null)
                    {
                        _importErr++;
                        _importLog.Add($"[ERR] Fila {r} ({doc}): SaveProfesional retorno null.");
                        continue;
                    }

                    if (_importCrearUsuario)
                    {
                        // Buscar TenantUser YA vinculado al profesional (por FK).
                        UsuarioDto? existingUsu = null;
                        try { existingUsu = await UsuSvc.GetPorProfesionalIdAsync(saved.Id); }
                        catch { /* no bloquear el import por esto */ }

                        var pwd = doc.Length >= 6 ? doc : doc.PadLeft(6, '0');

                        if (existingUsu is not null)
                        {
                            // UPDATE: el usuario ya existe -> reset clave = cedula,
                            // sincronizar perfil (documento, nombres, celular, ciudad).
                            // Rol + sedes ya se propagaron en SaveProfesionalAsync via
                            // PropagarAlUsuarioVinculadoAsync (asumiendo que rolNombre
                            // matcheo; si no, quedan los previos).
                            try
                            {
                                await UsuSvc.ResetPasswordAsync(existingUsu.Id, pwd, actor);
                                var perfil = new ActualizarPerfilUsuarioRequest(
                                    DisplayName: nombreCompleto,
                                    Username: existingUsu.Username,
                                    Documento: doc,
                                    PrimerNombre: string.IsNullOrWhiteSpace(pn) ? existingUsu.PrimerNombre : pn,
                                    SegundoNombre: string.IsNullOrWhiteSpace(sn) ? existingUsu.SegundoNombre : sn,
                                    PrimerApellido: string.IsNullOrWhiteSpace(pa) ? existingUsu.PrimerApellido : pa,
                                    SegundoApellido: string.IsNullOrWhiteSpace(sa) ? existingUsu.SegundoApellido : sa,
                                    Celular: string.IsNullOrWhiteSpace(celular) ? existingUsu.Celular : celular,
                                    Fijo: existingUsu.Fijo,
                                    Ciudad: string.IsNullOrWhiteSpace(ciudad) ? existingUsu.Ciudad : ciudad,
                                    Direccion: existingUsu.Direccion,
                                    Inhabilitado: false);
                                await UsuSvc.ActualizarPerfilAsync(existingUsu.Id, perfil, actor);
                                var rolMsg = rolIdImportRow is not null
                                    ? "rol actualizado"
                                    : (string.IsNullOrWhiteSpace(rolNombre) ? "rol sin cambios (Excel vacio)"
                                       : $"rol NO actualizado (nombre '{rolNombre}' no existe en catalogo)");
                                _importLog.Add($"[UP]  Fila {r}: usuario actualizado (clave=cedula, perfil, sedes; {rolMsg}).");
                            }
                            catch (InvalidOperationException ex)
                            {
                                _importLog.Add($"[..]  Fila {r}: usuario NO actualizado ({ex.Message}).");
                            }
                            catch (Microsoft.EntityFrameworkCore.DbUpdateException ex)
                            {
                                _importLog.Add($"[..]  Fila {r}: usuario NO actualizado ({DetalleError(ex)}).");
                            }
                        }
                        else
                        {
                            // CREATE: el usuario aun no existe. Requiere rol valido para
                            // no dejar el usuario huerfano sin permisos. Si no viene rol,
                            // el profesional queda sin usuario (se puede crear despues
                            // desde la ficha).
                            Guid? rolIdImport = null;
                            if (string.IsNullOrWhiteSpace(rolNombre))
                            {
                                _importLog.Add($"[..]  Fila {r}: usuario NO creado (falta columna Rol).");
                            }
                            else
                            {
                                var rolMatch = _roles.FirstOrDefault(x => string.Equals(x.Nombre.Trim(), rolNombre, StringComparison.OrdinalIgnoreCase));
                                if (rolMatch is null)
                                {
                                    var rolesDisp = string.Join(", ", _roles.Select(x => x.Nombre));
                                    _importLog.Add($"[..]  Fila {r}: usuario NO creado (rol '{rolNombre}' no existe). Roles disponibles: {rolesDisp}.");
                                }
                                else { rolIdImport = rolMatch.Id; }
                            }

                            if (rolIdImport is Guid rolIdOk)
                            {
                                var email = $"{doc}@visal.travels";
                                try
                                {
                                    await UsuSvc.CrearUsuarioDesdeProfesionalAsync(saved.Id, email, pwd, rolIdOk, actor);
                                    // Re-guardar para que el servicio propague sedes al TenantUser
                                    // recien creado (CrearUsuarioDesdeProfesionalAsync no asigna
                                    // sedes; el segundo Save del profesional dispara la
                                    // propagacion completa).
                                    await Svc.SaveProfesionalAsync(req, actor);
                                    _importLog.Add($"[NEW] Fila {r}: usuario creado (email={email}, clave=cedula).");
                                }
                                catch (InvalidOperationException ex)
                                {
                                    _importLog.Add($"[..]  Fila {r}: usuario no creado ({ex.Message}).");
                                }
                                catch (Microsoft.EntityFrameworkCore.DbUpdateException ex)
                                {
                                    _importLog.Add($"[..]  Fila {r}: usuario no creado ({DetalleError(ex)}).");
                                }
                            }
                        }
                    }

                    _importOk++;
                    _importLog.Add($"[OK]  Fila {r} ({doc}): {nombreCompleto}{(firmaUrl is null ? " (sin firma)" : "")}{(id is not null ? " [upsert]" : " [nuevo]")}.");
                }
                catch (Exception ex)
                {
                    _importErr++;
                    _importLog.Add($"[ERR] Fila {r}: {DetalleError(ex)}");
                }

                // Cada 10 filas refrescamos la UI para que el usuario vea avance.
                if (r % 5 == 0) { StateHasChanged(); await Task.Yield(); }
            }
            _importProgress = 100;
            await LoadLista();
            _ok = $"Import terminado: {_importOk} OK, {_importErr} errores.";
        }
        catch (Exception ex)
        {
            _importError = $"Error fatal: {ex.Message}";
        }
        finally
        {
            _importing = false;
            StateHasChanged();
        }
    }

    private void StartConfirmDelete()
    {
        _confirmingDelete = true;
        _confirmText = string.Empty;
    }

    private void CancelConfirmDelete()
    {
        _confirmingDelete = false;
        _confirmText = string.Empty;
    }

    private async Task OnConfirmKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _confirmText == "ELIMINAR") { await Delete(); }
        if (e.Key == "Escape") { CancelConfirmDelete(); }
    }

    private async Task Delete()
    {
        if (_id is not Guid id) { return; }
        if (_confirmText != "ELIMINAR") { return; }
        await Svc.DeleteProfesionalAsync(id, await Actor());
        _showForm = false; _id = null;
        _confirmingDelete = false; _confirmText = string.Empty;
        await LoadLista();
        _ok = "Profesional eliminado.";
    }

    private async Task OnFirmaSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        var file = e.File;
        const long max = 4L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { _error = "La firma debe pesar menos de 4 MB."; return; }
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(max).CopyToAsync(ms);
            var ext = Path.GetExtension(file.Name);
            var dir = Path.Combine(Env.WebRootPath, "uploads", "firmas");
            Directory.CreateDirectory(dir);
            var name = $"firma-{Guid.NewGuid():N}{ext}";
            await File.WriteAllBytesAsync(Path.Combine(dir, name), ms.ToArray());
            _firmaUrl = $"/uploads/firmas/{name}";
        }
        catch { _error = "No se pudo subir la firma."; }
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    /// <summary>
    /// Camina la cadena de InnerException hasta la raiz y, cuando encuentra un
    /// PostgresException (Npgsql), extrae MessageText + Detail + ConstraintName +
    /// ColumnName. Asi el log de importacion muestra el motivo real
    /// ("valor demasiado largo para columna X", "violacion de UNIQUE en Y",
    /// "valor NULL en columna NOT NULL Z") en vez del envoltorio EF Core
    /// generico "An error occurred while saving the entity changes".
    /// </summary>
    private static string SniffImageExt(byte[] bytes)
    {
        // Cabeceras PNG/JPG/GIF/BMP. Default png para PNG (mas comun en firmas modernas).
        if (bytes.Length >= 8 && bytes[0] == 0x89 && bytes[1] == 0x50 && bytes[2] == 0x4E && bytes[3] == 0x47) { return ".png"; }
        if (bytes.Length >= 3 && bytes[0] == 0xFF && bytes[1] == 0xD8 && bytes[2] == 0xFF) { return ".jpg"; }
        if (bytes.Length >= 4 && bytes[0] == 0x47 && bytes[1] == 0x49 && bytes[2] == 0x46) { return ".gif"; }
        if (bytes.Length >= 2 && bytes[0] == 0x42 && bytes[1] == 0x4D) { return ".bmp"; }
        return ".png";
    }

    private static string DetalleError(Exception ex)
    {
        // Recorremos la cadena hasta la raiz para no perder ningun eslabon con info util.
        var partes = new List<string>();
        Exception? cur = ex;
        while (cur is not null)
        {
            // PostgresException tiene los campos ricos — si aparece, es lo que queremos mostrar.
            if (cur.GetType().FullName == "Npgsql.PostgresException")
            {
                var t = cur.GetType();
                string? Prop(string name) => t.GetProperty(name)?.GetValue(cur) as string;
                var msg = Prop("MessageText");
                var det = Prop("Detail");
                var con = Prop("ConstraintName");
                var col = Prop("ColumnName");
                var tbl = Prop("TableName");
                var sql = Prop("SqlState");
                var sb = new System.Text.StringBuilder();
                if (!string.IsNullOrWhiteSpace(msg)) { sb.Append(msg); }
                if (!string.IsNullOrWhiteSpace(det)) { sb.Append(" | ").Append(det); }
                if (!string.IsNullOrWhiteSpace(con)) { sb.Append(" | constraint=").Append(con); }
                if (!string.IsNullOrWhiteSpace(col)) { sb.Append(" | columna=").Append(col); }
                if (!string.IsNullOrWhiteSpace(tbl)) { sb.Append(" | tabla=").Append(tbl); }
                if (!string.IsNullOrWhiteSpace(sql)) { sb.Append(" [SQLSTATE ").Append(sql).Append(']'); }
                var s = sb.ToString().Trim();
                if (!string.IsNullOrEmpty(s)) { partes.Add(s); }
            }
            else
            {
                // Otros niveles: incluimos solo el mensaje si no es el envoltorio
                // generico de EF Core (redundante y poco util).
                if (!string.IsNullOrWhiteSpace(cur.Message)
                    && !cur.Message.Contains("See the inner exception for details", StringComparison.OrdinalIgnoreCase))
                {
                    partes.Add(cur.Message);
                }
            }
            cur = cur.InnerException;
        }
        var final = partes.Count > 0 ? string.Join(" -> ", partes) : ex.Message;
        // Truncar por si el detalle trae la fila completa (comun en varchar overflow).
        return final.Length > 500 ? final[..500] + "..." : final;
    }
