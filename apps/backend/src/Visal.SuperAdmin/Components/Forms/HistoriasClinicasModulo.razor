    // Paciente efectivo: prioriza el parametro, despues el seleccionado en el modal interno.
    private PacienteAsignacionDto? PacienteActivo => PacienteContexto ?? _paciente;

    protected override async Task OnInitializedAsync()
    {
        // Suscribimos StateHasChanged al selector de acompanante para que el chip
        // del header y el modal se re-rendericen cuando la eleccion cambia (o
        // cuando el sub-tab dispara la apertura del modal via ResolverAsync).
        _acompSelector.StateChanged += OnAcompStateChanged;

        // Serializar TODO el arranque del componente contra el DbContext scoped
        // del circuito Blazor. Sin esto, en prod se disparaba
        // InvalidOperationException "A second operation was started..." porque
        // los subcomponentes hijos (WhatsAppChatPanel, tabs de HC) tambien
        // corren su OnInitialized/OnParametersSet al mismo tiempo y comparten
        // el mismo DbContext. El circuito Blazor moria y el usuario veia
        // "Ha ocurrido un error. Recargar."
        await LockedAsync(async () =>
        {
            _formatos = (await FormsSvc.ListAsync()).Where(f => f.Activo).ToList();
            // Si nos pasaron un codigo de formato forzado (viene del servicio asignado),
            // lo resolvemos a su Guid para usarlo al iniciar historia. NO toca _filFormato
            // (que es solo el filtro de busqueda de historias previas).
            if (!string.IsNullOrWhiteSpace(FormatoForzadoCodigo))
            {
                var match = _formatos.FirstOrDefault(f =>
                    string.Equals(f.Codigo, FormatoForzadoCodigo, StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(f.CodigoSecundario, FormatoForzadoCodigo, StringComparison.OrdinalIgnoreCase));
                _formatoForzadoId = match?.Id;
                _formatoForzadoNombre = match?.Nombre;
            }
            await CargarNombreTenantAsync();
            await ResolverPuedeReabrirAsync();
            await AutoCargarHcEnCursoSiCorrespondeAsync();
        });
    }

    /// <summary>
    /// Resuelve el Guid del PlatformUser logueado a partir del claim
    /// NameIdentifier — es el actor a pasar a los servicios que llevan
    /// auditoria (Cerrar, Reabrir, Descartar HC). Devuelve Guid.Empty si no
    /// se puede resolver (auditoria degradada pero no bloquea la accion).
    /// </summary>
    private async Task<Guid> ResolverActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        try
        {
            var state = await AuthState;
            var idStr = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            return Guid.TryParse(idStr, out var g) ? g : Guid.Empty;
        }
        catch { return Guid.Empty; }
    }

    /// <summary>
    /// Determina si el usuario logueado puede reabrir una HC cerrada. Tres vias
    /// dan el permiso (el orden refleja precedencia, aunque cualquiera basta):
    ///   1) Rol tenant Owner o Admin.
    ///   2) SuperAdmin de plataforma.
    ///   3) El rol asignado tiene marcado el permiso "historias.reabrir" en
    ///      /cfg-roles (se lee del claim "perms" que trae el token, un CSV con
    ///      los modulos con Ver=true del rol del usuario).
    /// Se resuelve una sola vez al inicializar el componente.
    /// </summary>
    private async Task ResolverPuedeReabrirAsync()
    {
        if (AuthState is null) { _puedeReabrir = false; return; }
        try
        {
            var state = await AuthState;
            var tenantRole = state.User.FindFirst("tenant_role")?.Value;
            var platformRole = state.User.FindFirst("platform_role")?.Value;
            var esAdminTenant = string.Equals(tenantRole, "Owner", StringComparison.OrdinalIgnoreCase)
                             || string.Equals(tenantRole, "Admin", StringComparison.OrdinalIgnoreCase);
            var esSuperAdmin = string.Equals(platformRole, "SuperAdmin", StringComparison.OrdinalIgnoreCase);
            // Permiso granular del rol: el claim "perms" es un CSV de los
            // modulos con Ver=true; si contiene "historias.reabrir" el usuario
            // tiene el permiso administrativo aunque no sea Owner/Admin.
            var perms = state.User.FindFirst("perms")?.Value;
            var tienePermiso = !string.IsNullOrEmpty(perms)
                && perms.Split(',', StringSplitOptions.RemoveEmptyEntries)
                        .Any(p => string.Equals(p.Trim(), "historias.reabrir", StringComparison.OrdinalIgnoreCase));
            _puedeReabrir = esAdminTenant || esSuperAdmin || tienePermiso;
        }
        catch { _puedeReabrir = false; }
    }

    /// <summary>
    /// Lee el claim 'tenant_id' del usuario logueado y trae el nombre de la
    /// agencia via ITenantAdminService (mismo patron que NavMenu). Se usa para
    /// componer la etiqueta "Servicios &lt;nombre_agencia&gt;" en el menu lateral.
    /// Es tolerante: si el usuario no tiene claim de tenant, o el servicio
    /// falla, _tenantName queda null y la etiqueta cae a "Servicios" pelado.
    /// </summary>
    private async Task CargarNombreTenantAsync()
    {
        if (AuthState is null) { return; }
        try
        {
            var state = await AuthState;
            var tenantClaim = state.User.FindFirst("tenant_id")?.Value;
            if (!Guid.TryParse(tenantClaim, out var tenantId)) { return; }
            var tenant = await TenantsSvc.GetAsync(tenantId);
            _tenantName = tenant?.Name;
        }
        catch
        {
            // No debe romper la carga del modulo si falla la lectura del tenant.
            _tenantName = null;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Si el modulo se re-usa con un paciente distinto sin recrearse, limpiamos
        // la eleccion de acompanante (era del paciente anterior). Con paciente
        // igual, mantenemos la eleccion.
        var pacIdActual = PacienteActivo?.Id;
        if (_acompPacienteId != pacIdActual)
        {
            _acompPacienteId = pacIdActual;
            _acompSelector.Reset();
        }
        // Cuando el modal cambia de paciente sin recrear el componente (raro pero
        // posible), re-evaluamos si hay HC en curso para auto-cargar.
        await AutoCargarHcEnCursoSiCorrespondeAsync();

        // Cargar visibilidad de pestanas segun TipoServicio (Modulo) del servicio
        // asignado. Si TipoServicio es null/vacio, no aplicamos filtros (todo
        // visible). Se recarga en cada cambio de parametro por si el modal se
        // re-usa para otro servicio.
        try { _pestanasOcultas = await MenuHcSvc.ObtenerPestanasOcultasAsync(TipoServicio); }
        catch { _pestanasOcultas = new(StringComparer.OrdinalIgnoreCase); }
        try { _aliasesPestanas = await MenuHcSvc.ObtenerAliasesAsync(); }
        catch { _aliasesPestanas = new(StringComparer.OrdinalIgnoreCase); }
        try { _ordenesPestanas = await MenuHcSvc.ObtenerOrdenesAsync(); }
        catch { _ordenesPestanas = new(StringComparer.OrdinalIgnoreCase); }
        // Si la pestana seleccionada quedo oculta por config, saltamos a Historial.
        if (_pestanasOcultas.Contains(_tabSel)) { _tabSel = "Historial"; }
    }

