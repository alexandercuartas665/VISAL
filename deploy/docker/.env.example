# Visal SaaS Medico - variables locales para docker compose
# Copiar este archivo como `.env` y ajustar contrasenas antes de levantar la pila.
# Este archivo es plantilla y puede versionarse; el `.env` real esta en .gitignore.
#
# Puertos elegidos para NO chocar con la pila CUBOT (5434/6381/5673/15673/5051)
# ni con la pila propia-* (5050/5433/6380).

# --- PostgreSQL ---
POSTGRES_DB=visal_dev
POSTGRES_USER=visal
POSTGRES_PASSWORD=cambiar-en-local
POSTGRES_PORT=5435

# --- Redis ---
REDIS_PASSWORD=cambiar-en-local
REDIS_PORT=6382

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=visal
RABBITMQ_DEFAULT_PASS=cambiar-en-local
RABBITMQ_PORT=5674
RABBITMQ_MGMT_PORT=15674

# --- pgAdmin ---
PGADMIN_EMAIL=admin@visal.local
PGADMIN_PASSWORD=cambiar-en-local
PGADMIN_PORT=5052

# --- Evolution API (deshabilitado por defecto, ver docker-compose.yml) ---
# EVOLUTION_API_KEY=cambiar-en-local
# EVOLUTION_PORT=8081
