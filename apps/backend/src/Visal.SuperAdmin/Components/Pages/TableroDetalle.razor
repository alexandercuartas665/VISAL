    private async Task MoveCardToColumnAsync(Guid columnId)
    {
        if (_cardDetail is null || columnId == _cardDetail.Card.ColumnId) { _showMovePop = false; return; }
        var newOrder = _cards.Count(c => c.ColumnId == columnId);
        await BoardsSvc.MoveCardAsync(_cardDetail.Card.Id, new MoveTaskCardRequest(columnId, newOrder), _actorId, _actorDisplayName);
        _showMovePop = false;
        await RefreshCardAndListAsync();
    }

    private async Task ToggleCardMemberAsync(TaskBoardMemberDto member, bool assign)
    {
        if (_cardDetail is null) { return; }
        if (assign)
        {
            await BoardsSvc.AssignMemberToCardAsync(new AssignMemberRequest(_cardDetail.Card.Id, member.PlatformUserId), _actorId, _actorDisplayName);
        }
        else
        {
            await BoardsSvc.UnassignMemberFromCardAsync(_cardDetail.Card.Id, member.PlatformUserId, _actorId, _actorDisplayName);
        }
        await RefreshCardAndListAsync();
    }

    private async Task ToggleCardTagAsync(Guid tagId, bool attach)
    {
        if (_cardDetail is null) { return; }
        if (attach)
        {
            await BoardsSvc.AttachTagToCardAsync(_cardDetail.Card.Id, tagId, _actorId);
        }
        else
        {
            await BoardsSvc.DetachTagFromCardAsync(_cardDetail.Card.Id, tagId, _actorId);
        }
        await RefreshCardAndListAsync();
    }

    private async Task DetachTagAsync(Guid tagId)
    {
        if (_cardDetail is null) { return; }
        await BoardsSvc.DetachTagFromCardAsync(_cardDetail.Card.Id, tagId, _actorId);
        await RefreshCardAndListAsync();
    }

    private async Task CreateTagAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTagName)) { return; }
        var tag = await BoardsSvc.CreateBoardTagAsync(new CreateBoardTagRequest(BoardId, _newTagName, _newTagColor), _actorId);
        if (tag is not null && _cardDetail is not null)
        {
            await BoardsSvc.AttachTagToCardAsync(_cardDetail.Card.Id, tag.Id, _actorId);
        }
        _newTagName = "";
        _boardTags = (await BoardsSvc.ListBoardTagsAsync(BoardId, _actorId)).ToList();
        await RefreshCardAndListAsync();
    }

    // ---- Helpers ----

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) { return "?"; }
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) { return "?"; }
        var first = char.ToUpperInvariant(parts[0][0]);
        if (parts.Length == 1) { return first.ToString(); }
        return $"{first}{char.ToUpperInvariant(parts[1][0])}";
    }

    /// <summary>Formato relativo tipo Trello: "hace 5 min", "ayer", "hace 3 dias", o fecha absoluta si es viejo.</summary>
    private static string FormatRelative(DateTimeOffset when)
    {
        var diff = DateTimeOffset.UtcNow - when;
        if (diff.TotalSeconds < 60) { return "recien ahora"; }
        if (diff.TotalMinutes < 60) { return $"hace {(int)diff.TotalMinutes} min"; }
        if (diff.TotalHours < 24) { return $"hace {(int)diff.TotalHours} h"; }
        if (diff.TotalDays < 2) { return "ayer"; }
        if (diff.TotalDays < 7) { return $"hace {(int)diff.TotalDays} dias"; }
        return when.ToLocalTime().ToString("dd MMM yyyy");
    }
