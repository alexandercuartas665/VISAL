# =========================================================================
#  Visal IPS - configuracion del entorno de PRODUCCION (docker-compose)
#  Copia este archivo como .env y edita los valores.
#  NO versionar el .env real (esta en .gitignore via deploy/docker-prod/.gitignore).
# =========================================================================

# ---------- Imagen a desplegar ----------
# Tag a usar de GHCR. Por defecto :latest (el ultimo build de main).
# Para pinear una version concreta, cambialo a :v1.2.3 o :sha-abcd123.
VISAL_IMAGE=ghcr.io/alexandercuartas665/visal/superadmin:latest

# ---------- Dominio + HTTPS ----------
# Dominio publico que apunta al servidor (DNS A record).
# Caddy obtendra automaticamente el certificado Let's Encrypt para este nombre.
VISAL_DOMAIN=visal.tudominio.com

# Email para que Let's Encrypt envie avisos de expiracion (cuenta ACME).
ACME_EMAIL=admin@tudominio.com

# ---------- Postgres ----------
POSTGRES_DB=visal
POSTGRES_USER=visal
# CAMBIA esta clave por una larga y aleatoria antes del primer arranque.
POSTGRES_PASSWORD=CAMBIAR_ESTA_CLAVE_LARGA_Y_ALEATORIA
