# Reverse proxy con TLS automatico (Let's Encrypt).
# Las variables {$VISAL_DOMAIN} y {$ACME_EMAIL} se leen del .env via docker compose.
{
    email {$ACME_EMAIL}
}

{$VISAL_DOMAIN} {
    encode gzip zstd

    # Cabeceras de seguridad razonables.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        X-Frame-Options SAMEORIGIN
        -Server
    }

    # Blazor Server usa WebSockets para el circuito SignalR. reverse_proxy soporta WS por defecto.
    reverse_proxy visal-app:8080 {
        # Le pasamos al backend que esta detras de un proxy con TLS terminado.
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For {remote}
    }
}
