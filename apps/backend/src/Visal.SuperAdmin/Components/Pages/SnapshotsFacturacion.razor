@page "/facturacion-clinica/snapshots"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using System.Text.Json
@using Visal.Application.Facturacion
@using Visal.Application.Tenancy
@using Visal.Domain.Enums
@inject IFacturacionSnapshotService Svc
@inject ISnapshotColumnaConfigService ColSvc
@inject IEnumerable<ISnapshotBuilder> Builders
@inject IAseguradoraService AseSvc
@inject ISucursalService SucSvc
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS

@*
   Modulo generico de snapshots de facturacion (Capa 07).
   Ruta: /facturacion-clinica/snapshots  (la ruta /facturacion ya la ocupa el
   modulo SaaS de la plataforma).

   Filosofia (ver doc "1. Motor de Snapshots"):
   - Snapshot = instantanea inmutable, no reporte.
   - Nunca DELETE. Solo Archivar con motivo obligatorio (min 10 chars).
   - El motor sirve a N tipos; cada tipo trae su ISnapshotBuilder + sus filtros.
     En Fase 2 el motor solo lista tipos con builder registrado.
*@

<PageTitle>Snapshots Transaccionales - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Facturacion</div>
        <h1 class="ase-title">Snapshots Transaccionales</h1>
        <p class="ase-sub" style="margin:4px 0 0;color:#475569;font-size:13px;">
            Instantaneas de datos para radicar facturas a la EPS. Se archivan con
            motivo pero nunca se eliminan.
        </p>
    </div>
    <div style="display:flex;gap:8px;">
        <button class="btn btn-outline-secondary btn-sm" @onclick="CargarLista" disabled="@_cargando">
            @(_cargando ? "..." : "Refrescar")
        </button>
        <button class="btn btn-outline-primary btn-sm" @onclick="AbrirConfigColumnas" disabled="@(_tiposDisponibles.Count == 0)">
            Configurar columnas
        </button>
        <button class="btn btn-primary btn-sm" @onclick="AbrirNuevo" disabled="@(_tiposDisponibles.Count == 0)">
            + Nuevo snapshot
        </button>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

@if (_tiposDisponibles.Count == 0)
{
    <div class="ase-alert" style="background:#fff7e6;border-color:#ffd591;color:#7a4f01;">
        <b>Aun no hay ningun tipo de snapshot habilitado.</b>
        Los tipos aparecen a medida que se registran sus builders (Fase 5+).
        Puedes ver el listado historico pero no puedes generar nuevos hasta entonces.
    </div>
}

<div class="ase-card sn-card">
    <div class="sn-tabs">
        <button class="sn-tab @(_tab == Tab.Vigentes ? "sel" : "")" @onclick="() => CambiarTab(Tab.Vigentes)">
            Vigentes @if (_conteoVigentes >= 0) { <span class="sn-tab-count">(@_conteoVigentes)</span> }
        </button>
        <button class="sn-tab @(_tab == Tab.Archivados ? "sel" : "")" @onclick="() => CambiarTab(Tab.Archivados)">
            Archivados @if (_conteoArchivados >= 0) { <span class="sn-tab-count">(@_conteoArchivados)</span> }
        </button>
    </div>

    <div class="sn-filtros">
        <div class="sn-f">
            <label>Tipo</label>
            <select class="form-select form-select-sm" @bind="_filtroTipo" @bind:after="CargarLista">
                <option value="">(Todos)</option>
                @foreach (var t in Enum.GetValues<TipoSnapshot>())
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>
        <div class="sn-f">
            <label>Aseguradora</label>
            <select class="form-select form-select-sm" @bind="_filtroAseguradora" @bind:after="CargarLista">
                <option value="">(Todas)</option>
                @foreach (var a in _relAseguradoras)
                {
                    <option value="@a.Id">@a.Nombre</option>
                }
            </select>
        </div>
        <div class="sn-f">
            <label>Fecha desde</label>
            <input type="date" class="form-control form-control-sm" @bind="_filtroDesde" @bind:after="CargarLista" />
        </div>
        <div class="sn-f">
            <label>Fecha hasta</label>
            <input type="date" class="form-control form-control-sm" @bind="_filtroHasta" @bind:after="CargarLista" />
        </div>
    </div>

    @if (_cargando)
    {
        <div class="sn-empty">Cargando...</div>
    }
    else if (_lista.Count == 0)
    {
        <div class="sn-empty">
            @if (_tab == Tab.Vigentes) { <span>No hay snapshots vigentes.</span> }
            else { <span>No hay snapshots archivados.</span> }
        </div>
    }
    else
    {
        <div class="sn-tabla-wrap">
            <table class="table table-sm sn-tabla">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Aseguradora</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Inicio</th>
                        <th>Tardo</th>
                        <th class="sn-th-num">Filas</th>
                        @if (_tab == Tab.Archivados)
                        {
                            <th>Motivo archivado</th>
                            <th>Fecha archivo</th>
                        }
                        <th class="sn-th-acc">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _lista)
                    {
                        <tr>
                            <td>
                                <strong>@s.Nombre</strong>
                                @if (s.Estado == EstadoSnapshot.Fallido && s.ErrorMensaje is not null)
                                {
                                    <div class="sn-error-inline" title="@s.ErrorMensaje">Error: @Truncar(s.ErrorMensaje, 80)</div>
                                }
                            </td>
                            <td>@(s.AseguradoraNombre ?? "-")</td>
                            <td><span class="sn-tag">@s.Tipo</span></td>
                            <td>
                                <span class="sn-estado sn-estado-@(s.Estado.ToString().ToLower())">@s.Estado</span>
                            </td>
                            <td class="sn-mono">@s.FechaEjecucionInicio.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="sn-mono">@FormatearDuracion(s.DuracionMs)</td>
                            <td class="sn-td-num">@s.TotalFilas</td>
                            @if (_tab == Tab.Archivados)
                            {
                                <td class="sn-truncate" title="@s.MotivoArchivado">@Truncar(s.MotivoArchivado, 60)</td>
                                <td class="sn-mono">@(s.FechaArchivado?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            }
                            <td class="sn-td-acc">
                                <button class="btn btn-outline-primary btn-sm"
                                        disabled="@(s.Estado != EstadoSnapshot.Vigente && s.Estado != EstadoSnapshot.Archivado)"
                                        @onclick="() => AbrirVer(s.Id)" title="Ver contenido del snapshot">Ver</button>
                                @if (s.Estado == EstadoSnapshot.Vigente || s.Estado == EstadoSnapshot.Archivado)
                                {
                                    <a class="btn btn-outline-success btn-sm ms-1"
                                       href="@($"/facturacion-clinica/snapshots/{s.Id}/download?formato=xlsx")"
                                       target="_blank" rel="noopener"
                                       title="Descargar Excel">xlsx</a>
                                    <a class="btn btn-outline-secondary btn-sm ms-1"
                                       href="@($"/facturacion-clinica/snapshots/{s.Id}/download?formato=csv")"
                                       target="_blank" rel="noopener"
                                       title="Descargar CSV">csv</a>
                                }
                                @if (_tab == Tab.Vigentes && s.Estado == EstadoSnapshot.Vigente && _puedeArchivar)
                                {
                                    <button class="btn btn-outline-danger btn-sm ms-1"
                                            @onclick="() => AbrirArchivar(s.Id, s.Nombre)"
                                            title="Archivar con motivo">Archivar</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* ============ Modal + Nuevo snapshot ============ *@
@if (_showNuevo)
{
    <div class="sn-modal-back" @onclick="CerrarNuevo">
        <div class="sn-modal sn-modal-md" @onclick:stopPropagation>
            <div class="sn-modal-h">
                <div>
                    <div class="sn-modal-eyebrow">Facturacion</div>
                    <h3>Nuevo Snapshot</h3>
                </div>
                <button class="sn-modal-x" @onclick="CerrarNuevo">&times;</button>
            </div>
            <div class="sn-modal-b">
                @if (_nuevoErr is not null) { <div class="ase-alert">@_nuevoErr</div> }
                <div class="ase-form" style="display:grid;gap:12px;">
                    <div class="ase-f">
                        <label>Tipo *</label>
                        <select class="form-select form-select-sm" @bind="_nuevoTipo">
                            @foreach (var t in _tiposDisponibles)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="ase-f">
                        <label>
                            Nombre *
                            <small class="text-muted">
                                @(_nuevoTipo == TipoSnapshot.RelacionFacturas && _relAseguradoraIds.Count > 1
                                    ? "(se sufija con el nombre de cada EPS)"
                                    : "(para identificarlo en el listado)")
                            </small>
                        </label>
                        <input class="form-control form-control-sm" @bind="_nuevoNombre" placeholder="Facturacion Julio 2026" />
                    </div>
                    @if (_nuevoTipo == TipoSnapshot.RelacionFacturas)
                    {
                        <div class="ase-f">
                            <label>
                                Aseguradoras *
                                <small class="text-muted">
                                    (@_relAseguradoraIds.Count seleccionada@(_relAseguradoraIds.Count == 1 ? "" : "s"))
                                </small>
                            </label>
                            <div style="display:flex;gap:8px;margin-bottom:6px;">
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="MarcarTodasAseguradoras">
                                    Marcar todas
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="QuitarTodasAseguradoras">
                                    Quitar todas
                                </button>
                            </div>
                            <div class="sn-multi" style="max-height:220px;overflow-y:auto;">
                                @foreach (var a in _relAseguradoras)
                                {
                                    <label class="sn-multi-chip">
                                        <input type="checkbox"
                                               checked="@_relAseguradoraIds.Contains(a.Id)"
                                               @onchange="e => ToggleAseguradora(a.Id, (bool)(e.Value ?? false))" />
                                        <span>@a.Nombre @(string.IsNullOrEmpty(a.Nit) ? "" : $"({a.Nit})")</span>
                                    </label>
                                }
                                @if (_relAseguradoras.Count == 0)
                                {
                                    <span class="text-muted">Sin aseguradoras activas.</span>
                                }
                            </div>
                            <small class="text-muted d-block mt-1">
                                Se genera un snapshot independiente por cada aseguradora marcada.
                            </small>
                        </div>
                        <div class="ase-f">
                            <label>Sucursales <small class="text-muted">(opcional — vacio = todas las del tenant)</small></label>
                            <div class="sn-multi">
                                @foreach (var s in _relSucursales)
                                {
                                    <label class="sn-multi-chip">
                                        <input type="checkbox"
                                               checked="@_relSucursalIds.Contains(s.Id)"
                                               @onchange="e => ToggleSucursal(s.Id, (bool)(e.Value ?? false))" />
                                        <span>@s.Nombre</span>
                                    </label>
                                }
                                @if (_relSucursales.Count == 0)
                                {
                                    <span class="text-muted">Sin sucursales activas.</span>
                                }
                            </div>
                        </div>
                        <div class="ase-f" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                            <div>
                                <label>Fecha inicio *</label>
                                <input type="date" class="form-control form-control-sm" @bind="_relFechaInicio" />
                            </div>
                            <div>
                                <label>Fecha fin *</label>
                                <input type="date" class="form-control form-control-sm" @bind="_relFechaFin" />
                            </div>
                        </div>
                        <div class="ase-f">
                            <label>
                                Filtro paciente <small class="text-muted">(opcional — para pruebas del sistema)</small>
                            </label>
                            <input class="form-control form-control-sm"
                                   @bind="_relPacienteQuery"
                                   placeholder="Nombre o identificacion del paciente" />
                            <small class="text-muted d-block mt-1">
                                Solo se incluiran en el snapshot las HC de pacientes cuyo nombre o documento contenga este texto (case y tildes insensibles). Vacio = todos.
                            </small>
                        </div>
                    }
                    else
                    {
                        <div class="ase-f">
                            <label>Filtros del snapshot (JSON)</label>
                            <textarea class="form-control form-control-sm" rows="4"
                                      style="font-family:'JetBrains Mono','Consolas',monospace;font-size:12px;"
                                      @bind="_nuevoFiltrosJson"
                                      placeholder='{"fechaInicio":"2026-06-01","fechaFin":"2026-06-30"}'></textarea>
                            <small class="text-muted d-block mt-1">
                                Este tipo aun no tiene formulario visual — captura el JSON de filtros a mano.
                            </small>
                        </div>
                    }
                </div>
            </div>
            <div class="sn-modal-f">
                <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarNuevo">Cancelar</button>
                <button class="btn btn-primary btn-sm" @onclick="ConfirmarNuevo" disabled="@_generando">
                    @(_generando ? "Generando..." : "Generar")
                </button>
            </div>
        </div>
    </div>
}

@* ============ Modal Ver snapshot ============ *@
@if (_showVer && _verDetalle is not null)
{
    <div class="sn-modal-back" @onclick="CerrarVer">
        <div class="sn-modal sn-modal-xl" @onclick:stopPropagation>
            <div class="sn-modal-h">
                <div>
                    <div class="sn-modal-eyebrow">@_verDetalle.Metadata.Tipo</div>
                    <h3>@_verDetalle.Metadata.Nombre <small class="text-muted">(@_verDetalle.Metadata.TotalFilas filas)</small></h3>
                    <div style="font-size:12px;color:var(--muted);margin-top:4px;">
                        Estado: <b>@_verDetalle.Metadata.Estado</b>
                        &middot; Generado @_verDetalle.Metadata.FechaEjecucionInicio.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        @if (_verDetalle.Metadata.DuracionMs is int d) { <span> &middot; Tardo @FormatearDuracion(d)</span> }
                    </div>
                </div>
                <button class="sn-modal-x" @onclick="CerrarVer">&times;</button>
            </div>
            <div class="sn-modal-controls">
                <div class="sn-modal-controls-l">
                    <label>Buscar</label>
                    <input class="form-control form-control-sm" style="width:220px;"
                           placeholder="texto libre..." @bind="_verBuscar" @bind:event="oninput" @onkeyup="OnBuscarKey" />
                    <label>Fijar hasta col</label>
                    <select class="form-select form-select-sm" style="width:70px;" @bind="_verFijar" @bind:after="StateHasChanged">
                        <option value="0">0</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                    </select>
                </div>
                <div class="sn-modal-controls-r">
                    <span class="sn-page-info">Pagina @_verPagina / @_verTotalPaginas &middot; @_verTotal filas</span>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => IrPagina(_verPagina - 1)" disabled="@(_verPagina <= 1)">&lt;</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => IrPagina(_verPagina + 1)" disabled="@(_verPagina >= _verTotalPaginas)">&gt;</button>
                </div>
            </div>
            <div class="sn-modal-b sn-modal-b-tabla">
                @if (_verCargando)
                {
                    <div class="sn-empty">Cargando...</div>
                }
                else if (_verFilas.Count == 0)
                {
                    <div class="sn-empty">No hay filas para mostrar.</div>
                }
                else
                {
                    <div class="sn-vertabla-wrap">
                        <table class="sn-vertabla">
                            <thead>
                                <tr>
                                    @for (var i = 0; i < _verDetalle.Columnas.Count; i++)
                                    {
                                        var col = _verDetalle.Columnas[i];
                                        var idx = i;
                                        <th class="@(idx < _verFijar ? "sn-vt-freeze" : "")"
                                            style="@(idx < _verFijar ? $"left:{idx * 160}px;" : "")"
                                            @onclick="() => Ordenar(col)">
                                            @col
                                            @if (_verOrden == col) { <span>@(_verOrdenDesc ? " v" : " ^")</span> }
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var fila in _verFilas)
                                {
                                    var filaIdObj = fila.TryGetValue("__filaId", out var fv) ? fv : null;
                                    var filaIdParsed = filaIdObj is Guid g ? g : (Guid.TryParse(filaIdObj?.ToString(), out var gg) ? gg : Guid.Empty);
                                    <tr>
                                        @for (var i = 0; i < _verDetalle.Columnas.Count; i++)
                                        {
                                            var col = _verDetalle.Columnas[i];
                                            var idx = i;
                                            var val = fila.TryGetValue(col, out var v) ? v?.ToString() ?? "" : "";
                                            var editable = _esColumnaEditable(col);
                                            var esVigente = _verDetalle.Metadata.Estado == EstadoSnapshot.Vigente;
                                            var cellClass = (idx < _verFijar ? "sn-vt-freeze" : "") + (editable && esVigente ? " sn-cell-editable" : "");
                                            <td class="@cellClass"
                                                style="@(idx < _verFijar ? $"left:{idx * 160}px;" : "")"
                                                title="@val">
                                                @if (editable && esVigente && filaIdParsed != Guid.Empty)
                                                {
                                                    <select class="form-select form-select-sm sn-cell-select"
                                                            value="@val"
                                                            @onchange="@(async (ChangeEventArgs e) => await EditarCeldaAsync(filaIdParsed, col, e.Value?.ToString()))">
                                                        <option value="">(vacio)</option>
                                                        <option value="AC">AC</option>
                                                        <option value="AP">AP</option>
                                                        <option value="AT">AT</option>
                                                        <option value="AM">AM</option>
                                                    </select>
                                                }
                                                else
                                                {
                                                    @val
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="sn-modal-f">
                <div class="d-flex gap-2">
                    <a class="btn btn-success btn-sm"
                       href="@($"/facturacion-clinica/snapshots/{_verDetalle.Metadata.Id}/download?formato=xlsx")"
                       target="_blank" rel="noopener">Descargar Excel</a>
                    <a class="btn btn-outline-success btn-sm"
                       href="@($"/facturacion-clinica/snapshots/{_verDetalle.Metadata.Id}/download?formato=csv")"
                       target="_blank" rel="noopener">Descargar CSV</a>
                    <a class="btn btn-outline-info btn-sm"
                       href="@($"/facturacion-clinica/snapshots/{_verDetalle.Metadata.Id}/download?formato=json")"
                       target="_blank" rel="noopener"
                       title="JSON RIPS Resolucion 2275/2023 (esqueleto R1)">Generar JSON RIPS</a>
                    <button class="btn btn-outline-primary btn-sm" @onclick="AbrirHistorial">Historial cambios</button>
                </div>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarVer">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ============ Modal Archivar ============ *@
@if (_showArchivar)
{
    <div class="sn-modal-back" @onclick="CerrarArchivar">
        <div class="sn-modal sn-modal-sm" @onclick:stopPropagation>
            <div class="sn-modal-h">
                <div>
                    <div class="sn-modal-eyebrow">Archivar</div>
                    <h3>@_archivarNombre</h3>
                </div>
                <button class="sn-modal-x" @onclick="CerrarArchivar">&times;</button>
            </div>
            <div class="sn-modal-b">
                @if (_archivarErr is not null) { <div class="ase-alert">@_archivarErr</div> }
                <p style="font-size:13px;">
                    El snapshot queda archivado pero <b>no se elimina</b>. Sigue consultable
                    en la tab Archivados con el motivo capturado.
                </p>
                <div class="ase-f">
                    <label>Motivo del archivado * <small class="text-muted">(min 10 caracteres)</small></label>
                    <textarea class="form-control form-control-sm" rows="4"
                              @bind="_archivarMotivo"
                              placeholder="Ej: Se regenero con filtros corregidos y este quedo obsoleto..."></textarea>
                </div>
            </div>
            <div class="sn-modal-f">
                <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarArchivar">Cancelar</button>
                <button class="btn btn-danger btn-sm" @onclick="ConfirmarArchivar" disabled="@_archivando">
                    @(_archivando ? "Archivando..." : "Archivar")
                </button>
            </div>
        </div>
    </div>
}

@* ============ Modal Historial de cambios ============ *@
@if (_showHistorial)
{
    <div class="sn-modal-back" @onclick="CerrarHistorial">
        <div class="sn-modal sn-modal-lg" @onclick:stopPropagation="true">
            <div class="sn-modal-h">
                <div>
                    <div class="sn-modal-eyebrow">Auditoria</div>
                    <h3>Historial de cambios manuales</h3>
                </div>
                <button class="sn-modal-x" @onclick="CerrarHistorial">&times;</button>
            </div>
            <div class="sn-modal-b">
                @if (_historial.Count == 0)
                {
                    <div class="sn-empty">Sin cambios manuales en este snapshot.</div>
                }
                else
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Fila</th>
                                <th>Columna</th>
                                <th>Antes</th>
                                <th>Despues</th>
                                <th>Motivo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _historial)
                            {
                                <tr>
                                    <td class="sn-mono">@c.Fecha.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="sn-td-num">@c.NumeroFila</td>
                                    <td>@c.ColumnaOriginal</td>
                                    <td><em>@(string.IsNullOrEmpty(c.ValorAntes) ? "(vacio)" : c.ValorAntes)</em></td>
                                    <td><strong>@(string.IsNullOrEmpty(c.ValorDespues) ? "(vacio)" : c.ValorDespues)</strong></td>
                                    <td>@(c.Motivo ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="sn-modal-f">
                <span></span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarHistorial">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ============ Modal Configurar columnas ============ *@
@if (_showColConfig)
{
    <div class="sn-modal-back" @onclick="CerrarColConfig">
    <div class="sn-modal sn-modal-lg" @onclick:stopPropagation="true">
        <div class="sn-modal-h">
            <b>Configurar columnas del archivo</b>
            <button class="sn-close" @onclick="CerrarColConfig">x</button>
        </div>
        <div class="sn-modal-b">
            <p style="margin:0 0 10px;color:#475569;font-size:13px;">
                Reordena arrastrando con las flechas, apaga el visto para ocultar la columna
                en el archivo, o escribe un alias para cambiar el titulo del encabezado. Aplica
                a TODOS los snapshots nuevos y descargas del tipo seleccionado.
            </p>
            <div style="display:flex;gap:8px;align-items:center;margin-bottom:12px;">
                <label style="font-size:12px;color:#475569;">Tipo:</label>
                <select class="form-control form-control-sm" style="max-width:280px;" value="@_colConfigTipo" @onchange="OnCambiarTipoColConfig" disabled="@_colConfigCargando">
                    @foreach (var t in _tiposDisponibles)
                    {
                        <option value="@t.ToString()">@NombreTipoSnapshot(t)</option>
                    }
                </select>
                @if (_colConfigCargando)
                {
                    <span style="color:#94a3b8;font-size:12px;">Cargando...</span>
                }
            </div>

            @if (_colConfigErr is not null) { <div class="ase-alert">@_colConfigErr</div> }

            <div class="fcc-list">
                <div class="fcc-item fcc-head">
                    <div class="fcc-row-main">
                        <div class="fcc-move"></div>
                        <div class="fcc-vis">Visible</div>
                        <div class="fcc-name">Columna original</div>
                        <div class="fcc-alias">Alias (header en archivo)</div>
                    </div>
                </div>
                @for (var i = 0; i < _colConfigItems.Count; i++)
                {
                    var idx = i;
                    var it = _colConfigItems[idx];
                    <div class="fcc-item @(it.Visible ? "" : "fcc-off")">
                        <div class="fcc-row-main">
                            <div class="fcc-move">
                                <button class="fcc-arr" title="Subir" disabled="@(idx == 0)" @onclick="() => SubirColConfig(idx)">^</button>
                                <button class="fcc-arr" title="Bajar" disabled="@(idx == _colConfigItems.Count - 1)" @onclick="() => BajarColConfig(idx)">v</button>
                            </div>
                            <div class="fcc-vis">
                                <input type="checkbox" checked="@it.Visible" @onchange="e => ToggleColConfig(idx, (bool)e.Value!)" />
                            </div>
                            <div class="fcc-name" title="@it.ColumnaOriginal">@it.ColumnaOriginal</div>
                            <div class="fcc-alias">
                                <input class="form-control form-control-sm" placeholder="@it.ColumnaOriginal"
                                       value="@(it.Alias ?? "")" @oninput="e => SetAliasColConfig(idx, e.Value?.ToString())" />
                            </div>
                        </div>
                        <div class="fcc-row-extra">
                            <div class="fcc-extra-field">
                                <label>Descripcion</label>
                                <textarea class="form-control form-control-sm" rows="2" placeholder="Que significa este campo..."
                                          @oninput="e => SetDescripcionColConfig(idx, e.Value?.ToString())">@(it.Descripcion ?? "")</textarea>
                            </div>
                            <div class="fcc-extra-field">
                                <label>Ruta origen</label>
                                <input class="form-control form-control-sm" placeholder="Paciente.NumeroDocumento"
                                       value="@(it.RutaOrigen ?? "")" @oninput="e => SetRutaOrigenColConfig(idx, e.Value?.ToString())" />
                            </div>
                        </div>
                    </div>
                }
                @if (_colConfigItems.Count == 0)
                {
                    <div class="ase-empty">Este tipo no expone columnas todavia.</div>
                }
            </div>
        </div>
        <div class="sn-modal-f" style="justify-content:space-between;">
            <button class="btn btn-outline-danger btn-sm" @onclick="ResetColConfig" disabled="@_colConfigGuardando">Restaurar defaults</button>
            <div style="display:flex;gap:8px;">
                <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarColConfig">Cancelar</button>
                <button class="btn btn-primary btn-sm" @onclick="GuardarColConfig" disabled="@(_colConfigGuardando || _colConfigItems.Count == 0)">
                    @(_colConfigGuardando ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
    </div>
}

