@page "/config/revision-policy"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Authorization
@using Visal.Application.Revision
@inject IRevisionPolicyService Svc

<PageTitle>Politica de Revision Clinica - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion de la Entidad</div>
        <h1 class="ase-title">Politica de Revision Clinica</h1>
        <small class="text-muted">
            Controla el comportamiento automatico del ciclo de revision (Capa 08 Ola 4).
            Aplica a todas las HCs del tenant.
        </small>
    </div>
</div>

@if (!_puedeConfig)
{
    <div class="ase-card">
        <div class="ase-alert">
            Solo el Owner del tenant o el SuperAdmin de la plataforma pueden modificar esta politica.
        </div>
    </div>
}
else if (_cargando && _policy is null)
{
    <div class="ase-card">
        <div class="ase-empty" style="padding:24px;">Cargando politica...</div>
    </div>
}
else if (_policy is not null)
{
    <div class="ase-card">
        <div class="ase-card-h">Trigger automatico</div>
        <div class="ase-card-body">
            <div class="rp-row rp-row-hero">
                <div class="rp-row-body">
                    <label class="form-check form-switch rp-switch">
                        <input class="form-check-input" type="checkbox" role="switch"
                               @bind="_policy.AutoTriggerCierre" />
                        <span class="rp-switch-l">Enviar automaticamente a revision al cerrar HC</span>
                    </label>
                    <p class="rp-help">
                        Cuando esta activo, al pulsar <b>Guardar definitivamente</b> una HC,
                        el sistema crea la revision y la deja en la columna <b>Cerradas</b> del
                        Kanban en <a href="/ordenes" target="_blank">Ordenes Clinicas</a>.
                        Si esta desactivado, el profesional debe pulsar manualmente
                        <b>Enviar a revision</b> desde el tab Revision del modal HC.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="ase-card">
        <div class="ase-card-h">Parametros del ciclo</div>
        <div class="ase-card-body">
            <div class="rp-grid">
                <div class="rp-field">
                    <label>Motivo minimo al inactivar (caracteres)</label>
                    <input type="number" class="form-control form-control-sm"
                           min="0" max="500" step="1"
                           @bind="_policy.MotivoInactivacionMinChars" />
                    <small class="rp-help-sm">
                        Cuantos caracteres minimo se exigen al inactivar una revision.
                        El rechazo siempre exige texto no vacio, este ajuste solo aplica a la inactivacion.
                    </small>
                </div>

                <div class="rp-field">
                    <label>
                        <input type="checkbox" @bind="_policy.ConfirmarAprobado" />
                        Pedir confirmacion antes de aprobar
                    </label>
                    <small class="rp-help-sm">
                        Cuando esta activo, la UI del Kanban abre un modal preguntando
                        antes de mover una card a Aprobadas.
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="ase-card">
        <div class="ase-card-h">Agente IA (reservado para olas futuras)</div>
        <div class="ase-card-body">
            <p class="rp-help">
                Estos toggles quedan disponibles pero no tienen efecto hasta que el
                agente <b>REVISOR CLINICO IA</b> este operativo (Ola 5 del plan) y la
                adopcion automatica del veredicto este implementada (Ola 6). Puedes
                dejarlos como estan por ahora.
            </p>
            <div class="rp-grid">
                <div class="rp-field">
                    <label>
                        <input type="checkbox" @bind="_policy.PreRevisionIAAutoTrigger" />
                        Pre-revision IA automatica al crear la revision (Ola 5)
                    </label>
                </div>
                <div class="rp-field">
                    <label>
                        <input type="checkbox" @bind="_policy.AdopcionAutomaticaAgente" />
                        Adopcion automatica del veredicto del agente (Ola 6)
                    </label>
                </div>
                <div class="rp-field">
                    <label>Umbral de confianza (0-1) para adopcion automatica</label>
                    <input type="number" class="form-control form-control-sm"
                           min="0" max="1" step="0.01"
                           @bind="_policy.UmbralConfianza" />
                    <small class="rp-help-sm">Default 0.95. Un veredicto del agente por debajo de este umbral requiere humano.</small>
                </div>
                <div class="rp-field">
                    <label>Ventana de asignaciones relacionadas (dias)</label>
                    <input type="number" class="form-control form-control-sm"
                           min="1" max="365" step="1"
                           @bind="_policy.VentanaAsignacionesRelacionadasDias" />
                    <small class="rp-help-sm">Cuantos dias hacia atras el agente busca contexto de asignaciones del paciente.</small>
                </div>
            </div>
        </div>
    </div>

    @if (_msg is not null) { <div class="ase-ok" style="margin-top:12px;">@_msg</div> }
    @if (_error is not null) { <div class="ase-alert" style="margin-top:12px;">@_error</div> }

    <div class="rp-actions">
        <button class="btn btn-primary" @onclick="GuardarAsync" disabled="@_guardando">
            @(_guardando ? "Guardando..." : "💾 Guardar politica")
        </button>
    </div>
}

<style>
    .rp-row { padding:16px 20px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; }
    .rp-row-hero { border-left:4px solid #1565c0; background:#f0f9ff; }
    .rp-switch { display:flex; align-items:center; gap:10px; margin:0; font-size:14px; }
    .rp-switch input { width:44px; height:24px; }
    .rp-switch-l { font-weight:600; color:#0f172a; }
    .rp-help { color:#475569; font-size:12.5px; margin:8px 0 0; }
    .rp-help-sm { color:#64748b; font-size:11.5px; display:block; margin-top:2px; }
    .rp-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:16px; }
    .rp-field { background:#fff; padding:12px 14px; border:1px solid #e5e7eb; border-radius:6px; }
    .rp-field > label { display:block; font-size:12px; font-weight:600; color:#334155; margin-bottom:6px; }
    .rp-field input[type=checkbox] { margin-right:6px; }
    .rp-actions { display:flex; justify-content:flex-end; padding:14px 0; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private sealed class PolicyModel
    {
        public bool AutoTriggerCierre { get; set; }
        public bool PreRevisionIAAutoTrigger { get; set; }
        public bool AdopcionAutomaticaAgente { get; set; }
        public decimal UmbralConfianza { get; set; }
        public int VentanaAsignacionesRelacionadasDias { get; set; }
        public bool ConfirmarAprobado { get; set; }
        public int MotivoInactivacionMinChars { get; set; }
    }

    private PolicyModel? _policy;
    private bool _cargando = true;
    private bool _guardando;
    private bool _puedeConfig;
    private Guid _actorId;
    private string? _msg;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await ResolverPermisosAsync();
        if (_puedeConfig)
        {
            await CargarAsync();
        }
        _cargando = false;
    }

    private async Task ResolverPermisosAsync()
    {
        if (AuthState is null) { return; }
        try
        {
            var state = await AuthState;
            var tenantRole = state.User.FindFirst("tenant_role")?.Value;
            var platformRole = state.User.FindFirst("platform_role")?.Value;
            _puedeConfig = string.Equals(tenantRole, "Owner", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(platformRole, "SuperAdmin", StringComparison.OrdinalIgnoreCase);
            var uidStr = state.User.FindFirst("user_id")?.Value ?? state.User.FindFirst("sub")?.Value;
            _actorId = Guid.TryParse(uidStr, out var uid) ? uid : Guid.Empty;
        }
        catch { }
    }

    private async Task CargarAsync()
    {
        try
        {
            var dto = await Svc.GetAsync();
            _policy = new PolicyModel
            {
                AutoTriggerCierre = dto.AutoTriggerCierre,
                PreRevisionIAAutoTrigger = dto.PreRevisionIAAutoTrigger,
                AdopcionAutomaticaAgente = dto.AdopcionAutomaticaAgente,
                UmbralConfianza = dto.UmbralConfianza,
                VentanaAsignacionesRelacionadasDias = dto.VentanaAsignacionesRelacionadasDias,
                ConfirmarAprobado = dto.ConfirmarAprobado,
                MotivoInactivacionMinChars = dto.MotivoInactivacionMinChars,
            };
        }
        catch (Exception ex) { _error = "No se pudo cargar la politica: " + ex.Message; }
    }

    private async Task GuardarAsync()
    {
        if (_policy is null) { return; }
        _guardando = true;
        _msg = null; _error = null;
        try
        {
            var dto = new RevisionPolicyDto(
                _policy.AutoTriggerCierre,
                _policy.PreRevisionIAAutoTrigger,
                _policy.AdopcionAutomaticaAgente,
                _policy.UmbralConfianza,
                _policy.VentanaAsignacionesRelacionadasDias,
                _policy.ConfirmarAprobado,
                _policy.MotivoInactivacionMinChars);
            await Svc.SaveAsync(dto, _actorId);
            _msg = "Politica guardada. Aplica en el proximo cierre de HC.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _guardando = false; }
    }
}
