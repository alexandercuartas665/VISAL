        new ColDef("orden",         "Orden",           "Orden",                                   7),
        new ColDef("tipo",          "Tipo",            "Tipo",                                    8),
        new ColDef("servicio",      "Servicio",        "Servicio",                                9),
        new ColDef("pkg_cod",       "PaqueteCod",      "Paquete<br/>Cod",                        10),
        new ColDef("pkg_nom",       "PaqueteNombre",   "Paquete<br/>Nombre",                     11),
        new ColDef("session_no",    "SessionNo",       "Sesion",                                 12),
        new ColDef("completado",    "Completado",     "Completado",                              13),
        new ColDef("tipo_doc_pac",  "TipoDocPac",      "Tipo<br/>DocPac",                        14),
        new ColDef("no_doc_pac",    "NoDocPac",        "NoDocPac",                                15),
        new ColDef("nom_paciente",  "NomPaciente",     "Paciente",                                16),
        new ColDef("profesional",   "Profesional",     "Profesional",                             17),
        new ColDef("fec_nota",      "FecNota",         "Fecha<br/>Nota",                          18),
    };

    private List<AtencionColumnaConfigDto> _configColumnas = new();

    /// <summary>Columnas visibles ya mezcladas con overrides y ordenadas.</summary>
    private IReadOnlyList<(string Key, string Titulo)> _columnasVisibles
    {
        get
        {
            var cfgDict = _configColumnas.ToDictionary(c => c.ColumnaKey, c => c);
            var items = _columnasDefault.Select(d =>
            {
                cfgDict.TryGetValue(d.Key, out var ov);
                var visible = ov?.Visible ?? true;
                var titulo = string.IsNullOrWhiteSpace(ov?.Alias) ? d.TituloHtml : System.Net.WebUtility.HtmlEncode(ov!.Alias!);
                var orden = ov?.Orden ?? d.OrdenDefault;
                return new { d.Key, Titulo = titulo, Visible = visible, Orden = orden };
            });
            return items.Where(x => x.Visible).OrderBy(x => x.Orden).Select(x => (x.Key, x.Titulo)).ToList();
        }
    }

