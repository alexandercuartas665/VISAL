    /// <summary>Actualiza el usuario ya existente en un solo paso: aplica rol
    /// (persistido en profesional -> propaga a TenantUser junto con las sedes) y
    /// resetea la clave si el operador ingreso una nueva.</summary>
    private async Task ActualizarUsuario()
    {
        if (_id is not Guid pid || _usuarioVinculado is null) { return; }
        if (!Guid.TryParse(_nuevoRolId, out var rolId))
        {
            _modalError = "Selecciona un rol.";
            return;
        }
        if (!string.IsNullOrEmpty(_nuevoPwd) && _nuevoPwd.Length < 6)
        {
            _modalError = "La clave debe tener al menos 6 caracteres o dejarse vacia para no cambiarla.";
            return;
        }

        _modalError = null; _busyCrearUsu = true;
        try
        {
            var actor = await Actor();

            // 1) Aplicar rol al profesional. Ese Save propaga rol + sedes al
            //    TenantUser vinculado en una sola operacion, asi que evitamos
            //    duplicar la logica de traduccion de sedes aqui.
            _rolPredeterminadoId = rolId.ToString();
            Guid? tipoId = Guid.TryParse(_tipoProfId, out var tg) ? tg : null;
            var req = new SaveProfesionalRequest(pid, _doc, _tipoDoc, _pNombre, _sNombre, _pApellido, _sApellido,
                _nombreCompleto, tipoId, _registro, _ciudad, _celular, _firmaUrl,
                _subSel.ToList(), _agencias, rolId);
            var saved = await Svc.SaveProfesionalAsync(req, actor);
            if (saved is null) { _modalError = "No se pudo actualizar el rol (sin tenant activo)."; return; }

            // 2) Reset de clave (opcional).
            if (!string.IsNullOrEmpty(_nuevoPwd))
            {
                var okPwd = await UsuSvc.ResetPasswordAsync(_usuarioVinculado.Id, _nuevoPwd, actor);
                if (!okPwd) { _modalError = "El rol se actualizo pero no se pudo reiniciar la clave."; return; }
            }

            // Refrescar estado + UI.
            _usuarioVinculado = (await UsuSvc.ListAsync()).FirstOrDefault(u => u.Id == _usuarioVinculado.Id);
            _ok = string.IsNullOrEmpty(_nuevoPwd)
                ? $"Usuario '{_usuarioVinculado?.Email}' actualizado: rol y sedes."
                : $"Usuario '{_usuarioVinculado?.Email}' actualizado: rol, sedes y clave.";
            _showCrearUsuModal = false;
        }
        catch (InvalidOperationException ex) { _modalError = ex.Message; }
        catch (Exception ex) { _modalError = "Error: " + ex.Message; }
        finally { _busyCrearUsu = false; }
    }

    private async Task ReiniciarClaveUsuario()
