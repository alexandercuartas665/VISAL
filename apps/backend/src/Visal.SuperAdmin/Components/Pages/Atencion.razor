    /// Config default de columnas. El orden aqui es el orden por defecto.
    /// El "TituloHtml" permite forzar saltos de linea (por ejemplo "HISTORIA
    /// MEDICA" en 2 lineas para que la columna sea mas angosta).
    /// </summary>
    private sealed record ColDef(string Key, string TituloDefault, string TituloHtml, int OrdenDefault);
