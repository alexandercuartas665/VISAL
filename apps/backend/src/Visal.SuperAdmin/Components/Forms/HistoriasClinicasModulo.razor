    /// Se resetea al cambiar PacienteContexto (ver OnParametersSetAsync).</summary>
    private readonly AcompananteSelectorContext _acompSelector = new();
    private Guid? _acompPacienteId;

    /// <summary>Devuelve (icono unicode, conteo de badge) para una etiqueta del menu.</summary>
    private (string icono, int badge) IconoYBadge(string tab) => tab switch
    {
        "Historial" => ("\U0001F4DD", 0),                      // notepad
        "Escalas" => ("\U0001F4CB", _escCount),                // clipboard
        "Evoluciones" => ("\U0001F4C8", _evoCount),            // chart up
        "Consentimientos" => ("✅", _conCount),            // check mark
        "Atenciones" => ("\U0001FA7A", _atCount),              // stethoscope
        "Documentos externos" => ("\U0001F4CE", _docExtCount), // paperclip
        "Ordenes medicamento" => ("\U0001F48A", _medCount),    // pill
        "Ordenes servicios" => ("\U0001F3E5", _servCount), // hospital
        "Insumos" => ("\U0001F4E6", _insCount),                // box
        "Remisiones" => ("↗", _remCount),                 // arrow up-right
        "Ordenes incapacidad" => ("\U0001F4C4", _incCount),    // page facing up
        "Ordenes certificaciones" => ("\U0001F4DC", _certCount), // scroll
        "RX Imagenologia" => ("\U0001F9BF", _rxExtCount),      // bone (radiografia)
        "Laboratorios" => ("\U0001F9EA", _labExtCount),        // test tube
        _ => ("•", 0)
    };

    /// <summary>
    /// Etiqueta VISIBLE de cada tab. Los identificadores internos (_tabSel,
    /// switch de IconoYBadge, etc.) siguen siendo los mismos — este metodo
    /// solo cambia lo que ve el usuario. Para "Ordenes servicios" agregamos
    /// el nombre de la agencia del tenant ("Servicios Agencia Demo") para
    /// diferenciarlo visualmente de las ordenes externas de otras IPS.
    /// Si aun no cargo el nombre del tenant (o el usuario es super admin)
    /// se muestra simplemente "Servicios".
    /// </summary>
    /// <summary>Aliases por pestana definidos por el admin en /config/menu-hc.
    /// Prioridad: alias configurado por el admin > etiqueta especial (ej. Ordenes
    /// servicios inyecta nombre de agencia) > clave por defecto.</summary>
    private Dictionary<string, string> _aliasesPestanas = new(StringComparer.OrdinalIgnoreCase);

    /// <summary>Orden explicito por pestana. Cuando una pestana no aparece aca
    /// usa su posicion en el array _tabs como fallback.</summary>
    private Dictionary<string, int> _ordenesPestanas = new(StringComparer.OrdinalIgnoreCase);

    /// <summary>Pestanas visibles ordenadas por (Orden configurado ASC, indice
    /// original ASC). Se aplica al menu lateral del modal HC.</summary>
    private IEnumerable<string> TabsOrdenadas()
    {
        return _tabs
            .Select((tab, idx) => (tab, idx))
            .Where(x => !_pestanasOcultas.Contains(x.tab))
            .OrderBy(x => _ordenesPestanas.TryGetValue(x.tab, out var o) ? o : x.idx + 1)
            .ThenBy(x => x.idx)
            .Select(x => x.tab);
    }

    private string EtiquetaTab(string tab)
    {
        // El alias configurado gana siempre — el admin lo puso a mano.
        if (_aliasesPestanas.TryGetValue(tab, out var alias) && !string.IsNullOrWhiteSpace(alias))
        {
            return alias;
        }
        return tab switch
        {
            "Ordenes servicios" => string.IsNullOrWhiteSpace(_tenantName)
                ? "Servicios"
                : $"Servicios {_tenantName}",
            _ => tab
        };
    }

    /// <summary>Nombre de la agencia/tenant del usuario logueado. Se carga en
