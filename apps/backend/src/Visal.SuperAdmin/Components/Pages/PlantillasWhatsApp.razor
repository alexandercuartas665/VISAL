@page "/lineas/plantillas"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Visal.Application.Admin
@using Visal.Application.Tenancy
@using Visal.Application.Tenancy.WhatsApp
@using Visal.Domain.Enums
@inject IWhatsAppLineService LinesSvc
@inject IHsmTemplateService HsmSvc
@inject IJSRuntime JS

<PageTitle>Plantillas WhatsApp - Visal</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <span>Infraestructura & IA</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Plantillas <span>WhatsApp</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Plantillas HSM aprobadas por Meta para iniciar conversaciones fuera de la ventana de 24 h.</p>
    </div>
    <div style="display:flex; gap:8px; align-items:center;">
        <button class="btn btn-outline-secondary" @onclick="ReloadTemplatesAsync" disabled="@(_busy || _gupshupLines.Count == 0)">Refrescar</button>
        <button class="btn btn-primary" @onclick="OpenNewTemplate" disabled="@(_busy || _selectedLineId is null)">+ Nueva plantilla</button>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando lineas...</em></p>
}
else if (_gupshupLines.Count == 0)
{
    <div class="card" style="max-width:720px;padding:18px 20px;">
        <p style="margin:0;">No tienes lineas Gupshup configuradas todavia.</p>
        <p class="text-muted" style="font-size:13px; margin-top:8px;">
            Ve a <a href="lineas">Lineas WhatsApp</a> y crea una linea Gupshup para gestionar sus plantillas aqui.
        </p>
    </div>
}
else
{
    <div class="card" style="max-width:1180px;padding:16px 20px; margin-bottom:16px;">
        <div style="display:flex; gap:16px; align-items:end;">
            <div class="field" style="flex:1;">
                <label class="form-label">Linea Gupshup</label>
                <select class="form-control" @bind="SelectedLineIdText" @bind:after="OnLineChangedAsync">
                    <option value="">— Selecciona —</option>
                    @foreach (var l in _gupshupLines)
                    {
                        <option value="@l.Id">@l.InstanceName @(string.IsNullOrEmpty(l.PhoneNumber) ? "" : $"({l.PhoneNumber})")</option>
                    }
                </select>
            </div>
            @if (_lastError is not null)
            {
                <div class="text-danger small" style="align-self:center;">@_lastError</div>
            }
        </div>
    </div>

    @if (_selectedLineId is null)
    {
        <p class="text-muted">Selecciona una linea para ver sus plantillas.</p>
    }
    else if (_templates.Count == 0)
    {
        <p class="text-muted">Sin plantillas aun. Crea la primera con "+ Nueva plantilla".</p>
    }
    else
    {
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:14px;">
            @foreach (var t in _templates)
            {
                <div class="card" style="padding:14px 16px; display:flex; flex-direction:column; gap:8px;">
                    <div style="display:flex; align-items:center; justify-content:space-between;">
                        <strong style="font-size:15px; word-break:break-all;">@t.ElementName</strong>
                        <span class="badge" style="background:@StatusColor(t.Status); color:#fff;">@t.Status</span>
                    </div>
                    <div style="font-size:12px; color:var(--muted-foreground);">
                        @t.LanguageCode · @t.Category · @t.ParameterCount parametro(s)
                    </div>
                    <div style="font-size:13px; color:#111; white-space:pre-wrap; background:#f8fafc; padding:8px; border-radius:6px; max-height:120px; overflow-y:auto;">@t.Body</div>
                    <div style="display:flex; gap:6px; margin-top:2px;">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenSendTest(t)" disabled="@(_busy || t.Status != "APPROVED")">Enviar test</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyBodyAsync(t.Body)" title="Copiar contenido">Copiar</button>
                    </div>
                </div>
            }
        </div>
    }
}

@* ===== Modal: Nueva plantilla ===== *@
@if (_newOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:640px;">
            <div class="modal-head">
                <h3>Nueva plantilla HSM</h3>
                <button class="modal-close" @onclick="() => _newOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre (element_name) *</label>
                    <input class="form-control" @bind="_newTpl.ElementName" placeholder="visal_recordatorio_cita (solo minusculas y guion bajo)" />
                    <small class="text-muted">Meta exige snake_case: solo letras minusculas, numeros y "_". Sin espacios.</small>
                </div>
                <div class="field" style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <div>
                        <label class="form-label">Idioma *</label>
                        <select class="form-control" @bind="_newTpl.LanguageCode">
                            <option value="es">es (Espanol)</option>
                            <option value="es_CO">es_CO (Espanol Colombia)</option>
                            <option value="en">en (Ingles)</option>
                            <option value="en_US">en_US</option>
                            <option value="pt_BR">pt_BR</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Categoria *</label>
                        <select class="form-control" @bind="_newTpl.Category">
                            <option value="UTILITY">UTILITY (recordatorios, actualizaciones)</option>
                            <option value="MARKETING">MARKETING (promocional)</option>
                            <option value="AUTHENTICATION">AUTHENTICATION (OTP / verificacion)</option>
                        </select>
                    </div>
                </div>
                <div class="field">
                    <label class="form-label">Cuerpo *</label>
                    <textarea class="form-control" rows="4" @bind="_newTpl.Content" placeholder="Hola {{1}}, te recordamos tu cita para el {{2}} a las {{3}}. Gracias."></textarea>
                    <small class="text-muted">Placeholders {{1}}, {{2}}, ... para valores dinamicos. Meta valida el orden.</small>
                </div>
                <div class="field">
                    <label class="form-label">Ejemplos (uno por placeholder, separados por | ) *</label>
                    <input class="form-control" @bind="_newTpl.Example" placeholder="Juan | 15/Julio | 10:30" />
                    <small class="text-muted">Meta necesita ejemplos para revisar. Deben coincidir con la cantidad de placeholders.</small>
                </div>
                @if (_newError is not null)
                {
                    <div class="text-danger small">@_newError</div>
                }
                @if (_newOk is not null)
                {
                    <div class="text-success small">@_newOk</div>
                }
                <div class="text-muted small" style="margin-top:8px;">
                    Al crear entra en <strong>PENDING</strong> y Meta la revisa en 1–24 h. Aprobada o no, aparecera al pulsar Refrescar.
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _newOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="CreateTemplateAsync" disabled="@_busy">Enviar a revisar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: Enviar test ===== *@
@if (_sendOpen && _sendTpl is { } st)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>Enviar prueba: @st.ElementName</h3>
                <button class="modal-close" @onclick="() => _sendOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Numero destino *</label>
                    <input class="form-control" @bind="_sendPhone" placeholder="573001234567 (con codigo pais, sin +)" />
                </div>
                @if (st.ParameterCount > 0)
                {
                    <div class="field">
                        <label class="form-label">Parametros ({{1}} a {{@st.ParameterCount}})</label>
                        @for (var i = 0; i < st.ParameterCount; i++)
                        {
                            var idx = i;
                            <input class="form-control" style="margin-bottom:6px;"
                                   placeholder="@($"Valor {{{{{idx + 1}}}}}")"
                                   value="@_sendParams[idx]"
                                   @onchange="e => _sendParams[idx] = e.Value?.ToString() ?? string.Empty" />
                        }
                    </div>
                }
                @if (_sendMsg is not null)
                {
                    <div class="@(_sendOk ? "text-success" : "text-danger") small">@_sendMsg</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _sendOpen = false">Cerrar</button>
                <button class="btn btn-primary" @onclick="SendTestAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_sendPhone))">Enviar</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private List<WhatsAppLineDto> _gupshupLines = new();
    private Guid? _selectedLineId;
    private List<GupshupTemplateInfo> _templates = new();
    private string? _lastError;

    // Nueva plantilla
    private bool _newOpen;
    private HsmCreateRequestDraft _newTpl = new();
    private string? _newError;
    private string? _newOk;

    // Enviar test
    private bool _sendOpen;
    private GupshupTemplateInfo? _sendTpl;
    private string? _sendPhone;
    private string[] _sendParams = Array.Empty<string>();
    private string? _sendMsg;
    private bool _sendOk;

    /// <summary>El select html devuelve string. Cast a Guid en el getter/setter
    /// para mantener _selectedLineId tipado.</summary>
    private string SelectedLineIdText
    {
        get => _selectedLineId?.ToString() ?? string.Empty;
        set => _selectedLineId = Guid.TryParse(value, out var g) ? g : null;
    }

    /// <summary>Draft del form: usamos strings sueltos y validamos al submit
    /// (los required no bastan porque Meta impone reglas extra sobre snake_case).</summary>
    private sealed class HsmCreateRequestDraft
    {
        public string ElementName { get; set; } = string.Empty;
        public string LanguageCode { get; set; } = "es";
        public string Category { get; set; } = "UTILITY";
        public string Content { get; set; } = string.Empty;
        public string Example { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        var all = await LinesSvc.ListAsync();
        _gupshupLines = all.Where(l => l.Provider == WhatsAppProvider.Gupshup).ToList();
        _loading = false;
    }

    private async Task OnLineChangedAsync()
    {
        _templates.Clear();
        _lastError = null;
        if (_selectedLineId is not Guid lid) { return; }
        await ReloadTemplatesForAsync(lid);
    }

    private Task ReloadTemplatesAsync()
        => _selectedLineId is Guid lid ? ReloadTemplatesForAsync(lid) : Task.CompletedTask;

    private async Task ReloadTemplatesForAsync(Guid lid)
    {
        _busy = true; _lastError = null;
        try
        {
            var r = await HsmSvc.ListByLineAsync(lid);
            _templates = r.Templates
                .OrderByDescending(t => t.Status == "APPROVED")
                .ThenBy(t => t.ElementName)
                .ToList();
            if (!r.Ok) { _lastError = r.Error; }
        }
        finally { _busy = false; }
    }

    private void OpenNewTemplate()
    {
        _newTpl = new HsmCreateRequestDraft();
        _newError = _newOk = null;
        _newOpen = true;
    }

    private async Task CreateTemplateAsync()
    {
        _newError = _newOk = null;
        if (_selectedLineId is not Guid lid) { _newError = "Selecciona una linea."; return; }
        if (string.IsNullOrWhiteSpace(_newTpl.ElementName)) { _newError = "Falta el nombre."; return; }
        // Meta rechaza mayusculas y espacios en element_name.
        foreach (var c in _newTpl.ElementName)
        {
            if (!(char.IsLower(c) || char.IsDigit(c) || c == '_'))
            {
                _newError = "El nombre solo admite minusculas, digitos y guion bajo.";
                return;
            }
        }
        if (string.IsNullOrWhiteSpace(_newTpl.Content)) { _newError = "Falta el cuerpo."; return; }

        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var req = new HsmCreateRequest(
                ElementName: _newTpl.ElementName.Trim(),
                LanguageCode: _newTpl.LanguageCode,
                Category: _newTpl.Category,
                TemplateType: "TEXT",
                Content: _newTpl.Content.Trim(),
                Example: _newTpl.Example.Trim());
            var r = await HsmSvc.CreateByLineAsync(lid, req, actor);
            if (!r.Ok) { _newError = r.Error ?? "No se pudo crear."; return; }
            _newOk = $"Enviada a Meta ({r.Status ?? "PENDING"}). ID: {r.Id ?? "—"}";
            await ReloadTemplatesForAsync(lid);
        }
        finally { _busy = false; }
    }

    private void OpenSendTest(GupshupTemplateInfo t)
    {
        _sendTpl = t;
        _sendPhone = null;
        _sendParams = new string[t.ParameterCount];
        _sendMsg = null;
        _sendOk = false;
        _sendOpen = true;
    }

    private async Task SendTestAsync()
    {
        if (_sendTpl is not { } t || _selectedLineId is not Guid lid) { return; }
        if (string.IsNullOrWhiteSpace(_sendPhone)) { return; }
        _busy = true; _sendMsg = null;
        try
        {
            var actor = await ActorAsync();
            var r = await HsmSvc.SendTestAsync(lid, t.Id, _sendPhone!.Trim(), _sendParams.ToList(), actor);
            _sendOk = r.Ok;
            _sendMsg = r.Ok ? "Enviada." : (r.Error ?? "Error al enviar.");
        }
        finally { _busy = false; }
    }

    private async Task CopyBodyAsync(string body)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", body); }
        catch { /* clipboard no disponible: el usuario copia a mano */ }
    }

    private static string StatusColor(string status) => status switch
    {
        "APPROVED" => "#22c55e",
        "PENDING" => "#f59e0b",
        "REJECTED" => "#ef4444",
        "PAUSED" => "#6b7280",
        "DELETED" => "#374151",
        _ => "#0ea5e9",
    };

    // Actor id: mismo patron que usan otras paginas.
    [Inject] private AuthenticationStateProvider Auth { get; set; } = default!;
    private async Task<Guid> ActorAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var sub = state.User.FindFirst("sub")?.Value ?? state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(sub, out var g) ? g : Guid.Empty;
    }
}
