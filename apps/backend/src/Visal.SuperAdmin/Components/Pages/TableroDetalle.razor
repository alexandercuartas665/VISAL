@page "/tableros/{BoardId:guid}"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Visal.Application.Tenancy
@inject ITaskBoardService BoardsSvc
@inject ITaskBoardMemberService MembersSvc
@inject NavigationManager Nav

<PageTitle>@(_board?.Name ?? "Tablero") - Visal</PageTitle>

@if (_loading)
{
    <p class="tb-loading">Cargando tablero...</p>
}
else if (_board is null || _accessDenied)
{
    <div class="tb-denied">
        <h2>Este tablero no existe o no fuiste invitado.</h2>
        <p>Pidele al dueño que te invite desde su tablero, o crea uno tuyo.</p>
        <button class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/tableros"))">Volver a Tableros</button>
    </div>
}
else
{
    <div class="td-page">
        @* ===== Header ===== *@
        <div class="td-head">
            <div class="td-head-left">
                <a href="/tableros" class="td-back">←</a>
                <span class="td-color-dot" style="background:@(_board.Color ?? "#3b82f6");"></span>
                <h1 class="td-title">@_board.Name</h1>
                @if (_board.IsOwner)
                {
                    <span class="tb-badge-owner">Owner</span>
                }
            </div>
            <div class="td-head-right">
                <button class="btn btn-outline-secondary btn-sm" @onclick="OpenMembers">👥 Miembros (@_board.MemberCount)</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="OpenEditBoard">✎ Editar</button>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(_board.Description))
        {
            <p class="td-desc">@_board.Description</p>
        }

        @* ===== Kanban ===== *@
        <div class="td-kanban">
            @foreach (var col in _columns)
            {
                <div class="td-col" @ondragover:preventDefault @ondragover="@(e => OnDragOver(col.Id))" @ondrop="@(() => OnDropAsync(col.Id))">
                    <div class="td-col-head" style="border-top:3px solid @(col.Color ?? "#94a3b8");">
                        <div class="td-col-title">@col.Name @if (col.IsDone) { <span title="Estado final">✓</span> }</div>
                        <div class="td-col-count">@col.CardCount</div>
                    </div>
                    <div class="td-col-body">
                        @foreach (var card in _cards.Where(c => c.ColumnId == col.Id).OrderBy(c => c.SortOrder))
                        {
                            <div class="td-card @(card.Color is null ? "" : "td-card-colored")"
                                 style="@(card.Color is null ? "" : $"border-left:3px solid {card.Color};")"
                                 draggable="true"
                                 @ondragstart="@(() => _draggingCardId = card.Id)"
                                 @ondragend="@(() => _draggingCardId = null)"
                                 @onclick="@(() => OpenCardAsync(card.Id))">
                                <div class="td-card-title">@card.Title</div>
                                @if (card.Tags.Count > 0)
                                {
                                    <div class="td-card-tags">
                                        @foreach (var tg in card.Tags)
                                        {
                                            <span class="td-tag" style="background:@(tg.Color ?? "#e2e8f0");">@tg.Name</span>
                                        }
                                    </div>
                                }
                                <div class="td-card-meta">
                                    @if (card.DueAt is DateTimeOffset due)
                                    {
                                        <span class="td-meta-item" title="Fecha limite">📅 @due.ToLocalTime().ToString("dd/MM")</span>
                                    }
                                    @if (card.ChecklistTotal > 0)
                                    {
                                        <span class="td-meta-item" title="Checklist">☑ @card.ChecklistDone/@card.ChecklistTotal</span>
                                    }
                                    @if (card.CommentsCount > 0)
                                    {
                                        <span class="td-meta-item" title="Comentarios">💬 @card.CommentsCount</span>
                                    }
                                    @if (card.AttachmentsCount > 0)
                                    {
                                        <span class="td-meta-item" title="Adjuntos">📎 @card.AttachmentsCount</span>
                                    }
                                    @if (card.Members.Count > 0)
                                    {
                                        <span class="td-meta-item" style="margin-left:auto;">
                                            @foreach (var mem in card.Members.Take(3))
                                            {
                                                <span class="td-mini-avatar" title="@mem.DisplayName">@mem.Initials</span>
                                            }
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                        <button class="td-add-card" @onclick="@(() => OpenNewCard(col.Id))">+ Añadir tarjeta</button>
                    </div>
                </div>
            }

            @* Nueva columna *@
            @if (_newColOpen)
            {
                <div class="td-col td-col-newform">
                    <input class="form-control form-control-sm" @bind="_newColName" placeholder="Nombre de la columna" />
                    <div style="display:flex; gap:6px; margin-top:8px;">
                        <button class="btn btn-primary btn-sm" @onclick="AddColumnAsync">Añadir</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => _newColOpen = false)">Cancelar</button>
                    </div>
                </div>
            }
            else
            {
                <button class="td-add-column" @onclick="@(() => { _newColName = ""; _newColOpen = true; })">+ Añadir columna</button>
            }
        </div>
    </div>
}

@* ===== Modal: Card detail (Trello-like) ===== *@
@if (_cardModalOpen && _cardDetail is not null)
{
    var detail = _cardDetail;
    var col = _columns.FirstOrDefault(c => c.Id == detail.Card.ColumnId);
    <div class="td-modal-overlay" @onclick="CloseCardModal">
        <div class="td-modal" @onclick:stopPropagation="true">
            @* ===== Header ===== *@
            <div class="td-modal-head">
                <span class="td-modal-head-icon">📋</span>
                <div class="td-modal-head-content">
                    @if (_editingTitle)
                    {
                        <input class="form-control td-modal-title-input" @bind="_editTitle" @bind:event="oninput" />
                        <div style="display:flex; gap:6px; margin-top:8px;">
                            <button class="btn btn-primary btn-sm" @onclick="SaveTitleAsync">Guardar</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => { _editingTitle = false; _editTitle = detail.Card.Title; })">Cancelar</button>
                        </div>
                    }
                    else
                    {
                        <h2 class="td-modal-title" style="@(string.IsNullOrEmpty(detail.Card.Color) ? "" : $"color:{detail.Card.Color};")"
                            @onclick="@(() => { _editingTitle = true; _editTitle = detail.Card.Title; })">@detail.Card.Title</h2>
                        <p class="td-modal-sub">en la lista <strong>@(col?.Name ?? "(sin columna)")</strong></p>
                    }
                </div>
                <button class="td-modal-x" @onclick="CloseCardModal" aria-label="Cerrar">×</button>
            </div>

            @* ===== Body: main + side + popovers ===== *@
            <div class="td-modal-body">
                <div class="td-modal-main">

                    @* --- Row inline: Miembros + Etiquetas + Fecha (chips arriba) --- *@
                    @if (detail.Card.Members.Count > 0 || detail.Card.Tags.Count > 0 || detail.Card.DueAt.HasValue)
                    {
                        <div class="td-modal-inline">
                            @if (detail.Card.Members.Count > 0)
                            {
                                <div>
                                    <h4 class="td-modal-mini">Miembros</h4>
                                    <div class="td-avatar-row">
                                        @foreach (var m in detail.Card.Members)
                                        {
                                            <div class="td-avatar" title="@m.DisplayName" @onclick="@(() => UnassignMemberAsync(m))">@m.Initials</div>
                                        }
                                        <button class="td-plus-btn" @onclick="@(() => TogglePopover("members"))" title="Agregar miembro">+</button>
                                    </div>
                                </div>
                            }
                            @if (detail.Card.Tags.Count > 0)
                            {
                                <div>
                                    <h4 class="td-modal-mini">Etiquetas</h4>
                                    <div style="display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
                                        @foreach (var t in detail.Card.Tags)
                                        {
                                            <span class="td-modal-tag" style="@(string.IsNullOrWhiteSpace(t.Color) ? "" : $"background:{t.Color};color:#fff;")"
                                                  @onclick="@(() => DetachTagAsync(t.Id))" title="Quitar etiqueta">@t.Name</span>
                                        }
                                        <button class="td-plus-btn td-plus-sq" @onclick="@(() => TogglePopover("tags"))" title="Agregar etiqueta">+</button>
                                    </div>
                                </div>
                            }
                            @if (detail.Card.DueAt is DateTimeOffset dueChip)
                            {
                                <div>
                                    <h4 class="td-modal-mini">Fecha limite</h4>
                                    <span class="td-modal-due-chip" @onclick="@(() => TogglePopover("date"))">📅 @dueChip.ToLocalTime().ToString("dd MMM yyyy")</span>
                                </div>
                            }
                        </div>
                    }

                    @* --- Descripcion --- *@
                    <div class="td-modal-section">
                        <span class="td-modal-section-icon">📝</span>
                        <div class="td-modal-section-body">
                            <div class="td-modal-section-head">
                                <h3 class="td-modal-section-title">Descripcion</h3>
                                @if (!string.IsNullOrWhiteSpace(detail.Card.Description) && !_editingDesc)
                                {
                                    <button class="td-modal-section-action" @onclick="@(() => { _editingDesc = true; _editDescription = detail.Card.Description ?? string.Empty; })">Editar</button>
                                }
                            </div>
                            @if (_editingDesc)
                            {
                                <div class="td-desc-edit">
                                    <textarea @bind="_editDescription" @bind:event="oninput" placeholder="Que detalles importantes debe saber el equipo?"></textarea>
                                    <div style="display:flex; gap:8px;">
                                        <button class="btn btn-primary btn-sm" @onclick="SaveDescriptionAsync">Guardar</button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => { _editingDesc = false; _editDescription = detail.Card.Description ?? string.Empty; })">Cancelar</button>
                                    </div>
                                </div>
                            }
                            else if (string.IsNullOrWhiteSpace(detail.Card.Description))
                            {
                                <div class="td-desc-empty" @onclick="@(() => { _editingDesc = true; _editDescription = string.Empty; })">
                                    Agrega una descripcion mas detallada...
                                </div>
                            }
                            else
                            {
                                <div class="td-desc-text" @onclick="@(() => { _editingDesc = true; _editDescription = detail.Card.Description ?? string.Empty; })">@detail.Card.Description</div>
                            }
                        </div>
                    </div>

                    @* --- Checklist --- *@
                    @if (detail.Checklist.Count > 0 || _showChecklistAdd)
                    {
                        var total = detail.Checklist.Count;
                        var done = detail.Checklist.Count(i => i.IsCompleted);
                        var pct = total == 0 ? 0 : (int)Math.Round((double)done / total * 100);
                        <div class="td-modal-section">
                            <span class="td-modal-section-icon">☑</span>
                            <div class="td-modal-section-body">
                                <div class="td-modal-section-head">
                                    <h3 class="td-modal-section-title">Checklist</h3>
                                </div>
                                @if (total > 0)
                                {
                                    <div class="td-check-progress">
                                        <span class="td-check-progress-label">@pct%</span>
                                        <div class="td-check-bar"><div class="td-check-bar-fill" style="width:@(pct)%"></div></div>
                                    </div>
                                }
                                <div class="td-check-list">
                                    @foreach (var it in detail.Checklist)
                                    {
                                        <div class="td-check-item">
                                            <input type="checkbox" checked="@it.IsCompleted" @onchange="@(e => ToggleChecklistAsync(it, (bool)(e.Value ?? false)))" />
                                            <span class="td-check-text @(it.IsCompleted ? "done" : "")">@it.Text</span>
                                            <button class="td-check-del" @onclick="@(() => DeleteChecklistAsync(it))">×</button>
                                        </div>
                                    }
                                </div>
                                <div class="td-check-add">
                                    <input @bind="_newChecklistText" @bind:event="oninput" placeholder="Agregar elemento al checklist..." />
                                    <button class="btn btn-primary btn-sm" @onclick="AddChecklistAsync" disabled="@string.IsNullOrWhiteSpace(_newChecklistText)">Agregar</button>
                                </div>
                            </div>
                        </div>
                    }

                    @* --- Adjuntos --- *@
                    @if (detail.Attachments.Count > 0 || _showAttachAdd)
                    {
                        <div class="td-modal-section">
                            <span class="td-modal-section-icon">📎</span>
                            <div class="td-modal-section-body">
                                <div class="td-modal-section-head">
                                    <h3 class="td-modal-section-title">Adjuntos</h3>
                                </div>
                                <div class="td-att-list">
                                    @foreach (var att in detail.Attachments)
                                    {
                                        <div class="td-att-item">
                                            <span class="td-att-thumb">📎</span>
                                            <div class="td-att-body">
                                                <a href="@att.Url" target="_blank" class="td-att-name">@att.FileName</a>
                                                <div class="td-att-meta">Subido @att.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy") @(att.UploadedByName is null ? "" : $"por {att.UploadedByName}")</div>
                                            </div>
                                            <button class="td-check-del" @onclick="@(() => DeleteAttachmentAsync(att))">×</button>
                                        </div>
                                    }
                                </div>
                                @if (_showAttachAdd)
                                {
                                    <div class="td-att-add">
                                        <input class="form-control form-control-sm" @bind="_newAttName" placeholder="Nombre visible..." />
                                        <input class="form-control form-control-sm" @bind="_newAttUrl" placeholder="URL del archivo (https://...)" />
                                        <div style="display:flex; gap:6px;">
                                            <button class="btn btn-primary btn-sm" @onclick="AddAttachmentAsync" disabled="@string.IsNullOrWhiteSpace(_newAttUrl)">Adjuntar</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => _showAttachAdd = false)">Cancelar</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @* --- Actividad --- *@
                    <div class="td-modal-section">
                        <span class="td-modal-section-icon">📣</span>
                        <div class="td-modal-section-body">
                            <div class="td-modal-section-head">
                                <h3 class="td-modal-section-title">Actividad</h3>
                            </div>
                            <div class="td-act-input">
                                <div class="td-avatar">@Initials(_actorDisplayName)</div>
                                <div class="td-act-input-box">
                                    <textarea @bind="_newCommentText" @bind:event="oninput" placeholder="Escribe un comentario..."></textarea>
                                    <div class="td-act-input-foot">
                                        <span></span>
                                        <button class="btn btn-primary btn-sm" @onclick="AddCommentAsync" disabled="@string.IsNullOrWhiteSpace(_newCommentText)">Guardar</button>
                                    </div>
                                </div>
                            </div>
                            <div class="td-act-list">
                                @if (detail.Activity.Count == 0)
                                {
                                    <p class="td-act-empty">No hay actividad reciente en esta tarjeta.</p>
                                }
                                @foreach (var a in detail.Activity)
                                {
                                    <div class="td-act-item">
                                        <div class="td-act-item-avatar">@Initials(a.ActorName)</div>
                                        @if (a.Type == Visal.Domain.Enums.TaskActivityType.Comment)
                                        {
                                            <div class="td-act-bubble">
                                                <div class="td-act-head">
                                                    <span class="td-act-name">@a.ActorName</span>
                                                    <span class="td-act-time">@FormatRelative(a.CreatedAt)</span>
                                                </div>
                                                <p class="td-act-text">@a.Text</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="td-act-action">
                                                <strong>@a.ActorName</strong> @a.Text
                                                <span class="td-act-time" style="margin-left:6px;">@FormatRelative(a.CreatedAt)</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @* ===== Sidebar derecha ===== *@
                <div class="td-modal-side">
                    <div>
                        <h4>Agregar a la tarjeta</h4>
                        <div class="td-modal-side-btns">
                            <button class="td-modal-side-btn" @onclick="@(() => TogglePopover("members"))">👥 Miembros</button>
                            <button class="td-modal-side-btn" @onclick="@(() => TogglePopover("tags"))">🏷 Etiquetas</button>
                            <button class="td-modal-side-btn" @onclick="@(() => { CloseAllPopovers(); _showChecklistAdd = true; })">☑ Checklist</button>
                            <button class="td-modal-side-btn" @onclick="@(() => TogglePopover("date"))">📅 Fecha</button>
                            <button class="td-modal-side-btn" @onclick="@(() => TogglePopover("color"))">🎨 Color</button>
                            <button class="td-modal-side-btn" @onclick="@(() => { CloseAllPopovers(); _showAttachAdd = true; })">📎 Adjunto</button>
                        </div>
                    </div>
                    <div>
                        <h4>Acciones</h4>
                        <div class="td-modal-side-btns">
                            <button class="td-modal-side-btn" @onclick="@(() => TogglePopover("move"))">➡ Mover</button>
                            <button class="td-modal-side-btn" @onclick="ArchiveCardAsync">
                                📦 @(detail.Card.IsArchived ? "Desarchivar" : "Archivar")
                            </button>
                            <hr class="td-modal-side-divider" />
                            <button class="td-modal-side-btn td-danger" @onclick="DeleteCardAsync">🗑 Eliminar</button>
                        </div>
                    </div>
                </div>

                @* ===== Popovers ===== *@
                @if (_showMembersPop)
                {
                    <div class="td-pop" style="top:90px;" @onclick:stopPropagation="true">
                        <div class="td-pop-head">
                            <span>Miembros del tablero</span>
                            <button class="td-modal-x" style="width:22px; height:22px; font-size:16px;" @onclick="@(() => _showMembersPop = false)">×</button>
                        </div>
                        <div class="td-pop-list">
                            @if (_boardMembers.Count == 0)
                            {
                                <div class="td-pop-empty">Aun no hay miembros. Invitalos desde el boton Miembros del header.</div>
                            }
                            else
                            {
                                @foreach (var bm in _boardMembers)
                                {
                                    var isSel = detail.Card.Members.Any(m => m.PlatformUserId == bm.PlatformUserId);
                                    <div class="td-pop-item @(isSel ? "selected" : "")" @onclick="@(() => ToggleCardMemberAsync(bm, !isSel))">
                                        <div class="td-avatar">@bm.Initials</div>
                                        <span style="flex:1;">@bm.DisplayName</span>
                                        @if (isSel) { <span>✓</span> }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

                @if (_showTagsPop)
                {
                    <div class="td-pop" style="top:150px;" @onclick:stopPropagation="true">
                        <div class="td-pop-head">
                            <span>Etiquetas</span>
                            <button class="td-modal-x" style="width:22px; height:22px; font-size:16px;" @onclick="@(() => _showTagsPop = false)">×</button>
                        </div>
                        <div class="td-pop-list">
                            @if (_boardTags.Count == 0)
                            {
                                <div class="td-pop-empty">Aun no hay etiquetas. Crea una abajo.</div>
                            }
                            else
                            {
                                @foreach (var t in _boardTags)
                                {
                                    var isSel = detail.Card.Tags.Any(x => x.Id == t.Id);
                                    <div class="td-pop-item @(isSel ? "selected" : "")" @onclick="@(() => ToggleCardTagAsync(t.Id, !isSel))">
                                        <span class="td-modal-tag" style="@(string.IsNullOrWhiteSpace(t.Color) ? "" : $"background:{t.Color};color:#fff;")">@t.Name</span>
                                        <span style="flex:1;"></span>
                                        @if (isSel) { <span>✓</span> }
                                    </div>
                                }
                            }
                        </div>
                        <div class="td-pop-add">
                            <input @bind="_newTagName" @bind:event="oninput" placeholder="Nueva etiqueta" />
                            <input type="color" @bind="_newTagColor" style="width:40px; height:32px; padding:2px;" />
                            <button class="btn btn-primary btn-sm" @onclick="CreateTagAsync" disabled="@string.IsNullOrWhiteSpace(_newTagName)">+</button>
                        </div>
                    </div>
                }

                @if (_showDatePop)
                {
                    <div class="td-pop" style="top:210px;" @onclick:stopPropagation="true">
                        <div class="td-pop-head">
                            <span>Fecha de vencimiento</span>
                            <button class="td-modal-x" style="width:22px; height:22px; font-size:16px;" @onclick="@(() => _showDatePop = false)">×</button>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:10px;">
                            <input type="date" class="form-control" @bind="_editCardDueDate" />
                            <div style="display:flex; gap:6px;">
                                <button class="btn btn-primary btn-sm" @onclick="SaveDueDateAsync">Guardar</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearDueDateAsync">Quitar</button>
                            </div>
                        </div>
                    </div>
                }

                @if (_showColorPop)
                {
                    <div class="td-pop" style="top:270px;" @onclick:stopPropagation="true">
                        <div class="td-pop-head">
                            <span>Color del titulo</span>
                            <button class="td-modal-x" style="width:22px; height:22px; font-size:16px;" @onclick="@(() => _showColorPop = false)">×</button>
                        </div>
                        <div class="td-color-swatches">
                            @foreach (var c in _colorPalette)
                            {
                                var isSel = detail.Card.Color == c;
                                <button class="td-color-swatch @(isSel ? "sel" : "")" style="background:@c;" @onclick="@(() => SaveColorAsync(c))" title="@c"></button>
                            }
                            <button class="td-color-swatch clear @(string.IsNullOrEmpty(detail.Card.Color) ? "sel" : "")" @onclick="@(() => SaveColorAsync(null))" title="Sin color">×</button>
                        </div>
                        <div style="display:flex; gap:6px; margin-top:10px;">
                            <input type="color" @bind="_editCardColor" style="width:44px; height:32px; padding:2px;" />
                            <button class="btn btn-primary btn-sm" style="flex:1;" @onclick="@(() => SaveColorAsync(_editCardColor))">Aplicar color libre</button>
                        </div>
                    </div>
                }

                @if (_showMovePop)
                {
                    <div class="td-pop" style="top:330px;" @onclick:stopPropagation="true">
                        <div class="td-pop-head">
                            <span>Mover a columna</span>
                            <button class="td-modal-x" style="width:22px; height:22px; font-size:16px;" @onclick="@(() => _showMovePop = false)">×</button>
                        </div>
                        <div class="td-pop-list">
                            @foreach (var c in _columns)
                            {
                                var isSel = c.Id == detail.Card.ColumnId;
                                <div class="td-pop-item @(isSel ? "selected" : "")" @onclick="@(() => MoveCardToColumnAsync(c.Id))">
                                    <span style="flex:1;">@c.Name @if (c.IsDone) { <span title="Estado final">✓</span> }</span>
                                    @if (isSel) { <span>✓</span> }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ===== Modal: Nueva tarjeta ===== *@
@if (_newCardOpen)
{
    <div class="tb-modal-backdrop" @onclick="@(() => _newCardOpen = false)"></div>
    <div class="tb-modal" style="width:480px;">
        <div class="tb-modal-h">
            <h3>Nueva tarjeta</h3>
            <button class="tb-modal-close" @onclick="@(() => _newCardOpen = false)">&times;</button>
        </div>
        <div class="tb-modal-body">
            <div class="tb-field">
                <label>Titulo *</label>
                <input class="form-control" @bind="_newCardTitle" autocomplete="off" />
            </div>
            <div class="tb-field">
                <label>Descripcion</label>
                <textarea class="form-control" rows="3" @bind="_newCardDescription"></textarea>
            </div>
        </div>
        <div class="tb-modal-foot">
            <button class="btn btn-outline-secondary" @onclick="@(() => _newCardOpen = false)">Cancelar</button>
            <button class="btn btn-primary" @onclick="CreateCardAsync">Crear</button>
        </div>
    </div>
}

@* ===== Modal: Editar tablero ===== *@
@if (_editBoardOpen && _board is not null)
{
    <div class="tb-modal-backdrop" @onclick="@(() => _editBoardOpen = false)"></div>
    <div class="tb-modal" style="width:520px;">
        <div class="tb-modal-h">
            <h3>Editar tablero</h3>
            <button class="tb-modal-close" @onclick="@(() => _editBoardOpen = false)">&times;</button>
        </div>
        <div class="tb-modal-body">
            <div class="tb-field">
                <label>Nombre</label>
                <input class="form-control" @bind="_editBoardName" />
            </div>
            <div class="tb-field">
                <label>Descripcion</label>
                <textarea class="form-control" rows="2" @bind="_editBoardDescription"></textarea>
            </div>
            <div class="tb-field">
                <label>Color</label>
                <input type="color" class="form-control" style="width:80px; height:36px; padding:2px;" @bind="_editBoardColor" />
            </div>
        </div>
        <div class="tb-modal-foot">
            <button class="btn btn-outline-secondary" @onclick="@(() => _editBoardOpen = false)">Cancelar</button>
            <button class="btn btn-primary" @onclick="SaveBoardEditAsync">Guardar</button>
        </div>
    </div>
}

@* ===== Modal: Miembros ===== *@
@if (_membersOpen && _board is not null)
{
    <div class="tb-modal-backdrop" @onclick="@(() => _membersOpen = false)"></div>
    <div class="tb-modal" style="width:640px;">
        <div class="tb-modal-h">
            <h3>Miembros — @_board.Name</h3>
            <button class="tb-modal-close" @onclick="@(() => _membersOpen = false)">&times;</button>
        </div>
        <div class="tb-modal-body">
            <div class="td-side-list">
                @foreach (var m in _members)
                {
                    <div class="td-side-item">
                        <span class="tb-avatar">@m.Initials</span>
                        <div style="flex:1;">
                            <div class="tb-member-name">@m.DisplayName</div>
                            <div class="tb-member-role">@(m.IsOwner ? "Dueño" : $"Invitado {m.InvitedAt.ToLocalTime():dd/MM/yyyy}")</div>
                        </div>
                        @if (_board.IsOwner && !m.IsOwner)
                        {
                            <button class="tb-icon-btn tb-icon-danger" @onclick="@(() => RemoveMemberAsync(m))">×</button>
                        }
                    </div>
                }
            </div>
            @if (_board.IsOwner)
            {
                <hr style="margin:16px 0;" />
                <div class="tb-field">
                    <label>Invitar usuario</label>
                    <input class="form-control" @bind="_inviteSearch" @bind:event="oninput" @onkeyup="OnInviteSearchKeyupAsync" placeholder="Busca por nombre o email..." />
                </div>
                <div class="td-side-list">
                    @foreach (var c in _inviteCandidates)
                    {
                        <div class="td-side-item">
                            <span class="tb-avatar">@c.Initials</span>
                            <div style="flex:1;">
                                <div class="tb-member-name">@c.DisplayName</div>
                                <div class="tb-member-role">@c.Email</div>
                            </div>
                            <button class="btn btn-primary btn-sm" @onclick="@(() => InviteAsync(c))">+ Invitar</button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

