                __b.AddAttribute(seq++, "title", "Abrir Historias Clinicas del paciente");
                __b.AddAttribute(seq++, "onclick", Microsoft.AspNetCore.Components.EventCallback.Factory.Create(this, () => AbrirHistoria(s)));
                __b.AddMarkupContent(seq++, "&#9998;");
