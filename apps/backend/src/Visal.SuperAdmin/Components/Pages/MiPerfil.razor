@page "/mi-perfil"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Visal.Application.Auth
@inject Visal.Application.Auth.IMiPerfilService PerfilSvc
@inject Visal.Application.Auth.IAuthService AuthSvc
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject NavigationManager Nav
@inject IHttpContextAccessor Http

<PageTitle>Mi perfil - Visal</PageTitle>

@*
   Modíulo de autogestion. El usuario logueado edita sus datos personales,
   su avatar y (si esta vinculado a un profesional en la sede activa) tambien
   la firma. Ademas cambia su clave dando la anterior. NO puede editar los
   datos maestros del profesional (esos los maneja el admin en /profesionales).
*@

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
            </div>
            <span>Autogestion</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Mi perfil</h1>
        <p class="page-sub" style="margin-bottom:0;">Actualiza tus datos personales, firma y clave de acceso.</p>
    </div>
</div>

@if (_perfil is null)
{
    <div class="ase-empty" style="padding:30px;">Cargando...</div>
}
else
{
    <div class="mp-tabs">
        <button class="mp-tab @(_tab == "datos" ? "active" : "")" @onclick='() => _tab = "datos"'>Datos personales</button>
        <button class="mp-tab @(_tab == "firma" ? "active" : "")" @onclick='() => { _tab = "firma"; _canvasInitPending = true; }' disabled="@(_perfil.Profesional is null)">Firma profesional</button>
        <button class="mp-tab @(_tab == "prof" ? "active" : "")" @onclick='() => _tab = "prof"' disabled="@(_perfil.Profesional is null)">Datos profesional</button>
        <button class="mp-tab @(_tab == "clave" ? "active" : "")" @onclick='() => _tab = "clave"'>Cambiar clave</button>
    </div>

    @if (!string.IsNullOrEmpty(_error)) { <div class="wac-error" style="margin-bottom:10px;">@_error</div> }
    @if (!string.IsNullOrEmpty(_ok)) { <div class="wac-ok" style="margin-bottom:10px;background:#dcfce7;color:#166534;padding:8px 12px;border-radius:6px;">@_ok</div> }

    @* ===== TAB DATOS PERSONALES ===== *@
    @if (_tab == "datos")
    {
        <div class="ase-card" style="max-width:820px;">
            <div class="ase-card-h">Identidad</div>
            <div class="ase-form">
                <div class="ase-f"><label>Documento</label><input class="form-control form-control-sm" value="@(_perfil.Documento ?? "")" readonly /></div>
                <div class="ase-f"><label>Usuario / Login</label><input class="form-control form-control-sm" value="@(_perfil.Username ?? "")" readonly /></div>
                <div class="ase-f ase-f-wide"><label>Correo electronico *</label>
                    <input class="form-control form-control-sm" @bind="_email" placeholder="correo@dominio.com" />
                </div>
            </div>

            <div class="ase-card-h" style="margin-top:14px;">Nombre completo</div>
            <div class="ase-form">
                <div class="ase-f"><label>Primer Nombre</label><input class="form-control form-control-sm" @bind="_pNombre" /></div>
                <div class="ase-f"><label>Segundo Nombre</label><input class="form-control form-control-sm" @bind="_sNombre" /></div>
                <div class="ase-f"><label>Primer Apellido</label><input class="form-control form-control-sm" @bind="_pApellido" /></div>
                <div class="ase-f"><label>Segundo Apellido</label><input class="form-control form-control-sm" @bind="_sApellido" /></div>
            </div>

            <div class="ase-card-h" style="margin-top:14px;">Contacto y ubicacion</div>
            <div class="ase-form">
                <div class="ase-f"><label>Celular</label><input class="form-control form-control-sm" @bind="_celular" placeholder="Solo digitos" /></div>
                <div class="ase-f"><label>Telefono fijo</label><input class="form-control form-control-sm" @bind="_fijo" /></div>
                <div class="ase-f"><label>Ciudad</label><input class="form-control form-control-sm" @bind="_ciudad" /></div>
                <div class="ase-f ase-f-wide"><label>Direccion</label><input class="form-control form-control-sm" @bind="_direccion" /></div>
            </div>

            <div class="ase-card-h" style="margin-top:14px;">Foto de perfil</div>
            <div style="display:flex; align-items:center; gap:14px; padding:6px 0;">
                <div style="width:64px; height:64px; border-radius:50%; background:#eef2ff; display:flex; align-items:center; justify-content:center; overflow:hidden; border:1px solid #cbd5e1;">
                    @if (!string.IsNullOrEmpty(_avatarUrl))
                    {
                        <img src="@_avatarUrl" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <span style="font-size:22px; color:#6366f1; font-weight:700;">@(Iniciales())</span>
                    }
                </div>
                <div style="flex:1;">
                    <InputFile OnChange="OnAvatarSelected" accept="image/*" class="form-control form-control-sm" />
                    <div style="font-size:11px; color:#64748b; margin-top:4px;">JPG o PNG. Max 2 MB.</div>
                    @if (!string.IsNullOrEmpty(_avatarUrl))
                    {
                        <button class="btn btn-outline-danger btn-sm" style="margin-top:6px;" type="button" @onclick="() => _avatarUrl = null">Quitar foto</button>
                    }
                </div>
            </div>

            <div style="margin-top:16px; display:flex; gap:10px;">
                <button class="btn btn-primary" @onclick="GuardarDatosAsync" disabled="@_busy">@(_busy ? "Guardando..." : "Guardar cambios")</button>
                <button class="btn btn-outline-secondary" @onclick="RecargarAsync" disabled="@_busy" type="button">Descartar</button>
            </div>
        </div>
    }

    @* ===== TAB FIRMA PROFESIONAL ===== *@
    @if (_tab == "firma" && _perfil.Profesional is not null)
    {
        <div class="ase-card" style="max-width:820px;">
            <div class="ase-card-h">Firma del profesional</div>
            <div style="font-size:12px; color:#64748b; margin-bottom:8px;">
                Esta firma se usara automaticamente en historias clinicas, notas medicas y consentimientos generados por vos.
                Firma con el dedo (movil) o el mouse (escritorio).
            </div>
            @if (!string.IsNullOrEmpty(_firmaActualUrl) && !_firmaCanvasAbierto)
            {
                <div style="margin:8px 0;">
                    <strong style="font-size:12px;">Firma actual:</strong>
                    <div style="margin-top:4px; border:1px solid #e2e8f0; border-radius:6px; padding:6px; background:#fff; max-width:400px;">
                        <img src="@_firmaActualUrl" alt="Firma" style="max-height:100px;" />
                    </div>
                </div>
                <button class="btn btn-outline-secondary" type="button" @onclick="AbrirCanvasFirma">&#9998; Cambiar firma</button>
            }
            @if (_firmaCanvasAbierto || string.IsNullOrEmpty(_firmaActualUrl))
            {
                <div style="margin-top:8px;">
                    <canvas id="mp-firma-canvas" style="width:100%; max-width:500px; height:170px; background:#fff; border:1px solid #cbd5e1; border-radius:6px; touch-action:none;"></canvas>
                    <div style="display:flex; gap:8px; margin-top:8px; flex-wrap:wrap;">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarCanvasFirmaAsync" type="button">&#129529; Limpiar</button>
                        <button class="btn btn-primary btn-sm" @onclick="GuardarFirmaAsync" disabled="@_busy" type="button">&#128190; Guardar firma</button>
                        @if (!string.IsNullOrEmpty(_firmaActualUrl))
                        {
                            <button class="btn btn-link btn-sm" @onclick="CerrarCanvasFirma" type="button">Cancelar</button>
                        }
                    </div>

                    @* Alternativa: subir archivo PNG/JPG con la firma escaneada. *@
                    <div style="margin-top:14px; padding-top:12px; border-top:1px dashed #cbd5e1;">
                        <div style="font-size:12px; color:#475569; margin-bottom:4px;">
                            &#128206; O sube una imagen escaneada / foto de tu firma (PNG, JPG - max 2 MB):
                        </div>
                        <InputFile OnChange="OnFirmaFileSelected" accept="image/png,image/jpeg" class="form-control form-control-sm" style="max-width:400px;" />
                    </div>
                </div>
            }
        </div>
    }

    @* ===== TAB DATOS PROFESIONAL (READONLY) ===== *@
    @if (_tab == "prof" && _perfil.Profesional is { } p)
    {
        <div class="ase-card" style="max-width:820px;">
            <div class="ase-card-h">Datos del profesional (solo consulta)</div>
            <div style="font-size:12px; color:#64748b; margin-bottom:8px;">
                Los datos maestros del profesional los administra el coordinador desde el modulo <a href="/profesionales">Profesionales</a>. Aqui solo puedes verlos.
            </div>
            <div class="ase-form">
                <div class="ase-f"><label>Tipo documento</label><input class="form-control form-control-sm" value="@p.TipoDocumento" readonly /></div>
                <div class="ase-f"><label>Numero documento</label><input class="form-control form-control-sm" value="@p.NumeroDocumento" readonly /></div>
                <div class="ase-f ase-f-wide"><label>Nombre completo</label><input class="form-control form-control-sm" value="@p.NombreCompleto" readonly /></div>
                <div class="ase-f"><label>Tipo profesional</label><input class="form-control form-control-sm" value="@(p.TipoProfesional ?? "")" readonly /></div>
                <div class="ase-f"><label>Registro medico</label><input class="form-control form-control-sm" value="@(p.Registro ?? "")" readonly /></div>
                <div class="ase-f"><label>Ciudad</label><input class="form-control form-control-sm" value="@(p.Ciudad ?? "")" readonly /></div>
                <div class="ase-f"><label>Celular</label><input class="form-control form-control-sm" value="@(p.Celular ?? "")" readonly /></div>
            </div>
            <div style="margin-top:10px;">
                <strong style="font-size:12px;">Subcategorias:</strong>
                @if (p.Subcategorias.Count == 0) { <span style="color:#94a3b8;">Ninguna</span> }
                else { foreach (var s in p.Subcategorias) { <span class="mp-chip">@s</span> } }
            </div>
            <div style="margin-top:6px;">
                <strong style="font-size:12px;">Sedes:</strong>
                @if (p.Sedes.Count == 0) { <span style="color:#94a3b8;">Ninguna</span> }
                else { foreach (var s in p.Sedes) { <span class="mp-chip">@s</span> } }
            </div>
        </div>
    }

    @* ===== TAB CAMBIAR CLAVE ===== *@
    @if (_tab == "clave")
    {
        <div class="ase-card" style="max-width:560px;">
            <div class="ase-card-h">Cambiar clave</div>
            <div class="ase-form">
                <div class="ase-f ase-f-wide"><label>Clave actual</label>
                    <input type="password" class="form-control form-control-sm" @bind="_claveActual" autocomplete="current-password" />
                </div>
                <div class="ase-f ase-f-wide"><label>Nueva clave</label>
                    <input type="password" class="form-control form-control-sm" @bind="_claveNueva" autocomplete="new-password" placeholder="Minimo 6 caracteres" />
                </div>
                <div class="ase-f ase-f-wide"><label>Confirmar nueva clave</label>
                    <input type="password" class="form-control form-control-sm" @bind="_claveNueva2" autocomplete="new-password" />
                </div>
            </div>
            <div style="margin-top:12px;">
                <button class="btn btn-primary" @onclick="CambiarClaveAsync" disabled="@_busy">@(_busy ? "Cambiando..." : "Cambiar clave")</button>
            </div>
        </div>
    }
}

<style>
    .mp-tabs { display:flex; gap:2px; border-bottom:1px solid #e2e8f0; margin-bottom:16px; }
    .mp-tab { background:transparent; border:none; padding:10px 16px; font-size:13px; color:#64748b; cursor:pointer; border-bottom:3px solid transparent; }
    .mp-tab:hover:not(:disabled) { color:#1565c0; }
    .mp-tab.active { color:#1565c0; border-bottom-color:#1565c0; font-weight:600; }
    .mp-tab:disabled { color:#cbd5e1; cursor:not-allowed; }
    .mp-chip { display:inline-block; margin:2px 4px 2px 0; background:#eff6ff; color:#1565c0; padding:2px 10px; border-radius:999px; font-size:11px; font-weight:600; }
    .wac-error { background:#fee2e2; color:#991b1b; padding:8px 12px; border-radius:6px; font-size:13px; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private MiPerfilDto? _perfil;
    private string _tab = "datos";
    private bool _busy;
    private string? _error, _ok;

    // Bindings de datos personales
    private string _email = "";
    private string? _pNombre, _sNombre, _pApellido, _sApellido;
    private string? _celular, _fijo, _ciudad, _direccion;
    private string? _avatarUrl;

    // Firma
    private string? _firmaActualUrl;
    private bool _firmaCanvasAbierto;
    private bool _canvasInitPending;

    // Cambio de clave
    private string _claveActual = "", _claveNueva = "", _claveNueva2 = "";

    protected override async Task OnInitializedAsync() => await RecargarAsync();

    private async Task<Guid> UsuarioIdAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task RecargarAsync()
    {
        _error = _ok = null;
        var uid = await UsuarioIdAsync();
        if (uid == Guid.Empty) { _error = "No hay sesion activa."; return; }
        _perfil = await PerfilSvc.GetAsync(uid);
        if (_perfil is null) { _error = "No se pudo cargar tu perfil."; return; }
        _email = _perfil.Email;
        _pNombre = _perfil.PrimerNombre; _sNombre = _perfil.SegundoNombre;
        _pApellido = _perfil.PrimerApellido; _sApellido = _perfil.SegundoApellido;
        _celular = _perfil.Celular; _fijo = _perfil.Fijo;
        _ciudad = _perfil.Ciudad; _direccion = _perfil.Direccion;
        _avatarUrl = _perfil.AvatarUrl;
        _firmaActualUrl = _perfil.Profesional?.FirmaUrl;
        _firmaCanvasAbierto = false;
    }

    private string Iniciales()
    {
        var pn = (_perfil?.PrimerNombre ?? "").Trim();
        var pa = (_perfil?.PrimerApellido ?? "").Trim();
        var i1 = pn.Length > 0 ? pn[0] : (_perfil?.Email.Length > 0 ? _perfil.Email[0] : '?');
        var i2 = pa.Length > 0 ? pa[0] : ' ';
        return $"{char.ToUpperInvariant(i1)}{char.ToUpperInvariant(i2)}".Trim();
    }

    private async Task GuardarDatosAsync()
    {
        _error = _ok = null; _busy = true;
        try
        {
            var uid = await UsuarioIdAsync();
            if (uid == Guid.Empty) { _error = "No hay sesion activa."; return; }
            var req = new ActualizarMiPerfilRequest(
                _email, _pNombre, _sNombre, _pApellido, _sApellido,
                _celular, _fijo, _ciudad, _direccion, _avatarUrl);
            _perfil = await PerfilSvc.ActualizarPerfilAsync(uid, req);
            _ok = "Cambios guardados.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        catch (Exception ex) { _error = "Error al guardar: " + ex.Message; }
        finally { _busy = false; }
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        try
        {
            const long max = 2 * 1024 * 1024;
            var file = e.File;
            if (file.Size > max) { _error = "Archivo mayor a 2 MB."; return; }
            var dir = Path.Combine(Env.WebRootPath, "uploads", "avatars");
            Directory.CreateDirectory(dir);
            var ext = Path.GetExtension(file.Name);
            if (string.IsNullOrEmpty(ext) || ext.Length > 6) { ext = ".png"; }
            var name = $"avatar-{Guid.NewGuid():N}{ext}";
            var path = Path.Combine(dir, name);
            await using var stream = File.Create(path);
            await file.OpenReadStream(max).CopyToAsync(stream);
            _avatarUrl = $"/uploads/avatars/{name}";
        }
        catch (Exception ex) { _error = "Error subiendo la imagen: " + ex.Message; }
    }

    // ==== Firma ====
    private void AbrirCanvasFirma()
    {
        _firmaCanvasAbierto = true;
        _canvasInitPending = true;
    }

    private void CerrarCanvasFirma()
    {
        _firmaCanvasAbierto = false;
    }

    private async Task LimpiarCanvasFirmaAsync()
    {
        try { await JS.InvokeVoidAsync("visalFirma.clear", "mp-firma-canvas"); } catch { }
    }

    /// <summary>Sube una imagen PNG/JPG con la firma escaneada o fotografiada
    /// y la guarda como firma del profesional. Uso: escritorios donde no es
    /// comodo dibujar la firma con el mouse, o si el profesional ya tiene la
    /// firma digitalizada.</summary>
    private async Task OnFirmaFileSelected(InputFileChangeEventArgs e)
    {
        _error = _ok = null; _busy = true;
        try
        {
            const long max = 2 * 1024 * 1024;
            var file = e.File;
            if (file.Size == 0) { _error = "Archivo vacio."; return; }
            if (file.Size > max) { _error = "Archivo mayor a 2 MB."; return; }
            var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "image/png" : file.ContentType.ToLowerInvariant();
            if (mime != "image/png" && mime != "image/jpeg" && mime != "image/jpg")
            {
                _error = "Formato no soportado. Usa PNG o JPG.";
                return;
            }
            using var ms = new MemoryStream();
            await file.OpenReadStream(max).CopyToAsync(ms);
            var bytes = ms.ToArray();
            // Guardamos como data URL igual que el canvas para que el mismo
            // servicio de perfil lo persista sin diferenciar el origen.
            var dataUrl = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
            var uid = await UsuarioIdAsync();
            var ok = await PerfilSvc.ActualizarFirmaProfesionalAsync(uid, dataUrl);
            if (!ok) { _error = "No pudimos guardar la firma."; return; }
            _firmaActualUrl = dataUrl;
            _firmaCanvasAbierto = false;
            _ok = "Firma actualizada desde archivo.";
        }
        catch (Exception ex) { _error = "Error subiendo la firma: " + ex.Message; }
        finally { _busy = false; }
    }

    private async Task GuardarFirmaAsync()
    {
        _error = _ok = null; _busy = true;
        try
        {
            var dataUrl = await JS.InvokeAsync<string?>("visalFirma.getDataUrl", "mp-firma-canvas");
            if (string.IsNullOrWhiteSpace(dataUrl)) { _error = "El canvas esta vacio."; return; }
            var uid = await UsuarioIdAsync();
            var ok = await PerfilSvc.ActualizarFirmaProfesionalAsync(uid, dataUrl);
            if (!ok) { _error = "No pudimos guardar la firma."; return; }
            _firmaActualUrl = dataUrl;
            _firmaCanvasAbierto = false;
            _ok = "Firma actualizada.";
        }
        catch (Exception ex) { _error = "Error: " + ex.Message; }
        finally { _busy = false; }
    }

    // ==== Cambio de clave ====
    private async Task CambiarClaveAsync()
    {
        _error = _ok = null;
        if (string.IsNullOrWhiteSpace(_claveActual)) { _error = "Ingresa la clave actual."; return; }
        if (_claveNueva.Length < 6) { _error = "La nueva clave debe tener al menos 6 caracteres."; return; }
        if (_claveNueva != _claveNueva2) { _error = "Las nuevas claves no coinciden."; return; }
        _busy = true;
        try
        {
            var uid = await UsuarioIdAsync();
            var r = await AuthSvc.ChangePasswordAsync(uid, _claveActual, _claveNueva);
            if (!r.Ok) { _error = r.Error; return; }
            _ok = "Clave actualizada. Usa la nueva en tu proximo inicio de sesion.";
            _claveActual = _claveNueva = _claveNueva2 = "";
        }
        finally { _busy = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Inicializa el canvas cada vez que este visible: al pulsar "Cambiar firma"
        // o al entrar directamente al tab firma cuando aun no hay firma cargada
        // (en ese caso el canvas aparece de una y antes no lo estabamos inicializando).
        var canvasVisible = _tab == "firma"
                             && _perfil.Profesional is not null
                             && (_firmaCanvasAbierto || string.IsNullOrEmpty(_firmaActualUrl));
        if (canvasVisible && (_canvasInitPending || firstRender))
        {
            _canvasInitPending = false;
            try { await JS.InvokeVoidAsync("visalFirma.init", "mp-firma-canvas"); } catch { }
        }
    }
}
