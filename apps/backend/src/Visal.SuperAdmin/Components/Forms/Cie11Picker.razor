@using Visal.Application.Tenancy
@inject IDiagnosticoService DiagSvc

@*
    Modal reusable de busqueda de diagnostico. Encapsula la lupita/busqueda/seleccion
    que estaba inline en Admision.razor para poder usarla tambien dentro del
    FormViewer (celdas de tabla con fieldType=autocomplete + catalog=cie11).

    El nombre "Cie11Picker" se conserva por compatibilidad con los llamadores,
    pero la fuente de datos es ahora la BD local (IDiagnosticoService) que
    reemplaza a la WHO ICD-11 API. Ver /diagnosticos para cargar el Excel.

    Uso:
        <Cie11Picker @bind-Visible="_pickerOpen" OnSelected="OnCiePicked" />

    El consumidor controla la visibilidad y recibe el (Code, Title) elegido.
    El componente se preocupa de su estado interno (query, results, errores).
*@

@if (Visible)
{
    <div class="cie-backdrop" @onclick="Cerrar"></div>
    <div class="cie-modal">
        <div class="cie-modal-h">
            <h3>Buscar Diagnostico o Codigo</h3>
            <button class="cie-modal-close" @onclick="Cerrar">&times;</button>
        </div>
        <div class="cie-modal-body">
            <div class="cie-search-row">
                <input class="form-control form-control-sm" placeholder="Ej.: diabetes, covid, 5A11..."
                       @bind="_query" @bind:event="oninput"
                       @onkeyup="OnKeyUp" />
                <button class="btn btn-danger btn-sm" @onclick="Buscar" disabled="@_busy">
                    @(_busy ? "..." : "Buscar")
                </button>
            </div>
            @if (_error is not null) { <div class="ase-alert" style="margin-top:10px;">@_error</div> }
            <div class="cie-result-h">Resultados de la Busqueda</div>
            <div class="cie-result-list">
                @if (_busy) { <div class="cie-empty">Buscando en la BD local...</div> }
                else if (_results.Count == 0) { <div class="cie-empty">Escribe un termino y pulsa Buscar.</div> }
                else
                {
                    @foreach (var r in _results)
                    {
                        <button class="cie-result-item" @onclick="() => SeleccionarAsync(r)">
                            <span class="cie-code">@r.Codigo</span>
                            <span class="cie-title">@r.Nombre</span>
                        </button>
                    }
                }
            </div>
        </div>
    </div>
}

<style>
    .cie-backdrop { position: fixed; inset: 0; background: rgba(15,23,42,.45); z-index: 1050; }
    .cie-modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 720px; max-width: 95vw; max-height: 80vh; background: #fff; border-radius: 12px; box-shadow: 0 20px 60px rgba(15,23,42,.25); z-index: 1051; display: flex; flex-direction: column; }
    .cie-modal-h { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid #e2e8f0; }
    .cie-modal-h h3 { margin: 0; font-size: 16px; font-weight: 700; color: #0f172a; }
    .cie-modal-close { background: none; border: none; font-size: 22px; line-height: 1; cursor: pointer; color: #64748b; }
    .cie-modal-body { padding: 18px; overflow: auto; }
    .cie-search-row { display: flex; gap: 6px; }
    .cie-search-row input { flex: 1; }
    .cie-result-h { margin-top: 14px; margin-bottom: 8px; font-size: 11px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.4px; }
    .cie-result-list { display: flex; flex-direction: column; gap: 4px; max-height: 380px; overflow-y: auto; }
    .cie-result-item { display: flex; gap: 10px; padding: 8px 10px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; cursor: pointer; text-align: left; transition: background .12s; }
    .cie-result-item:hover { background: #eff6ff; }
    .cie-code { font-family: 'JetBrains Mono','Consolas',monospace; font-size: 11.5px; font-weight: 700; color: #1565c0; min-width: 70px; }
    .cie-title { font-size: 12.5px; color: #0f172a; }
    .cie-empty { padding: 20px; text-align: center; color: #94a3b8; font-size: 12.5px; font-style: italic; }
    .ase-alert { background: #fef2f2; border: 1px solid #fecaca; color: #7f1d1d; padding: 8px 12px; border-radius: 6px; font-size: 12.5px; }
</style>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    /// <summary>Se dispara cuando el usuario selecciona un item de la lista.
    /// El componente cierra el modal automaticamente despues de notificar.</summary>
    [Parameter] public EventCallback<(string Code, string Title)> OnSelected { get; set; }

    private string _query = "";
    private List<DiagnosticoDto> _results = new();
    private bool _busy;
    private string? _error;

    /// <summary>Cada vez que el padre abre el picker, limpiamos el estado anterior
    /// para que no aparezcan resultados de una busqueda previa.</summary>
    protected override void OnParametersSet()
    {
        if (Visible && _results.Count > 0 && string.IsNullOrEmpty(_query))
        {
            _results = new();
            _error = null;
        }
    }

    private async Task Cerrar()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { await Buscar(); }
    }

    private async Task Buscar()
    {
        if (string.IsNullOrWhiteSpace(_query)) { return; }
        _error = null; _busy = true; _results = new();
        try
        {
            var (rows, _) = await DiagSvc.SearchAsync(_query.Trim(), 0, 50, soloHabilitados: true);
            _results = rows.ToList();
            if (_results.Count == 0)
            {
                _error = "Sin resultados. Verifica que la BD de diagnosticos este cargada en /diagnosticos.";
            }
        }
        catch (Exception ex) { _error = "Error tecnico: " + ex.Message; }
        finally { _busy = false; }
    }

    private async Task SeleccionarAsync(DiagnosticoDto item)
    {
        _error = null;
        await OnSelected.InvokeAsync((item.Codigo, item.Nombre));
        await Cerrar();
    }
}
