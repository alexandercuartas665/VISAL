@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _ok;

    // Filtros
    private int _filtroAnio = DateTime.Today.Year;
    private int _filtroMes = 0;
    private string _filtroSucursalStr = "";
    private string _filtroTipoServicioStr = "";
    private bool _soloActivas = true;

    // Data
    private List<TurnoProgramacionDto> _rows = new();
    private List<TipoTurnoDto> _tipos = new();
    private Dictionary<string, TipoTurnoDto> _tiposMap = new();
    private List<SucursalDto> _sucursales = new();
    private List<CatalogoTipoServicioDto> _tiposServicio = new();
    private int[] _aniosDisponibles = Array.Empty<int>();

    // Gestor de tipos (modal secundario embebido)
    private bool _tiposModalOpen;
    private bool _ttFormOpen;
    private Guid? _ttEditId;
    private string _ttCodigo = "";
    private string _ttEtiqueta = "";
    private decimal _ttHoras = 8m;
    private string _ttBg = "#FEF9C3";
    private string _ttFg = "#713F12";
    private string _ttBd = "#FCD34D";
    private int _ttOrden = 100;
    private bool _ttActivo = true;
    private bool _ttBusy;
    private string? _ttError;
    private string? _ttOk;
    private List<TipoTurnoDto> _tiposFull = new(); // incluye inactivos para el gestor

    // Modal
    private bool _modalOpen;
    private Guid? _editId;
    private string _fNombre = "";
    private int _fAnio = DateTime.Today.Year;
    private int _fMes = DateTime.Today.Month;
    private string _fSucursalStr = "";
    private string _fTipoServicioStr = "";
    private string _fDescripcion = "";
    private bool _fActiva = true;
    private GridDataModel _grid = GridDataModel.FromJson(null);
    private string? _brocha;
    private string? _modalError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tipos = (await TiposSvc.ListarAsync()).ToList();
            _tiposMap = _tipos.ToDictionary(t => t.Codigo, t => t, StringComparer.Ordinal);
            _sucursales = (await Sucursales.ListAsync(soloActivas: false)).ToList();
            _tiposServicio = (await TiposServicio.ListarAsync()).ToList();
            var hoy = DateTime.Today.Year;
            _aniosDisponibles = new[] { hoy - 1, hoy, hoy + 1 };
            await CargarAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task CargarAsync()
    {
        _error = null;
        try
        {
            Guid? suc = null;
            bool sucFilter = false;
            if (_filtroSucursalStr == "null") { sucFilter = true; suc = null; }
            else if (Guid.TryParse(_filtroSucursalStr, out var g)) { sucFilter = true; suc = g; }

            Guid? tipo = null;
            bool tipoFilter = false;
            if (_filtroTipoServicioStr == "null") { tipoFilter = true; tipo = null; }
            else if (Guid.TryParse(_filtroTipoServicioStr, out var g2)) { tipoFilter = true; tipo = g2; }

            var all = await Svc.ListarAsync(
                sucursalId: null, tipoServicioId: null,
                anio: _filtroAnio == 0 ? null : _filtroAnio,
                mes: _filtroMes == 0 ? null : _filtroMes,
                soloActivas: _soloActivas);

            // Filtro cliente por sucursal / tipoServicio: el service listar recibe
            // Guid?, no distingue "sin filtro" de "explicito null", asi que hacemos
            // el drill-down aca.
            IEnumerable<TurnoProgramacionDto> q = all;
            if (sucFilter) { q = q.Where(r => r.SucursalId == suc); }
            if (tipoFilter) { q = q.Where(r => r.TipoServicioId == tipo); }
            _rows = q.OrderByDescending(r => r.Anio).ThenByDescending(r => r.Mes).ThenBy(r => r.Nombre).ToList();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void Nueva()
    {
        _editId = null; _modalError = null;
        _fNombre = "";
        _fAnio = DateTime.Today.Year;
        _fMes = DateTime.Today.Month;
        _fSucursalStr = "";
        _fTipoServicioStr = "";
        _fDescripcion = "";
        _fActiva = true;
        _grid = GridDataModel.FromJson(null);
        _brocha = _tipos.FirstOrDefault()?.Codigo;
        _modalOpen = true;
    }

    private async Task EditarAsync(Guid id)
    {
        _modalError = null;
        try
        {
            var d = await Svc.ObtenerAsync(id);
            if (d is null) { _error = "Programacion no encontrada."; return; }
            _editId = id;
            _fNombre = d.Nombre;
            _fAnio = d.Anio; _fMes = d.Mes;
            _fSucursalStr = d.SucursalId?.ToString() ?? "";
            _fTipoServicioStr = d.TipoServicioId?.ToString() ?? "";
            _fDescripcion = d.Descripcion ?? "";
            _fActiva = d.Activa;
            _grid = GridDataModel.FromJson(d.GridDataJson);
            _brocha = _tipos.FirstOrDefault()?.Codigo;
            _modalOpen = true;
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void Cerrar() => _modalOpen = false;

    private async Task GuardarAsync()
    {
        _modalError = null;
        if (string.IsNullOrWhiteSpace(_fNombre)) { _modalError = "El nombre es obligatorio."; return; }
        if (_fMes < 1 || _fMes > 12) { _modalError = "Mes fuera de rango."; return; }
        if (_fAnio < 2024 || _fAnio > 2100) { _modalError = "Anio fuera de rango."; return; }

        Guid? suc = Guid.TryParse(_fSucursalStr, out var gs) ? gs : (Guid?)null;
        Guid? tsv = Guid.TryParse(_fTipoServicioStr, out var gt) ? gt : (Guid?)null;
        var json = _grid.ToJson();
        _busy = true; _error = _ok = null;
        try
        {
            var actor = await ActorAsync();
            if (_editId is null)
            {
                await Svc.CrearAsync(new CrearTurnoProgramacionCmd(
                    suc, tsv, _fNombre.Trim(), _fAnio, _fMes,
                    string.IsNullOrWhiteSpace(_fDescripcion) ? null : _fDescripcion.Trim(),
                    json), actor);
                _ok = "Programacion creada.";
            }
            else
            {
                await Svc.ActualizarAsync(_editId.Value, new ActualizarTurnoProgramacionCmd(
                    suc, tsv, _fNombre.Trim(), _fAnio, _fMes,
                    string.IsNullOrWhiteSpace(_fDescripcion) ? null : _fDescripcion.Trim(),
                    json, _fActiva), actor);
                _ok = "Programacion actualizada.";
            }
            _modalOpen = false;
            await CargarAsync();
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task DuplicarAsync(TurnoProgramacionDto r)
    {
        var mesStr = await JS.InvokeAsync<string>("prompt",
            $"Duplicar '{r.Nombre}' a que mes? (1-12)", (r.Mes + 1 > 12 ? 1 : r.Mes + 1).ToString());
        if (string.IsNullOrWhiteSpace(mesStr) || !int.TryParse(mesStr, out var m) || m < 1 || m > 12)
        { return; }
        var anioStr = await JS.InvokeAsync<string>("prompt",
            "A que anio?", (m == 1 && r.Mes == 12 ? r.Anio + 1 : r.Anio).ToString());
        if (string.IsNullOrWhiteSpace(anioStr) || !int.TryParse(anioStr, out var a)) { return; }
        _busy = true; _error = _ok = null;
        try
        {
            await Svc.DuplicarAsync(r.Id, a, m, await ActorAsync());
            _ok = "Programacion duplicada.";
            await CargarAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task DesactivarAsync(TurnoProgramacionDto r)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Desactivar la programacion '{r.Nombre}'? Se puede reactivar editandola.");
        if (!ok) { return; }
        _busy = true; _error = _ok = null;
        try
        {
            await Svc.DesactivarAsync(r.Id, await ActorAsync());
            _ok = "Programacion desactivada.";
            await CargarAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task EliminarAsync(TurnoProgramacionDto r)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Eliminar definitivamente '{r.Nombre}'? Esta accion no se puede deshacer.");
        if (!ok) { return; }
        _busy = true; _error = _ok = null;
        try
        {
            await Svc.EliminarAsync(r.Id, await ActorAsync());
            _ok = "Programacion eliminada.";
            await CargarAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    // ---- Editor ----
    private int DiasEnMes() => DateTime.DaysInMonth(_fAnio, _fMes);

    private void AgregarTurno()
    {
        if (_grid.Turnos.Count >= GridDataModel.MaxTurnos) { return; }
        var i = _grid.Turnos.Count + 1;
        string nombre;
        do { nombre = $"Turno {i}"; i++; } while (_grid.Turnos.Contains(nombre));
        _grid.Turnos.Add(nombre);
        _grid.Dias[nombre] = new Dictionary<string, GridCell>();
    }

    private void EliminarTurno(int idx)
    {
        if (_grid.Turnos.Count <= GridDataModel.MinTurnos) { return; }
        var t = _grid.Turnos[idx];
        _grid.Turnos.RemoveAt(idx);
        _grid.Dias.Remove(t);
    }

    private void RenombrarTurno(int idx, string nuevo)
    {
        nuevo = (nuevo ?? "").Trim();
        if (string.IsNullOrWhiteSpace(nuevo)) { return; }
        var anterior = _grid.Turnos[idx];
        if (nuevo == anterior) { return; }
        if (_grid.Turnos.Contains(nuevo)) { return; } // silencioso: no duplicar
        _grid.Turnos[idx] = nuevo;
        if (_grid.Dias.Remove(anterior, out var celdas))
        {
            _grid.Dias[nuevo] = celdas;
        }
    }

    private void PintarCelda(string turno, int dia)
    {
        if (_brocha is null) { return; }
        if (!_grid.Dias.TryGetValue(turno, out var celdas))
        {
            celdas = new Dictionary<string, GridCell>();
            _grid.Dias[turno] = celdas;
        }
        var key = dia.ToString();
        if (_brocha == "__ERASER__")
        {
            celdas.Remove(key);
            return;
        }
        var t = _tiposMap.GetValueOrDefault(_brocha);
        if (t is null) { return; }
        celdas[key] = new GridCell(t.Codigo, t.HorasDefault);
    }

    private void LimpiarTodo()
    {
        foreach (var t in _grid.Turnos) { _grid.Dias[t] = new Dictionary<string, GridCell>(); }
    }

    /// <summary>
    /// Toma la secuencia contigua de celdas pintadas desde el dia 1 de la fila
    /// como "patron" y la repite hasta el fin del mes. NO sobrescribe celdas que
    /// el usuario haya pintado manualmente mas alla del patron: solo llena huecos.
    /// Si el usuario pinto dia 1=D, dia 2=N, el patron es [D,N] y desde el dia 3
    /// se auto-llena D,N,D,N... hasta el ultimo dia del mes. Si el dia 15 ya estaba
    /// pintado con "L" manualmente, se conserva "L".
    /// </summary>
    private void ReplicarPatronDeFila(string turno)
    {
        _modalError = null;
        if (!_grid.Dias.TryGetValue(turno, out var celdas) || celdas.Count == 0)
        {
            _modalError = $"La fila \"{turno}\" no tiene celdas pintadas. Pinta al menos el dia 1 para definir el patron.";
            return;
        }
        var diasEnMes = DiasEnMes();
        // Detectar patron: bloque contiguo desde el dia 1.
        var patron = new List<GridCell>();
        for (var d = 1; d <= diasEnMes; d++)
        {
            if (celdas.TryGetValue(d.ToString(), out var c)) { patron.Add(c); }
            else { break; }
        }
        if (patron.Count == 0)
        {
            _modalError = $"El patron debe empezar en el dia 1. Pinta la celda del dia 1 primero.";
            return;
        }
        // Replicar preservando lo manual.
        for (var d = patron.Count + 1; d <= diasEnMes; d++)
        {
            var k = d.ToString();
            if (celdas.ContainsKey(k)) { continue; }
            var idx = (d - 1) % patron.Count;
            celdas[k] = patron[idx];
        }
    }

    private decimal TotalHorasMes()
    {
        var total = 0m;
        var dias = DiasEnMes();
        for (var d = 1; d <= dias; d++) { total += _grid.HorasDelDia(d); }
        return total;
    }

    // ---- helpers ----
    private static readonly string[] _meses = new[]
    {
        "Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic"
    };
    private static string NombreMes(int m) => (m >= 1 && m <= 12) ? _meses[m - 1] : "?";

    private static string DayOfWeekEs(int anio, int mes, int dia)
    {
        var dt = new DateTime(anio, mes, dia);
        return dt.DayOfWeek switch
        {
            DayOfWeek.Monday => "lun",
            DayOfWeek.Tuesday => "mar",
            DayOfWeek.Wednesday => "mie",
            DayOfWeek.Thursday => "jue",
            DayOfWeek.Friday => "vie",
            DayOfWeek.Saturday => "sab",
            _ => "dom",
        };
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var g) ? g : Guid.Empty;
    }

    // ---- Gestor de tipos ----

    private async Task AbrirGestorTipos()
    {
        _ttError = _ttOk = null;
        _ttFormOpen = false;
        _tiposFull = (await TiposSvc.ListarAsync(incluirInactivos: true)).ToList();
        _tiposModalOpen = true;
    }

    private void CerrarGestorTipos() => _tiposModalOpen = false;

    private void NuevoTipo()
    {
        _ttEditId = null; _ttError = _ttOk = null;
        _ttCodigo = ""; _ttEtiqueta = ""; _ttHoras = 8m;
        _ttBg = "#FEF9C3"; _ttFg = "#713F12"; _ttBd = "#FCD34D";
        _ttOrden = (_tiposFull.Count == 0 ? 1 : _tiposFull.Max(r => r.Orden) + 1);
        _ttActivo = true;
        _ttFormOpen = true;
    }

    private void EditarTipo(TipoTurnoDto r)
    {
        _ttEditId = r.Id; _ttError = _ttOk = null;
        _ttCodigo = r.Codigo; _ttEtiqueta = r.Etiqueta; _ttHoras = r.HorasDefault;
        _ttBg = r.ColorFondo; _ttFg = r.ColorTexto; _ttBd = r.ColorBorde;
        _ttOrden = r.Orden; _ttActivo = r.Activo;
        _ttFormOpen = true;
    }

    private void CancelarFormTipo() { _ttFormOpen = false; _ttError = null; }

    private async Task GuardarTipoAsync()
    {
        _ttError = _ttOk = null; _ttBusy = true;
        try
        {
            var actor = await ActorAsync();
            var cmd = new GuardarTipoTurnoCmd(
                _ttEditId, _ttCodigo, _ttEtiqueta, _ttHoras,
                _ttBg, _ttFg, _ttBd, _ttOrden, _ttActivo);
            await TiposSvc.GuardarAsync(cmd, actor);
            _ttOk = _ttEditId is null ? "Tipo creado." : "Tipo actualizado.";
            _ttFormOpen = false;
            await RecargarTiposAsync();
        }
        catch (Exception ex) { _ttError = ex.Message; }
        finally { _ttBusy = false; }
    }

    private async Task EliminarTipoAsync(TipoTurnoDto r)
    {
        var ok = await JS.InvokeAsync<bool>("confirm",
            $"Eliminar el tipo '{r.Codigo}'? Si esta usado en alguna programacion, la celda quedara sin color hasta que reasignes otro tipo.");
        if (!ok) { return; }
        _ttError = _ttOk = null; _ttBusy = true;
        try
        {
            await TiposSvc.EliminarAsync(r.Id, await ActorAsync());
            _ttOk = "Tipo eliminado.";
            await RecargarTiposAsync();
        }
        catch (Exception ex) { _ttError = ex.Message; }
        finally { _ttBusy = false; }
    }

    /// <summary>Recarga la lista completa (para la tabla del gestor) y la lista
    /// activa (para el sidebar del editor), y refresca _tiposMap para que las
    /// celdas ya pintadas conserven los nuevos colores en vivo.</summary>
    private async Task RecargarTiposAsync()
    {
        _tiposFull = (await TiposSvc.ListarAsync(incluirInactivos: true)).ToList();
        _tipos = _tiposFull.Where(t => t.Activo).OrderBy(t => t.Orden).ThenBy(t => t.Codigo).ToList();
        _tiposMap = _tipos.ToDictionary(t => t.Codigo, t => t, StringComparer.Ordinal);
        // Si la brocha activa apuntaba a un codigo que ya no existe, la limpiamos.
        if (_brocha is not null && _brocha != "__ERASER__" && !_tiposMap.ContainsKey(_brocha))
        {
            _brocha = null;
        }
    }
}
