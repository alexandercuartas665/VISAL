        OrigenInformeItem.HistoriaClinicaPdf => "Historia clinica (PDF)",
        OrigenInformeItem.DocumentoHc => "Documento de HC",
        OrigenInformeItem.DocumentoPacienteLibre => "Documento libre del paciente",
        OrigenInformeItem.DocumentoNota => "Adjunto de nota",
        OrigenInformeItem.FirmaPaciente => "Firma del paciente",
        OrigenInformeItem.AutorizacionAsignacion => "Autorizacion (asignacion)",
        OrigenInformeItem.Consentimiento => "Consentimiento (HC)",
        OrigenInformeItem.Evolucion => "Evolucion (HC)",
        OrigenInformeItem.Escala => "Escala (HC)",
