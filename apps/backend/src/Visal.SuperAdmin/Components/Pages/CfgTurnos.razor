@page "/cfg-turnos"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using System.Security.Claims
@using System.Text.Json
@using Visal.Application.Tenancy
@using Visal.Application.Tenancy.Turnos
@inject ITurnoProgramacionService Svc
@inject ITipoTurnoService TiposSvc
@inject ISucursalService Sucursales
@inject ICatalogoTipoServicioService TiposServicio
@inject IJSRuntime JS

<PageTitle>Programaciones de turnos - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion del Sistema</div>
        <h1 class="ase-title">Programaciones de turnos</h1>
        <small class="text-muted">
            Plantillas mensuales tipo rotacion (Manana / Tarde / Noche / Descanso).
            Se aplican luego en Coordinacion para asignar profesionales a turnos individuales.
        </small>
    </div>
    <button class="btn btn-primary" @onclick="Nueva" disabled="@_busy">+ Nueva programacion</button>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-card" style="padding:14px;">
    <div class="row g-2 align-items-end mb-2">
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Anio</label>
            <select class="form-select form-select-sm" @bind="_filtroAnio" @bind:after="CargarAsync">
                <option value="0">Todos</option>
                @foreach (var a in _aniosDisponibles)
                {
                    <option value="@a">@a</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Mes</label>
            <select class="form-select form-select-sm" @bind="_filtroMes" @bind:after="CargarAsync">
                <option value="0">Todos</option>
                @for (var m = 1; m <= 12; m++)
                {
                    <option value="@m">@NombreMes(m)</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Sede</label>
            <select class="form-select form-select-sm" @bind="_filtroSucursalStr" @bind:after="CargarAsync">
                <option value="">Todas</option>
                <option value="null">(Sin sede)</option>
                @foreach (var s in _sucursales)
                {
                    <option value="@s.Id">@s.Nombre</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Tipo de servicio</label>
            <select class="form-select form-select-sm" @bind="_filtroTipoServicioStr" @bind:after="CargarAsync">
                <option value="">Todos</option>
                <option value="null">(Sin tipo)</option>
                @foreach (var t in _tiposServicio)
                {
                    <option value="@t.Id">@t.Nombre</option>
                }
            </select>
        </div>
        <div class="col-md-2 text-end">
            <label class="ase-chk" style="margin-top:8px;">
                <input type="checkbox" @bind="_soloActivas" @bind:after="CargarAsync" />
                <span>Solo activas</span>
            </label>
        </div>
    </div>

    @if (_loading)
    {
        <div class="ase-empty">Cargando...</div>
    }
    else if (_rows.Count == 0)
    {
        <div class="ase-empty" style="padding:30px;">No hay programaciones que coincidan con el filtro.</div>
    }
    else
    {
        <div class="med-tbl-wrap">
            <table class="table table-sm med-tbl align-middle">
                <thead>
                    <tr>
                        <th style="width:70px">Anio</th>
                        <th style="width:110px">Mes</th>
                        <th>Nombre</th>
                        <th>Sede</th>
                        <th>Tipo de servicio</th>
                        <th class="text-center" style="width:90px">Turnos</th>
                        <th class="text-center" style="width:90px">Estado</th>
                        <th style="width:190px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr class="@(r.Activa ? "" : "rf-row-inactiva")">
                            <td>@r.Anio</td>
                            <td>@NombreMes(r.Mes)</td>
                            <td><strong>@r.Nombre</strong></td>
                            <td>@(r.SucursalNombre ?? "-")</td>
                            <td>@(r.TipoServicioNombre ?? "-")</td>
                            <td class="text-center">@r.CantidadTurnos</td>
                            <td class="text-center">
                                @if (r.Activa) { <span class="badge bg-success">Activa</span> }
                                else { <span class="badge bg-secondary">Inactiva</span> }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-link btn-sm" title="Editar" @onclick="() => EditarAsync(r.Id)">&#9998;</button>
                                <button class="btn btn-link btn-sm" title="Duplicar" @onclick="() => DuplicarAsync(r)">&#128203;</button>
                                @if (r.Activa)
                                {
                                    <button class="btn btn-link btn-sm text-warning" title="Desactivar" @onclick="() => DesactivarAsync(r)">&#9210;</button>
                                }
                                <button class="btn btn-link btn-sm text-danger" title="Eliminar" @onclick="() => EliminarAsync(r)">&#128465;</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* ============= EDITOR MODAL ============= *@
@if (_modalOpen)
{
    <div class="cie-backdrop" @onclick="Cerrar"></div>
    <div class="cie-modal turnos-modal">
        <div class="cie-modal-h">
            <h3>@(_editId is null ? "Nueva programacion" : "Editar programacion")</h3>
            <button class="cie-modal-close" @onclick="Cerrar">&times;</button>
        </div>
        <div class="cie-modal-body">
            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Nombre *</label>
                    <input class="form-control form-control-sm" @bind="_fNombre"
                           placeholder="Ej: Rotacion Enfermeria" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Anio *</label>
                    <input type="number" class="form-control form-control-sm" @bind="_fAnio" min="2024" max="2100" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Mes *</label>
                    <select class="form-select form-select-sm" @bind="_fMes">
                        @for (var m = 1; m <= 12; m++)
                        {
                            <option value="@m">@NombreMes(m)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small mb-1">Sede</label>
                    <select class="form-select form-select-sm" @bind="_fSucursalStr">
                        <option value="">(Sin sede especifica)</option>
                        @foreach (var s in _sucursales)
                        {
                            <option value="@s.Id">@s.Nombre</option>
                        }
                    </select>
                </div>
            </div>
            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Tipo de servicio</label>
                    <select class="form-select form-select-sm" @bind="_fTipoServicioStr">
                        <option value="">(Sin tipo especifico)</option>
                        @foreach (var t in _tiposServicio)
                        {
                            <option value="@t.Id">@t.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small mb-1">Descripcion</label>
                    <input class="form-control form-control-sm" @bind="_fDescripcion"
                           placeholder="Notas opcionales de esta programacion" />
                </div>
                <div class="col-md-2">
                    <label class="ase-chk" style="margin-top:24px;">
                        <input type="checkbox" @bind="_fActiva" /> <span>Activa</span>
                    </label>
                </div>
            </div>

            @* Editor de grid *@
            <div class="tgrid-wrap">
                @* Sidebar de tipos (brocha) *@
                <div class="tgrid-side">
                    <div class="small text-muted mb-2">Brocha activa</div>
                    <div class="tgrid-brocha">
                        @if (_brocha is null)
                        {
                            <span class="text-muted small">(ninguna)</span>
                        }
                        else if (_brocha == "__ERASER__")
                        {
                            <span class="badge bg-dark">BORRAR</span>
                        }
                        else
                        {
                            var t = _tiposMap.GetValueOrDefault(_brocha);
                            if (t is not null)
                            {
                                <span class="tgrid-chip" style="background:@t.ColorFondo;color:@t.ColorTexto;border-color:@t.ColorBorde;">
                                    @t.Codigo @($" ({t.HorasDefault.ToString("0.#")}h)")
                                </span>
                            }
                        }
                    </div>
                    <hr class="my-2" />
                    <div class="d-flex align-items-center justify-content-between mb-1">
                        <div class="small text-muted">Tipos de turno</div>
                        <button type="button" class="btn btn-link btn-sm p-0"
                                title="Gestionar tipos de turno"
                                @onclick="AbrirGestorTipos">&#9881; Gestionar</button>
                    </div>
                    @if (_tipos.Count == 0)
                    {
                        <div class="ase-empty small" style="padding:8px 4px;">
                            No hay tipos configurados.
                            <button type="button" class="btn btn-link btn-sm p-0" @onclick="AbrirGestorTipos">Crear tipos &rarr;</button>
                        </div>
                    }
                    <div class="tgrid-tipos">
                        @foreach (var t in _tipos)
                        {
                            <button type="button"
                                    class="tgrid-tipo @(("__="+_brocha) == ("__="+t.Codigo) ? "sel" : "")"
                                    style="background:@t.ColorFondo;color:@t.ColorTexto;border-color:@t.ColorBorde;"
                                    title="@t.Etiqueta (@t.HorasDefault.ToString("0.#")h)"
                                    @onclick="() => _brocha = t.Codigo">
                                <strong>@t.Codigo</strong>
                                <div class="tgrid-tipo-lbl">@t.Etiqueta</div>
                            </button>
                        }
                        <button type="button" class="tgrid-tipo eraser @(_brocha == "__ERASER__" ? "sel" : "")"
                                @onclick='() => _brocha = "__ERASER__"'>
                            <strong>&#9003;</strong>
                            <div class="tgrid-tipo-lbl">Borrar</div>
                        </button>
                    </div>
                    <hr class="my-2" />
                    <div class="small text-muted">
                        Total horas mes: <strong>@TotalHorasMes().ToString("0.#")</strong>h<br />
                        Turnos: <strong>@_grid.Turnos.Count</strong> / @GridDataModel.MaxTurnos
                    </div>
                </div>

                @* Grid principal: turnos x dias *@
                <div class="tgrid-main">
                    <div class="tgrid-toolbar">
                        <button class="btn btn-outline-primary btn-sm"
                                disabled="@(_grid.Turnos.Count >= GridDataModel.MaxTurnos)"
                                @onclick="AgregarTurno">+ Agregar turno</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarTodo">Limpiar todo</button>
                        <span class="text-muted small ms-2">
                            Elegi una brocha del panel izquierdo y hace click en las celdas para pintar.
                        </span>
                    </div>
                    <div class="tgrid-scroll">
                        <table class="tgrid">
                            <thead>
                                <tr>
                                    <th class="tgrid-hcol">Turno</th>
                                    @for (var d = 1; d <= DiasEnMes(); d++)
                                    {
                                        var di = d;
                                        var dow = DayOfWeekEs(_fAnio, _fMes, di);
                                        var esFinde = dow == "sab" || dow == "dom";
                                        <th class="tgrid-hday @(esFinde ? "finde" : "")">
                                            <div class="tgrid-day-num">@di</div>
                                            <div class="tgrid-day-dow">@dow</div>
                                        </th>
                                    }
                                    <th class="tgrid-hact"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var iT = 0; iT < _grid.Turnos.Count; iT++)
                                {
                                    var idx = iT;
                                    var turno = _grid.Turnos[idx];
                                    <tr>
                                        <th class="tgrid-hrow">
                                            <input class="form-control form-control-sm"
                                                   value="@turno"
                                                   @onchange="@((ChangeEventArgs e) => RenombrarTurno(idx, e.Value?.ToString() ?? turno))" />
                                        </th>
                                        @for (var d = 1; d <= DiasEnMes(); d++)
                                        {
                                            var dia = d;
                                            var key = dia.ToString();
                                            _grid.Dias.TryGetValue(turno, out var celdas);
                                            GridCell? celda = null;
                                            if (celdas is not null && celdas.TryGetValue(key, out var c)) { celda = c; }
                                            var tp = celda is not null ? _tiposMap.GetValueOrDefault(celda.Tipo) : null;
                                            var style = tp is not null
                                                ? $"background:{tp.ColorFondo};color:{tp.ColorTexto};border-color:{tp.ColorBorde};"
                                                : "";
                                            <td class="tgrid-cell"
                                                style="@style"
                                                title="@(celda is not null ? $"{celda.Tipo} ({celda.Horas:0.#}h)" : "")"
                                                @onclick="() => PintarCelda(turno, dia)">
                                                @(celda is not null ? celda.Tipo : "")
                                            </td>
                                        }
                                        <th class="tgrid-hact">
                                            <button class="btn btn-link btn-sm text-primary p-0 me-2"
                                                    title="Replicar patron hasta fin de mes: toma la secuencia contigua desde el dia 1 y la repite. No sobrescribe celdas ya pintadas mas alla del patron."
                                                    @onclick="() => ReplicarPatronDeFila(turno)">&#128260;</button>
                                            <button class="btn btn-link btn-sm text-danger p-0"
                                                    title="Eliminar turno"
                                                    disabled="@(_grid.Turnos.Count <= GridDataModel.MinTurnos)"
                                                    @onclick="() => EliminarTurno(idx)">&#128465;</button>
                                        </th>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @if (_modalError is not null) { <div class="text-danger small mt-2">@_modalError</div> }
        </div>
        <div class="cie-modal-foot" style="justify-content:flex-end;gap:8px;">
            <button class="btn btn-outline-secondary btn-sm" @onclick="Cerrar">Cancelar</button>
            <button class="btn btn-primary btn-sm" @onclick="GuardarAsync" disabled="@_busy">
                @(_editId is null ? "Crear" : "Guardar")
            </button>
        </div>
    </div>
}

@* ============= GESTOR DE TIPOS ============= *@
@if (_tiposModalOpen)
{
    <div class="cie-backdrop" @onclick="CerrarGestorTipos"></div>
    <div class="cie-modal" style="width:900px; max-width:95vw; z-index:1060;">
        <div class="cie-modal-h">
            <h3>Tipos de turno</h3>
            <button class="cie-modal-close" @onclick="CerrarGestorTipos">&times;</button>
        </div>
        <div class="cie-modal-body">
            @if (_ttError is not null) { <div class="text-danger small mb-2">@_ttError</div> }
            @if (_ttOk is not null) { <div class="text-success small mb-2">@_ttOk</div> }

            @if (_ttFormOpen)
            {
                <div class="tt-form-card">
                    <div class="row g-2">
                        <div class="col-3">
                            <label class="form-label small mb-1">Codigo *</label>
                            <input class="form-control form-control-sm mono" @bind="_ttCodigo" maxlength="8"
                                   style="text-transform:uppercase;" placeholder="Ej: M" />
                        </div>
                        <div class="col-5">
                            <label class="form-label small mb-1">Etiqueta *</label>
                            <input class="form-control form-control-sm" @bind="_ttEtiqueta" maxlength="40" placeholder="Ej: Manana" />
                        </div>
                        <div class="col-2">
                            <label class="form-label small mb-1">Horas</label>
                            <input type="number" class="form-control form-control-sm" @bind="_ttHoras" step="0.5" min="0" max="24" />
                        </div>
                        <div class="col-2">
                            <label class="form-label small mb-1">Orden</label>
                            <input type="number" class="form-control form-control-sm" @bind="_ttOrden" min="0" />
                        </div>
                    </div>
                    <div class="row g-2 mt-2">
                        <div class="col-3">
                            <label class="form-label small mb-1">Fondo</label>
                            <input class="form-control form-control-sm mono" @bind="_ttBg" placeholder="#FEF9C3" />
                        </div>
                        <div class="col-3">
                            <label class="form-label small mb-1">Texto</label>
                            <input class="form-control form-control-sm mono" @bind="_ttFg" placeholder="#713F12" />
                        </div>
                        <div class="col-3">
                            <label class="form-label small mb-1">Borde</label>
                            <input class="form-control form-control-sm mono" @bind="_ttBd" placeholder="#FCD34D" />
                        </div>
                        <div class="col-3">
                            <label class="form-label small mb-1">Preview</label>
                            <div>
                                <span class="tgrid-chip" style="background:@_ttBg;color:@_ttFg;border-color:@_ttBd;">
                                    @(string.IsNullOrWhiteSpace(_ttCodigo) ? "??" : _ttCodigo.ToUpperInvariant())
                                    @(string.IsNullOrWhiteSpace(_ttEtiqueta) ? "" : _ttEtiqueta)
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2 mt-2">
                        <label class="ase-chk">
                            <input type="checkbox" @bind="_ttActivo" /> <span>Activo</span>
                        </label>
                        <div class="ms-auto">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelarFormTipo">Cancelar</button>
                            <button class="btn btn-primary btn-sm" @onclick="GuardarTipoAsync" disabled="@_ttBusy">
                                @(_ttEditId is null ? "Crear" : "Guardar")
                            </button>
                        </div>
                    </div>
                </div>
                <hr />
            }

            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="small text-muted">@_tiposFull.Count tipos configurados</div>
                @if (!_ttFormOpen)
                {
                    <button class="btn btn-primary btn-sm" @onclick="NuevoTipo">+ Nuevo tipo</button>
                }
            </div>

            @if (_tiposFull.Count == 0)
            {
                <div class="ase-empty" style="padding:24px;">Aun no hay tipos. Crea el primero.</div>
            }
            else
            {
                <div class="med-tbl-wrap">
                    <table class="table table-sm med-tbl align-middle">
                        <thead>
                            <tr>
                                <th style="width:60px">Orden</th>
                                <th style="width:90px">Codigo</th>
                                <th>Etiqueta</th>
                                <th style="width:70px" class="text-end">Horas</th>
                                <th style="width:150px">Preview</th>
                                <th style="width:80px" class="text-center">Activo</th>
                                <th style="width:100px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in _tiposFull)
                            {
                                <tr class="@(r.Activo ? "" : "rf-row-inactiva")">
                                    <td>@r.Orden</td>
                                    <td><code>@r.Codigo</code></td>
                                    <td>@r.Etiqueta</td>
                                    <td class="text-end">@r.HorasDefault.ToString("0.#")</td>
                                    <td>
                                        <span class="tgrid-chip"
                                              style="background:@r.ColorFondo;color:@r.ColorTexto;border-color:@r.ColorBorde;">
                                            @r.Codigo @r.Etiqueta
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (r.Activo) { <span class="badge bg-success">Activo</span> }
                                        else { <span class="badge bg-secondary">Apagado</span> }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-link btn-sm" title="Editar" @onclick="() => EditarTipo(r)">&#9998;</button>
                                        <button class="btn btn-link btn-sm text-danger" title="Eliminar" @onclick="() => EliminarTipoAsync(r)">&#128465;</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        <div class="cie-modal-foot" style="justify-content:flex-end;">
            <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarGestorTipos">Cerrar</button>
        </div>
    </div>
}

<style>
    .rf-row-inactiva { opacity: 0.55; background: #f8fafc; }

    .cie-backdrop { position: fixed; inset: 0; background: rgba(15,23,42,.45); z-index: 1050; }
    .cie-modal {
        position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);
        max-width: 95vw; max-height: 92vh; background: #fff;
        border-radius: 12px; box-shadow: 0 20px 60px rgba(15,23,42,.25);
        z-index: 1051; display: flex; flex-direction: column;
    }
    .turnos-modal { width: 1400px; }
    .cie-modal-h { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid #e2e8f0; }
    .cie-modal-h h3 { margin: 0; font-size: 16px; font-weight: 700; color: #0f172a; }
    .cie-modal-close { background: none; border: none; font-size: 22px; line-height: 1; cursor: pointer; color: #64748b; }
    .cie-modal-body { padding: 18px; overflow: auto; }
    .cie-modal-foot { padding: 12px 18px; border-top: 1px solid #e2e8f0; display: flex; }

    /* ---- Editor de grid ---- */
    .tgrid-wrap { display: grid; grid-template-columns: 200px 1fr; gap: 12px; align-items: flex-start; }
    .tgrid-side { border: 1px solid #e2e8f0; border-radius: 10px; padding: 10px; background: #f8fafc; position: sticky; top: 0; }
    .tgrid-brocha { min-height: 32px; display: flex; align-items: center; }
    .tgrid-chip { display: inline-block; padding: 4px 10px; border: 1px solid; border-radius: 999px; font-weight: 700; font-size: 12px; }
    .tgrid-tipos { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .tgrid-tipo { border: 1px solid; border-radius: 8px; padding: 6px 4px; cursor: pointer; text-align: center; font-size: 12px; }
    .tgrid-tipo.sel { outline: 2px solid #2563eb; outline-offset: 1px; }
    .tgrid-tipo.eraser { grid-column: 1 / span 2; background: #fff; color: #374151; border-color: #cbd5e1; }
    .tgrid-tipo-lbl { font-size: 10px; line-height: 1.1; margin-top: 2px; opacity: .85; }

    .tgrid-main { min-width: 0; }
    .tgrid-toolbar { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
    .tgrid-scroll { overflow: auto; max-height: 55vh; border: 1px solid #e2e8f0; border-radius: 8px; }
    table.tgrid { border-collapse: separate; border-spacing: 0; width: max-content; }
    table.tgrid th, table.tgrid td { border-right: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0; padding: 0; }
    table.tgrid thead th { background: #f1f5f9; position: sticky; top: 0; z-index: 2; }
    table.tgrid .tgrid-hcol { min-width: 160px; text-align: left; padding: 6px 8px; font-weight: 600; }
    table.tgrid .tgrid-hday { min-width: 34px; text-align: center; padding: 4px 2px; font-weight: 600; }
    table.tgrid .tgrid-hday.finde { background: #e0e7ff; }
    table.tgrid .tgrid-day-num { font-size: 12px; }
    table.tgrid .tgrid-day-dow { font-size: 9px; color: #64748b; text-transform: uppercase; }
    table.tgrid .tgrid-hact { min-width: 34px; text-align: center; background: #f1f5f9; }
    table.tgrid .tgrid-hrow { position: sticky; left: 0; background: #fff; z-index: 1; padding: 3px; min-width: 160px; }
    table.tgrid .tgrid-hrow input { min-width: 150px; }
    table.tgrid .tgrid-cell {
        min-width: 34px; height: 34px; text-align: center; cursor: pointer;
        font-weight: 700; font-size: 11px; user-select: none;
        border: 1px solid #e2e8f0;
    }
    table.tgrid .tgrid-cell:hover { outline: 2px solid #2563eb; outline-offset: -2px; }

    /* ---- Gestor de tipos ---- */
    .tt-form-card { background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:10px; margin-bottom:8px; }
    .mono { font-family: ui-monospace, Menlo, Consolas, monospace; }
    .rf-row-inactiva { opacity: 0.55; background: #f8fafc; }
