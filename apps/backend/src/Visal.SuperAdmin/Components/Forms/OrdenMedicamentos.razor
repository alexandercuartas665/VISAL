@using Visal.Application.Tenancy
@using Visal.Application.Common
@inject IOrdenMedicamentoService OrdSvc
@inject IJSRuntime JS

@*
   Pestana "Orden de Medicamentos" de la HC. Buscador con autocompletado
   contra el catalogo CUM (/medicamentos), agregar/editar/eliminar items
   atados a la HistoriaClinicaId, cada item con su observacion. Cambios
   se persisten al instante (no requiere "Guardar" explicito).
*@

<div class="od-bar">
    <div class="od-bar-left">
        <label>Orden de Medicamentos</label>
        <span class="od-bar-count">@_items.Count item(s)</span>
    </div>
    <div class="od-bar-right">
        <button class="btn btn-outline-primary btn-sm" title="Imprimir orden"
                disabled="@(HistoriaClinicaId is null || _items.Count == 0)"
                @onclick="ImprimirAsync">&#128424; Imprimir</button>
    </div>
</div>

@if (HistoriaClinicaId is null)
{
    <div class="od-card od-empty-hc">
        Selecciona o inicia una historia para registrar medicamentos.
    </div>
}
else
{
    <div class="od-card">
        @* ---- Fila de captura: autocompletado + posologia + cantidad ---- *@
        <div class="od-row">
            <div class="od-f od-c-6 od-search-wrap">
                <label>Nombre del Medicamento</label>
                <input class="form-control form-control-sm"
                       placeholder="Buscar medicamento (min 2 caracteres)..."
                       value="@_terminoBusqueda"
                       @oninput="OnTerminoChanged" />
                @if (_sugerencias.Count > 0)
                {
                    <div class="od-suggest">
                        @foreach (var s in _sugerencias)
                        {
                            var sCopy = s;
                            <button class="od-suggest-item" @onclick="() => SeleccionarSugerencia(sCopy)">
                                <div class="od-suggest-nm">@s.Producto</div>
                                <div class="od-suggest-meta">
                                    @if (!string.IsNullOrWhiteSpace(s.PrincipioActivo)) { <span>@s.PrincipioActivo</span> }
                                    @if (!string.IsNullOrWhiteSpace(s.Concentracion)) { <span>&middot; @s.Concentracion</span> }
                                    @if (!string.IsNullOrWhiteSpace(s.FormaFarmaceutica)) { <span>&middot; @s.FormaFarmaceutica</span> }
                                    @if (!string.IsNullOrWhiteSpace(s.RegistroSanitario)) { <span class="od-suggest-reg">@s.RegistroSanitario</span> }
                                </div>
                            </button>
                        }
                        @* "Cargar mas" aparece cuando la ultima consulta trajo el tope
                           actual (_pageSize) — es la senal de que probablemente hay mas
                           registros que la BD podria retornar. Sube el tope y re-consulta. *@
                        @if (_sugerencias.Count >= _pageSize)
                        {
                            <button class="od-suggest-more" @onclick="CargarMasSugerenciasAsync" disabled="@_buscando">
                                @(_buscando ? "Cargando..." : $"+ Cargar mas resultados ({_pageSize} mostrados)")
                            </button>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_terminoBusqueda) && _terminoBusqueda.Trim().Length >= 2 && !_buscando)
                {
                    <div class="od-suggest od-suggest-empty">Sin resultados para "@_terminoBusqueda"</div>
                }
            </div>
            <div class="od-f od-c-4">
                <div class="od-posol">
                    <div class="od-posol-grid">
                        <div>
                            <label class="od-mini">Cantidad</label>
                            <input class="form-control form-control-sm text-center"
                                   @bind="_borrador.Cantidad" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="od-mini" title="Intervalo entre dosis en horas (8 = cada 8 horas, 24 = una vez al dia)">Cada (h)</label>
                            <input class="form-control form-control-sm text-center"
                                   @bind="_borrador.Frecuencia" @bind:event="oninput"
                                   placeholder="8" />
                        </div>
                        <div>
                            <label class="od-mini">Dias</label>
                            <input class="form-control form-control-sm text-center"
                                   @bind="_borrador.Dias" @bind:event="oninput" />
                        </div>
                    </div>
                    <div class="od-posol-preview">@PosologiaPreview()</div>
                </div>
            </div>
            <div class="od-f od-c-2">
                <label>Accion</label>
                <button class="btn btn-primary btn-sm od-add"
                        @onclick="AgregarAsync"
                        disabled="@(string.IsNullOrWhiteSpace(_borrador.NombreMedicamento) || _agregando)">
                    @(_agregando ? "Agregando..." : "+ Agregar")
                </button>
            </div>
        </div>

        @* ---- Fila 2: observacion del medicamento en captura (evita tener que
             agregar el item primero e ir a la tabla a editar la observacion). ---- *@
        <div class="od-row od-row-obs">
            <div class="od-f od-c-12">
                <label>Observacion clinica (opcional)</label>
                <input class="form-control form-control-sm"
                       placeholder="Ej: administrar con alimentos, suspender si aparece rash..."
                       @bind="_borrador.Observacion" @bind:event="oninput" />
            </div>
        </div>

@if (!string.IsNullOrWhiteSpace(_borrador.NombreMedicamento))
        {
            <div class="od-borrador">
                Medicamento seleccionado: <strong>@_borrador.NombreMedicamento</strong>
                <button class="btn btn-link btn-sm od-borrador-x" @onclick="LimpiarBorrador" title="Quitar">&times;</button>
            </div>
        }

        @* ---- Grilla de items agregados ---- *@
        <div class="od-grid-wrap">
            <table class="table table-sm od-tbl">
                <thead>
                    <tr>
                        <th style="width:40px">#</th>
                        <th style="width:130px">Codigo</th>
                        <th>Nombre del Medicamento</th>
                        <th>Posologia</th>
                        <th class="text-center" style="width:80px">Total</th>
                        <th>Observacion</th>
                        <th class="text-center" style="width:50px"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_items.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted od-empty-row">Sin medicamentos agregados.</td></tr>
                    }
                    else
                    {
                        @foreach (var it in _items)
                        {
                            var total = CalcularTotal(it.Cantidad, it.Frecuencia, it.Dias);
                            <tr>
                                <td class="text-center">@it.Orden</td>
                                <td class="od-codigo">@(string.IsNullOrWhiteSpace(it.CodigoMedicamento) ? "—" : it.CodigoMedicamento)</td>
                                <td>
                                    <strong>@it.NombreMedicamento</strong>
                                </td>
                                <td>
                                    <input class="form-control form-control-sm od-inline-input"
                                           value="@it.Posologia"
                                           @onchange="@(e => GuardarPosologia(it, e.Value?.ToString()))" />
                                </td>
                                <td class="text-center od-total">@(total ?? "—")</td>
                                <td>
                                    <input class="form-control form-control-sm od-inline-input"
                                           placeholder="Observacion clinica..."
                                           value="@it.Observacion"
                                           @onchange="@(e => GuardarObservacion(it, e.Value?.ToString()))" />
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="() => EliminarAsync(it)"
                                            title="Quitar de la orden">&#128465;</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<style>
    .od-bar { display:flex; justify-content:space-between; align-items:center; padding:8px 12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; margin-bottom:12px; gap:10px; flex-wrap:wrap; }
    .od-bar-left { display:flex; align-items:center; gap:10px; font-size:13px; font-weight:700; color:#0f172a; }
    .od-bar-count { background:#1565c0; color:#fff; padding:2px 10px; border-radius:999px; font-size:11px; font-weight:700; }
    .od-card { border:1px solid #e2e8f0; border-radius:8px; padding:16px; background:#fff; position:relative; }
    .od-empty-hc { color:#64748b; text-align:center; padding:30px; font-style:italic; }
    .od-row { display:grid; grid-template-columns:repeat(12, 1fr); gap:12px; margin-bottom:12px; align-items:end; }
    .od-f label { font-size:11px; font-weight:700; color:#334155; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:4px; display:block; }
    .od-c-2 { grid-column: span 2; }
    .od-c-4 { grid-column: span 4; }
    .od-c-6 { grid-column: span 6; }

    .od-search-wrap { position:relative; }
    .od-suggest { position:absolute; top:100%; left:0; right:0; background:#fff; border:1px solid #cbd5e1; border-radius:8px; box-shadow:0 12px 30px rgba(15,23,42,.12); max-height:300px; overflow-y:auto; z-index:50; margin-top:4px; }
    .od-suggest-item { display:block; width:100%; text-align:left; padding:10px 12px; border:0; background:transparent; cursor:pointer; border-bottom:1px solid #f1f5f9; }
    .od-suggest-item:hover { background:#eff6ff; }
    .od-suggest-item:last-child { border-bottom:0; }
    .od-suggest-nm { font-size:13px; font-weight:700; color:#0f172a; margin-bottom:2px; }
    .od-suggest-meta { font-size:11px; color:#64748b; display:flex; gap:4px; flex-wrap:wrap; }
    .od-suggest-reg { background:#f1f5f9; color:#475569; padding:1px 6px; border-radius:4px; font-family:'JetBrains Mono','Consolas',monospace; }
    .od-suggest-empty { padding:10px 12px; font-size:12px; color:#64748b; font-style:italic; }
    .od-suggest-more { display:block; width:100%; text-align:center; padding:10px 12px; border:0; border-top:2px dashed #cbd5e1; background:#f8fafc; color:#2563eb; font-weight:600; cursor:pointer; font-size:12px; position:sticky; bottom:0; }
    .od-suggest-more:hover:not(:disabled) { background:#eff6ff; }
    .od-suggest-more:disabled { color:#94a3b8; cursor:wait; }

    .od-borrador { margin-bottom:12px; padding:8px 12px; background:#eff6ff; border:1px solid #bfdbfe; border-radius:6px; font-size:12.5px; color:#1e40af; display:flex; align-items:center; gap:8px; }
    .od-borrador-x { color:#dc2626; padding:0 4px; }

    .od-posol { background:#f1f5f9; border:1px solid #e2e8f0; border-radius:8px; padding:8px; }
    .od-posol-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:6px; }
    .od-mini { font-size:10px !important; text-align:center; }
    .od-posol-preview { font-size:11px; color:#64748b; font-style:italic; text-align:center; margin-top:6px; min-height:14px; }
    .od-add { width:100%; }
    .od-grid-wrap { margin-top:14px; border:1px solid #e2e8f0; border-radius:6px; overflow:auto; }
    .od-tbl { margin:0; font-size:12.5px; }
    .od-tbl thead th { background:#1565c0; color:#fff; padding:8px 10px; font-size:11px; font-weight:700; text-transform:uppercase; }
    .od-tbl td { padding:8px 10px; border-bottom:1px solid #f1f5f9; vertical-align:middle; }
    .od-empty-row { padding:30px !important; font-style:italic; }
    .od-inline-input { font-size:12px; }
    .od-codigo { font-family:'JetBrains Mono','Consolas',monospace; font-size:11.5px; color:#475569; }
    .od-total { font-weight:700; color:#0f172a; background:#fef9c3; }
    .od-c-12 { grid-column: span 12; }
    .od-row-obs { margin-top:-4px; }
    .od-row-mip { margin-top:-4px; }
    .od-mip-input { font-family:'JetBrains Mono','Consolas',monospace; font-size:11.5px; }
    .od-mip-link { margin-left:10px; padding:2px 10px; font-size:11px; font-weight:600; vertical-align:baseline; text-decoration:none; }
    .od-mip-req { color:#b91c1c; font-weight:700; font-size:10px; text-transform:uppercase; letter-spacing:0.4px; margin-left:6px; }
</style>

@code {
    /// <summary>Id de la HC actualmente abierta. Cuando cambia, recargamos los items.</summary>
    [Parameter] public Guid? HistoriaClinicaId { get; set; }
    [Parameter] public EventCallback<int> OnCountChanged { get; set; }
    /// <summary>
    /// Se dispara cada vez que la lista de medicamentos cambia (agregar,
    /// actualizar posologia/observacion, eliminar). Sirve para que el padre
    /// (HistoriasClinicasModulo) recargue ValoresJson y refresque el
    /// FormViewer del tab Historial en vivo: sin esto, el usuario tenia que
    /// salir y volver a la HC para ver la observacion actualizada.
    /// </summary>
    [Parameter] public EventCallback OnItemsChanged { get; set; }

    private async Task NotifyItemsChanged()
    {
        if (OnItemsChanged.HasDelegate) { await OnItemsChanged.InvokeAsync(); }
    }

    private Guid? _ultimoIdCargado;
    private string _terminoBusqueda = "";
    private List<MedicamentoSugerenciaDto> _sugerencias = new();
    private List<OrdenMedicamentoItemDto> _items = new();
    private bool _buscando;
    private bool _agregando;
    private System.Threading.CancellationTokenSource? _debounceCts;

    /// <summary>Tope de sugerencias por consulta. Empieza en 50 y sube en +50
    /// cada vez que el usuario pulsa "Cargar mas resultados". Se reinicia al
    /// cambiar el termino de busqueda para no acumular tope infinito.</summary>
    private const int _pageStep = 50;
    private int _pageSize = _pageStep;

    private BorradorMed _borrador = new();

    protected override async Task OnParametersSetAsync()
    {
        if (HistoriaClinicaId != _ultimoIdCargado)
        {
            _ultimoIdCargado = HistoriaClinicaId;
            _borrador = new();
            _terminoBusqueda = "";
            _sugerencias.Clear();
            _pageSize = _pageStep;
            await CargarItemsAsync();
        }
    }

    private async Task CargarItemsAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { _items = new(); return; }
        _items = (await OrdSvc.ListarPorHistoriaAsync(hid)).ToList();
        await NotifyCount();
    }

    private async Task NotifyCount()
    {
        if (OnCountChanged.HasDelegate) { await OnCountChanged.InvokeAsync(_items.Count); }
    }

    /// <summary>Lanza busqueda al catalogo con debounce de ~200ms para no saturar.
    /// Cada nuevo tecleo reinicia _pageSize al step base — asi el usuario no arrastra
    /// un tope inflado de una busqueda anterior.</summary>
    private async Task OnTerminoChanged(ChangeEventArgs e)
    {
        _terminoBusqueda = e.Value?.ToString() ?? "";
        _pageSize = _pageStep;
        _debounceCts?.Cancel();
        _debounceCts = new();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(200, token);
            _buscando = true;
            var t = _terminoBusqueda;
            _sugerencias = (await OrdSvc.BuscarSugerenciasAsync(t, _pageSize, token)).ToList();
            _buscando = false;
            StateHasChanged();
        }
        catch (TaskCanceledException) { /* siguiente tecleo cancelo */ }
    }

    /// <summary>Sube el tope en +_pageStep y re-consulta. Aparece cuando
    /// _sugerencias.Count == _pageSize (la BD probablemente tiene mas).</summary>
    private async Task CargarMasSugerenciasAsync()
    {
        if (string.IsNullOrWhiteSpace(_terminoBusqueda) || _buscando) { return; }
        _pageSize += _pageStep;
        _buscando = true;
        try
        {
            _sugerencias = (await OrdSvc.BuscarSugerenciasAsync(_terminoBusqueda, _pageSize)).ToList();
        }
        finally { _buscando = false; }
    }

    private void SeleccionarSugerencia(MedicamentoSugerenciaDto s)
    {
        _borrador.MedicamentoId = s.Id;
        // El "codigo" mostrado al doctor es el RegistroSanitario INVIMA (lo
        // que ya se ve como tag en la lista de sugerencias). Cae al IUM si no
        // hay registro sanitario.
        _borrador.Codigo = !string.IsNullOrWhiteSpace(s.RegistroSanitario) ? s.RegistroSanitario : s.Ium;
        _borrador.NombreMedicamento = ArmarNombreCompleto(s);
        _sugerencias.Clear();
        _terminoBusqueda = "";
    }

    private static string ArmarNombreCompleto(MedicamentoSugerenciaDto s)
    {
        var partes = new List<string> { s.Producto };
        if (!string.IsNullOrWhiteSpace(s.Concentracion)) { partes.Add(s.Concentracion!); }
        if (!string.IsNullOrWhiteSpace(s.FormaFarmaceutica)) { partes.Add(s.FormaFarmaceutica!); }
        return string.Join(" - ", partes);
    }

    private string PosologiaPreview()
    {
        var c = _borrador.Cantidad?.Trim();
        var f = _borrador.Frecuencia?.Trim();
        var d = _borrador.Dias?.Trim();
        if (string.IsNullOrWhiteSpace(c) && string.IsNullOrWhiteSpace(f) && string.IsNullOrWhiteSpace(d))
        {
            return "Define cantidad, frecuencia y dias para armar la posologia.";
        }
        // Reconstruye la frase clinica:
        //   "1 cada 6 horas durante 30 dias - Total: 120."
        // - La frecuencia es el INTERVALO EN HORAS entre dosis (lo que el medico
        //   pone directo). Asi:
        //     N=24 -> "cada 24 horas" (1 dosis/dia) -> total = c * 1 * d
        //     N=12 -> "cada 12 horas" (2 dosis/dia) -> total = c * 2 * d
        //     N=8  -> "cada 8 horas"  (3 dosis/dia) -> total = c * 3 * d
        //     N=6  -> "cada 6 horas"  (4 dosis/dia) -> total = c * 4 * d
        //     N=1  -> "cada hora"    (24 dosis/dia) -> total = c * 24 * d
        // - Si frecuencia trae texto custom (ej. "PRN", "cada 8h") se respeta.
        var sb = new System.Text.StringBuilder();
        if (!string.IsNullOrWhiteSpace(c)) { sb.Append(c); }
        if (!string.IsNullOrWhiteSpace(f))
        {
            if (sb.Length > 0) { sb.Append(' '); }
            sb.Append(FrecuenciaTexto(f!));
        }
        if (!string.IsNullOrWhiteSpace(d))
        {
            if (sb.Length > 0) { sb.Append(' '); }
            sb.Append(int.TryParse(d, out _) ? $"durante {d} dias" : d!);
        }
        var preview = sb.ToString();
        var total = CalcularTotal(c, f, d);
        if (total is not null) { preview += $" - Total: {total}"; }
        return preview + ".";
    }

    private static string FrecuenciaTexto(string f)
    {
        if (!int.TryParse(f, out var fn) || fn <= 0) { return f; }
        if (fn == 1) { return "cada hora"; }
        return $"cada {fn} horas";
    }

    /// <summary>Cantidad total = cantidad por toma * (24/intervalo_horas) * dias.
    /// La "frecuencia" que entra es el INTERVALO en horas (cada N horas), no
    /// las veces por dia. Devuelve null si alguno no se puede parsear como
    /// numero positivo. Misma logica que
    /// HistoriaMedicaPrefillHelper.CalcularTotalUnidades pero replicada aqui
    /// para evitar acoplar el componente al Application.</summary>
    private static string? CalcularTotal(string? cantidad, string? frecuencia, string? dias)
    {
        if (decimal.TryParse(cantidad?.Trim(), System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out var c)
            && decimal.TryParse(frecuencia?.Trim(), System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out var f)
            && int.TryParse(dias?.Trim(), out var d)
            && c > 0 && f > 0 && d > 0)
        {
            // dosis por dia = 24 / intervalo
            var total = c * (24m / f) * d;
            return total == Math.Truncate(total)
                ? ((int)total).ToString(System.Globalization.CultureInfo.InvariantCulture)
                : total.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
        }
        return null;
    }

    private async Task AgregarAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        if (string.IsNullOrWhiteSpace(_borrador.NombreMedicamento)) { return; }
        _agregando = true;
        try
        {
            var preview = PosologiaPreview();
            var creado = await OrdSvc.AgregarAsync(hid, new AgregarMedicamentoRequest(
                _borrador.MedicamentoId,
                _borrador.Codigo,
                _borrador.NombreMedicamento!,
                _borrador.Cantidad,
                _borrador.Frecuencia,
                _borrador.Dias,
                preview,
                _borrador.Observacion,
                _borrador.MipresUrl), Guid.Empty);
            _items.Add(creado);
            await NotifyCount();
            await NotifyItemsChanged();
            LimpiarBorrador();
        }
        finally { _agregando = false; }
    }

    private void LimpiarBorrador()
    {
        _borrador = new();
        _terminoBusqueda = "";
        _sugerencias.Clear();
    }

    private async Task GuardarPosologia(OrdenMedicamentoItemDto it, string? nuevaPosologia)
    {
        var req = new ActualizarMedicamentoRequest(it.Cantidad, it.Frecuencia, it.Dias, nuevaPosologia, it.Observacion);
        await OrdSvc.ActualizarAsync(it.Id, req, Guid.Empty);
        var idx = _items.FindIndex(x => x.Id == it.Id);
        if (idx >= 0) { _items[idx] = it with { Posologia = nuevaPosologia }; }
        await NotifyItemsChanged();
    }

    private async Task GuardarObservacion(OrdenMedicamentoItemDto it, string? nuevaObs)
    {
        var req = new ActualizarMedicamentoRequest(it.Cantidad, it.Frecuencia, it.Dias, it.Posologia, nuevaObs);
        await OrdSvc.ActualizarAsync(it.Id, req, Guid.Empty);
        var idx = _items.FindIndex(x => x.Id == it.Id);
        if (idx >= 0) { _items[idx] = it with { Observacion = nuevaObs }; }
        await NotifyItemsChanged();
    }

    private async Task EliminarAsync(OrdenMedicamentoItemDto it)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Quitar \"{it.NombreMedicamento}\" de la orden?");
        if (!ok) { return; }
        await OrdSvc.EliminarAsync(it.Id, Guid.Empty);
        _items.RemoveAll(x => x.Id == it.Id);
        await NotifyCount();
        await NotifyItemsChanged();
    }

    /// <summary>Abre la vista imprimible /orden-doc en una nueva pestana del navegador.</summary>
    private async Task ImprimirAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        await JS.InvokeVoidAsync("open", $"/orden-doc/{hid}/ORDEN_MEDICAMENTOS", "_blank");
    }

    private sealed class BorradorMed
    {
        public Guid? MedicamentoId { get; set; }
        public string? Codigo { get; set; }
        public string? NombreMedicamento { get; set; }
        public string? Cantidad { get; set; }
        public string? Frecuencia { get; set; }
        public string? Dias { get; set; }
        public string? Observacion { get; set; }
        public string? MipresUrl { get; set; }
    }
}
