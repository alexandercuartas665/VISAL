@inherits LayoutComponentBase

<div class="visal-shell">
    <!-- Toggles solo-CSS. Funcionan en cualquier render mode. -->
    <!--   visal-nav-toggle:    abre/cierra el menu en movil (off-canvas). -->
    <!--   visal-nav-collapse:  colapsa el menu en escritorio (deja la pagina full width). -->
    <input type="checkbox" id="visal-nav-toggle" class="visal-nav-toggle" autocomplete="off" />
    <input type="checkbox" id="visal-nav-collapse" class="visal-nav-collapse" autocomplete="off" />

    <aside class="visal-sidebar">
        <!-- Boton para colapsar desde dentro del sidebar (anclado a la esquina sup. der.). -->
        <label for="visal-nav-collapse" class="visal-nav-collapse-btn" aria-label="Ocultar menu" title="Ocultar menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </label>
        <NavMenu />
    </aside>

    <!-- Capa oscura: al tocarla se cierra el menu (es un label del checkbox). -->
    <label for="visal-nav-toggle" class="visal-nav-overlay" aria-hidden="true"></label>

    <div class="visal-main">
        <div class="visal-topbar">
            <!-- Hamburguesa: en movil abre el menu off-canvas; en escritorio reaparece el menu colapsado. -->
            <label for="visal-nav-toggle" class="visal-hamburger visal-hamburger-mobile" aria-label="Abrir menu">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M3 6h18"/><path d="M3 12h18"/><path d="M3 18h18"/></svg>
            </label>
            <label for="visal-nav-collapse" class="visal-hamburger visal-hamburger-desktop" aria-label="Mostrar menu" title="Mostrar menu">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M3 6h18"/><path d="M3 12h18"/><path d="M3 18h18"/></svg>
            </label>
            <span class="visal-topbar-brand">Visal</span>

            <AuthorizeView>
                <Authorized>
                    <span class="visal-user-chip">@(context.User.FindFirst("platform_role") is not null ? "Operador" : "Agencia") · <strong>@context.User.Identity?.Name</strong></span>
                    <form method="post" action="/auth/logout" class="m-0">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Salir</button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>

        <AiQuotaBanner />

        <div class="visal-content">
            @Body
        </div>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ha ocurrido un error.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>

<script>
    // Cierra el menu movil al tocar un enlace de navegacion (complementa el cierre por overlay
    // y el reseteo en navegaciones de pagina completa).
    document.addEventListener('click', function (e) {
        if (e.target.closest && e.target.closest('.visal-nav-link')) {
            var t = document.getElementById('visal-nav-toggle');
            if (t) t.checked = false;
        }
    });
</script>
