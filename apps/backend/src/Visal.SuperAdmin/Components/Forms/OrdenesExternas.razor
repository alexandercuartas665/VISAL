@using Visal.Application.Tenancy
@using Visal.Domain.Enums
@inject IOrdenExternaService Svc
@inject ICatalogoServicioService CatSvc
@inject IJSRuntime JS

@*
   Tab generico para ordenes EXTERNAS de la HC. Un componente reusado por
   los 4 tipos (RX Imagenologia, Laboratorio, Servicio Externo, Insumo). El
   codigo trae autocomplete desde CatalogoServicioReferencia del mismo tipo.
*@

<div class="oi-bar">
    <div class="oi-bar-left">
        <label>@Titulo:</label>
        <span class="oi-bar-count">@_items.Count item(s)</span>
    </div>
</div>

@if (HistoriaClinicaId is null)
{
    <div class="oi-card oi-empty-hc">
        Selecciona o inicia una historia para registrar @Titulo.
    </div>
}
else
{
    <div class="oi-card">
        <div class="oi-row">
            <div class="oi-f oi-c-3">
                <label>Codigo</label>
                <input class="form-control form-control-sm"
                       placeholder="Opcional"
                       @bind="_borrador.Codigo" @bind:event="oninput" />
            </div>
            <div class="oi-f oi-c-9" style="position:relative;">
                <label>Descripcion (busca en el catalogo)</label>
                <input class="form-control form-control-sm"
                       placeholder="Escribe 2+ letras para buscar por codigo o nombre..."
                       value="@_borrador.Descripcion"
                       @oninput="OnDescripcionChanged" />
                @if (_sugerencias.Count > 0)
                {
                    <div class="oi-sug">
                        @foreach (var s in _sugerencias)
                        {
                            var sCopy = s;
                            <div class="oi-sug-item" @onmousedown="() => AplicarSugerencia(sCopy)">
                                <span class="oi-sug-cod">@sCopy.Codigo</span>
                                <span class="oi-sug-nom">@sCopy.Nombre</span>
                            </div>
                        }
                        @* "Cargar mas" aparece cuando llenamos el tope actual — indica
                           que hay probablemente mas resultados y sube _pageSize +50. *@
                        @if (_sugerencias.Count >= _pageSize)
                        {
                            <button type="button" class="oi-sug-more"
                                    @onclick="CargarMasSugerenciasAsync"
                                    disabled="@_buscando">
                                @(_buscando ? "Cargando..." : $"+ Cargar mas resultados ({_pageSize} mostrados)")
                            </button>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_borrador.Descripcion) && _borrador.Descripcion.Trim().Length >= 2 && !_buscando)
                {
                    <div class="oi-sug oi-sug-empty">Sin coincidencias en el catalogo — puedes agregar el texto libre.</div>
                }
            </div>
        </div>
        <div class="oi-row">
            <div class="oi-f oi-c-3">
                <label>Cantidad</label>
                <input class="form-control form-control-sm"
                       placeholder="Ej: 1, 3 sesiones"
                       @bind="_borrador.Cantidad" @bind:event="oninput" />
            </div>
            <div class="oi-f oi-c-9">
                <label>Observaciones</label>
                <input class="form-control form-control-sm"
                       placeholder="Opcional"
                       @bind="_borrador.Observaciones" @bind:event="oninput" />
            </div>
        </div>
        <div class="oi-row oi-row-action">
            <button class="btn btn-primary btn-sm"
                    @onclick="AgregarAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_borrador.Descripcion) || _agregando)">
                @(_agregando ? "Guardando..." : "+ Agregar")
            </button>
        </div>

        <div class="oi-list">
            @if (_items.Count == 0)
            {
                <div class="oi-empty-row">Sin items agregados.</div>
            }
            else
            {
                <table class="table table-sm oi-table">
                    <thead>
                        <tr>
                            <th style="width:48px;">#</th>
                            <th style="width:110px;">Codigo</th>
                            <th>Descripcion</th>
                            <th style="width:120px;">Cantidad</th>
                            <th>Observaciones</th>
                            <th style="width:60px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var it in _items)
                        {
                            <tr>
                                <td>@it.Orden</td>
                                <td>@(string.IsNullOrWhiteSpace(it.Codigo) ? "—" : it.Codigo)</td>
                                <td>@it.Descripcion</td>
                                <td>@(string.IsNullOrWhiteSpace(it.Cantidad) ? "—" : it.Cantidad)</td>
                                <td>@(string.IsNullOrWhiteSpace(it.Observaciones) ? "—" : it.Observaciones)</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="() => EliminarAsync(it)"
                                            title="Quitar">&#128465;</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

<style>
    .oi-bar { display:flex; justify-content:space-between; align-items:center; padding:8px 12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; margin-bottom:12px; gap:10px; flex-wrap:wrap; }
    .oi-bar-left { display:flex; align-items:center; gap:10px; font-size:13px; font-weight:700; color:#0f172a; }
    .oi-bar-count { background:#1565c0; color:#fff; padding:2px 10px; border-radius:999px; font-size:11px; font-weight:700; }
    .oi-card { border:1px solid #e2e8f0; border-radius:8px; padding:16px; background:#fff; }
    .oi-empty-hc { color:#64748b; text-align:center; padding:30px; font-style:italic; }
    .oi-row { display:grid; grid-template-columns:repeat(12, 1fr); gap:12px; margin-bottom:12px; align-items:end; }
    .oi-row-action { display:flex; justify-content:flex-end; }
    .oi-f label { font-size:11px; font-weight:700; color:#334155; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:4px; display:block; }
    .oi-c-3 { grid-column: span 3; }
    .oi-c-9 { grid-column: span 9; }
    .oi-list { margin-top:16px; }
    .oi-empty-row { padding:30px; text-align:center; font-style:italic; color:#64748b; border:1px dashed #cbd5e1; border-radius:8px; }
    .oi-table { font-size:12.5px; }
    .oi-sug { position:absolute; top:100%; left:0; right:0; background:#fff; border:1px solid #cbd5e1; border-radius:6px; max-height:320px; overflow-y:auto; z-index:30; box-shadow:0 6px 18px rgba(0,0,0,.12); margin-top:2px; }
    .oi-sug-item { padding:6px 10px; cursor:pointer; display:grid; grid-template-columns:100px 1fr; gap:8px; align-items:baseline; font-size:12px; border-bottom:1px solid #f1f5f9; }
    .oi-sug-item:hover { background:#eff6ff; }
    .oi-sug-item:last-child { border-bottom:none; }
    .oi-sug-cod { font-family:'JetBrains Mono','Consolas',monospace; color:#1565c0; font-weight:600; }
    .oi-sug-nom { color:#0f172a; }
    .oi-sug-empty { padding:10px 12px; font-size:12px; color:#64748b; font-style:italic; }
    .oi-sug-more { display:block; width:100%; text-align:center; padding:10px 12px; border:0; border-top:2px dashed #cbd5e1; background:#f8fafc; color:#2563eb; font-weight:600; cursor:pointer; font-size:12px; position:sticky; bottom:0; }
    .oi-sug-more:hover:not(:disabled) { background:#eff6ff; }
    .oi-sug-more:disabled { color:#94a3b8; cursor:wait; }
</style>

@code {
    [Parameter] public Guid? HistoriaClinicaId { get; set; }
    [Parameter] public TipoCatalogoServicio Tipo { get; set; }
    [Parameter] public string Titulo { get; set; } = "Items";
    [Parameter] public EventCallback<int> OnCountChanged { get; set; }
    /// <summary>Refresca el FormViewer del tab Historial tras Agregar/Eliminar.
    /// Necesario para que las tablas RxImagenologia / Laboratorios / Insumos
    /// Externos de HC-FO-08 se llenen en vivo.</summary>
    [Parameter] public EventCallback OnItemsChanged { get; set; }

    private async Task NotifyItemsChanged()
    {
        if (OnItemsChanged.HasDelegate) { await OnItemsChanged.InvokeAsync(); }
    }

    private Guid? _ultimoIdCargado;
    private TipoCatalogoServicio? _ultimoTipo;
    private List<OrdenExternaItemDto> _items = new();
    private List<CatalogoServicioDto> _sugerencias = new();
    private bool _agregando;
    private bool _buscando;
    private Borrador _borrador = new();

    private System.Threading.CancellationTokenSource? _debounceCts;

    /// <summary>Tope de sugerencias por consulta. Empieza en 50 y sube en +50
    /// al pulsar "Cargar mas resultados". Se reinicia al cambiar el termino.</summary>
    private const int _pageStep = 50;
    private int _pageSize = _pageStep;

    protected override async Task OnParametersSetAsync()
    {
        if (HistoriaClinicaId != _ultimoIdCargado || _ultimoTipo != Tipo)
        {
            _ultimoIdCargado = HistoriaClinicaId;
            _ultimoTipo = Tipo;
            _borrador = new();
            _sugerencias.Clear();
            _pageSize = _pageStep;
            await CargarItemsAsync();
        }
    }

    private async Task CargarItemsAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { _items = new(); return; }
        _items = (await Svc.ListarPorHistoriaAsync(hid, Tipo)).ToList();
        await NotifyCount();
    }

    private async Task NotifyCount()
    {
        if (OnCountChanged.HasDelegate) { await OnCountChanged.InvokeAsync(_items.Count); }
    }

    /// <summary>Busca por codigo O nombre en CatalogoServicioReferencia del Tipo
    /// activo mientras el doctor teclea en Descripcion. Debounce 200ms para no
    /// saturar. Tope inicial _pageStep (50), sube al pulsar "Cargar mas". El
    /// tope se resetea al cambiar el termino.</summary>
    private async Task OnDescripcionChanged(ChangeEventArgs e)
    {
        _borrador.Descripcion = e.Value?.ToString();
        _pageSize = _pageStep;
        _debounceCts?.Cancel();
        _debounceCts = new();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(200, token);
            var q = _borrador.Descripcion;
            if (string.IsNullOrWhiteSpace(q) || q.Trim().Length < 2)
            {
                _sugerencias.Clear();
                StateHasChanged();
                return;
            }
            _buscando = true;
            var (rows, _) = await CatSvc.SearchAsync(Tipo, q.Trim(), 0, _pageSize, token);
            _sugerencias = rows.ToList();
            _buscando = false;
            StateHasChanged();
        }
        catch (TaskCanceledException) { /* proximo tecleo cancelo */ }
    }

    /// <summary>Sube el tope en +_pageStep y re-consulta. Aparece cuando
    /// _sugerencias.Count == _pageSize (probable que la BD tenga mas).</summary>
    private async Task CargarMasSugerenciasAsync()
    {
        var q = _borrador.Descripcion;
        if (string.IsNullOrWhiteSpace(q) || _buscando) { return; }
        _pageSize += _pageStep;
        _buscando = true;
        try
        {
            var (rows, _) = await CatSvc.SearchAsync(Tipo, q.Trim(), 0, _pageSize);
            _sugerencias = rows.ToList();
        }
        finally { _buscando = false; }
    }

    private void AplicarSugerencia(CatalogoServicioDto s)
    {
        _borrador.Codigo = s.Codigo;
        _borrador.Descripcion = s.Nombre;
        _sugerencias.Clear();
    }

    private async Task AgregarAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        if (string.IsNullOrWhiteSpace(_borrador.Descripcion)) { return; }
        _agregando = true;
        try
        {
            var creado = await Svc.AgregarAsync(hid, Tipo, new AgregarOrdenExternaRequest(
                _borrador.Codigo,
                _borrador.Descripcion!,
                _borrador.Cantidad,
                _borrador.Observaciones), Guid.Empty);
            _items.Add(creado);
            await NotifyCount();
            await NotifyItemsChanged();
            _borrador = new();
            _sugerencias.Clear();
            _pageSize = _pageStep;
        }
        finally { _agregando = false; }
    }

    private async Task EliminarAsync(OrdenExternaItemDto it)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Quitar \"{it.Descripcion}\"?");
        if (!ok) { return; }
        await Svc.EliminarAsync(it.Id, Guid.Empty);
        _items.RemoveAll(x => x.Id == it.Id);
        await NotifyCount();
        await NotifyItemsChanged();
    }

    private sealed class Borrador
    {
        public string? Codigo { get; set; }
        public string? Descripcion { get; set; }
        public string? Cantidad { get; set; }
        public string? Observaciones { get; set; }
    }
}
