            if (u is null) { _modalError = "No se pudo crear (sin tenant activo)."; return; }
            _ok = $"Usuario '{u.Email}' creado para {_nombreCompleto} con rol '{u.RolNombre}'.";
            _showCrearUsuModal = false;
            _usuarioVinculado = u; // refrescar UI
        }
