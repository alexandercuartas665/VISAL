@using Visal.Application.Tenancy
@using Visal.Application.Common
@using Visal.Domain.Enums
@inject IInsumoService InsumoSvc
@inject ICatalogoServicioService CatSvc
@inject ISucursalService SucSvc
@inject ITenantContext Tenant
@inject IJSRuntime JS

@*
   Pestana "Insumos" de la HC. Autocompleta la descripcion contra el
   Catalogo de Insumos (CatalogoServicioReferencia con Tipo=Insumo). El
   profesional escribe 2+ letras en Descripcion y elige de la lista — al
   seleccionar se copia codigo y descripcion. Puede escribir libre si
   el insumo no esta en catalogo. Persiste atado a HistoriaClinicaId y
   refresca el prefill historiaMedica.insumos.lista_numerada en cada
   Add/Delete. Guarda tambien la URL de MIPRES (opcional) para
   trazabilidad de radicaciones ante la EPS.
*@

<div class="oi-bar">
    <div class="oi-bar-left">
        <label>Orden de Insumos Numero:</label>
        <span class="oi-bar-count">@_items.Count item(s)</span>
    </div>
    <div class="oi-bar-right">
        <button class="btn btn-outline-primary btn-sm" title="Imprimir insumos"
                disabled="@(HistoriaClinicaId is null || _items.Count == 0)"
                @onclick="ImprimirAsync">&#128424; Imprimir</button>
    </div>
</div>

@if (HistoriaClinicaId is null)
{
    <div class="oi-card oi-empty-hc">
        Selecciona o inicia una historia para registrar insumos.
    </div>
}
else
{
    <div class="oi-card">
        <div class="oi-row">
            <div class="oi-f oi-c-3">
                <label>Codigo</label>
                <input class="form-control form-control-sm"
                       placeholder="Opcional"
                       @bind="_borrador.Codigo" @bind:event="oninput" />
            </div>
            <div class="oi-f oi-c-9 oi-autocomplete">
                <label>Descripcion del Insumo</label>
                <input class="form-control form-control-sm"
                       placeholder="Escribe para buscar en el catalogo (min 2 caracteres)..."
                       @bind="_borrador.Descripcion"
                       @bind:event="oninput"
                       @onkeyup="BuscarSugerenciasAsync"
                       @onblur="() => _mostrarSugerencias = false" />
                @if (_mostrarSugerencias && _sugerencias.Count > 0)
                {
                    <div class="oi-sug-list">
                        @foreach (var s in _sugerencias)
                        {
                            @* onmousedown en vez de onclick para que dispare antes que el blur del input *@
                            <div class="oi-sug-item" @onmousedown="() => SeleccionarSugerencia(s)">
                                <span class="oi-sug-cod">@s.Codigo</span>
                                <span class="oi-sug-nom">@s.Nombre</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        <div class="oi-row">
            @* Posologia: reemplaza el input de Cantidad libre. Al Agregar se
               calcula el total (cantidad_por_toma * (24/frecuencia) * dias) y
               ese numero se guarda como Cantidad en la tabla del detalle. *@
            <div class="oi-f oi-c-4">
                <div class="oi-posol">
                    <div class="oi-posol-grid">
                        <div>
                            <label class="oi-mini">Cantidad</label>
                            <input class="form-control form-control-sm text-center"
                                   @bind="_borrador.PosolCantidad" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="oi-mini" title="Intervalo entre dosis en horas (8 = cada 8 horas, 24 = una vez al dia)">Cada (h)</label>
                            <input class="form-control form-control-sm text-center"
                                   @bind="_borrador.Frecuencia" @bind:event="oninput"
                                   placeholder="8" />
                        </div>
                        <div>
                            <label class="oi-mini">Dias</label>
                            <input class="form-control form-control-sm text-center"
                                   @bind="_borrador.Dias" @bind:event="oninput" />
                        </div>
                    </div>
                    <div class="oi-posol-preview">@PosologiaPreview()</div>
                </div>
            </div>
            <div class="oi-f oi-c-8">
                <label>Observaciones</label>
                <input class="form-control form-control-sm"
                       placeholder="Opcional"
                       @bind="_borrador.Observaciones" @bind:event="oninput" />
            </div>
        </div>
        <div class="oi-row">
            <div class="oi-f oi-c-12">
                <label>
                    URL MIPRES @if (_sedeExigeMipres) { <span class="oi-mipres-req" title="La sede exige registrar el MIPRES">obligatorio</span> } else { <small class="text-muted">(opcional, pega el link del formato radicado)</small> }
                    <a class="btn btn-outline-primary btn-sm oi-mipres-link" href="https://mipres.sispro.gov.co/" target="_blank" rel="noopener noreferrer"
                       title="Abrir MIPRES en una nueva pestana">
                        &#128279; Abrir MIPRES
                    </a>
                </label>
                <input class="form-control form-control-sm oi-mipres-input"
                       type="url"
                       placeholder="https://mipres.sispro.gov.co/..."
                       @bind="_borrador.MipresUrl" @bind:event="oninput" />
            </div>
        </div>
        <div class="oi-row oi-row-action">
            <button class="btn btn-primary btn-sm"
                    @onclick="AgregarAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_borrador.Descripcion) || _agregando)">
                @(_agregando ? "Guardando..." : "+ Agregar insumo")
            </button>
        </div>

        <div class="oi-list">
            @if (_items.Count == 0)
            {
                <div class="oi-empty-row">Sin insumos agregados.</div>
            }
            else
            {
                <table class="table table-sm oi-table">
                    <thead>
                        <tr>
                            <th style="width:48px;">#</th>
                            <th style="width:110px;">Codigo</th>
                            <th>Descripcion</th>
                            <th style="width:120px;">Cantidad</th>
                            <th>Observaciones</th>
                            <th style="width:100px;">MIPRES</th>
                            <th style="width:60px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var it in _items)
                        {
                            <tr>
                                <td>@it.Orden</td>
                                <td>@(string.IsNullOrWhiteSpace(it.Codigo) ? "—" : it.Codigo)</td>
                                <td>@it.Descripcion</td>
                                <td>@(string.IsNullOrWhiteSpace(it.Cantidad) ? "—" : it.Cantidad)</td>
                                <td>@(string.IsNullOrWhiteSpace(it.Observaciones) ? "—" : it.Observaciones)</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(it.MipresUrl))
                                    {
                                        <a href="@it.MipresUrl" target="_blank" rel="noopener"
                                           title="@it.MipresUrl">&#128279; Abrir</a>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="() => EliminarAsync(it)"
                                            title="Quitar">&#128465;</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

<style>
    .oi-bar { display:flex; justify-content:space-between; align-items:center; padding:8px 12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; margin-bottom:12px; gap:10px; flex-wrap:wrap; }
    .oi-bar-left { display:flex; align-items:center; gap:10px; font-size:13px; font-weight:700; color:#0f172a; }
    .oi-bar-count { background:#1565c0; color:#fff; padding:2px 10px; border-radius:999px; font-size:11px; font-weight:700; }
    .oi-card { border:1px solid #e2e8f0; border-radius:8px; padding:16px; background:#fff; }
    .oi-empty-hc { color:#64748b; text-align:center; padding:30px; font-style:italic; }
    .oi-row { display:grid; grid-template-columns:repeat(12, 1fr); gap:12px; margin-bottom:12px; align-items:end; }
    .oi-row-action { display:flex; justify-content:flex-end; }
    .oi-f label { font-size:11px; font-weight:700; color:#334155; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:4px; display:block; }
    .oi-c-3 { grid-column: span 3; }
    .oi-c-4 { grid-column: span 4; }
    .oi-c-8 { grid-column: span 8; }
    .oi-c-9 { grid-column: span 9; }
    .oi-c-12 { grid-column: span 12; }
    /* Bloque de posologia (identico al de OrdenMedicamentos, prefijo oi- en vez de od-) */
    .oi-posol { background:#f1f5f9; border:1px solid #e2e8f0; border-radius:8px; padding:8px; }
    .oi-posol-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:6px; }
    .oi-mini { font-size:10px !important; text-align:center; }
    .oi-posol-preview { font-size:11px; color:#64748b; font-style:italic; text-align:center; margin-top:6px; min-height:14px; }
    .oi-list { margin-top:16px; }
    .oi-empty-row { padding:30px; text-align:center; font-style:italic; color:#64748b; border:1px dashed #cbd5e1; border-radius:8px; }
    .oi-table { font-size:12.5px; }
    /* Autocomplete: contenedor relativo para posicionar el dropdown. */
    .oi-autocomplete { position: relative; }
    .oi-sug-list { position: absolute; top: 100%; left: 0; right: 0; background:#fff; border:1px solid #cbd5e1; border-radius:6px; box-shadow:0 6px 18px rgba(0,0,0,0.12); max-height: 240px; overflow-y:auto; z-index: 30; margin-top: 2px; }
    .oi-sug-item { padding: 6px 10px; cursor: pointer; display: grid; grid-template-columns: 90px 1fr; gap: 8px; align-items: baseline; font-size: 12px; border-bottom: 1px solid #f1f5f9; }
    .oi-sug-item:last-child { border-bottom: none; }
    .oi-sug-item:hover { background: #eff6ff; }
    .oi-sug-cod { font-family: 'JetBrains Mono','Consolas',monospace; color:#1565c0; font-weight: 600; }
    .oi-sug-nom { color:#0f172a; }
    .oi-mipres-input { font-family: 'JetBrains Mono','Consolas',monospace; font-size: 11.5px; }
    .oi-mipres-link { margin-left:10px; padding:2px 10px; font-size:11px; font-weight:600; vertical-align:baseline; text-decoration:none; }
    .oi-mipres-req { color:#b91c1c; font-weight:700; font-size:10px; text-transform:uppercase; letter-spacing:0.4px; margin-left:6px; }
</style>

@code {
    [Parameter] public Guid? HistoriaClinicaId { get; set; }
    [Parameter] public EventCallback<int> OnCountChanged { get; set; }

    private Guid? _ultimoIdCargado;
    private List<InsumoItemDto> _items = new();
    private bool _agregando;

    private Borrador _borrador = new();

    /// <summary>La sede activa exige registrar MIPRES al entregar insumos.
    /// Regla del cliente (IBAGUE): sin URL MIPRES no se agrega. Sedes sin el
    /// flag dejan pasar.</summary>
    private bool _sedeExigeMipres;

    // Autocomplete contra el catalogo de Insumos.
    private List<CatalogoServicioDto> _sugerencias = new();
    private bool _mostrarSugerencias;
    // Serializa las queries al DbContext scoped — en Blazor Server dos
    // busquedas concurrentes rompen EF Core con "second operation started".
    private readonly SemaphoreSlim _busquedaLock = new(1, 1);
    // Contador monotono: cada tecla lo incrementa. Si al terminar la query
    // el contador cambio, descartamos el resultado (llego uno mas nuevo).
    private int _busquedaSeq;

    protected override async Task OnParametersSetAsync()
    {
        if (HistoriaClinicaId != _ultimoIdCargado)
        {
            _ultimoIdCargado = HistoriaClinicaId;
            _borrador = new();
            _sugerencias.Clear();
            _mostrarSugerencias = false;
            await CargarItemsAsync();
            _sedeExigeMipres = false;
            if (Tenant.SucursalId is Guid sid)
            {
                _sedeExigeMipres = await SucSvc.GetMipresObligatorioAsync(sid);
            }
        }
    }

    private async Task CargarItemsAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { _items = new(); return; }
        _items = (await InsumoSvc.ListarPorHistoriaAsync(hid)).ToList();
        await NotifyCount();
    }

    private async Task NotifyCount()
    {
        if (OnCountChanged.HasDelegate) { await OnCountChanged.InvokeAsync(_items.Count); }
    }

    /// <summary>
    /// Busca contra el catalogo de Insumos (CatalogoServicioReferencia con
    /// Tipo=Insumo) en cuanto el usuario escribe 2 o mas caracteres. Debounce
    /// de 220ms + semaforo + secuencia: si el usuario sigue escribiendo,
    /// las busquedas viejas se descartan antes de tocar el DbContext.
    /// </summary>
    private async Task BuscarSugerenciasAsync()
    {
        var q = _borrador.Descripcion;
        if (string.IsNullOrWhiteSpace(q) || q.Length < 2)
        {
            _sugerencias.Clear();
            _mostrarSugerencias = false;
            return;
        }
        var mySeq = ++_busquedaSeq;
        try
        {
            await Task.Delay(220);
            if (mySeq != _busquedaSeq) { return; }
            await _busquedaLock.WaitAsync();
            try
            {
                if (mySeq != _busquedaSeq) { return; }
                var (rows, _) = await CatSvc.SearchAsync(TipoCatalogoServicio.Insumo, q, 0, 15);
                if (mySeq != _busquedaSeq) { return; }
                _sugerencias = rows.Where(r => r.Activo).ToList();
                _mostrarSugerencias = _sugerencias.Count > 0;
                StateHasChanged();
            }
            finally { _busquedaLock.Release(); }
        }
        catch (Exception) { /* silenciar: proxima tecla lo reintenta */ }
    }

    private void SeleccionarSugerencia(CatalogoServicioDto sug)
    {
        _borrador.Codigo = sug.Codigo;
        _borrador.Descripcion = sug.Nombre;
        _sugerencias.Clear();
        _mostrarSugerencias = false;
    }

    private async Task AgregarAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        if (string.IsNullOrWhiteSpace(_borrador.Descripcion)) { return; }
        // Regla operativa: si la sede tiene MipresObligatorio=true, no permitir
        // agregar insumos sin URL MIPRES. Misma politica que Medicamentos.
        if (_sedeExigeMipres && string.IsNullOrWhiteSpace(_borrador.MipresUrl))
        {
            await JS.InvokeVoidAsync("alert",
                "La sede activa exige registrar la URL de MIPRES antes de agregar un insumo. " +
                "Pega el link del formato radicado en el campo MIPRES para continuar.");
            return;
        }
        _agregando = true;
        try
        {
            // Calcula el total (cantidad_por_toma * (24/intervalo_horas) * dias)
            // y lo persiste como el valor "Cantidad" del item — el que se ve en
            // la tabla del detalle. Si la posologia esta incompleta o no numerica,
            // guardamos el texto libre de cantidad como fallback.
            var totalPosologia = CalcularTotal(_borrador.PosolCantidad, _borrador.Frecuencia, _borrador.Dias);
            var cantidadPersistida = totalPosologia ?? _borrador.PosolCantidad?.Trim();
            var creado = await InsumoSvc.AgregarAsync(hid, new AgregarInsumoRequest(
                _borrador.Codigo,
                _borrador.Descripcion!,
                cantidadPersistida,
                _borrador.Observaciones,
                _borrador.MipresUrl), Guid.Empty);
            _items.Add(creado);
            await NotifyCount();
            _borrador = new();
            _sugerencias.Clear();
            _mostrarSugerencias = false;
        }
        finally { _agregando = false; }
    }

    /// <summary>Vista previa de la frase clinica: "1 cada 8 horas durante 5 dias
    /// - Total: 15". Si aun no hay datos completos muestra un hint.</summary>
    private string PosologiaPreview()
    {
        var c = _borrador.PosolCantidad?.Trim();
        var f = _borrador.Frecuencia?.Trim();
        var d = _borrador.Dias?.Trim();
        if (string.IsNullOrWhiteSpace(c) && string.IsNullOrWhiteSpace(f) && string.IsNullOrWhiteSpace(d))
        {
            return "Define cantidad, frecuencia y dias.";
        }
        var sb = new System.Text.StringBuilder();
        if (!string.IsNullOrWhiteSpace(c)) { sb.Append(c); }
        if (!string.IsNullOrWhiteSpace(f))
        {
            if (sb.Length > 0) { sb.Append(' '); }
            sb.Append(FrecuenciaTexto(f!));
        }
        if (!string.IsNullOrWhiteSpace(d))
        {
            if (sb.Length > 0) { sb.Append(' '); }
            sb.Append(int.TryParse(d, out _) ? $"durante {d} dias" : d!);
        }
        var preview = sb.ToString();
        var total = CalcularTotal(c, f, d);
        if (total is not null) { preview += $" - Total: {total}"; }
        return preview + ".";
    }

    private static string FrecuenciaTexto(string f)
    {
        if (!int.TryParse(f, out var fn) || fn <= 0) { return f; }
        if (fn == 1) { return "cada hora"; }
        return $"cada {fn} horas";
    }

    /// <summary>Cantidad total = cantidad_por_toma * (24/intervalo_horas) * dias.
    /// Devuelve null si alguno no se puede parsear — misma logica que
    /// OrdenMedicamentos para consistencia visual y de datos.</summary>
    private static string? CalcularTotal(string? cantidad, string? frecuencia, string? dias)
    {
        if (decimal.TryParse(cantidad?.Trim(), System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out var c)
            && decimal.TryParse(frecuencia?.Trim(), System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out var f)
            && int.TryParse(dias?.Trim(), out var d)
            && c > 0 && f > 0 && d > 0)
        {
            var total = c * (24m / f) * d;
            return total == Math.Truncate(total)
                ? ((int)total).ToString(System.Globalization.CultureInfo.InvariantCulture)
                : total.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
        }
        return null;
    }

    private async Task EliminarAsync(InsumoItemDto it)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Quitar el insumo \"{it.Descripcion}\"?");
        if (!ok) { return; }
        await InsumoSvc.EliminarAsync(it.Id, Guid.Empty);
        _items.RemoveAll(x => x.Id == it.Id);
        await NotifyCount();
    }

    private async Task ImprimirAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        await JS.InvokeVoidAsync("open", $"/orden-doc/{hid}/INSUMOS", "_blank");
    }

    private sealed class Borrador
    {
        public string? Codigo { get; set; }
        public string? Descripcion { get; set; }
        // Posologia: cantidad por toma + intervalo entre tomas en horas + dias.
        // Al Agregar se calcula el TOTAL y ese numero se persiste como
        // "Cantidad" del item (columna en la tabla del detalle).
        public string? PosolCantidad { get; set; }
        public string? Frecuencia { get; set; }
        public string? Dias { get; set; }
        public string? Observaciones { get; set; }
        public string? MipresUrl { get; set; }
    }
}
