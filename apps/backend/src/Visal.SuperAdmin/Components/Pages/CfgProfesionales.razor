    private async Task CrearUsuario()
    {
        if (_id is not Guid pid) { return; }
        if (!Guid.TryParse(_nuevoRolId, out var rolId))
        {
            _modalError = "Selecciona un rol antes de crear el usuario.";
            return;
        }
        _modalError = null; _busyCrearUsu = true;
        try
        {
