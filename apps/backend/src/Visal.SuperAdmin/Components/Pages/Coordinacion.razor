    .cd-kb-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px; cursor: pointer; transition: transform .1s, box-shadow .1s; }
    .cd-kb-card:hover { transform: translateY(-1px); box-shadow: 0 4px 8px rgba(15,23,42,.08); border-color: #93c5fd; }
    .cd-kb-card-tit { font-weight: 700; font-size: 12.5px; color: #0f172a; line-height: 1.2; }
