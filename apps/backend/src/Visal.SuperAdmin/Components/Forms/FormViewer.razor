@using Visal.SuperAdmin.Components.Forms

@* ============================================================
   FormViewer: renderiza un FormSchema como una vista
   EDITABLE (no editor). Cabecera institucional + secciones +
   campos. Los valores diligenciados viven en el dict Valores.
   ============================================================ *@

@if (Schema is null)
{
    <div class="fv-empty">Sin formato cargado.</div>
}
else
{
    <div class="fv-doc">

        @* ----- Cabecera ----- *@
        @if (Schema.Header is not null || !string.IsNullOrEmpty(Titulo))
        {
            var hd = Schema.Header ?? new FormHeader();
            <div class="fv-head">
                <div class="fv-head-logo">
                    @if (!string.IsNullOrWhiteSpace(hd.LogoUrl))
                    {
                        <img src="@hd.LogoUrl" alt="logo" />
                    }
                    else
                    {
                        <div class="fv-logo-fallback">@(!string.IsNullOrWhiteSpace(hd.Institucion) ? hd.Institucion : "IPS")</div>
                    }
                    <div class="fv-head-tag">@hd.Tagline</div>
                </div>
                <div class="fv-head-title">
                    <h3>@(string.IsNullOrWhiteSpace(hd.Titulo) ? Titulo : hd.Titulo)</h3>
                    <div class="fv-head-nit">@Subtitulo</div>
                </div>
                <div class="fv-head-meta">
                    @foreach (var cabF in hd.Campos)
                    {
                        var hdrKey = "hdr:" + cabF.Id;
                        <div class="fv-head-meta-row">
                            <label>@cabF.Label:</label>
                            <input class="form-control form-control-sm" value="@GetValue(hdrKey)"
                                   @onchange="e => SetValue(hdrKey, e.Value?.ToString())" />
                        </div>
                    }
                </div>
            </div>
        }

        @* ----- Cuerpo: secciones + campos ----- *@
        @foreach (var node in Schema.Children)
        {
            if (node.IsSection)
            {
                <div class="fv-section">
                    <div class="fv-section-h">@node.Label</div>
                    <div class="fv-grid">
                        @if (node.Children is not null)
                        {
                            @foreach (var f in node.Children)
                            {
                                @RenderField(f)
                            }
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="fv-grid fv-grid-root">
                    @RenderField(node)
                </div>
            }
        }
    </div>
}

@code {
    [Parameter] public FormSchema? Schema { get; set; }
    [Parameter] public Dictionary<string, string?> Valores { get; set; } = new();
    [Parameter] public string? Titulo { get; set; }
    [Parameter] public string? Subtitulo { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    /// <summary>
    /// Conjunto de Names de campos cuyo valor viene de una fuente derivada
    /// (sourceModule = "historiaMedica"). El FormViewer los renderiza como
    /// disabled y muestra un badge "auto" para que el usuario sepa que no debe
    /// editarlos a mano (su valor se recalcula desde la fuente).
    /// </summary>
    [Parameter] public HashSet<string>? ReadOnlyKeys { get; set; }
    [Parameter] public EventCallback<KeyValuePair<string, string?>> OnValueChanged { get; set; }

    /// <summary>True si el nodo concreto debe renderizarse readonly: porque el visor
    /// entero esta en modo lectura, o porque su Name esta en ReadOnlyKeys.</summary>
    private bool IsNodeReadOnly(FormNode n) =>
        ReadOnly || (!string.IsNullOrEmpty(n.Name) && ReadOnlyKeys is not null && ReadOnlyKeys.Contains(n.Name));

    private string? GetValue(string key) => Valores.TryGetValue(key, out var v) ? v : null;

    private async Task SetValue(string key, string? value)
    {
        Valores[key] = value;
        // Recalcular todos los campos calculated tras cualquier cambio.
        // Cada calculated puede depender de N campos; lo mas simple es revaluar todo.
        // Para fórmulas que dependen de OTROS calculated (ej: cases(total)), hacemos
        // dos pasadas para que el orden de declaracion no importe.
        RecalculateAll();
        RecalculateAll();
        if (OnValueChanged.HasDelegate) { await OnValueChanged.InvokeAsync(new(key, value)); }
    }

    protected override void OnParametersSet()
    {
        // Calcular valores iniciales al abrir/cambiar de schema.
        RecalculateAll();
        RecalculateAll();
    }

    private void RecalculateAll()
    {
        if (Schema is null) { return; }
        foreach (var n in WalkNodes(Schema.Children))
        {
            if (n.FieldType == "calculated" && !string.IsNullOrWhiteSpace(n.Formula))
            {
                var key = n.Name ?? $"fld:{n.Id}";
                Valores[key] = EvalFormula(n.Formula!, Valores);
            }
        }
    }

    private static IEnumerable<FormNode> WalkNodes(List<FormNode>? nodes)
    {
        if (nodes is null) { yield break; }
        foreach (var n in nodes)
        {
            yield return n;
            if (n.Children is not null)
            {
                foreach (var c in WalkNodes(n.Children)) { yield return c; }
            }
        }
    }

    // Evaluador minimo de formulas usado por campos calculated.
    // Sintaxis soportada:
    //   sum(a, b, c, ...)                   -> suma numerica de los campos por nombre
    //   cases(ref, "lo-hi=Etiqueta; lo-hi=Etiqueta; default=X")  -> mapeo por rango
    //   edad(fecha_nacimiento)              -> anios desde la fecha al hoy
    private static string EvalFormula(string formula, Dictionary<string, string?> values)
    {
        var f = formula.Trim();
        var ci = System.Globalization.CultureInfo.InvariantCulture;

        // sum(...)
        var mSum = System.Text.RegularExpressions.Regex.Match(
            f, @"^sum\s*\(([^)]*)\)\s*$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (mSum.Success)
        {
            double total = 0;
            // Para extraer el numero al principio de strings tipo "10 - Independiente..."
            var numFirst = new System.Text.RegularExpressions.Regex(@"-?\d+(?:[.,]\d+)?");
            foreach (var raw in mSum.Groups[1].Value.Split(','))
            {
                var name = raw.Trim();
                if (string.IsNullOrEmpty(name)) { continue; }
                if (!values.TryGetValue(name, out var v) || string.IsNullOrWhiteSpace(v)) { continue; }

                // Primero intentamos parse directo (campos number puros).
                if (double.TryParse(v, System.Globalization.NumberStyles.Any, ci, out var nDirect))
                {
                    total += nDirect;
                    continue;
                }
                // Fallback: extraer el primer numero del string (selects tipo "10 - texto...").
                var m = numFirst.Match(v);
                if (m.Success &&
                    double.TryParse(m.Value.Replace(',', '.'), System.Globalization.NumberStyles.Any, ci, out var nExtract))
                {
                    total += nExtract;
                }
            }
            return (total == Math.Floor(total) ? ((long)total).ToString(ci) : total.ToString(ci));
        }

        // sumprod(field1:peso1, field2:peso2, ...)  -> Sum(valorField * peso)
        // Util para escalas donde cada item tiene un ponderador distinto
        // (ej: Escala Visal de requerimiento de enfermeria).
        var mSp = System.Text.RegularExpressions.Regex.Match(
            f, @"^sumprod\s*\(([^)]*)\)\s*$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (mSp.Success)
        {
            double total = 0;
            var numFirst = new System.Text.RegularExpressions.Regex(@"-?\d+(?:[.,]\d+)?");
            foreach (var raw in mSp.Groups[1].Value.Split(','))
            {
                var pair = raw.Split(':');
                if (pair.Length != 2) { continue; }
                var name = pair[0].Trim();
                if (!double.TryParse(pair[1].Trim().Replace(',', '.'),
                        System.Globalization.NumberStyles.Any, ci, out var peso)) { continue; }
                if (!values.TryGetValue(name, out var v) || string.IsNullOrWhiteSpace(v)) { continue; }

                double n;
                if (!double.TryParse(v, System.Globalization.NumberStyles.Any, ci, out n))
                {
                    var m = numFirst.Match(v);
                    if (!m.Success ||
                        !double.TryParse(m.Value.Replace(',', '.'), System.Globalization.NumberStyles.Any, ci, out n))
                    { continue; }
                }
                total += (n * peso);
            }
            // Mostrar con un decimal cuando no es entero (Enfermeria da fraccionarios).
            return (total == Math.Floor(total)
                ? ((long)total).ToString(ci)
                : total.ToString("0.0", ci));
        }

        // cases(refName, "0-19=DEPENDENCIA TOTAL;20-35=DEPENDENCIA SEVERA;...")
        var mCases = System.Text.RegularExpressions.Regex.Match(
            f, @"^cases\s*\(\s*([A-Za-z0-9_]+)\s*,\s*""(.+)""\s*\)\s*$");
        if (mCases.Success)
        {
            var refName = mCases.Groups[1].Value;
            var rules = mCases.Groups[2].Value;
            if (!values.TryGetValue(refName, out var refVal) || string.IsNullOrWhiteSpace(refVal))
            {
                return "";
            }
            double num;
            if (!double.TryParse(refVal, System.Globalization.NumberStyles.Any, ci, out num))
            {
                // Mismo fallback que sum(): extraer el primer numero del string.
                var m = System.Text.RegularExpressions.Regex.Match(refVal, @"-?\d+(?:[.,]\d+)?");
                if (!m.Success ||
                    !double.TryParse(m.Value.Replace(',', '.'), System.Globalization.NumberStyles.Any, ci, out num))
                {
                    return "";
                }
            }
            foreach (var rule in rules.Split(';'))
            {
                var parts = rule.Split(new[] { '=' }, 2);
                if (parts.Length != 2) { continue; }
                var range = parts[0].Trim();
                var label = parts[1].Trim();
                if (string.Equals(range, "default", StringComparison.OrdinalIgnoreCase)) { return label; }
                var mr = System.Text.RegularExpressions.Regex.Match(
                    range, @"^(-?\d+(?:\.\d+)?)\s*-\s*(-?\d+(?:\.\d+)?)$");
                if (mr.Success)
                {
                    var lo = double.Parse(mr.Groups[1].Value, ci);
                    var hi = double.Parse(mr.Groups[2].Value, ci);
                    if (num >= lo && num <= hi) { return label; }
                }
            }
            return "";
        }

        // edad(fecha_nacimiento) - util en HC.
        var mEdad = System.Text.RegularExpressions.Regex.Match(
            f, @"^edad\s*\(\s*([A-Za-z0-9_]+)\s*\)\s*$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (mEdad.Success)
        {
            if (values.TryGetValue(mEdad.Groups[1].Value, out var dv) && !string.IsNullOrWhiteSpace(dv) &&
                DateTime.TryParse(dv, ci, System.Globalization.DateTimeStyles.None, out var dob))
            {
                var today = DateTime.Today;
                var age = today.Year - dob.Year;
                if (dob.Date > today.AddYears(-age)) { age--; }
                return age.ToString(ci);
            }
            return "";
        }

        return ""; // formula no reconocida -> dejamos vacio
    }

    private RenderFragment RenderField(FormNode node) => __builder =>
    {
        var span = Math.Clamp(node.WidthColumns <= 0 ? 12 : node.WidthColumns, 1, 12);
        <div class="@($"fv-col fv-col-{span}")">
            @if (node.IsText)
            {
                if (node.TextStyle == "heading")
                {
                    <h4 class="fv-h">@node.Content</h4>
                }
                else if (node.TextStyle == "subheading")
                {
                    <h5 class="fv-sh">@node.Content</h5>
                }
                else
                {
                    <p class="fv-p">@node.Content</p>
                }
            }
            else if (node.IsTable)
            {
                <label class="fv-lbl">@node.Label @(node.Required ? "*" : "")</label>
                <div class="fv-tbl-wrap">
                    <table class="table table-sm fv-tbl">
                        <thead>
                            <tr>
                                @if (node.Columns is not null)
                                {
                                    @foreach (var c in node.Columns)
                                    {
                                        <th>@c.Label</th>
                                    }
                                    @if (!node.LockRows)
                                    {
                                        <th style="width:32px"></th>
                                    }
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var key = $"tbl:{node.Id}";
                                var seedCount = node.SeedRows?.Count ?? 0;
                                // GetRowCount cuenta solo las filas EXTRAS (las que el usuario agrega).
                                // Para tablas LockRows=true el contador se ignora.
                                var extraRows = node.LockRows ? 0 : GetRowCount(key);
                                var totalRows = seedCount + extraRows;
                            }
                            @for (int i = 0; i < totalRows; i++)
                            {
                                var idx = i;
                                var isSeed = i < seedCount;
                                var seedRow = isSeed ? node.SeedRows![i] : null;
                                <tr class="@(isSeed ? "fv-tbl-seed-row" : "")">
                                    @if (node.Columns is not null)
                                    {
                                        var colIdx = 0;
                                        @foreach (var c in node.Columns)
                                        {
                                            // Si esta fila es semilla y la celda tiene valor en seedRow,
                                            // mostramos texto fijo. Si esta vacia (null/empty), es editable.
                                            var seedVal = (seedRow is not null && colIdx < seedRow.Count) ? seedRow[colIdx] : null;
                                            var cellKey = $"{key}:{idx}:{c.Id}";
                                            <td>
                                                @if (!string.IsNullOrEmpty(seedVal))
                                                {
                                                    <span class="fv-tbl-seed-cell">@seedVal</span>
                                                }
                                                else
                                                {
                                                    @RenderTableCell(c, cellKey)
                                                }
                                            </td>
                                            colIdx++;
                                        }
                                        @if (!node.LockRows)
                                        {
                                            <td>
                                                @if (!isSeed)
                                                {
                                                    // El idx que ve RemoveRow es el indice en el espacio EXTRAS.
                                                    var extraIdx = idx - seedCount;
                                                    <button class="btn btn-link btn-sm fv-tbl-rm" @onclick="() => RemoveRow(key, extraIdx)" disabled="@ReadOnly">&times;</button>
                                                }
                                            </td>
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (!node.LockRows)
                    {
                        <button class="btn btn-outline-secondary btn-sm fv-tbl-add" @onclick="() => AddRow(key)" disabled="@ReadOnly">+ Agregar fila</button>
                    }
                </div>
            }
            else
            {
                var auto = !string.IsNullOrEmpty(node.Name) && ReadOnlyKeys is not null && ReadOnlyKeys.Contains(node.Name);
                <label class="fv-lbl">
                    @node.Label @(node.Required ? "*" : "")
                    @if (auto) { <span class="fv-auto-badge" title="Este campo se llena automaticamente desde la HC. No se edita manualmente.">auto</span> }
                </label>
                @RenderInput(node)
            }
        </div>
    };

    /// <summary>Detecta si un Name corresponde a un campo de firma. Usado para
    /// renderizar un preview de imagen cuando el valor es una URL de PNG.</summary>
    private static bool IsFirmaField(string? name) =>
        !string.IsNullOrWhiteSpace(name) &&
        name.Contains("firma", StringComparison.OrdinalIgnoreCase);

    /// <summary>True si el valor parece una URL renderizable como <img>: ruta
    /// relativa (/uploads/...), http(s)://, o data:image/...</summary>
    private static bool IsImageUrlLike(string? v) =>
        !string.IsNullOrWhiteSpace(v) &&
        (v.StartsWith('/') ||
         v.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
         v.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
         v.StartsWith("data:image/", StringComparison.OrdinalIgnoreCase));

    private RenderFragment RenderInput(FormNode node) => __builder =>
    {
        var key = node.Name ?? $"fld:{node.Id}";
        var val = GetValue(key) ?? node.DefaultValue ?? "";
        var ro = IsNodeReadOnly(node);

        // Caso especial: campo de firma con URL -> mostrar la imagen ademas
        // del input de texto. Esto cubre firma_paciente_consent,
        // firma_profesional_consent, y cualquier otro campo cuyo name contenga
        // "firma" y reciba una URL como valor (clip de FirmasPrefillHelper o
        // pegado manualmente por el usuario).
        if (IsFirmaField(node.Name) && IsImageUrlLike(val))
        {
            <div class="fv-firma-prev">
                <img src="@val" alt="firma" class="fv-firma-img"
                     style="max-height:90px;max-width:100%;border:1px solid #e2e8f0;border-radius:4px;background:#fff;padding:4px;display:block;margin-bottom:6px;" />
            </div>
            <input type="text" class="form-control form-control-sm"
                   disabled="@ro" value="@val"
                   @onchange="e => SetValue(key, e.Value?.ToString())" />
            return;
        }

        switch (node.FieldType)
        {
            case "textarea":
                <textarea class="form-control form-control-sm" rows="3" placeholder="@node.Placeholder"
                          disabled="@ro" value="@val"
                          @onchange="e => SetValue(key, e.Value?.ToString())"></textarea>
                break;
            case "number":
                <input type="number" class="form-control form-control-sm" placeholder="@node.Placeholder"
                       disabled="@ro" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
            case "date":
                <input type="date" class="form-control form-control-sm"
                       disabled="@ro" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
            case "email":
                <input type="email" class="form-control form-control-sm" placeholder="@node.Placeholder"
                       disabled="@ro" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
            case "select":
                <select class="form-select form-select-sm" disabled="@ro" value="@val"
                        @onchange="e => SetValue(key, e.Value?.ToString())">
                    <option value="">Seleccione...</option>
                    @if (node.Options is not null)
                    {
                        @foreach (var o in node.Options)
                        {
                            <option value="@o">@o</option>
                        }
                    }
                </select>
                break;
            case "autocomplete":
                <input class="form-control form-control-sm" placeholder="@(node.Placeholder ?? $"Buscar en {node.Catalog}...")"
                       disabled="@ro" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
            case "calculated":
                <input class="form-control form-control-sm fv-calc"
                       readonly
                       value="@val"
                       placeholder="(automatico: @node.Formula)"
                       title="@($"Calculado por formula: {node.Formula}")" />
                break;
            default:
                <input type="text" class="form-control form-control-sm" placeholder="@node.Placeholder"
                       disabled="@ro" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
        }
    };

    private RenderFragment RenderTableCell(FormColumn c, string key) => __builder =>
    {
        var val = GetValue(key) ?? "";
        switch (c.FieldType)
        {
            case "number":
                <input type="number" class="form-control form-control-sm" disabled="@ReadOnly" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
            case "date":
                <input type="date" class="form-control form-control-sm" disabled="@ReadOnly" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
            case "select":
                <input class="form-control form-control-sm" placeholder="@c.Catalog"
                       disabled="@ReadOnly" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
            default:
                <input type="text" class="form-control form-control-sm" disabled="@ReadOnly" value="@val"
                       @onchange="e => SetValue(key, e.Value?.ToString())" />
                break;
        }
    };

    private int GetRowCount(string key)
    {
        var raw = GetValue($"{key}:_rows");
        if (int.TryParse(raw, out var n) && n >= 0) { return n; }
        return 1; // siempre arranca con 1 fila editable
    }

    private async Task AddRow(string key)
    {
        var n = GetRowCount(key) + 1;
        await SetValue($"{key}:_rows", n.ToString());
    }

    private async Task RemoveRow(string key, int idx)
    {
        var n = Math.Max(0, GetRowCount(key) - 1);
        await SetValue($"{key}:_rows", n.ToString());
    }
}
