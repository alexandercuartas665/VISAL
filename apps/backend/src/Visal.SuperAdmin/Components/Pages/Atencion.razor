    // ===== Modal configurar columnas =====

    private bool _showConfigCols;
    private bool _cfgGuardando;

    private sealed class CfgFila
    {
        public string Key { get; set; } = "";
        public string TituloDefault { get; set; } = "";
        public bool Visible { get; set; } = true;
        public string? Alias { get; set; }
        public int? Orden { get; set; }
    }
    private List<CfgFila> _cfgEdicion = new();

    private void AbrirConfigColumnas()
    {
        var cfgDict = _configColumnas.ToDictionary(c => c.ColumnaKey, c => c);
        _cfgEdicion = _columnasDefault.Select(d =>
        {
            cfgDict.TryGetValue(d.Key, out var ov);
            return new CfgFila
            {
                Key = d.Key,
                TituloDefault = d.TituloDefault,
                Visible = ov?.Visible ?? true,
                Alias = ov?.Alias,
                Orden = ov?.Orden ?? d.OrdenDefault
            };
        }).OrderBy(x => x.Orden ?? int.MaxValue).ToList();
        _showConfigCols = true;
    }

    private void CerrarConfigColumnas()
    {
        _showConfigCols = false;
    }

    private void MoverArriba(int idx)
    {
        if (idx <= 0 || idx >= _cfgEdicion.Count) { return; }
        (_cfgEdicion[idx - 1], _cfgEdicion[idx]) = (_cfgEdicion[idx], _cfgEdicion[idx - 1]);
    }

    private void MoverAbajo(int idx)
    {
        if (idx < 0 || idx >= _cfgEdicion.Count - 1) { return; }
        (_cfgEdicion[idx + 1], _cfgEdicion[idx]) = (_cfgEdicion[idx], _cfgEdicion[idx + 1]);
    }

    private async Task GuardarConfigColumnas()
    {
        if (_cfgGuardando) { return; }
        _cfgGuardando = true;
        try
        {
            // El orden se toma de la posicion actual en la lista tras el drag con
            // flechas. Asi el usuario no pisa numeros a mano y el orden es siempre
            // consistente con lo que ve en el modal.
            for (var i = 0; i < _cfgEdicion.Count; i++) { _cfgEdicion[i].Orden = i + 1; }
            var reqs = _cfgEdicion.Select(f => new GuardarAtencionColumnaRequest(
                f.Key,
                f.Visible,
                string.IsNullOrWhiteSpace(f.Alias) ? null : f.Alias.Trim(),
                f.Orden)).ToList();
            await ColSvc.GuardarLoteAsync(reqs);
            // Recargar overrides para que _columnasVisibles refleje inmediato.
            _configColumnas = (await ColSvc.ListarAsync()).ToList();
            _showConfigCols = false;
            _ok = "Configuracion guardada.";
        }
        catch (Exception ex) { _error = "Error guardando columnas: " + ex.Message; }
        finally { _cfgGuardando = false; }
    }
