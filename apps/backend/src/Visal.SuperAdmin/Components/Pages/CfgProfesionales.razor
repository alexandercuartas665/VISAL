@page "/cfg-profesionales"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.IO
@using System.Security.Claims
@using Visal.Application.Tenancy
@inject IProfesionalConfigService Svc
@inject IUsuarioAdminService UsuSvc
@inject IWebHostEnvironment Env

<PageTitle>Profesionales - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion del Sistema</div>
        <h1 class="ase-title">Profesionales</h1>
    </div>
    <button class="btn btn-primary btn-sm" @onclick="New">+ Nuevo profesional</button>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-grid">
    <div class="ase-card ase-list">
        <div class="ase-card-h">Profesionales (@_lista.Count)</div>
        <input class="form-control form-control-sm mb-2" placeholder="Buscar..." value="@_filtro" @oninput="OnFiltro" />
        @foreach (var p in _lista)
        {
            <button class="ase-li @(p.Id == _id ? "sel" : "")" @onclick="() => Select(p.Id)">
                <div class="ase-li-name">@p.NombreCompleto</div>
                <div class="ase-li-sub">@p.NumeroDocumento &middot; @(p.TipoProfesional ?? "-") &middot; @(p.Ciudad ?? "-")</div>
            </button>
        }
        @if (_lista.Count == 0) { <div class="ase-empty">Sin profesionales.</div> }
    </div>

    <div class="ase-detail">
        @if (!_showForm)
        {
            <div class="ase-card"><div class="ase-empty">Selecciona o crea un profesional.</div></div>
        }
        else
        {
            <div class="ase-card">
                <div class="ase-card-h">Datos</div>
                <div class="ase-form">
                    <div class="ase-f"><label>Numero Documento *</label><input class="form-control form-control-sm" @bind="_doc" /></div>
                    <div class="ase-f"><label>Tipo documento</label>
                        <select class="form-select form-select-sm" @bind="_tipoDoc">
                            <option>CC</option><option>CE</option><option>TI</option><option>PA</option><option>NIT</option>
                        </select>
                    </div>
                    <div class="ase-f ase-f-wide"><label>Nombre Completo</label><input class="form-control form-control-sm" @bind="_nombreCompleto" placeholder="(se arma con los nombres si lo dejas vacio)" /></div>
                    <div class="ase-f"><label>Primer Nombre</label><input class="form-control form-control-sm" @bind="_pNombre" /></div>
                    <div class="ase-f"><label>Segundo Nombre</label><input class="form-control form-control-sm" @bind="_sNombre" /></div>
                    <div class="ase-f"><label>Primer Apellido</label><input class="form-control form-control-sm" @bind="_pApellido" /></div>
                    <div class="ase-f"><label>Segundo Apellido</label><input class="form-control form-control-sm" @bind="_sApellido" /></div>
                    <div class="ase-f"><label>Tipo Profesional</label>
                        <select class="form-select form-select-sm" @bind="_tipoProfId">
                            <option value="">Seleccione...</option>
                            @foreach (var t in _tipos)
                            {
                                <option value="@t.Id">@t.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="ase-f"><label>Registro Medico</label><input class="form-control form-control-sm" @bind="_registro" /></div>
                    <div class="ase-f"><label>Ciudad</label><input class="form-control form-control-sm" @bind="_ciudad" /></div>
                    <div class="ase-f"><label>Celular</label><input class="form-control form-control-sm" @bind="_celular" /></div>
                </div>

                <div class="ase-subcats">
                    <label class="ase-subcats-lbl">Sub Categoria</label>
                    <div class="ase-subcats-grid">
                        @foreach (var s in _subcats)
                        {
                            <label class="ase-chk">
                                <input type="checkbox" checked="@_subSel.Contains(s.Id)" @onchange="e => ToggleSub(s.Id, e)" />
                                <span>@s.Nombre</span>
                            </label>
                        }
                        @if (_subcats.Count == 0) { <span class="ase-empty">No hay subcategorias. Configuralas en el catalogo.</span> }
                    </div>
                </div>

                <div class="ase-actions">
                    <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@_busy">Guardar profesional</button>
                    @if (_id is not null)
                    {
                        <button class="btn btn-outline-success btn-sm" @onclick="OpenCrearUsuario" title="Crear usuario de login para este profesional">&#128100; Crear usuario</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="Delete">Eliminar</button>
                    }
                </div>
            </div>

            <!-- Agencias activas -->
            <div class="ase-card">
                <div class="ase-card-h">Agencias activas <button class="btn btn-outline-primary btn-sm ms-2" @onclick="AddAgencia">+ Agencia</button></div>
                @for (var i = 0; i < _agencias.Count; i++)
                {
                    var idx = i;
                    <div class="ase-ag-row">
                        <input class="form-control form-control-sm" @bind="_agencias[idx]" placeholder="Ciudad / sede" />
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => _agencias.RemoveAt(idx)">&times;</button>
                    </div>
                }
                @if (_agencias.Count == 0) { <div class="ase-empty">Sin agencias. Agrega una y guarda el profesional.</div> }
            </div>

            <!-- Firma + usuario -->
            <div class="ase-card">
                <div class="ase-card-h">Firma del profesional</div>
                @if (!string.IsNullOrWhiteSpace(_firmaUrl))
                {
                    <div class="ase-firma"><img src="@_firmaUrl" alt="firma" /></div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _firmaUrl = null">Quitar firma</button>
                }
                else
                {
                    <InputFile class="form-control form-control-sm" accept="image/*" OnChange="OnFirmaSelected" />
                    <div class="ase-hint">Sube la imagen de la firma (PNG/JPG, max 4 MB).</div>
                }

                <div class="ase-card-h" style="margin-top:16px;">Usuario de acceso</div>
                <div class="usu-info">
                    Si este profesional necesita acceder al modulo de atencion para ver sus turnos asignados,
                    presiona "Crear usuario" arriba. El usuario heredara los datos personales del profesional.
                </div>
            </div>
        }
    </div>
</div>

@* ===== Modal Crear usuario para profesional ===== *@
@if (_showCrearUsuModal)
{
    <div class="usu-modal-backdrop" @onclick="CloseCrearUsuario"></div>
    <div class="usu-modal">
        <div class="usu-modal-h">
            <h3>Crear usuario para @_nombreCompleto</h3>
            <button class="usu-modal-close" @onclick="CloseCrearUsuario">&times;</button>
        </div>
        <div class="usu-modal-body">
            @if (_modalError is not null) { <div class="ase-alert">@_modalError</div> }
            <div class="ase-form">
                <div class="ase-f ase-f-wide">
                    <label>Correo *</label>
                    <input class="form-control form-control-sm" @bind="_nuevoEmail" placeholder="profesional@ips.com" />
                </div>
                <div class="ase-f ase-f-wide">
                    <label>Clave temporal *</label>
                    <input type="password" class="form-control form-control-sm" @bind="_nuevoPwd" placeholder="Minimo 6 caracteres" />
                    <small class="text-muted">El profesional la cambiara en su primer ingreso.</small>
                </div>
                <div class="ase-f ase-f-wide">
                    <small class="usu-info">
                        Se creara un usuario heredando documento, nombre, apellidos, celular y ciudad
                        de <strong>@_nombreCompleto</strong>. Quedara vinculado a este profesional para
                        ver sus turnos en el modulo de Atencion.
                    </small>
                </div>
            </div>
        </div>
        <div class="usu-modal-f">
            <button class="btn btn-secondary btn-sm" @onclick="CloseCrearUsuario">Cancelar</button>
            <button class="btn btn-primary btn-sm" @onclick="CrearUsuario" disabled="@_busyCrearUsu">
                @(_busyCrearUsu ? "Creando..." : "Crear usuario")
            </button>
        </div>
    </div>
}

<style>
    .usu-modal-backdrop { position: fixed; inset: 0; background: rgba(15,23,42,.45); z-index: 950; }
    .usu-modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 520px; max-width: 95vw; max-height: 90vh; background: #fff; border-radius: 12px; box-shadow: 0 20px 60px rgba(15,23,42,.25); z-index: 951; display: flex; flex-direction: column; }
    .usu-modal-h { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid #e2e8f0; }
    .usu-modal-h h3 { margin: 0; font-size: 15px; font-weight: 700; color: #0f172a; }
    .usu-modal-close { background: none; border: none; font-size: 22px; line-height: 1; cursor: pointer; color: #64748b; }
    .usu-modal-body { padding: 18px; overflow: auto; }
    .usu-modal-f { padding: 12px 18px; border-top: 1px solid #e2e8f0; display: flex; gap: 8px; justify-content: flex-end; }
    .usu-info { font-size: 12px; color: #475569; padding: 8px 10px; background: #f1f5f9; border-radius: 8px; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<ProfesionalDto> _lista = new();
    private List<CatalogItemDto> _tipos = new();
    private List<CatalogItemDto> _subcats = new();
    private string _filtro = "";

    private bool _showForm;
    private Guid? _id;
    private string _doc = "", _tipoDoc = "CC";
    private string? _nombreCompleto, _pNombre, _sNombre, _pApellido, _sApellido;
    private string _tipoProfId = "";
    private string? _registro, _ciudad, _celular, _firmaUrl;
    private HashSet<Guid> _subSel = new();
    private List<string> _agencias = new();

    private bool _busy;
    private string? _error, _ok;

    // Modal crear usuario para profesional.
    private bool _showCrearUsuModal;
    private string _nuevoEmail = "", _nuevoPwd = "";
    private string? _modalError;
    private bool _busyCrearUsu;

    private void OpenCrearUsuario()
    {
        if (_id is null) { _error = "Guarda el profesional antes de crear su usuario."; return; }
        _nuevoEmail = ""; _nuevoPwd = ""; _modalError = null;
        _showCrearUsuModal = true;
    }

    private void CloseCrearUsuario() => _showCrearUsuModal = false;

    private async Task CrearUsuario()
    {
        if (_id is not Guid pid) { return; }
        _modalError = null; _busyCrearUsu = true;
        try
        {
            var u = await UsuSvc.CrearUsuarioDesdeProfesionalAsync(pid, _nuevoEmail, _nuevoPwd, await Actor());
            if (u is null) { _modalError = "No se pudo crear (sin tenant activo)."; return; }
            _ok = $"Usuario '{u.Email}' creado para {_nombreCompleto}.";
            _showCrearUsuModal = false;
        }
        catch (InvalidOperationException ex) { _modalError = ex.Message; }
        catch (Exception ex) { _modalError = "Error: " + ex.Message; }
        finally { _busyCrearUsu = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        _tipos = (await Svc.ListTiposAsync(soloActivos: true)).ToList();
        _subcats = (await Svc.ListSubcategoriasAsync(soloActivos: true)).ToList();
        await LoadLista();
    }

    private async Task LoadLista() => _lista = (await Svc.ListProfesionalesAsync(string.IsNullOrWhiteSpace(_filtro) ? null : _filtro)).ToList();
    private async Task OnFiltro(ChangeEventArgs e) { _filtro = e.Value?.ToString() ?? ""; await LoadLista(); }

    private void New()
    {
        _id = null; _doc = ""; _tipoDoc = "CC"; _nombreCompleto = _pNombre = _sNombre = _pApellido = _sApellido = null;
        _tipoProfId = ""; _registro = _ciudad = _celular = _firmaUrl = null;
        _subSel = new(); _agencias = new();
        _showForm = true; _error = _ok = null;
    }

    private async Task Select(Guid id)
    {
        var d = await Svc.GetProfesionalAsync(id);
        if (d is null) { return; }
        _id = d.Id; _doc = d.NumeroDocumento; _tipoDoc = d.TipoDocumento;
        _nombreCompleto = d.NombreCompleto; _pNombre = d.PrimerNombre; _sNombre = d.SegundoNombre;
        _pApellido = d.PrimerApellido; _sApellido = d.SegundoApellido;
        _tipoProfId = d.TipoProfesionalId?.ToString() ?? "";
        _registro = d.RegistroMedico; _ciudad = d.Ciudad; _celular = d.Celular; _firmaUrl = d.FirmaUrl;
        _subSel = new(d.SubCategoriaIds);
        _agencias = d.Agencias.ToList();
        _showForm = true; _error = _ok = null;
    }

    private void ToggleSub(Guid id, ChangeEventArgs e)
    {
        if (e.Value is bool b && b) { _subSel.Add(id); } else { _subSel.Remove(id); }
    }

    private void AddAgencia() => _agencias.Add("");

    private async Task Save()
    {
        _error = _ok = null; _busy = true;
        try
        {
            Guid? tipoId = Guid.TryParse(_tipoProfId, out var tg) ? tg : null;
            var req = new SaveProfesionalRequest(_id, _doc, _tipoDoc, _pNombre, _sNombre, _pApellido, _sApellido,
                _nombreCompleto, tipoId, _registro, _ciudad, _celular, _firmaUrl,
                _subSel.ToList(), _agencias);
            var saved = await Svc.SaveProfesionalAsync(req, await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            await Select(saved.Id);
            await LoadLista();
            _ok = $"Profesional \"{saved.NombreCompleto}\" guardado.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task Delete()
    {
        if (_id is not Guid id) { return; }
        await Svc.DeleteProfesionalAsync(id, await Actor());
        _showForm = false; _id = null;
        await LoadLista();
        _ok = "Profesional eliminado.";
    }

    private async Task OnFirmaSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        var file = e.File;
        const long max = 4L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { _error = "La firma debe pesar menos de 4 MB."; return; }
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(max).CopyToAsync(ms);
            var ext = Path.GetExtension(file.Name);
            var dir = Path.Combine(Env.WebRootPath, "uploads", "firmas");
            Directory.CreateDirectory(dir);
            var name = $"firma-{Guid.NewGuid():N}{ext}";
            await File.WriteAllBytesAsync(Path.Combine(dir, name), ms.ToArray());
            _firmaUrl = $"/uploads/firmas/{name}";
        }
        catch { _error = "No se pudo subir la firma."; }
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }
}
