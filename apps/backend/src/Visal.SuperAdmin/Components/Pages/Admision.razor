@* ===== Modal Importar pacientes desde Excel ===== *@
@if (_showImportModal)
{
    <div class="cie-backdrop" @onclick="CloseImport"></div>
    <div class="cie-modal">
        <div class="cie-modal-h">
            <h3>Importar pacientes desde Excel</h3>
            <button class="cie-modal-close" @onclick="CloseImport">&times;</button>
        </div>
        <div class="cie-modal-body">
            @if (_importError is not null) { <div class="ase-alert">@_importError</div> }
            <div class="ase-f">
                <label>Archivo Excel (.xlsx)</label>
                <div style="display:flex; gap:8px; align-items:flex-start;">
                    <InputFile class="form-control form-control-sm" accept=".xlsx" OnChange="OnExcelSelected" disabled="@_importing" />
                    <a class="btn btn-outline-secondary btn-sm" href="/api/pacientes/plantilla.xlsx" download="plantilla-pacientes.xlsx" title="Descargar plantilla en blanco">&#128229; Plantilla</a>
                </div>
                <div class="ase-hint" style="margin-top:6px;">
                    <strong>51 columnas</strong> alineadas con la ficha del paciente.
                    Bloques: Identificacion (A-H), Caracteristicas (I-O), Contacto (P-T),
                    Geografia (U-Y), <strong>Admin PAD</strong> incl. Aseguradora, IPS Que Comenta,
                    Codigo aceptacion, Fechas comentan/ingreso/egreso (Z-AG), Clasificacion (AH-AM),
                    Diagnostico CIE (AN-AO), Tutela (AP-AQ), Contratos 1/2/3 (AR-AT),
                    Sede atencion (AU), Emergencia (AV-AX), Activo (AY).
                    La plantilla trae <strong>10 dropdowns</strong> (tabs auxiliares) para evitar
                    errores tipograficos. Duplicados por documento hacen upsert.
                </div>
            </div>

            @if (_importing || _importTotal > 0)
            {
                <div style="margin-top:14px;">
                    <div style="width:100%; height:10px; background:#e2e8f0; border-radius:6px; overflow:hidden;">
                        <div style="width:@($"{_importProgress:0}%"); height:100%; background:linear-gradient(90deg,#2563eb,#1d4ed8); transition:width .15s linear;"></div>
                    </div>
                    <div class="ase-hint" style="margin-top:6px;">
                        @if (_importing) { <span>Procesando fila @_importCurrent de @_importTotal&hellip;</span> }
                        else { <span>Listo: @_importOk OK, @_importErr errores.</span> }
                    </div>
                </div>
                <div style="margin-top:10px; max-height:220px; overflow-y:auto; background:#0f172a; color:#cbd5e1; border-radius:6px; padding:8px 10px; font-family:ui-monospace,Consolas,monospace; font-size:11.5px; line-height:1.5;">
                    @foreach (var line in _importLog.TakeLast(40))
                    {
                        var color = line.StartsWith("[OK]") ? "#86efac" : line.StartsWith("[ERR]") ? "#fca5a5" : "#93c5fd";
                        <div style="color:@color;">@line</div>
                    }
                </div>
            }
        </div>
        <div style="display:flex; justify-content:flex-end; padding:12px 18px; border-top:1px solid #e2e8f0;">
            <button class="btn btn-secondary btn-sm" @onclick="CloseImport" disabled="@_importing">Cerrar</button>
        </div>
    </div>
}

