@implements IDisposable
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.Extensions.DependencyInjection
@using Visal.Application.Tenancy
@using Visal.Domain.Enums
@using Visal.SuperAdmin.Components.Forms
@inject IFormDefinitionService FormsSvc
@inject IAsignacionService AsigSvc
@inject IHistoriaClinicaService HcSvc
@inject IOrdenMedicamentoService OrdMedSvc
@inject IOrdenServicioService OrdSrvSvc
@inject IIncapacidadService IncSvc
@inject ICertificacionService CertSvc
@inject IRemisionService RemSvc
@inject IInsumoService InsumoSvc
@inject IOrdenExternaService OrdExtSvc
@inject IEscalaService EscSvc
@inject IDocumentoHcService DocSvc
@inject INotaMedicaService NotaSvc
@inject IHcMenuConfigService MenuHcSvc
@inject IFirmaResolverService FirmaResolverSvc
@inject IPacienteService PacientesSvc
@inject ICatalogoPacienteService CatPacSvc
@inject ITenantAdminService TenantsSvc
@inject IServiceScopeFactory ScopeFactory
@inject IJSRuntime JS
@inject NavigationManager Nav

@*
   Modulo reutilizable de Historias Clinicas.
   Se invoca como submodulo desde /atencion recibiendo el paciente como contexto.
   No tiene @page: no es ruta independiente.
*@

@* CascadingValue expone _acompSelector a HcDocumentos y HcEscalas para que
   antes de crear un consentimiento/evolucion/escala pregunten cual acompanante
   firma (cuando el paciente tiene 2+ contactos). Ver AcompananteSelectorContext.cs *@
<CascadingValue Value="_acompSelector" IsFixed="true">
<div class="hc-grid @(_pacienteColapsado ? "paciente-colapsado" : "") @(_chatColapsado ? "chat-colapsado" : "")">

    @* =========== SIDEBAR IZQUIERDO: filtros + lista historias =========== *@
    @* Colapsable: si _pacienteColapsado es true se reduce a una franja vertical
       que solo muestra el boton para volver a expandir. Asi el doctor maximiza
       el ancho del modulo de historias en pantallas chicas. *@
    @if (_pacienteColapsado)
    {
        <div class="hc-paciente-strip">
            <button class="hc-paciente-expand" @onclick="() => _pacienteColapsado = false" title="Mostrar paciente y filtros">
                <span class="hc-paciente-expand-ico">&#128100;</span>
                <span class="hc-paciente-expand-text">Paciente</span>
            </button>
        </div>
    }
    else
    {
    <div class="hc-col">
        <div class="ase-card">
            <div class="ase-card-h" style="display:flex; justify-content:space-between; align-items:center;">
                <span>Paciente</span>
                <button class="hc-col-toggle" @onclick="() => _pacienteColapsado = true" title="Ocultar columna paciente">&laquo;</button>
            </div>
            <div class="hc-form-padding">
                @if (PacienteContexto is PacienteAsignacionDto pc)
                {
                    @* Paciente recibido por parametro: NO permite cambiar. *@
                    <div class="hc-paciente-card">
                        <div class="hc-paciente-nm">@pc.NombreCompleto</div>
                        <div class="hc-paciente-doc">@pc.TipoDocumento @pc.NumeroDocumento</div>
                        <small class="text-muted">Paciente fijado por el modulo de Atencion.</small>
                    </div>
                }
                else if (_paciente is PacienteAsignacionDto p)
                {
                    <div class="hc-paciente-card">
                        <div class="hc-paciente-nm">@p.NombreCompleto</div>
                        <div class="hc-paciente-doc">@p.TipoDocumento @p.NumeroDocumento</div>
                        <button class="btn btn-link btn-sm" @onclick="OpenPacienteModal">Cambiar paciente</button>
                    </div>
                }
                else
                {
                    <button class="btn btn-outline-primary btn-sm" @onclick="OpenPacienteModal">&#128270; Seleccionar paciente</button>
                }
            </div>
        </div>

        @if (_formatoForzadoId is not null)
        {
            <div class="ase-card hc-forzado-card">
                <div class="ase-card-h">Formato de historia para este servicio</div>
                <div class="hc-form-padding">
                    <div class="hc-forzado-name">@_formatoForzadoNombre</div>
                    <small class="text-muted">Definido por el servicio asignado. Al iniciar una historia nueva se usa este formato automaticamente.</small>
                </div>
            </div>
        }

        <div class="ase-card">
            <div class="ase-card-h">Filtros de busqueda</div>
            <div class="ase-form hc-form">
                <div class="ase-f"><label>Fecha inicial</label><input type="date" class="form-control form-control-sm" @bind="_filFechaIni" /></div>
                <div class="ase-f"><label>Fecha final</label><input type="date" class="form-control form-control-sm" @bind="_filFechaFin" /></div>
                <div class="ase-f ase-f-wide">
                    <label>Formato de historia <small class="text-muted">(opcional - filtro)</small></label>
                    <select class="form-select form-select-sm" @bind="_filFormato">
                        <option value="">Todos los formatos</option>
                        @foreach (var f in _formatos)
                        {
                            <option value="@f.Id">[@f.Codigo] @f.Nombre</option>
                        }
                    </select>
                </div>
                <div class="ase-f ase-f-wide">
                    <button class="btn btn-outline-primary btn-sm" @onclick="MostrarHistorias">Mostrar historias</button>
                </div>
            </div>
        </div>

        <div class="ase-card hc-list-card">
            <div class="ase-card-h">Historias del paciente (@_historias.Count)</div>
            <div class="hc-list">
                @if (_historias.Count == 0)
                {
                    <div class="ase-empty">Aplica un filtro y presiona "Mostrar historias".</div>
                }
                @foreach (var h in _historias)
                {
                    <div class="hc-item @(h.Id == _historiaSel?.Id ? "sel" : "")">
                        <div class="hc-item-h">
                            <div>
                                <div class="hc-item-prof">Especialista: <strong>@h.Especialista</strong></div>
                                <div class="hc-item-fecha">Fecha inicial: @h.Fecha.ToString("dd/MM/yyyy")</div>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-link btn-sm hc-item-menu" @onclick="() => ToggleMenu(h.Id)">&#8942;</button>
                                @if (_menuAbierto == h.Id)
                                {
                                    <div class="hc-menu">
                                        <div class="hc-menu-h">Acciones</div>
                                        <button class="hc-menu-item" @onclick="() => Seleccionar(h)">Ver esta historia</button>
                                        <button class="hc-menu-item" @onclick="() => CrearCopiaAsync(h)">Crear una copia</button>
                                        <button class="hc-menu-item" @onclick='() => AccionSinPermisoAsync("Impresion")'>Impresion</button>
                                        <button class="hc-menu-item" @onclick='() => AccionSinPermisoAsync("Procesar Interoperabilidad")'>Procesar Interoperabilidad</button>
                                        <button class="hc-menu-item" @onclick='() => AccionSinPermisoAsync("Abrir Documento")'>Abrir Documento</button>
                                    </div>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(h.Observaciones))
                        {
                            <div class="hc-item-obs">Obs: @h.Observaciones</div>
                        }
                        <div class="hc-item-pill @($"hc-est-{h.Estado.ToLower()}")">@h.Estado</div>
                    </div>
                }
            </div>
        </div>
    </div>
    }

    @* =========== COLUMNA CENTRAL: chat WhatsApp del paciente =========== *@
    @* Vive en el hc-grid (no dentro del modal) para que el doctor pueda colapsar
       paciente + chat y dejar el modulo de historia a maximo ancho. *@
    <div class="hc-chat-outer @(_chatColapsado ? "hc-chat-colapsado" : "")">
        @* Telefono completo con codigo pais concatenado. Gupshup rechaza numeros
           en formato nacional (10 digitos "3217626882") — necesita E.164
           completo "573217626882". Si el paciente no tiene codigo pais, cae
           a +57. WhatsAppChatPanel aplica SoloDigitos internamente. *@
        <WhatsAppChatPanel Telefono="@PhoneFormatHelper.BuildFullDigits(PacienteActivo?.CodigoPaisTelefono, Visal.Application.Common.PacienteTelefonoHelper.Principal(PacienteActivo?.Telefono))"
                           NombreContacto="@PacienteActivo?.NombreCompleto"
                           Cedula="@PacienteActivo?.NumeroDocumento"
                           PacienteId="@PacienteActivo?.Id"
                           Colapsable="true"
                           @bind-Colapsado="_chatColapsado"
                           OnTelefonoActualizado="HandleTelefonoActualizado" />
    </div>

    @* =========== PANEL DERECHO: detalle + tabs =========== *@
    <div class="hc-col hc-col-main">
        <div class="ase-card">
            <div class="hc-actions">
                <button class="btn btn-primary btn-sm" @onclick="IniciarHistoria"
                        disabled="@(_formatoForzadoId is null && string.IsNullOrEmpty(_filFormato))"
                        title="@(_formatoForzadoId is not null ? $"Inicia historia con formato {_formatoForzadoNombre}" : "Selecciona un formato del filtro o abre desde un servicio asignado")">
                    &#128221; Iniciar historia medica
                </button>
                <button class="btn btn-outline-success btn-sm" disabled="@(_schemaActual is null)" @onclick="Imprimir" title="Abrir vista documento en nueva pestana para imprimir o guardar PDF">&#128424; Imprimir</button>
                @* Descartar y Guardar definitivamente solo aplican mientras la HC este Abierta.
                   Cuando esta Cerrada mostramos Reabrir para usuarios con permiso administrativo. *@
                @if (_historiaSel is null || string.Equals(_historiaSel.Estado, "Abierta", StringComparison.OrdinalIgnoreCase))
                {
                    <button class="btn btn-danger btn-sm" disabled="@(_schemaActual is null)" @onclick="Descartar">&#128465; Descartar</button>
                    <button class="btn btn-outline-secondary btn-sm" disabled="@(_schemaActual is null)" @onclick="Cerrar"
                            title="Cierra la historia clinica y la marca como Cerrada. Solo un administrador puede reabrirla despues.">
                        &#10004; Guardar definitivamente
                    </button>
                }
                else if (string.Equals(_historiaSel.Estado, "Cerrada", StringComparison.OrdinalIgnoreCase) && _puedeReabrir)
                {
                    <button class="btn btn-warning btn-sm" @onclick="Reabrir"
                            title="Reabre la historia clinica para permitir editar. Requiere permiso administrativo.">
                        &#128275; Reabrir historia
                    </button>
                }
                else if (string.Equals(_historiaSel.Estado, "Cerrada", StringComparison.OrdinalIgnoreCase))
                {
                    <span class="hc-est-lock" title="Solo un usuario con permiso administrativo puede reabrir esta HC.">
                        &#128274; Cerrada definitivamente
                    </span>
                }
                @* Indicador de autoguardado. Solo se muestra cuando hay HC abierta. *@
                @if (_historiaSel is not null && string.Equals(_historiaSel.Estado, "Abierta", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="hc-autosave hc-autosave-@_saveStatus" title="@_saveTitle">
                        @switch (_saveStatus)
                        {
                            case "limpio":     <span>&#10003; Guardado</span> break;
                            case "sucio":      <span>&#9998; Cambios sin guardar</span> break;
                            case "guardando":  <span>&#8635; Guardando...</span> break;
                            case "guardado":   <span>&#10003; Guardado @(_ultimoGuardado?.ToString("HH:mm:ss"))</span> break;
                            case "error":      <span>&#9888; Error al guardar - reintento automatico</span> break;
                        }
                    </div>
                }
            </div>
            @if (_imprimirMsg is not null) { <div class="hc-info-msg">@_imprimirMsg</div> }

            @* Chip con el acompanante activo (elegido para firmar los consentimientos
               / evoluciones / escalas del paciente actual). Solo se muestra cuando ya
               se resolvio y no es "sin acompanante". Boton "Cambiar" limpia el estado
               para que el proximo Iniciar vuelva a preguntar. *@
            @if (_acompSelector.OrdenActivo.HasValue && _acompSelector.OrdenActivo.Value > 0
                 && !string.IsNullOrWhiteSpace(_acompSelector.EtiquetaActivo))
            {
                <div class="hc-acomp-chip" title="Este acompanante se usara al iniciar consentimientos, evoluciones y escalas de este paciente.">
                    <span class="hc-acomp-chip-ico">&#128101;</span>
                    <span class="hc-acomp-chip-lbl">Firma acompanante:</span>
                    <span class="hc-acomp-chip-val">@_acompSelector.EtiquetaActivo</span>
                    <button type="button" class="hc-acomp-chip-cambiar" @onclick="() => _acompSelector.Reset()">
                        Cambiar
                    </button>
                </div>
            }

            @* Datos RIPS de la HC seleccionada (Res. 202/2021). Se muestran como
               chips debajo de la barra de acciones cuando la HC ya se creo. *@
            @if (_historiaSel is not null &&
                 (!string.IsNullOrWhiteSpace(_historiaSel.RipsViaNombre)
                  || !string.IsNullOrWhiteSpace(_historiaSel.RipsFinalidadNombre)
                  || !string.IsNullOrWhiteSpace(_historiaSel.RipsCausaNombre)))
            {
                <div class="hc-rips-tags">
                    @if (!string.IsNullOrWhiteSpace(_historiaSel.RipsViaNombre))
                    {
                        <span class="hc-rips-tag" title="RIPS - Via de ingreso al servicio de salud">
                            <span class="hc-rips-tag-lbl">Via:</span> @_historiaSel.RipsViaNombre
                        </span>
                    }
                    @if (!string.IsNullOrWhiteSpace(_historiaSel.RipsFinalidadNombre))
                    {
                        <span class="hc-rips-tag" title="RIPS - Finalidad de la consulta">
                            <span class="hc-rips-tag-lbl">Finalidad:</span> @_historiaSel.RipsFinalidadNombre
                        </span>
                    }
                    @if (!string.IsNullOrWhiteSpace(_historiaSel.RipsCausaNombre))
                    {
                        <span class="hc-rips-tag" title="RIPS - Causa externa que motiva la atencion">
                            <span class="hc-rips-tag-lbl">Causa:</span> @_historiaSel.RipsCausaNombre
                        </span>
                    }
                </div>
            }

            <div class="hc-buscar">
                <label class="hc-buscar-lbl">BUSCAR DATOS DE HISTORIA:</label>
                <div class="hc-buscar-row">
                    <input class="form-control form-control-sm" placeholder="BUSCA INFORMACION DE LA HISTORIA" @bind="_busqueda" />
                    <button class="btn btn-outline-secondary btn-sm" title="Filtrar por campo">&#9776;</button>
                </div>
            </div>
        </div>

        <div class="ase-card hc-col-full hc-with-menu @(_menuColapsado ? "menu-colapsado" : "")">
            @* ===== Menu lateral del modulo (izquierda) ===== *@
            <aside class="hc-side-menu">
                <button class="hc-side-toggle" title="@(_menuColapsado ? "Expandir menu" : "Colapsar menu")"
                        @onclick="() => _menuColapsado = !_menuColapsado">
                    @if (_menuColapsado) { <span>&raquo;</span> } else { <span>&laquo;</span> <span class="hc-side-toggle-lbl">Menu</span> }
                </button>
                <nav class="hc-side-nav">
                    @foreach (var t in TabsOrdenadas())
                    {
                        var (icono, badge) = IconoYBadge(t);
                        var etiqueta = EtiquetaTab(t);
                        <button class="hc-side-item @(t == _tabSel ? "sel" : "")"
                                title="@etiqueta"
                                @onclick="() => _tabSel = t">
                            <span class="hc-side-icon">@icono</span>
                            <span class="hc-side-lbl">@etiqueta</span>
                            @if (badge > 0) { <span class="hc-side-badge">@badge</span> }
                        </button>
                    }
                </nav>
            </aside>

            @* ===== Cuerpo del tab seleccionado (centro) ===== *@
            <div class="hc-tab-body">
                @if (_historiaSel is null)
                {
                    <div class="ase-empty hc-empty-detail">
                        Selecciona una historia de la lista o presiona "Iniciar historia medica" para crear una nueva.
                    </div>
                }
                else
                {
                    @if (_tabSel == "Historial")
                    {
                        @if (_schemaActual is null)
                        {
                            <div class="hc-placeholder">
                                <div class="hc-placeholder-t">Selecciona un formato y presiona "Iniciar historia medica"</div>
                                <div class="hc-placeholder-d">
                                    El motor de formularios cargara la plantilla seleccionada para que la diligencies aqui mismo.
                                </div>
                            </div>
                        }
                        else
                        {
                            @if (_hcEsDeOtroDoctor)
                            {
                                <div class="ase-alert" style="background:#fef3c7;color:#92400e;border-color:#fbbf24;margin-bottom:10px;">
                                    <strong>&#128274; Solo lectura.</strong>
                                    Esta historia clinica fue iniciada por <strong>@_historiaSel?.Especialista</strong>.
                                    No puedes modificarla. Inicia una nueva con tu usuario si necesitas registrar tu propia atencion.
                                </div>
                            }
                            else if (_hcCerrada)
                            {
                                <div class="ase-alert" style="background:#fee2e2;color:#991b1b;border-color:#f87171;margin-bottom:10px;">
                                    <strong>&#128274; Historia cerrada.</strong>
                                    Esta historia clinica esta en estado <strong>@_historiaSel?.Estado</strong> y no admite cambios.
                                    Si tienes permiso "historias.reabrir" puedes abrirla desde el menu de la fila; de lo contrario,
                                    inicia una nueva historia.
                                </div>
                            }
                            <FormViewer Schema="@_schemaActual" Valores="@_valores"
                                        Titulo="@_formatoActualNombre" Subtitulo="@_subtituloFormato"
                                        ReadOnlyKeys="@_hcReadOnlyKeys"
                                        ReadOnly="@_hcSoloLectura"
                                        OnValueChanged="OnValorCambiado" />
                        }
                    }
                    else
                    {
                        // Todos los sub-tabs (Escalas, Evoluciones, Consentimientos, Ordenes
                        // *, RX, Lab, Insumos, Remisiones, etc.) van dentro de un wrapper
                        // que se pone en modo consulta si la HC ya no esta Abierta. Los
                        // sub-componentes en si no aceptan un flag readonly (todavia); los
                        // desactivamos con el atributo HTML "inert", que ignora clicks,
                        // teclado y focus sin ocultar el contenido. Complementa la
                        // validacion en backend (HistoriaClinicaService rechaza mutaciones
                        // sobre HC cerrada).
                        if (_hcCerrada)
                        {
                            <div class="ase-alert" style="background:#fee2e2;color:#991b1b;border-color:#f87171;margin-bottom:10px;">
                                <strong>&#128274; Historia cerrada.</strong>
                                Esta pestana esta en modo consulta: puedes ver los registros
                                pero no agregar, editar ni eliminar. Reabre la HC (si tienes
                                permiso) o inicia una nueva para registrar cambios.
                            </div>
                        }
                        <div inert="@_hcCerrada" style="@(_hcCerrada ? "opacity:.75;filter:grayscale(.15);" : "")">
                            @if (_tabSel == "Escalas")
                            {
                                <HcEscalas HistoriaClinicaId="@_historiaSel?.Id"
                                           PacienteId="@PacienteActivo?.Id"
                                           Paciente="@PacienteActivo"
                                           EspecialistaNombre="@_historiaSel?.Especialista"
                                           OnCountChanged="@(c => _escCount = c)" />
                            }
                            else if (_tabSel == "Evoluciones")
                            {
                                <HcDocumentos Tipo="EVOLUCION"
                                              HistoriaClinicaId="@_historiaSel?.Id"
                                              PacienteId="@PacienteActivo?.Id"
                                              Paciente="@PacienteActivo"
                                              EspecialistaNombre="@_historiaSel?.Especialista"
                                              OnCountChanged="@(c => _evoCount = c)" />
                            }
                            else if (_tabSel == "Consentimientos")
                            {
                                <HcDocumentos Tipo="CONSENTIMIENTO"
                                              HistoriaClinicaId="@_historiaSel?.Id"
                                              PacienteId="@PacienteActivo?.Id"
                                              Paciente="@PacienteActivo"
                                              EspecialistaNombre="@_historiaSel?.Especialista"
                                              OnCountChanged="@(c => _conCount = c)" />
                            }
                            else if (_tabSel == "Atenciones")
                            {
                                <HcDocumentos Tipo="ATENCION"
                                              AllFormatsMode="true"
                                              HistoriaClinicaId="@_historiaSel?.Id"
                                              PacienteId="@PacienteActivo?.Id"
                                              Paciente="@PacienteActivo"
                                              EspecialistaNombre="@_historiaSel?.Especialista"
                                              OnCountChanged="@(c => _atCount = c)" />
                            }
                            else if (_tabSel == "Documentos externos")
                            {
                                <HcDocumentosExternos HistoriaClinicaId="@_historiaSel?.Id"
                                                       PacienteId="@PacienteActivo?.Id"
                                                       OnCountChanged="@(c => _docExtCount = c)" />
                            }
                            else if (_tabSel == "Ordenes medicamento")
                            {
                                <OrdenMedicamentos HistoriaClinicaId="@_historiaSel?.Id"
                                                   OnCountChanged="OnMedicamentosCountChanged"
                                                   OnItemsChanged="RecargarValoresDesdeBackendAsync" />
                            }
                            else if (_tabSel == "Ordenes servicios")
                            {
                                <OrdenServicios HistoriaClinicaId="@_historiaSel?.Id"
                                                OnCountChanged="@(c => _servCount = c)"
                                                OnItemsChanged="RecargarValoresDesdeBackendAsync" />
                            }
                            else if (_tabSel == "Insumos")
                            {
                                <OrdenInsumos HistoriaClinicaId="@_historiaSel?.Id"
                                              OnCountChanged="@(c => _insCount = c)"
                                              OnItemsChanged="RecargarValoresDesdeBackendAsync" />
                            }
                            else if (_tabSel == "Remisiones")
                            {
                                <OrdenRemisiones HistoriaClinicaId="@_historiaSel?.Id"
                                                 OnCountChanged="@(c => _remCount = c)"
                                                 OnItemsChanged="RecargarValoresDesdeBackendAsync" />
                            }
                            else if (_tabSel == "Ordenes incapacidad")
                            {
                                <OrdenIncapacidades HistoriaClinicaId="@_historiaSel?.Id"
                                                    OnCountChanged="@(c => _incCount = c)"
                                                    OnItemsChanged="RecargarValoresDesdeBackendAsync" />
                            }
                            else if (_tabSel == "Ordenes certificaciones")
                            {
                                <OrdenCertificaciones HistoriaClinicaId="@_historiaSel?.Id"
                                                      OnCountChanged="@(c => _certCount = c)"
                                                      OnItemsChanged="RecargarValoresDesdeBackendAsync" />
                            }
                            else if (_tabSel == "RX Imagenologia")
                            {
                                <OrdenesExternas HistoriaClinicaId="@_historiaSel?.Id"
                                                Tipo="Visal.Domain.Enums.TipoCatalogoServicio.RxImagenologia"
                                                Titulo="RX / Imagenologia"
                                                OnCountChanged="@(c => _rxExtCount = c)"
                                                OnItemsChanged="RecargarValoresDesdeBackendAsync" />
                            }
                            else if (_tabSel == "Laboratorios")
                            {
                                <OrdenesExternas HistoriaClinicaId="@_historiaSel?.Id"
                                                Tipo="Visal.Domain.Enums.TipoCatalogoServicio.Laboratorio"
                                                Titulo="Laboratorios"
                                                OnCountChanged="@(c => _labExtCount = c)"
                                                OnItemsChanged="RecargarValoresDesdeBackendAsync" />
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
</CascadingValue>

@* Modal de seleccion del acompanante firmante. Se abre desde AcompananteSelectorContext
   cuando un sub-tab (HcDocumentos / HcEscalas) llama ResolverAsync y el paciente tiene
   2+ contactos. La eleccion queda memorizada por la vida del contexto (hasta que se
   cambia de paciente o se pulsa "Cambiar" en el chip). *@
<SelectorAcompananteModal IsOpen="_acompSelector.ModalVisible"
                          Contactos="_acompSelector.Contactos"
                          OnElegido="_acompSelector.Elegir"
                          OnCancelado="_acompSelector.Cancelar" />

@* ===== Modal IMPRIMIR (paquete) ===== *@
@if (_showImprimirModal)
{
    <div class="cie-backdrop" @onclick="CancelarImprimir"></div>
    <div class="cie-modal" style="width: 480px;">
        <div class="cie-modal-h">
            <h3>&#128424; Imprimir documentos</h3>
            <button class="cie-modal-close" @onclick="CancelarImprimir">&times;</button>
        </div>
        <div class="cie-modal-body">
            <p style="font-size: 12.5px; color: #475569; margin-bottom: 14px;">
                Selecciona los documentos que deseas imprimir. Solo aparecen las
                ordenes que tienen items registrados en esta historia.
            </p>

            <div class="hc-impr-opt">
                <label>
                    <input type="checkbox" @bind="_imprIncluirHc" />
                    <span><b>Historia clinica</b></span>
                </label>
                <small>Documento principal del formato de la HC.</small>
            </div>

            @if (_imprMedCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirMed" />
                        <span><b>Orden de Medicamentos</b> <em>(@_imprMedCount item@(_imprMedCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprSrvCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirSrv" />
                        <span><b>Orden a Servicios</b> <em>(@_imprSrvCount item@(_imprSrvCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprInsCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirIns" />
                        <span><b>Orden de Insumos</b> <em>(@_imprInsCount item@(_imprInsCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprRemCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirRem" />
                        <span><b>Remisiones</b> <em>(@_imprRemCount item@(_imprRemCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprRxExtCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirRxExt" />
                        <span><b>Orden RX Imagenologia</b> <em>(@_imprRxExtCount item@(_imprRxExtCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprLabExtCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirLabExt" />
                        <span><b>Orden Laboratorios</b> <em>(@_imprLabExtCount item@(_imprLabExtCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprInsExtCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirInsExt" />
                        <span><b>Orden Insumos Externos</b> <em>(@_imprInsExtCount item@(_imprInsExtCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprIncCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirInc" />
                        <span><b>Orden de Incapacidad</b> <em>(@_imprIncCount item@(_imprIncCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprCertCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirCert" />
                        <span><b>Certificacion Medica</b> <em>(@_imprCertCount item@(_imprCertCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprEscCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirEsc" />
                        <span><b>Escalas diligenciadas</b> <em>(@_imprEscCount escala@(_imprEscCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprEvoCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirEvo" />
                        <span><b>Evoluciones diligenciadas</b> <em>(@_imprEvoCount evolucion@(_imprEvoCount == 1 ? "" : "es"))</em></span>
                    </label>
                </div>
            }
            @if (_imprConCount > 0)
            {
                <div class="hc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_imprIncluirCon" />
                        <span><b>Consentimientos diligenciados</b> <em>(@_imprConCount consentimiento@(_imprConCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_imprMedCount == 0 && _imprSrvCount == 0 && _imprInsCount == 0 && _imprRemCount == 0
                 && _imprRxExtCount == 0 && _imprLabExtCount == 0 && _imprInsExtCount == 0
                 && _imprIncCount == 0 && _imprCertCount == 0
                 && _imprEscCount == 0 && _imprEvoCount == 0 && _imprConCount == 0)
            {
                <div style="font-size:12px; color:#94a3b8; font-style:italic; padding:10px 0;">
                    Esta historia no tiene ordenes, escalas, evoluciones ni consentimientos registrados.
                </div>
            }

            @if (_imprSeccionesOpcionales.Count > 0)
            {
                <div style="margin-top:14px; padding-top:10px; border-top:1px solid #e2e8f0;">
                    <div style="font-size:11px; font-weight:700; color:#334155; text-transform:uppercase; letter-spacing:.04em; margin-bottom:8px;">
                        Secciones opcionales de la HC
                    </div>
                    <div style="font-size:12px; color:#64748b; margin-bottom:8px;">
                        Estas secciones se imprimen solo si las seleccionas.
                    </div>
                    @foreach (var s in _imprSeccionesOpcionales)
                    {
                        <div class="hc-impr-opt">
                            <label>
                                <input type="checkbox"
                                       checked="@_imprSeccionesOpcionalesSel.Contains(s.Id)"
                                       @onchange="e => ToggleSeccionOpcional(s.Id, (bool)e.Value!)" />
                                <span>@s.Label</span>
                            </label>
                        </div>
                    }
                </div>
            }

            <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:14px;">
                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelarImprimir">Cancelar</button>
                <button class="btn btn-primary btn-sm" @onclick="ConfirmarImprimirAsync">&#128424; Imprimir seleccion</button>
            </div>
        </div>
    </div>
}

@* ===== Modal BUSCAR PACIENTE (solo si NO viene paciente por parametro) ===== *@
@if (_showPacModal)
{
    <div class="cie-backdrop" @onclick="ClosePacienteModal"></div>
    <div class="cie-modal cie-modal-lg">
        <div class="cie-modal-h">
            <h3>BUSCAR PACIENTE</h3>
            <button class="cie-modal-close" @onclick="ClosePacienteModal">&times;</button>
        </div>
        <div class="cie-modal-body">
            <div class="ase-form" style="grid-template-columns: 1fr 1fr 200px; display:grid; gap:10px; margin-bottom:14px;">
                <div class="ase-f"><label>No Documento</label><input class="form-control form-control-sm mono" @bind="_modalDoc" /></div>
                <div class="ase-f"><label>Nombre</label><input class="form-control form-control-sm" @bind="_modalNombre" /></div>
                <div style="display:flex; align-items:end;"><button class="btn btn-primary btn-sm" @onclick="BuscarPaciente" disabled="@_modalBusy">@(_modalBusy ? "Buscando..." : "Aplicar filtro")</button></div>
            </div>
            <div class="bp-results" style="border:1px solid #e2e8f0; border-radius:8px; max-height:340px; overflow:auto;">
                <table class="table table-sm" style="margin:0; font-size:12px;">
                    <thead style="background:#f8fafc;">
                        <tr><th style="width:50px"></th><th>Documento</th><th>Nombre</th><th>Contrato</th><th>Telefono</th></tr>
                    </thead>
                    <tbody>
                        @if (_modalGrid.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center text-muted" style="padding:20px;">@(_modalBusy ? "Buscando..." : "Aplica un filtro para ver pacientes.")</td></tr>
                        }
                        else
                        {
                            @foreach (var r in _modalGrid)
                            {
                                <tr>
                                    <td><button class="btn btn-primary btn-sm" @onclick="() => PickPaciente(r)">&#10003;</button></td>
                                    <td class="mono">@r.Documento</td>
                                    <td>@r.NombreCompleto</td>
                                    <td>@(r.Contrato ?? "-")</td>
                                    <td>@(r.Telefono ?? "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* =============================================================================
   Modal RIPS: aparece al pulsar "Iniciar historia medica". Captura los 3 datos
   obligatorios de la Res. 202/2021 de MinSalud (via + finalidad + causa externa)
   antes de crear la HC. Sin estos tres campos la HC no se persiste.
   z-index alto (1200/1201) para quedar por encima del modal padre de HC.
   ============================================================================= *@
@if (_showRipsModal)
{
    <div class="rips-backdrop" @onclick="CerrarModalRips"></div>
    <div class="rips-modal">
        <div class="rips-modal-h">
            <h3>&#128203; Datos RIPS obligatorios</h3>
            <button class="rips-modal-close" @onclick="CerrarModalRips" title="Cerrar">&times;</button>
        </div>
        <div class="rips-modal-body">
            <div class="rips-intro">
                Selecciona los tres datos obligatorios de la Resolucion 202/2021 de MinSalud.
                Estos datos quedan atados a la Historia Clinica y no pueden cambiar despues.
            </div>

            @if (_ripsError is not null) { <div class="ase-alert" style="margin-bottom:12px;">@_ripsError</div> }

            <div class="rips-row">
                <label class="rips-lbl">Via de ingreso al servicio de salud <span class="rips-req">*</span></label>
                <select class="form-select" @bind="_ripsViaCod">
                    <option value="">-- Selecciona --</option>
                    @foreach (var v in _ripsVias)
                    {
                        <option value="@v.Codigo">@v.Codigo - @v.Nombre</option>
                    }
                </select>
            </div>

            <div class="rips-row">
                <label class="rips-lbl">Finalidad de la consulta <span class="rips-req">*</span></label>
                <select class="form-select" @bind="_ripsFinCod">
                    <option value="">-- Selecciona --</option>
                    @foreach (var v in _ripsFinalidades)
                    {
                        <option value="@v.Codigo">@v.Codigo - @v.Nombre</option>
                    }
                </select>
            </div>

            <div class="rips-row">
                <label class="rips-lbl">Causa externa que motiva la atencion <span class="rips-req">*</span></label>
                <select class="form-select" @bind="_ripsCausaCod">
                    <option value="">-- Selecciona --</option>
                    @foreach (var v in _ripsCausas)
                    {
                        <option value="@v.Codigo">@v.Codigo - @v.Nombre</option>
                    }
                </select>
            </div>
        </div>
        <div class="rips-modal-f">
            <button class="btn btn-outline-secondary" @onclick="CerrarModalRips">Cancelar</button>
            <button class="btn btn-primary" @onclick="ConfirmarRipsYCrearAsync">
                &#128221; Iniciar historia
            </button>
        </div>
    </div>
}

<style>
    /* Grid externo de 3 columnas: paciente (320px) | chat WhatsApp (320px) | modulo
       de historias (1fr). Cada columna puede colapsar a 50px (paciente/chat) para
       que el modulo de historias respire en pantallas chicas. align-items: start
       permite que el chat se quede sticky cuando se hace scroll en la HC. */
    .hc-grid { display: grid; grid-template-columns: 320px 320px 1fr; gap: 14px; align-items: start; }
    .hc-grid.paciente-colapsado { grid-template-columns: 50px 320px 1fr; }
    .hc-grid.chat-colapsado { grid-template-columns: 320px 50px 1fr; }
    .hc-grid.paciente-colapsado.chat-colapsado { grid-template-columns: 50px 50px 1fr; }
    .hc-col { display: flex; flex-direction: column; gap: 14px; min-width: 0; min-height: 600px; }
    .hc-col-main { min-width: 0; }
    /* Chat WhatsApp: queda sticky al hacer scroll en la HC. Forzamos 600px de
       altura para que el panel sea generoso (thread amplio que crece via flex
       aunque no haya mensajes aun). Sticky top deja el panel fijo arriba al
       scrollear la HC. */
    .hc-chat-outer {
        display: flex; flex-direction: column; min-width: 0;
        border-radius: 8px; overflow: hidden;
        box-shadow: 0 1px 3px rgba(15,23,42,.08);
        position: sticky; top: 12px;
        height: 600px;
    }
    .hc-chat-outer > * { flex: 1; min-height: 0; }
    .hc-chat-outer.hc-chat-colapsado { height: 240px; }

    /* Franja vertical cuando la columna paciente esta colapsada. */
    .hc-paciente-strip { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; display: flex; align-items: flex-start; justify-content: center; padding-top: 12px; min-height: 600px; }
    .hc-paciente-expand { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 8px 4px; border: 1px solid #cbd5e1; background: #fff; border-radius: 8px; cursor: pointer; min-width: 36px; }
    .hc-paciente-expand:hover { background: #eef6ff; border-color: #1565c0; }
    .hc-paciente-expand-ico { font-size: 18px; }
    .hc-paciente-expand-text { font-size: 9px; font-weight: 700; color: #475569; writing-mode: vertical-rl; transform: rotate(180deg); letter-spacing: .04em; text-transform: uppercase; }
    .hc-col-toggle { background: rgba(255,255,255,.7); border: 1px solid #e2e8f0; color: #1e40af; padding: 0 8px; border-radius: 4px; cursor: pointer; font-size: 14px; line-height: 22px; }
    .hc-col-toggle:hover { background: #fff; border-color: #1565c0; }
    .hc-col > .ase-card:last-child { flex: 1; display: flex; flex-direction: column; min-height: 0; }
    .hc-col-full { flex: 1; display: flex; flex-direction: column; min-height: 0; }

    .hc-form { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .hc-form .ase-f-wide { grid-column: span 2; }
    .hc-form label { font-size: 11px; color: #475569; font-weight: 600; text-transform: uppercase; }

    .hc-list-card { min-height: 0; }
    .hc-list { overflow: auto; flex: 1; padding: 4px; max-height: 440px; }
    .hc-item { padding: 10px 12px; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 8px; background: #fff; cursor: pointer; position: relative; }
    .hc-item.sel { border-color: #1565c0; background: #eff6ff; }
    .hc-item-h { display: flex; justify-content: space-between; align-items: flex-start; }
    .hc-item-prof { font-size: 12.5px; color: #0f172a; }
    .hc-item-fecha { font-size: 11px; color: #64748b; margin-top: 2px; }
    .hc-item-obs { font-size: 11px; color: #475569; font-style: italic; margin-top: 6px; }
    .hc-item-pill { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 999px; margin-top: 6px; text-transform: uppercase; }
    .hc-est-abierta { background: #dbeafe; color: #1e40af; }
    .hc-est-cerrada { background: #dcfce7; color: #166534; }
    .hc-est-inactiva { background: #fee2e2; color: #991b1b; }
    .hc-item-menu { font-size: 20px; color: #64748b; padding: 0 6px; }

    .dropdown { position: relative; }
    .hc-menu { position: absolute; right: 0; top: 24px; background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; box-shadow: 0 4px 12px rgba(15,23,42,.1); min-width: 200px; z-index: 100; padding: 6px 0; }
    .hc-menu-h { font-size: 11px; font-weight: 700; color: #94a3b8; padding: 6px 12px; text-transform: uppercase; }
    .hc-menu-item { display: block; width: 100%; padding: 8px 12px; background: none; border: none; text-align: left; font-size: 12.5px; color: #0f172a; cursor: pointer; }
    .hc-menu-item:hover { background: #f1f5f9; }
    .hc-menu-item:disabled { color: #cbd5e1; cursor: not-allowed; }

    .hc-actions { display: flex; gap: 6px; padding: 10px 14px; border-bottom: 1px solid #e5e7eb; justify-content: flex-end; flex-wrap: wrap; align-items: center; }
    .hc-info-msg { padding: 8px 14px; background: #ecfdf5; border-left: 3px solid #16a34a; font-size: 12px; color: #166534; }
    /* Chip que se muestra cuando la HC esta Cerrada y el usuario NO tiene permiso para reabrirla. */
    .hc-est-lock { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 999px; font-size: 11.5px; font-weight: 600; background: #e2e8f0; color: #475569; }
    .hc-autosave { margin-left: auto; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; transition: background-color .25s, color .25s; }
    .hc-autosave-limpio    { background: #f1f5f9; color: #475569; }
    .hc-autosave-sucio     { background: #fef3c7; color: #92400e; }
    .hc-autosave-guardando { background: #dbeafe; color: #1e40af; }
    .hc-autosave-guardado  { background: #d1fae5; color: #065f46; }
    .hc-autosave-error     { background: #fee2e2; color: #991b1b; }
    .hc-buscar { padding: 12px 14px; }
    .hc-buscar-lbl { font-size: 11px; color: #6b7280; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
    .hc-buscar-row { display: flex; gap: 6px; margin-top: 4px; max-width: 520px; }
    .hc-buscar-row > input { flex: 1; }

    /* Menu lateral del modulo (reemplaza los tabs horizontales).
       Usamos !important porque hay reglas heredadas en app.css que aplican
       display:flex a .ase-card y vencen a la specificity de 2 clases. */
    /* Grid del modal interno (vuelve a 2 columnas tras sacar el chat al grid externo):
       menu lateral (izquierda) | cuerpo del tab (centro). */
    .hc-col-full.hc-with-menu { display: grid !important; grid-template-columns: 230px 1fr !important; grid-template-rows: 1fr; gap: 0; min-height: 0; }
    .hc-col-full.hc-with-menu.menu-colapsado { grid-template-columns: 56px 1fr !important; }
    .hc-side-menu { background: #f8fafc; border-right: 1px solid #e2e8f0; display: flex; flex-direction: column; overflow: hidden; }
    .hc-side-toggle { background: none; border: none; border-bottom: 1px solid #e2e8f0; padding: 10px 12px; font-size: 14px; color: #1565c0; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; text-align: left; }
    .hc-side-toggle:hover { background: #eef6ff; }
    .hc-side-toggle-lbl { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #475569; font-weight: 700; }
    .hc-side-nav { flex: 1; overflow-y: auto; padding: 6px 0; }
    .hc-side-item { display: flex; align-items: center; gap: 12px; width: 100%; padding: 10px 14px; background: none; border: none; border-left: 3px solid transparent; color: #334155; font-size: 12.5px; font-weight: 600; cursor: pointer; text-align: left; position: relative; transition: background .15s, border-color .15s; }
    .hc-side-item:hover { background: #eef6ff; }
    .hc-side-item.sel { background: #dbeafe; color: #1565c0; border-left-color: #1565c0; }
    .hc-side-icon { font-size: 16px; flex-shrink: 0; width: 22px; text-align: center; }
    .hc-side-lbl { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .hc-side-badge { background: #1565c0; color: #fff; font-size: 10px; font-weight: 700; padding: 1px 7px; border-radius: 999px; flex-shrink: 0; }
    .menu-colapsado .hc-side-lbl, .menu-colapsado .hc-side-badge { display: none; }
    .menu-colapsado .hc-side-item { justify-content: center; padding: 10px 6px; }
    .menu-colapsado .hc-side-toggle { justify-content: center; padding: 10px 6px; }
    /* Conservamos las clases tab por compat — escondidas (no se renderizan) */
    .hc-tabs { display: none; }
    .hc-tab { display: none; }
    .hc-tab.sel { display: none; }
    /* Badge con conteo dentro de la pestana (ej. cantidad de medicamentos en la orden). */
    .hc-tab-badge { display:inline-block; background:#1565c0; color:#fff; font-size:10px; font-weight:700; padding:1px 7px; border-radius:999px; margin-left:6px; vertical-align:middle; }
    .hc-tab-body { padding: 18px; flex: 1; overflow: auto; }
    .hc-empty-detail { padding: 60px 30px; }
    .hc-placeholder { padding: 30px; text-align: center; background: #f8fafc; border: 2px dashed #cbd5e1; border-radius: 12px; }
    .hc-placeholder-t { font-size: 14px; font-weight: 700; color: #0f172a; margin-bottom: 6px; }
    .hc-placeholder-d { font-size: 12.5px; color: #64748b; }

    .hc-form-padding { padding: 14px; }
    .hc-paciente-card { padding: 10px 12px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; }
    .hc-paciente-nm { font-weight: 700; color: #0f172a; font-size: 13px; }
    .hc-paciente-doc { font-family: monospace; font-size: 11.5px; color: #1e40af; margin-top: 2px; }
    .hc-paciente-card button { padding: 0 4px; font-size: 11px; margin-top: 4px; }

    /* Card que se muestra cuando el formato de historia viene fijado por el servicio
       asignado. Lo destacamos en amber para distinguirlo de los filtros normales. */
    .hc-forzado-card { border-left: 3px solid #f59e0b; }
    .hc-forzado-name { font-size: 13px; font-weight: 700; color: #92400e; margin-bottom: 4px; }

    /* Opcion del modal "Imprimir paquete": checkbox + label + sub-texto. */
    .hc-impr-opt { padding: 8px 10px; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 8px; background: #fff; }
    .hc-impr-opt label { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px; color: #0f172a; margin: 0; }
    .hc-impr-opt label input { margin: 0; }
    .hc-impr-opt label em { color: #64748b; font-style: normal; font-size: 11.5px; font-weight: 500; }
    .hc-impr-opt small { display: block; margin-left: 26px; color: #94a3b8; font-size: 11px; margin-top: 2px; }

    .cie-backdrop { position: fixed; inset: 0; background: rgba(15,23,42,.45); z-index: 950; }
    .cie-modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 720px; max-width: 95vw; max-height: 80vh; background: #fff; border-radius: 12px; box-shadow: 0 20px 60px rgba(15,23,42,.25); z-index: 951; display: flex; flex-direction: column; }
    .cie-modal-lg { width: 900px; }
    .cie-modal-h { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid #e2e8f0; }
    .cie-modal-h h3 { margin: 0; font-size: 16px; font-weight: 700; color: #0f172a; }
    .cie-modal-close { background: none; border: none; font-size: 22px; cursor: pointer; color: #64748b; }
