@page "/asignacion"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Visal.Application.Tenancy
@inject IAsignacionService Svc
@inject IPacienteService PacSvc
@inject IPaqueteService PaqSvc
@inject IAseguradoraService AseSvc
@inject ICuotaCopagoService CuotaSvc
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject IJSRuntime JS

<PageTitle>Asignacion de Servicios - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Operacion Clinica</div>
        <h1 class="ase-title">Asignacion de Servicios</h1>
    </div>
    @if (_tab == "wizard")
    {
        <button class="btn btn-warning btn-sm" @onclick="Reset">Nuevo</button>
    }
</div>

<div class="asg-tabs">
    <button class="asg-tab @(_tab == "wizard" ? "asg-tab-active" : "")"
            @onclick='() => SwitchTab("wizard")'>Registrar</button>
    <button class="asg-tab @(_tab == "listado" ? "asg-tab-active" : "")"
            @onclick='() => SwitchTab("listado")'>Listado</button>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@* _ok se renderiza dentro de la columna 3, antes de "Datos del servicio a agregar",
   para dar feedback contextual al lado de la accion. *@

@if (_tab == "wizard")
{
<div class="asg-grid">

    @* ============ COLUMNA 1: Paciente + servicios disponibles ============ *@
    <div class="asg-col">
        <div class="ase-card">
            <div class="ase-card-h">1. Agregar Servicios</div>

            <div class="ase-form">
                @* La fila de busqueda ocupa toda la columna 1 para dar aire al input + lupa + reset.
                   Numero Historia y Tipo doc quedan en una fila aparte (2 cols cada uno). *@
                <div class="ase-f ase-f-full">
                    <label>Numero Documento</label>
                    <div class="asg-input-row">
                        <input class="form-control form-control-sm mono" placeholder="Busqueda por identificacion"
                               value="@_docBusqueda" @oninput="e => _docBusqueda = e.Value?.ToString() ?? string.Empty" @onkeyup="OnDocKey" />
                        <button class="btn btn-outline-secondary btn-sm" title="Busqueda avanzada" @onclick="OpenBuscadorModal">&#128270;</button>
                        <button class="btn btn-primary btn-sm" title="Buscar" @onclick="BuscarPorDocumento">&#128269;</button>
                    </div>
                </div>
                <div class="ase-f ase-f-wide"><label>Numero Historia</label><input class="form-control form-control-sm mono asg-ro" readonly value="@_paciente?.NumeroDocumento" /></div>
                <div class="ase-f ase-f-wide"><label>Tipo doc</label><input class="form-control form-control-sm mono asg-ro" readonly value="@_paciente?.TipoDocumento" /></div>
                <div class="ase-f ase-f-full"><label>Nombre paciente</label><input class="form-control form-control-sm asg-ro" readonly value="@_paciente?.NombreCompleto" /></div>
                <div class="ase-f ase-f-wide"><label>Sede</label><input class="form-control form-control-sm asg-ro" readonly value="@_paciente?.Sede" /></div>
                <div class="ase-f ase-f-wide"><label>Municipio</label><input class="form-control form-control-sm asg-ro" readonly value="@_paciente?.Ciudad" /></div>
                <div class="ase-f ase-f-wide">
                    <label>Contratos</label>
                    <select class="form-select form-select-sm" value="@_contratoIdSel" @onchange="OnContratoChanged" disabled="@(_paciente == null)">
                        @if (_paciente is null)
                        {
                            <option value="">Carga un paciente primero</option>
                        }
                        else if (_paciente.Contratos.Count == 0)
                        {
                            <option value="">Paciente sin contratos configurados</option>
                        }
                        else
                        {
                            <option value="">Selecciona un contrato</option>
                            @for (var i = 0; i < _paciente.Contratos.Count; i++)
                            {
                                var c = _paciente.Contratos[i];
                                <option value="@c.ContratoId">@(i + 1). @c.CodigoContrato - @c.AseguradoraNombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="ase-f ase-f-wide">
                    <div class="asg-modulos">
                        @if (_modulos.Count == 0)
                        {
                            <span class="asg-muted">Selecciona un contrato para ver los modulos disponibles.</span>
                        }
                        else
                        {
                            @foreach (var m in _modulos)
                            {
                                <label class="asg-mod-radio">
                                    <input type="radio" name="modSvc" checked="@(m == _moduloSel)" @onchange="() => OnModuloChanged(m)" />
                                    <span>@m</span>
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="ase-card">
            <div class="ase-card-h">2. Seleccione el Servicio</div>
            <div class="ase-form">
                <div class="ase-f">
                    <label>Paquete</label>
                    <select class="form-select form-select-sm mono" @bind="_paqueteSel" @bind:after="StateHasChanged">
                        <option value="">(todos)</option>
                        @foreach (var p in _paquetesDisponibles)
                        {
                            <option value="@p.Codigo">@p.Codigo</option>
                        }
                    </select>
                </div>
                <div class="ase-f ase-f-full">
                    <label>Busqueda por servicio</label>
                    <input class="form-control form-control-sm" placeholder="Buscar por descripcion o codigo..."
                           value="@_filtroSvc" @oninput="e => _filtroSvc = e.Value?.ToString() ?? string.Empty" />
                </div>
            </div>
            <div class="asg-grid-wrap asg-grid-svc">
                @if (_serviciosVisibles.Count == 0)
                {
                    <div class="ase-empty">
                        @(_contratoIdSel == "" ? "Selecciona un contrato primero." :
                          _moduloSel == "" ? "Selecciona un modulo arriba (EQUIPOS, INSUMOS, ...)." :
                          "Sin servicios para esta combinacion.")
                    </div>
                }
                else
                {
                    <table class="table table-sm asg-tbl">
                        <thead>
                            <tr>
                                <th style="width:90px">Accion</th>
                                <th>CodServicio</th>
                                <th>CodInterno</th>
                                <th>Historia</th>
                                <th>Paquete</th>
                                <th>Descripcion</th>
                                <th>Clasificacion</th>
                                <th>Modulo</th>
                                <th>Modalidad</th>
                                <th class="text-end">Tarifa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _serviciosVisibles)
                            {
                                <tr class="@(_servicioSel?.Id == s.Id ? "asg-row-sel" : "")">
                                    <td><button class="btn btn-primary btn-sm" @onclick="() => PreseleccionarServicio(s)">Seleccionar</button></td>
                                    <td class="mono">@s.Codigo</td>
                                    <td class="mono">@s.CodigoInterno</td>
                                    <td class="mono">@s.Historia</td>
                                    <td class="mono">@s.PaqueteCodigo</td>
                                    <td>@s.Descripcion</td>
                                    <td>@s.Clasificacion</td>
                                    <td>@s.Modulo</td>
                                    <td>@s.Modalidad</td>
                                    <td class="text-end">@(s.Tarifa is decimal t ? $"$ {t:N0}" : "")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    @* ============ COLUMNA 2: Ultimos servicios agregados (BD del paciente) ============ *@
    <div class="asg-col">
        <div class="ase-card asg-col-full">
            <div class="ase-card-h">Ultimo servicios agregados</div>
            <div class="asg-historico">
                @if (_ultimas.Count == 0) { <div class="ase-empty">@(_paciente == null ? "Selecciona un paciente." : "Sin asignaciones previas.")</div> }
                @foreach (var u in _ultimas)
                {
                    var puedeEditar = !string.Equals(u.Estado, "Asignado", StringComparison.OrdinalIgnoreCase)
                                    && !string.Equals(u.Estado, "Cerrado", StringComparison.OrdinalIgnoreCase);
                    var puedeBorrar = puedeEditar;
                    <div class="asg-hist @(u.Id == _editandoId ? "asg-hist-editing" : "")">
                        <div class="asg-hist-h">
                            <div class="asg-hist-nm">@u.NombreServicio</div>
                            <div class="dropdown asg-hist-menu-wrap">
                                <button class="asg-hist-menu-btn" title="Acciones"
                                        @onclick="() => ToggleHistMenu(u.Id)" @onclick:stopPropagation="true">⋮</button>
                                @if (_menuHistAbierto == u.Id)
                                {
                                    <div class="asg-hist-menu" @onclick:stopPropagation="true">
                                        <button class="asg-hist-menu-item" disabled="@(!puedeEditar)"
                                                title="@(puedeEditar ? "Editar esta asignacion" : "Ya esta tomada por Coordinacion - no se puede editar")"
                                                @onclick="() => EditarAsignacion(u)">
                                            <span>&#9998;</span> Editar
                                        </button>
                                        <button class="asg-hist-menu-item" @onclick="() => CopiarProgramacion(u)">
                                            <span>&#128203;</span> Copiar programacion
                                        </button>
                                        <button class="asg-hist-menu-item asg-hist-menu-danger" disabled="@(!puedeBorrar)"
                                                title="@(puedeBorrar ? "Eliminar asignacion" : "Ya esta tomada por Coordinacion - no se puede eliminar desde aqui")"
                                                @onclick="() => EliminarUltimaAsync(u)">
                                            <span>&#128465;</span> Eliminar
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="asg-hist-sub">
                            <span class="asg-pill">@u.TipoServicio</span>
                            <span>Cant: @u.Cantidad</span>
                            <span>@u.FechaInicio.ToString("dd MMM")</span>
                            <span class="asg-state asg-st-@u.Estado.ToLower()">@u.Estado</span>
                        </div>
                        <div class="asg-hist-sub2">@u.ContratoCodigo · @u.CreadoEn.LocalDateTime.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ============ COLUMNA 3: Carrito "Servicios Agregados" ============ *@
    <div class="asg-col">
        <div class="ase-card">
            <div class="ase-card-h">3. Servicios Agregados (@_carrito.Count)</div>
            @* Botones del carrito en su propia fila, debajo del titulo. Asi no compiten por
               ancho con el titulo y no se desbordan a una segunda linea solo cuando se acomodan. *@
            <div class="asg-carrito-acts">
                <button class="btn btn-primary btn-sm" title="Eliminar items seleccionados" @onclick="EliminarSeleccionados" disabled="@(_carrito.Count == 0)">Eliminar items</button>
                <button class="btn btn-danger btn-sm" title="Limpiar carrito" @onclick="LimpiarCarrito" disabled="@(_carrito.Count == 0)">Limpiar items</button>
            </div>
            <div class="asg-carrito">
                @if (_carrito.Count == 0) { <div class="ase-empty">Sin servicios en el lote.</div> }
                @foreach (var c in _carrito)
                {
                    <div class="asg-cart-row">
                        <input type="checkbox" @bind="c.Seleccionado" />
                        <div class="asg-cart-info">
                            <div class="asg-cart-nm">@c.NombreServicio</div>
                            <div class="asg-cart-meta">Codigo: <code>@(c.Servicio.Codigo ?? "-")</code></div>
                            <div class="asg-cart-meta">Cantidad: <strong>@c.Cantidad</strong></div>
                            @if (!string.IsNullOrWhiteSpace(c.Observaciones))
                            {
                                <div class="asg-cart-meta asg-cart-obs">Obs: @c.Observaciones</div>
                            }
                            <div class="asg-cart-sub">
                                <span class="asg-pill">@c.TipoServicio</span>
                                <span>@c.FechaInicio.ToString("dd MMM")@(c.FechaFinal is DateOnly f ? " - " + f.ToString("dd MMM") : "")</span>
                                @if (!string.IsNullOrWhiteSpace(c.Autorizacion))
                                {
                                    <span>Aut: <code>@c.Autorizacion</code></span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* Mensaje contextual: aparece justo encima del bloque "Datos del servicio".
               Cubre los 3 momentos: preseleccion, agregado al carrito y guardado del lote. *@
            @if (_ok is not null) { <div class="ase-ok asg-svc-ok">@_ok</div> }

            <div class="ase-card-h" style="margin-top:14px;">Datos del servicio a agregar</div>
            @* Los campos del form son editables cuando hay paciente cargado, no requieren
               que se haya preseleccionado un servicio. Asi el operador puede ajustar la
               programacion (sea recien escrita o copiada desde una tarjeta) antes de
               elegir un servicio en la grilla. El boton Agregar si sigue gateado por
               la preseleccion de servicio, porque sin servicio no hay nada que agregar. *@
            <div class="ase-form asg-form-col3">
                <div class="ase-f"><label>Autorizacion</label><input class="form-control form-control-sm" @bind="_autorizacion" disabled="@(_paciente == null)" /></div>
                @if (_contratoSel is not null && _contratoSel.RequierePdfAutorizacion)
                {
                    <div class="ase-f ase-f-wide">
                        <label>
                            PDF de autorizacion <span class="asg-req-badge" title="El contrato exige adjuntar el PDF de autorizacion">obligatorio</span>
                        </label>
                        <div class="asg-input-row">
                            <InputFile OnChange="OnPdfUploaded" accept="application/pdf" class="form-control form-control-sm" disabled="@(_paciente == null)" />
                            @if (!string.IsNullOrWhiteSpace(_pdfAutorizacionUrl))
                            {
                                <a class="btn btn-outline-secondary btn-sm" href="@_pdfAutorizacionUrl" target="_blank" title="Ver PDF cargado">Ver</a>
                                <button class="btn btn-outline-danger btn-sm" @onclick="LimpiarPdf" type="button" title="Quitar PDF">&times;</button>
                            }
                        </div>
                        @if (_pdfBusy) { <div class="asg-hint">Subiendo PDF...</div> }
                        else if (!string.IsNullOrWhiteSpace(_pdfNombre))
                        {
                            <div class="asg-hint asg-hint-ok">@_pdfNombre cargado.</div>
                        }
                    </div>
                }
                @* ── Panel Cuota moderadora / Copago ──────────────────────── *@
                <div class="ase-f ase-f-wide">
                    <div class="asg-pago-head">
                        <span>Cuota moderadora / Copago</span>
                        @if (!string.IsNullOrWhiteSpace(_tipoPago))
                        {
                            <span class="asg-pago-badge">@_tipoPago @(_valorPagoReal is decimal r ? $"· ${r:N0}" : "")</span>
                        }
                        <button class="btn btn-outline-primary btn-sm ms-auto" type="button" @onclick="AbrirModalPago" disabled="@(_paciente == null)">
                            @(string.IsNullOrWhiteSpace(_tipoPago) ? "Registrar pago" : "Editar pago")
                        </button>
                        @if (!string.IsNullOrWhiteSpace(_tipoPago))
                        {
                            <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="LimpiarPago" title="Quitar informacion de pago">&times;</button>
                        }
                    </div>
                </div>
                <div class="ase-f"><label>INICIO</label><input type="date" class="form-control form-control-sm" @bind="_fechaInicio" disabled="@(_paciente == null)" /></div>
                <div class="ase-f"><label>FINAL</label><input type="date" class="form-control form-control-sm" @bind="_fechaFinal" disabled="@(_paciente == null)" /></div>
                <div class="ase-f"><label>Periodo (Año)</label>
                    <select class="form-select form-select-sm" @bind="_anio" disabled="@(_paciente == null)">
                        <option value="">--</option>
                        @for (int y = DateTime.Now.Year - 2; y <= DateTime.Now.Year + 2; y++) { <option value="@y">@y</option> }
                    </select>
                </div>
                <div class="ase-f"><label>Mes Vigencia</label>
                    <select class="form-select form-select-sm" @bind="_mesVig" disabled="@(_paciente == null)">
                        <option value="0">--</option>
                        @for (int m = 1; m <= 12; m++) { <option value="@m">@MesNombre(m)</option> }
                    </select>
                </div>
                <div class="ase-f"><label>Mes final</label>
                    <select class="form-select form-select-sm" @bind="_mesFin" disabled="@(_paciente == null)">
                        <option value="0">--</option>
                        @for (int m = 1; m <= 12; m++) { <option value="@m">@MesNombre(m)</option> }
                    </select>
                </div>
                <div class="ase-f ase-f-wide"><label>Observaciones</label><textarea class="form-control form-control-sm" @bind="_obs" rows="2" disabled="@(_paciente == null)"></textarea></div>
                @* Fila final: Cantidad + Agregar (de la izquierda) y Guardar registro a la
                   derecha, todos en linea. Ocupamos el ancho completo (ase-f-wide) y
                   dejamos que asg-input-row distribuya los 3 controles. *@
                <div class="ase-f ase-f-wide">
                    <label>Cantidad</label>
                    <div class="asg-input-row asg-final-row">
                        <input type="number" min="1" class="form-control form-control-sm asg-cant-inp" @bind="_cantidad" disabled="@(_paciente == null)" />
                        @if (_editandoId is null)
                        {
                            <button class="btn btn-primary btn-sm" @onclick="Agregar" disabled="@(_servicioSel == null)" title="@(_servicioSel == null ? "Selecciona primero un servicio en la grilla" : "Agregar al lote")">Agregar</button>
                            <button class="btn btn-primary btn-sm asg-guardar-btn" @onclick="Guardar" disabled="@(_busy || _carrito.Count == 0 || _paciente == null)">@(_busy ? "Guardando..." : "Guardar registro")</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelarEdicion" disabled="@_busy">Cancelar</button>
                            <button class="btn btn-primary btn-sm asg-guardar-btn" @onclick="GuardarEdicion" disabled="@(_busy || _servicioSel == null)">@(_busy ? "Guardando..." : "Guardar cambios")</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
}
else
{
    <div class="asg-listado">
        <div class="ase-card">
            <div class="ase-card-h">Filtros</div>
            <div class="ase-form asg-list-filtros">
                <div class="ase-f"><label>Fecha inicial</label>
                    <input type="date" class="form-control form-control-sm"
                           value="@_fFechaIni?.ToString("yyyy-MM-dd")"
                           @onchange="e => { _fFechaIni = DateOnly.TryParse(e.Value?.ToString(), out var d) ? d : null; }" />
                </div>
                <div class="ase-f"><label>Fecha final</label>
                    <input type="date" class="form-control form-control-sm"
                           value="@_fFechaFin?.ToString("yyyy-MM-dd")"
                           @onchange="e => { _fFechaFin = DateOnly.TryParse(e.Value?.ToString(), out var d) ? d : null; }" />
                </div>
                <div class="ase-f"><label>Aseguradora / EPS</label>
                    <select class="form-select form-select-sm" @bind="_fAseId">
                        <option value="">(todas)</option>
                        @foreach (var a in _aseguradorasFiltro)
                        {
                            <option value="@a.Id">@a.Nombre</option>
                        }
                    </select>
                </div>
                <div class="ase-f"><label>Contrato</label>
                    <select class="form-select form-select-sm" @bind="_fContratoCod">
                        <option value="">(todos)</option>
                        @foreach (var c in _todosContratos)
                        {
                            <option value="@c.CodigoContrato">@c.CodigoContrato - @c.AseguradoraNombre</option>
                        }
                    </select>
                </div>
                <div class="ase-f"><label>Tipo servicio (modulo)</label>
                    <select class="form-select form-select-sm" @bind="_fModulo">
                        <option value="">(todos)</option>
                        <option value="CONSULTAS">CONSULTAS</option>
                        <option value="ENFERMERIA">ENFERMERIA</option>
                        <option value="EQUIPOS">EQUIPOS</option>
                        <option value="INSUMOS">INSUMOS</option>
                        <option value="TERAPIAS">TERAPIAS</option>
                    </select>
                </div>
                <div class="ase-f"><label>Paciente (documento)</label>
                    <input class="form-control form-control-sm mono" placeholder="Cedula del paciente..."
                           @bind="_fDocumento" @bind:event="oninput" />
                </div>
                <div class="ase-f ase-f-wide"><label>Nombre servicio</label>
                    <input class="form-control form-control-sm" placeholder="Busca por descripcion del servicio..."
                           @bind="_fNombreServ" @bind:event="oninput" />
                </div>
                <div class="ase-f ase-f-wide">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="AplicarFiltrosListado" disabled="@_listBusy">
                            @(_listBusy ? "Buscando..." : "Aplicar filtros")
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarFiltrosListado">Limpiar</button>
                        <div class="ms-auto text-muted small">
                            @_listado.Count resultado(s)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="ase-card">
            <div class="ase-card-h">Asignaciones</div>
            <div class="table-responsive asg-list-wrap">
                <table class="table table-sm table-striped asg-list-tbl">
                    <thead>
                        <tr>
                            <th>Fecha creado</th>
                            <th>Documento</th>
                            <th>Paciente</th>
                            <th>Aseguradora</th>
                            <th>Contrato</th>
                            <th>Servicio</th>
                            <th>Modulo</th>
                            <th class="text-end">Cant</th>
                            <th>Estado</th>
                            <th>Vigencia</th>
                            <th>Fecha inicio</th>
                            <th>Autorizacion</th>
                            <th>Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_listado.Count == 0)
                        {
                            <tr><td colspan="13" class="text-center text-muted p-3">Sin resultados para los filtros aplicados.</td></tr>
                        }
                        @foreach (var a in _listado)
                        {
                            <tr>
                                <td class="mono">@a.CreadoEn.LocalDateTime.ToString("dd/MM/yy HH:mm")</td>
                                <td class="mono">@a.PacienteDocumento</td>
                                <td>@a.PacienteNombre</td>
                                <td>@(a.AseguradoraNombre ?? "-")</td>
                                <td class="mono">@a.ContratoCodigo</td>
                                <td>@a.NombreServicio</td>
                                <td>@(a.Modulo ?? a.TipoServicio)</td>
                                <td class="text-end">@a.Cantidad</td>
                                <td><span class="asg-state asg-st-@a.Estado.ToLower()">@a.Estado</span></td>
                                <td>@FormatVigencia(a.AnioServicio, a.MesVigencia, a.MesFinal)</td>
                                <td class="mono">@a.FechaInicio.ToString("dd/MM/yyyy")</td>
                                <td class="mono">@(a.CodigoAutorizacion ?? "")</td>
                                <td class="text-muted small">@(a.Observaciones ?? "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* ============ Modal CUOTA / COPAGO (botones grandes tipo tarjeta) ============ *@
@if (_modalPago)
{
    <div class="cie-backdrop" @onclick="CerrarModalPago"></div>
    <div class="cie-modal asg-pago-modal">
        <div class="cie-modal-h">
            <h3>Cuota moderadora / Copago</h3>
            <button class="cie-modal-close" @onclick="CerrarModalPago">&times;</button>
        </div>
        <div class="cie-modal-body">

            @* ── PASO 1: Tipo (3 botones grandes) ── *@
            <div class="asg-pago-step-label">1. Tipo de pago</div>
            <div class="asg-pago-tipo-grid">
                <button type="button"
                        class="asg-pago-tile asg-tile-neutral @(string.IsNullOrEmpty(_modalPagoTipo) ? "sel" : "")"
                        @onclick='() => SetPagoTipo("")'>
                    <div class="asg-tile-ico">&times;</div>
                    <div class="asg-tile-title">Sin cargo</div>
                    <div class="asg-tile-sub">El paciente no paga</div>
                </button>
                <button type="button"
                        class="asg-pago-tile asg-tile-cuota @(_modalPagoTipo == "CUOTA" ? "sel" : "")"
                        @onclick='() => SetPagoTipo("CUOTA")'>
                    <div class="asg-tile-ico">$</div>
                    <div class="asg-tile-title">Cuota moderadora</div>
                    <div class="asg-tile-sub">Regimen contributivo</div>
                </button>
                <button type="button"
                        class="asg-pago-tile asg-tile-copago @(_modalPagoTipo == "COPAGO" ? "sel" : "")"
                        @onclick='() => SetPagoTipo("COPAGO")'>
                    <div class="asg-tile-ico">&#128176;</div>
                    <div class="asg-tile-title">Copago</div>
                    <div class="asg-tile-sub">Regimen subsidiado</div>
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_modalPagoTipo))
            {
                @* ── PASO 2: Rango (una tarjeta por rango del catalogo) ── *@
                <div class="asg-pago-step-label">2. Rango salarial</div>
                <div class="asg-pago-rango-grid">
                    @foreach (var c in _catalogoPago.Where(x => x.Tipo == _modalPagoTipo))
                    {
                        var isSel = _modalPagoCategoria == c.Categoria;
                        <button type="button"
                                class="asg-pago-rango @(isSel ? "sel" : "")"
                                @onclick="() => SetPagoCategoria(c)">
                            <div class="asg-rango-cat">@c.Categoria</div>
                            <div class="asg-rango-val">$ @c.ValorSugerido.ToString("N0")</div>
                            @if (!string.IsNullOrWhiteSpace(c.Descripcion))
                            {
                                <div class="asg-rango-desc">@c.Descripcion</div>
                            }
                        </button>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_modalPagoCategoria))
                {
                    @* ── PASO 3: Valores editables ── *@
                    <div class="asg-pago-step-label">3. Valor a pagar</div>
                    <div class="asg-pago-valores">
                        <div class="asg-pago-val-box">
                            <label>Valor sugerido</label>
                            <input type="number" class="form-control asg-pago-input" @bind="_modalPagoSugerido" step="100" min="0" />
                        </div>
                        <div class="asg-pago-val-box asg-pago-val-real">
                            <label>Valor real pagado</label>
                            <input type="number" class="form-control asg-pago-input" @bind="_modalPagoReal" step="100" min="0" />
                        </div>
                    </div>
                }
            }
        </div>
        <div class="asg-pago-footer">
            <button class="btn btn-outline-secondary btn-lg" @onclick="CerrarModalPago">Cancelar</button>
            <button class="btn btn-primary btn-lg asg-pago-confirmar" @onclick="ConfirmarPago"
                    disabled="@(!string.IsNullOrEmpty(_modalPagoTipo) && string.IsNullOrEmpty(_modalPagoCategoria))">
                Confirmar
            </button>
        </div>
    </div>
}

@* ============ Modal BUSCAR PACIENTES (filtros + grid) ============ *@
@if (_modal)
{
    <div class="cie-backdrop" @onclick="CloseBuscadorModal"></div>
    <div class="cie-modal cie-modal-lg">
        <div class="cie-modal-h">
            <h3>BUSCAR PACIENTES</h3>
            <button class="cie-modal-close" @onclick="CloseBuscadorModal">&times;</button>
        </div>
        <div class="cie-modal-body">

            <div class="bp-section">
                <div class="bp-section-h"><span class="bp-filtro-ico">&#9776;</span> Filtros</div>
                <div class="bp-filtros">
                    <div class="bp-filtros-title">Filtrar Datos</div>
                    <div class="bp-filtros-grid">
                        <div class="bp-f bp-f-contrato">
                            <label>Contrato:</label>
                            <div class="bp-contratos-list">
                                @if (_modalContratos.Count == 0) { <div class="bp-muted">Sin contratos activos.</div> }
                                @foreach (var c in _modalContratos)
                                {
                                    <label class="bp-contrato-row">
                                        <input type="checkbox" checked="@_modalContratoSel.Contains(c.ContratoId)" @onchange="e => ToggleContratoModal(c.ContratoId, e)" />
                                        <span>@c.CodigoContrato - @c.AseguradoraNombre</span>
                                    </label>
                                }
                            </div>
                        </div>
                        <div class="bp-f">
                            <label>No Documento:</label>
                            <input class="form-control form-control-sm" @bind="_modalDoc" @onkeyup="OnModalKey" />
                        </div>
                        <div class="bp-f">
                            <label>Nombre:</label>
                            <input class="form-control form-control-sm" @bind="_modalNombre" @onkeyup="OnModalKey" />
                        </div>
                        <div class="bp-f">
                            <label>Telefono:</label>
                            <input class="form-control form-control-sm" @bind="_modalTel" @onkeyup="OnModalKey" />
                        </div>
                        <div class="bp-f">
                            <label>Correo:</label>
                            <input class="form-control form-control-sm" @bind="_modalCorreo" @onkeyup="OnModalKey" />
                        </div>
                    </div>
                    <div class="bp-actions">
                        <button class="btn btn-primary btn-sm" @onclick="BuscarEnModal" disabled="@_modalBusy">@(_modalBusy ? "..." : "Aplicar filtro")</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarFiltrosModal">Limpiar Filtro</button>
                    </div>
                </div>
            </div>

            <div class="bp-results">
                <table class="table table-sm bp-grid">
                    <thead>
                        <tr>
                            <th style="width:50px"></th>
                            <th>Documento</th>
                            <th>Nombre Paciente</th>
                            <th>Contrato</th>
                            <th>Telefono</th>
                            <th>Correo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_modalGrid.Count == 0)
                        {
                            <tr><td colspan="6" class="bp-empty">@(_modalBusy ? "Buscando..." : "Aplica un filtro para ver pacientes.")</td></tr>
                        }
                        else
                        {
                            @foreach (var r in _modalGrid)
                            {
                                <tr>
                                    <td><button class="btn btn-primary btn-sm" title="Seleccionar" @onclick="() => PickPacienteFromGrid(r)">&#10003;</button></td>
                                    <td class="mono">@r.Documento</td>
                                    <td>@r.NombreCompleto</td>
                                    <td>@(r.Contrato ?? "-")</td>
                                    <td>@(r.Telefono ?? "-")</td>
                                    <td>@(r.Correo ?? "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<style>
    /* Tabs primarias de /asignacion (Registrar | Listado). Estilo minimal alineado con la HC. */
    .asg-tabs { display:flex; gap:2px; border-bottom:2px solid #e2e8f0; margin: 0 0 14px; }
    .asg-tab { background:transparent; border:0; padding:8px 18px; font-size:13px; font-weight:600; color:#64748b; border-bottom:2px solid transparent; margin-bottom:-2px; cursor:pointer; }
    .asg-tab:hover { color:#1565c0; }
    .asg-tab-active { color:#1565c0; border-bottom-color:#1565c0; }
    /* Tab Listado */
    .asg-listado { display:flex; flex-direction:column; gap:14px; }
    .asg-list-filtros { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .asg-list-filtros .ase-f-wide { grid-column: span 4; }
    .asg-list-wrap { max-height: calc(100vh - 380px); overflow:auto; }
    .asg-list-tbl { font-size:12px; }
    .asg-list-tbl th { position:sticky; top:0; background:#f8fafc; z-index:1; font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:0.03em; color:#475569; }
    .asg-list-tbl td { vertical-align:top; padding:6px 8px; }
    .asg-list-tbl .mono { font-family: ui-monospace, "Cascadia Code", monospace; font-size:11px; }
    .asg-hist-editing { outline:2px solid #1565c0; outline-offset:2px; }
    .asg-req-badge { display:inline-block; margin-left:6px; padding:1px 8px; border-radius:999px; background:#fef3c7; color:#92400e; font-size:10px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
    .asg-pago-head { display:flex; align-items:center; gap:8px; padding:8px 12px; border:1px solid #e2e8f0; border-radius:6px; background:#f8fafc; font-size:12px; font-weight:600; color:#334155; }
    .asg-pago-badge { display:inline-block; padding:2px 8px; border-radius:999px; background:#dbeafe; color:#1e40af; font-size:11px; font-weight:600; }
    /* ── Modal de pago con botones grandes ────────────────────────────── */
    .asg-pago-modal { max-width: 760px; }
    .asg-pago-step-label { font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#64748b; margin:14px 4px 8px; }
    .asg-pago-step-label:first-child { margin-top: 4px; }
    .asg-pago-tipo-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:12px; }
    .asg-pago-tile { display:flex; flex-direction:column; align-items:center; justify-content:center;
                     min-height: 130px; padding:16px 12px; gap:6px; border-radius:14px;
                     border:2px solid #e2e8f0; background:#fff; cursor:pointer; transition:all .15s ease;
                     text-align:center; box-shadow: 0 1px 2px rgba(15,23,42,.04); }
    .asg-pago-tile:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(15,23,42,.10); }
    .asg-pago-tile.sel { border-width:3px; box-shadow: 0 8px 24px rgba(21,101,192,.20); transform: translateY(-2px); }
    .asg-tile-ico { font-size:34px; line-height:1; margin-bottom:2px; }
    .asg-tile-title { font-size:15px; font-weight:700; color:#0f172a; }
    .asg-tile-sub { font-size:11px; color:#64748b; }
    /* Colores por tipo */
    .asg-tile-neutral .asg-tile-ico { color:#94a3b8; }
    .asg-tile-neutral.sel { border-color:#94a3b8; background:#f8fafc; }
    .asg-tile-cuota .asg-tile-ico { color:#1565c0; }
    .asg-tile-cuota.sel { border-color:#1565c0; background:#eff6ff; }
    .asg-tile-cuota.sel .asg-tile-title { color:#1565c0; }
    .asg-tile-copago .asg-tile-ico { color:#059669; }
    .asg-tile-copago.sel { border-color:#059669; background:#ecfdf5; }
    .asg-tile-copago.sel .asg-tile-title { color:#059669; }
    /* Rangos */
    .asg-pago-rango-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:10px; }
    .asg-pago-rango { display:flex; flex-direction:column; gap:4px; padding:14px; border-radius:12px;
                      border:2px solid #e2e8f0; background:#fff; cursor:pointer; transition:all .15s ease; text-align:center; }
    .asg-pago-rango:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(15,23,42,.08); border-color:#cbd5e1; }
    .asg-pago-rango.sel { border-color:#1565c0; background:#eff6ff; box-shadow: 0 6px 20px rgba(21,101,192,.18); }
    .asg-rango-cat { font-size:12px; font-weight:700; color:#475569; letter-spacing:0.03em; }
    .asg-rango-val { font-size:22px; font-weight:800; color:#1565c0; font-variant-numeric: tabular-nums; }
    .asg-pago-rango.sel .asg-rango-val { color:#0d47a1; }
    .asg-rango-desc { font-size:11px; color:#64748b; }
    /* Valores editables */
    .asg-pago-valores { display:grid; grid-template-columns: 1fr 1fr; gap:12px; }
    .asg-pago-val-box { display:flex; flex-direction:column; gap:6px; padding:12px 14px; border-radius:12px; background:#f8fafc; border:1px solid #e2e8f0; }
    .asg-pago-val-box label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:#64748b; margin:0; }
    .asg-pago-val-real { background:#eff6ff; border-color:#bfdbfe; }
    .asg-pago-input { font-size:22px; font-weight:700; text-align:right; padding:8px 12px; height:auto; font-variant-numeric: tabular-nums; }
    .asg-pago-footer { display:flex; justify-content:flex-end; gap:10px; padding:14px 20px; border-top:1px solid #e2e8f0; }
