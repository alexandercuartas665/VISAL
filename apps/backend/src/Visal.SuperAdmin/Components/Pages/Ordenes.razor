</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // Tab secundario activo — "lista", "kanban" o "archivo". Ver Ola 2 Capa 08.
    private string _tabActivo = "lista";

    // ── Estado del tablero Kanban (Ola 2 Capa 08) ────────────────────────
    private RevisionKanbanBoardDto? _board;
    private bool _cargandoKanban;
    private bool _procesando;
    private string? _kanbanError;
    private RevisionKanbanCardDto? _cardArrastrada;
    private RevisionKanbanCardDto? _cardEnAccion;
    private bool _showRechazoModal;
    private string _rechazoMotivo = "";
    private string _rechazoNota = "";
    private bool _showArchivarModal;
    private ArchivarSabor _archivarSabor = ArchivarSabor.Ok;
    private string _archivarMotivo = "";
    private bool _puedeRevisar;
    private bool _puedeAprobarFinal;
    private Guid _actorId;

    // ── Estado del tab Dashboard (Ola 7 RC7a) ────────────────────────────
    private RevisionDashboardDto? _dashboard;
    private bool _cargandoDashboard;

    // ── Filtros del tab Kanban (Ola 7 RC7d) ──────────────────────────────
    private string _kbFiltroEspecialista = "";
    private DateTime? _kbFiltroDesde;
    private DateTime? _kbFiltroHasta;

    // ── Estado del tab Archivo (RC2d) ────────────────────────────────────
    private List<RevisionArchivoItemDto> _archivo = new();
    private bool _cargandoArchivo;
    private string _archPaciente = "";
    private string _archSabor = ""; // "", "ArchivadaOk", "Inactivada"
    private DateTime? _archDesde;
    private DateTime? _archHasta;

    private string _filtroPaciente = "";
    private DateTime? _desde;
    private DateTime? _hasta;
    private string _especialista = "";
    private string _estadoFiltro = ""; // "", "Cerrada", "Abierta"
    private List<string> _especialistas = new();
    private List<OrdenClinicaItemDto> _rows = new();
    private bool _buscando;

    // Kebab de acciones en cada fila: guarda el id de la HC cuyo menu esta abierto
    // (o null si ninguno). Solo un menu abierto a la vez para simplificar.
    private Guid? _kebabRowId;

    // Modal grande "Ver revision": iframe con la impresion de la HC a la izquierda
    // y HcRevisionPanel a la derecha (bitacora + aprobar/rechazar).
    private bool _showRevisionModal;
    private Guid? _revisionModalHcId;
    private string _revisionModalDocs = "";

    // Estado del modal de impresion
    private bool _showImprimirModal;
    private OrdenClinicaItemDto? _rowSel;
    private string? _modalErr;
    private bool _selHc = true, _selMed, _selSrv, _selIns, _selRem, _selRxExt, _selLabExt, _selInsExt, _selInc, _selCert, _selEsc, _selEvo, _selCon;

    protected override async Task OnInitializedAsync()
    {
        _especialistas = (await OcSvc.ListarEspecialistasAsync()).ToList();
        await ResolverPermisosAsync();
        await Buscar();
    }

    /// <summary>
    /// Determina si el usuario puede revisar / aprobar final del ciclo Kanban.
    /// Sigue el mismo patron que Admision.ResolverPuedeReabrirAsync: Owner/Admin
    /// del tenant y SuperAdmin de plataforma tienen ambos permisos implicitos.
    /// </summary>
    private async Task ResolverPermisosAsync()
    {
        if (AuthState is null) { _puedeRevisar = false; _puedeAprobarFinal = false; return; }
        try
        {
            var state = await AuthState;
            var tenantRole = state.User.FindFirst("tenant_role")?.Value;
            var platformRole = state.User.FindFirst("platform_role")?.Value;
            var esAdminTenant = string.Equals(tenantRole, "Owner", StringComparison.OrdinalIgnoreCase)
                             || string.Equals(tenantRole, "Admin", StringComparison.OrdinalIgnoreCase);
            var esSuperAdmin = string.Equals(platformRole, "SuperAdmin", StringComparison.OrdinalIgnoreCase);
            var perms = (state.User.FindFirst("perms")?.Value ?? "")
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(p => p.Trim())
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            var implicito = esAdminTenant || esSuperAdmin;
            _puedeRevisar = implicito || perms.Contains("historias.revisar");
            _puedeAprobarFinal = implicito || perms.Contains("historias.revisar.aprobar_final");
            var uidStr = state.User.FindFirst("user_id")?.Value
                        ?? state.User.FindFirst("sub")?.Value;
            _actorId = Guid.TryParse(uidStr, out var uid) ? uid : Guid.Empty;
        }
        catch
        {
            _puedeRevisar = false; _puedeAprobarFinal = false;
        }
    }

    private async Task Buscar()
    {
        _buscando = true;
        try
        {
            // SoloCerradas se resuelve segun el filtro visual: por defecto trae
            // todas, pero el usuario puede restringir a solo cerradas o solo
            // abiertas. Para "solo abiertas" pedimos todas y filtramos en memoria
            // ya que el DTO trae Estado. Es simple y N<=500.
            var f = new OrdenesClinicasFiltro(
                PacienteTexto: string.IsNullOrWhiteSpace(_filtroPaciente) ? null : _filtroPaciente.Trim(),
                Desde: _desde is DateTime d1 ? DateOnly.FromDateTime(d1) : (DateOnly?)null,
                Hasta: _hasta is DateTime d2 ? DateOnly.FromDateTime(d2) : (DateOnly?)null,
                Especialista: string.IsNullOrWhiteSpace(_especialista) ? null : _especialista,
                SoloCerradas: string.Equals(_estadoFiltro, "Cerrada", StringComparison.OrdinalIgnoreCase));
            var todas = (await OcSvc.BuscarAsync(f)).ToList();
            if (string.Equals(_estadoFiltro, "Abierta", StringComparison.OrdinalIgnoreCase))
            {
                todas = todas.Where(x => string.Equals(x.Estado, "Abierta", StringComparison.OrdinalIgnoreCase)).ToList();
            }
            _rows = todas;
        }
        finally { _buscando = false; }
    }

    private async Task OnKeyup(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { await Buscar(); }
    }

    private async Task Limpiar()
    {
        _filtroPaciente = ""; _desde = null; _hasta = null; _especialista = ""; _estadoFiltro = "";
        await Buscar();
    }

    /// <summary>Consultar: abre el paquete completo (todos los docs) en vista read-only.</summary>
    private async Task Consultar(OrdenClinicaItemDto r)
    {
        var docs = BuildAllDocsQuery(r);
        await JS.InvokeVoidAsync("open", $"/imprimir-paquete/{r.HistoriaClinicaId}?docs={docs}", "_blank");
    }

    /// <summary>Abre el modal para que el usuario elija que documentos imprimir.</summary>
    private void AbrirModalImprimir(OrdenClinicaItemDto r)
    {
        _rowSel = r;
        _modalErr = null;
        // Preselecciona todo lo que tiene datos (HC siempre, resto segun count).
        _selHc = true;
        _selMed = r.MedicamentosCount > 0;
        _selSrv = r.ServiciosCount > 0;
        _selIns = r.InsumosCount > 0;
        _selRem = r.RemisionesCount > 0;
        _selRxExt = r.RxImagCount > 0;
        _selLabExt = r.LabExtCount > 0;
        _selInsExt = r.InsExtCount > 0;
        _selInc = r.IncapacidadesCount > 0;
        _selCert = r.CertificacionesCount > 0;
        _selEsc = r.EscalasCount > 0;
        _selEvo = r.EvolucionesCount > 0;
        _selCon = r.ConsentimientosCount > 0;
        _showImprimirModal = true;
    }

    private void CerrarModalImprimir()
    {
        _showImprimirModal = false;
        _rowSel = null;
        _modalErr = null;
    }

    /// <summary>Confirmacion del modal: abre /imprimir-paquete con los seleccionados y dispara print.</summary>
    private async Task ConfirmarImprimir()
    {
        if (_rowSel is null) { CerrarModalImprimir(); return; }
        var docs = new List<string>();
        if (_selHc)     { docs.Add("HC"); }
        if (_selMed)    { docs.Add("MED"); }
        if (_selSrv)    { docs.Add("SRV"); }
        if (_selIns)    { docs.Add("INS"); }
        if (_selRem)    { docs.Add("REM"); }
        if (_selRxExt)  { docs.Add("RXEXT"); }
        if (_selLabExt) { docs.Add("LABEXT"); }
        if (_selInsExt) { docs.Add("INSEXT"); }
        if (_selInc)    { docs.Add("INC"); }
        if (_selCert)   { docs.Add("CERT"); }
        if (_selEsc)    { docs.Add("ESC"); }
        if (_selEvo)    { docs.Add("EVO"); }
        if (_selCon)    { docs.Add("CON"); }
        if (docs.Count == 0) { _modalErr = "Selecciona al menos un documento."; return; }
        var url = $"/imprimir-paquete/{_rowSel.HistoriaClinicaId}?docs={string.Join(",", docs)}#print=1";
        _showImprimirModal = false;
        _rowSel = null;
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    /// <summary>Cambia entre los tabs secundarios (Ola 2 + Ola 7). El tab Lista es el default.</summary>
    private async Task SeleccionarTab(string tab)
    {
        _tabActivo = tab;
        _kanbanError = null;
        if (tab == "kanban" && _board is null)
        {
            await RefrescarKanban();
        }
        else if (tab == "archivo" && _archivo.Count == 0)
        {
            await RefrescarArchivo();
        }
        else if (tab == "dashboard" && _dashboard is null)
        {
            await RefrescarDashboard();
        }
    }

    /// <summary>
    /// Ola 7 RC7b — dispara la descarga del CSV del tab Archivo con los filtros
    /// actuales. Construye la URL del endpoint minimal API y navega en una
    /// nueva ventana para que el browser maneje el download.
    /// </summary>
    private async Task DescargarArchivoCsv()
    {
        var qs = new List<string>();
        if (!string.IsNullOrWhiteSpace(_archPaciente)) { qs.Add("paciente=" + Uri.EscapeDataString(_archPaciente.Trim())); }
        if (!string.IsNullOrWhiteSpace(_archSabor)) { qs.Add("sabor=" + Uri.EscapeDataString(_archSabor)); }
        if (_archDesde is DateTime d1) { qs.Add("desde=" + d1.ToString("yyyy-MM-dd")); }
        if (_archHasta is DateTime d2) { qs.Add("hasta=" + d2.ToString("yyyy-MM-dd")); }
        var url = "/revision/archivo/export.csv" + (qs.Count > 0 ? "?" + string.Join("&", qs) : "");
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    /// <summary>Ola 7 RC7a — carga las metricas del Dashboard de /ordenes.</summary>
    private async Task RefrescarDashboard()
    {
        if (_cargandoDashboard) { return; }
        _cargandoDashboard = true;
        try
        {
            _dashboard = await DashboardSvc.GetAsync();
        }
        catch (Exception ex)
        {
            _kanbanError = "No se pudo cargar el dashboard: " + ex.Message;
        }
        finally { _cargandoDashboard = false; }
    }

    /// <summary>Carga el listado del tab Archivo con los filtros actuales.</summary>
    private async Task RefrescarArchivo()
    {
        if (_cargandoArchivo) { return; }
        _cargandoArchivo = true;
        _kanbanError = null;
        try
        {
            RevisionEstadoAgregado? saborFiltro = _archSabor switch
            {
                "ArchivadaOk" => RevisionEstadoAgregado.ArchivadaOk,
                "Inactivada" => RevisionEstadoAgregado.Inactivada,
                _ => null,
            };
            var filtro = new RevisionArchivoFiltro(
                PacienteTexto: string.IsNullOrWhiteSpace(_archPaciente) ? null : _archPaciente.Trim(),
                Sabor: saborFiltro,
                FechaDesde: _archDesde is DateTime d1 ? DateOnly.FromDateTime(d1) : null,
                FechaHasta: _archHasta is DateTime d2 ? DateOnly.FromDateTime(d2) : null);
            _archivo = (await KanbanSvc.GetArchivoAsync(filtro)).ToList();
        }
        catch (Exception ex)
        {
            _kanbanError = "No se pudo cargar el archivo: " + ex.Message;
        }
        finally { _cargandoArchivo = false; }
    }

    // ── Kanban: carga + drag&drop + acciones ─────────────────────────────

    /// <summary>
    /// Ejecuta la pre-revision IA sobre la HC del card. Si la card aun no tiene ciclo,
    /// lo abre on-demand (idempotente). Persiste un evento `PreRevisionAgente` en la
    /// bitacora sin cambiar el estado agregado — el reviewer humano sigue decidiendo.
    /// </summary>
    private async Task EjecutarPreRevisionIa(RevisionKanbanCardDto card)
    {
        if (_procesando) { return; }
        _procesando = true;
        _kanbanError = null;
        try
        {
            var revisionId = card.RevisionId ?? (await KanbanSvc.SolicitarSiFaltaAsync(card.HistoriaClinicaId, _actorId)).Id;
            var res = await PreIaSvc.EjecutarAsync(revisionId);
            if (!res.Ok)
            {
                _kanbanError = "Pre-revision IA: " + (res.Error ?? "error desconocido");
            }
            await RefrescarKanban();
        }
        catch (Exception ex)
        {
            _kanbanError = "Pre-revision IA fallo: " + ex.Message;
        }
        finally { _procesando = false; }
    }

    private async Task RefrescarKanban()
    {
        if (_cargandoKanban) { return; }
        _cargandoKanban = true;
        _kanbanError = null;
        try
        {
            // Ola 7 RC7d — pasa filtros del toolbar al servicio.
            var filtro = new RevisionKanbanFiltro(
                EspecialistaNombre: string.IsNullOrWhiteSpace(_kbFiltroEspecialista) ? null : _kbFiltroEspecialista,
                FechaDesde: _kbFiltroDesde is DateTime d1 ? DateOnly.FromDateTime(d1) : null,
                FechaHasta: _kbFiltroHasta is DateTime d2 ? DateOnly.FromDateTime(d2) : null);
            _board = await KanbanSvc.GetBoardAsync(filtro);
        }
        catch (Exception ex)
        {
            _kanbanError = "No se pudo cargar el tablero: " + ex.Message;
        }
        finally { _cargandoKanban = false; }
    }

    /// <summary>Ola 7 RC7d — recarga el Kanban aplicando los filtros del toolbar.</summary>
    private Task AplicarFiltrosKanban() => RefrescarKanban();

    /// <summary>Ola 7 RC7d — limpia todos los filtros y recarga.</summary>
    private async Task LimpiarFiltrosKanban()
    {
        _kbFiltroEspecialista = "";
        _kbFiltroDesde = null;
        _kbFiltroHasta = null;
        await RefrescarKanban();
    }

    private void OnDragStart(RevisionKanbanCardDto card)
    {
        _cardArrastrada = card;
        _kanbanError = null;
    }

    private void OnDragEnd()
    {
        _cardArrastrada = null;
    }

    /// <summary>Ejecuta el drop en la columna destino, con validacion de permisos y motivo.</summary>
    private async Task OnDropColumnaAsync(RevisionKanbanColumna destino)
    {
        var card = _cardArrastrada;
        if (card is null) { return; }
        _cardArrastrada = null;

        if (card.Columna == destino) { return; }
        if (destino == RevisionKanbanColumna.Abiertas)
        {
            _kanbanError = "No se puede mover una revision a Abiertas — esa columna refleja HCs abiertas por el profesional.";
            return;
        }
        if (!_puedeRevisar)
        {
            _kanbanError = "No tienes permiso historias.revisar para mover cards.";
            return;
        }

        if (card.RevisionId is null)
        {
            // La HC aun no entra al ciclo — la creamos on-demand para permitir el drag.
            var rev = await KanbanSvc.SolicitarSiFaltaAsync(card.HistoriaClinicaId, _actorId);
            card = card with { RevisionId = rev.Id };
        }

        // Rechazar exige motivo — abrimos modal.
        if (destino == RevisionKanbanColumna.Rechazadas)
        {
            _cardEnAccion = card;
            _rechazoMotivo = "";
            _rechazoNota = "";
            _showRechazoModal = true;
            return;
        }

        await EjecutarMoverCardAsync(card, destino, motivo: null, nota: null);
    }

    private async Task EjecutarMoverCardAsync(RevisionKanbanCardDto card, RevisionKanbanColumna destino, string? motivo, string? nota)
    {
        if (card.RevisionId is null) { return; }
        _procesando = true;
        _kanbanError = null;
        try
        {
            await KanbanSvc.MoverCardAsync(
                new MoverCardCmd(card.RevisionId.Value, destino, _actorId, motivo, nota),
                tienePermisoRevisar: _puedeRevisar);
            await RefrescarKanban();
        }
        catch (Exception ex)
        {
            _kanbanError = ex.Message;
        }
        finally { _procesando = false; }
    }

    private void CerrarRechazoModal()
    {
        _showRechazoModal = false;
        _cardEnAccion = null;
        _rechazoMotivo = "";
        _rechazoNota = "";
    }

    private async Task ConfirmarRechazoAsync()
    {
        if (_cardEnAccion is null || string.IsNullOrWhiteSpace(_rechazoMotivo)) { return; }
        var card = _cardEnAccion;
        var motivo = _rechazoMotivo;
        var nota = string.IsNullOrWhiteSpace(_rechazoNota) ? null : _rechazoNota;
        CerrarRechazoModal();
        await EjecutarMoverCardAsync(card, RevisionKanbanColumna.Rechazadas, motivo, nota);
    }

    private void AbrirModalArchivar(RevisionKanbanCardDto card)
    {
        if (!_puedeAprobarFinal)
        {
            _kanbanError = "No tienes permiso historias.revisar.aprobar_final para archivar.";
            return;
        }
        _cardEnAccion = card;
        _archivarSabor = ArchivarSabor.Ok;
        _archivarMotivo = "";
        _showArchivarModal = true;
    }

    private void CerrarArchivarModal()
    {
        _showArchivarModal = false;
        _cardEnAccion = null;
        _archivarMotivo = "";
    }

    private async Task ConfirmarArchivarAsync(Guid revisionId)
    {
        if (_archivarSabor == ArchivarSabor.Inactivar && string.IsNullOrWhiteSpace(_archivarMotivo)) { return; }
        _procesando = true;
        _kanbanError = null;
        try
        {
            await KanbanSvc.ArchivarAsync(
                new ArchivarKanbanCmd(revisionId, _archivarSabor, _actorId,
                    string.IsNullOrWhiteSpace(_archivarMotivo) ? null : _archivarMotivo),
                tienePermisoFinal: _puedeAprobarFinal);
            CerrarArchivarModal();
            await RefrescarKanban();
        }
        catch (Exception ex)
        {
            _kanbanError = ex.Message;
        }
        finally { _procesando = false; }
    }

    private static string ColumnaLabel(RevisionKanbanColumna col) => col switch
    {
        RevisionKanbanColumna.Abiertas => "Abiertas",
        RevisionKanbanColumna.Cerradas => "Cerradas",
        RevisionKanbanColumna.Rechazadas => "Rechazadas",
        RevisionKanbanColumna.Aprobadas => "Aprobadas",
        _ => col.ToString(),
    };

    private static (string txt, string cls, string title) AgenteBadge(RevisionResultado r) => r switch
    {
        RevisionResultado.Aprobado => ("IA ✓", "oc-kb-badge-ag-ok", "Agente sugiere aprobar"),
        RevisionResultado.Rechazado => ("IA ✗", "oc-kb-badge-ag-rej", "Agente sugiere rechazar"),
        RevisionResultado.Neutral => ("IA ~", "oc-kb-badge-ag-neu", "Agente sin veredicto claro"),
        _ => ("", "", ""),
    };

    private static string FormatearDuracion(TimeSpan t)
    {
        if (t.TotalDays >= 1) { return $"{(int)t.TotalDays}d {t.Hours}h"; }
        if (t.TotalHours >= 1) { return $"{(int)t.TotalHours}h {t.Minutes}m"; }
        return $"{(int)t.TotalMinutes}m";
    }

    /// <summary>Abre el modal grande de revision: HC impresa a la izquierda +
    /// panel de revision (bitacora + aprobar/rechazar) a la derecha. El panel
    /// reutiliza el componente <see cref="Visal.SuperAdmin.Components.Forms.HcRevisionPanel"/>
    /// que ya vive en el modal HC.</summary>
    private void AbrirRevision(OrdenClinicaItemDto r)
    {
        _revisionModalHcId = r.HistoriaClinicaId;
        _revisionModalDocs = BuildAllDocsQuery(r);
        _showRevisionModal = true;
    }

    private async Task CerrarRevisionModalAsync()
    {
        _showRevisionModal = false;
        _revisionModalHcId = null;
        _revisionModalDocs = "";
        // Refresca la tabla para reflejar cambios de estado (aprobado/rechazado
        // pudo ocurrir dentro del panel via HcRevisionPanel).
        await Buscar();
    }

    // ─────────────── Kebab de acciones ───────────────

    private void ToggleKebab(Guid rowId)
    {
        _kebabRowId = _kebabRowId == rowId ? null : rowId;
    }

    /// <summary>Cierra el kebab y ejecuta la accion sincrona. Uso: acciones de UI
    /// que no requieren await (abrir modal, navegar).</summary>
    private void KebabRun(Action action)
    {
        _kebabRowId = null;
        action();
    }

    /// <summary>Sobrecarga async — cierra el kebab y espera la accion.</summary>
    private async Task KebabRun(Func<Task> action)
    {
        _kebabRowId = null;
        await action();
    }

    /// <summary>Wrapper explicito async para el pattern @@onclick que espera Task.</summary>
    private async Task KebabRunAsync(Func<Task> action)
    {
        _kebabRowId = null;
        await action();
    }

    /// <summary>Aprueba desde la tabla: reusa el mismo pipe del Kanban
    /// (`EjecutarMoverCardAsync` mueve a Aprobadas). Si la HC aun no tiene
    /// revision, `EjecutarMoverCardAsync`/`MoverCardAsync` la crea on-demand
    /// via el mismo helper que usa el drag&drop del Kanban.</summary>
    private async Task AprobarDesdeTablaAsync(OrdenClinicaItemDto r)
    {
        if (!_puedeRevisar) { return; }
        var card = CardDesdeRow(r);
        if (card.RevisionId is null)
        {
            var rev = await KanbanSvc.SolicitarSiFaltaAsync(card.HistoriaClinicaId, _actorId);
            card = card with { RevisionId = rev.Id };
        }
        await EjecutarMoverCardAsync(card, RevisionKanbanColumna.Aprobadas, motivo: null, nota: null);
        await Buscar();
    }

    /// <summary>Rechaza desde la tabla: abre el mismo modal de motivo que usa el
    /// drag&drop del Kanban. `ConfirmarRechazoAsync` finaliza el movimiento.</summary>
    private void RechazarDesdeTabla(OrdenClinicaItemDto r)
    {
        if (!_puedeRevisar) { return; }
        _cardEnAccion = CardDesdeRow(r);
        _rechazoMotivo = "";
        _rechazoNota = "";
        _showRechazoModal = true;
    }

    /// <summary>Construye un card minimo desde la fila para reusar los helpers
    /// del Kanban. Solo se usan `HistoriaClinicaId`, `RevisionId`, `Columna` y
    /// los campos que el modal de rechazo muestra (paciente, formato).</summary>
    private static RevisionKanbanCardDto CardDesdeRow(OrdenClinicaItemDto r) => new(
        HistoriaClinicaId: r.HistoriaClinicaId,
        RevisionId: r.RevisionId,
        PacienteId: r.PacienteId,
        PacienteNombre: r.PacienteNombre,
        PacienteTipoDoc: r.PacienteTipoDoc,
        PacienteDoc: r.PacienteDoc,
        FormatoNombre: r.FormatoNombre,
        EspecialistaNombre: r.EspecialistaNombre,
        FechaCierre: r.FechaCierre,
        FechaApertura: r.FechaApertura,
        Columna: RevisionKanbanColumna.Cerradas,
        EstadoAgregado: r.RevisionEstado,
        EstadoAgente: r.RevisionAgente,
        Iteracion: r.RevisionIteracion ?? 1,
        UltimoMotivo: null,
        UltimoResumenAgente: r.RevisionAgenteResumen,
        UltimaAccionEn: r.FechaCierre ?? r.FechaApertura);

    /// <summary>Pinta el chip de estado de revision. Devuelve texto, clase CSS y title del tooltip.</summary>
    private static (string txt, string cls, string title) ChipRevisionEstado(OrdenClinicaItemDto r)
    {
        if (r.RevisionEstado is null)
        {
            // HC sin revision — depende del estado clinico.
            return string.Equals(r.Estado, "Cerrada", StringComparison.OrdinalIgnoreCase)
                ? ("Sin solicitar", "oc-rv-none", "HC cerrada pero aun no entra al ciclo de revision")
                : ("—", "oc-rv-none", "HC abierta — el ciclo de revision empieza al cerrar");
        }
        return r.RevisionEstado switch
        {
            RevisionEstadoAgregado.SinRevisar => ("Sin revisar", "oc-rv-sinrev", "Revision solicitada, aun sin revisor"),
            RevisionEstadoAgregado.PreRevision => ("Pre-revision", "oc-rv-prerev", "El agente IA ya opino — falta revisor humano"),
            RevisionEstadoAgregado.EnRevision => ("En revision", "oc-rv-enrev", "Un revisor humano tomo esta HC"),
            RevisionEstadoAgregado.Aprobada => ("Aprobada", "oc-rv-aprob", "Aprobada por el revisor"),
            RevisionEstadoAgregado.Rechazada => ("Rechazada", "oc-rv-rech", "Rechazada — espera reenvio del profesional"),
            RevisionEstadoAgregado.ArchivadaOk => ("Archivada", "oc-rv-arch", "Ciclo cerrado — archivada OK"),
            RevisionEstadoAgregado.Inactivada => ("Inactivada", "oc-rv-inac", "Revision inactivada — captura invalida"),
            _ => ("—", "oc-rv-none", ""),
        };
    }

    /// <summary>Pinta el chip del veredicto del agente IA. Devuelve null cuando aun no corrio.</summary>
    private static (string? txt, string cls, string title) ChipAgente(OrdenClinicaItemDto r)
    {
        if (r.RevisionAgente is null)
        {
            return (null, "", "");
        }
        var resumen = string.IsNullOrWhiteSpace(r.RevisionAgenteResumen)
            ? "Sin resumen"
            : (r.RevisionAgenteResumen.Length > 240 ? r.RevisionAgenteResumen[..240] + "..." : r.RevisionAgenteResumen);
        return r.RevisionAgente switch
        {
            RevisionResultado.Aprobado => ("IA: aprobar", "oc-ag-aprob", resumen),
            RevisionResultado.Rechazado => ("IA: rechazar", "oc-ag-rech", resumen),
            RevisionResultado.Neutral => ("IA: neutral", "oc-ag-neutral", resumen),
            _ => (null, "", ""),
        };
    }

    /// <summary>Construye la query de docs incluyendo TODOS los tipos con count > 0. Uso por Consultar.</summary>
    private static string BuildAllDocsQuery(OrdenClinicaItemDto r)
    {
        var parts = new List<string> { "HC" };
        if (r.MedicamentosCount > 0)    { parts.Add("MED"); }
        if (r.ServiciosCount > 0)       { parts.Add("SRV"); }
        if (r.InsumosCount > 0)         { parts.Add("INS"); }
        if (r.RemisionesCount > 0)      { parts.Add("REM"); }
        if (r.RxImagCount > 0)          { parts.Add("RXEXT"); }
        if (r.LabExtCount > 0)          { parts.Add("LABEXT"); }
        if (r.InsExtCount > 0)          { parts.Add("INSEXT"); }
        if (r.IncapacidadesCount > 0)   { parts.Add("INC"); }
        if (r.CertificacionesCount > 0) { parts.Add("CERT"); }
        if (r.EscalasCount > 0)         { parts.Add("ESC"); }
        if (r.EvolucionesCount > 0)     { parts.Add("EVO"); }
        if (r.ConsentimientosCount > 0) { parts.Add("CON"); }
        return string.Join(",", parts);
    }
