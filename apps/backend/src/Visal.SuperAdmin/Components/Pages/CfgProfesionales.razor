@page "/cfg-profesionales"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.IO
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Web
@using Visal.Application.Common
@using Visal.Application.Tenancy
@inject IProfesionalConfigService Svc
@inject IUsuarioAdminService UsuSvc
@inject IRolService RolesSvc
@inject ISucursalService SucSvc
@inject IWebHostEnvironment Env
@inject IJSRuntime JS

<PageTitle>Profesionales - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion del Sistema</div>
        <h1 class="ase-title">Profesionales</h1>
    </div>
    <div style="display:flex; gap:8px;">
        <button class="btn btn-outline-primary btn-sm" @onclick="OpenImport" title="Importar desde Excel con plantilla Visal">&#128229; Importar Excel</button>
        <button class="btn btn-primary btn-sm" @onclick="New">+ Nuevo profesional</button>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

@* Tabs: Fichas (vista actual detalle + edicion) | Listado (tabla completa con filtros) *@
<div class="prof-tabs">
    <button class="prof-tab @(_tabActivo == 0 ? "sel" : "")" @onclick="() => SetTab(0)">
        &#128100; Fichas
    </button>
    <button class="prof-tab @(_tabActivo == 1 ? "sel" : "")" @onclick="() => SetTab(1)">
        &#128203; Listado
    </button>
</div>

@if (_tabActivo == 1)
{
    @* ===================== TAB LISTADO (tabla) ===================== *@
    <div class="ase-card">
        <div class="prof-filtros">
            <div class="prof-f prof-f-wide">
                <label>Nombre</label>
                <input class="form-control form-control-sm"
                       placeholder="Nombre o identificacion..."
                       @bind="_tFilNombre" @bind:event="oninput" />
            </div>
            <div class="prof-f">
                <label>Sede</label>
                <select class="form-select form-select-sm" @bind="_tFilSede">
                    <option value="">(Todas)</option>
                    @foreach (var s in _tSedesDisponibles)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="prof-f">
                <label>Rol asignado</label>
                <select class="form-select form-select-sm" @bind="_tFilRol">
                    <option value="">(Todos)</option>
                    @foreach (var r in _tRolesDisponibles)
                    {
                        <option value="@r">@r</option>
                    }
                    <option value="__SIN_ROL__">(Sin rol)</option>
                </select>
            </div>
            <div class="prof-f">
                <label>Firma</label>
                <select class="form-select form-select-sm" @bind="_tFilFirma">
                    <option value="">(Cualquiera)</option>
                    <option value="si">Con firma</option>
                    <option value="no">Sin firma</option>
                </select>
            </div>
            <div class="prof-f prof-f-acts">
                <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarFiltrosTabla">Limpiar</button>
            </div>
        </div>

        <div class="prof-tbl-h">
            Profesionales (@FilteredTabla.Count de @_tabla.Count)
        </div>

        @if (_tabla.Count == 0)
        {
            <div class="ase-empty" style="padding:30px;">Cargando o sin profesionales.</div>
        }
        else
        {
            <div class="prof-tbl-wrap">
                <table class="table table-sm prof-tbl">
                    <thead>
                        <tr>
                            <th style="min-width:220px">Nombre</th>
                            <th style="width:160px">Identificacion</th>
                            <th style="min-width:180px">Tipo profesional</th>
                            <th style="min-width:180px">Rol asignado</th>
                            <th>Sedes que aplica</th>
                            <th class="text-center" style="width:90px">Firma</th>
                            <th class="text-end" style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in FilteredTabla)
                        {
                            <tr>
                                <td><div class="prof-nombre">@r.NombreCompleto</div></td>
                                <td class="mono">@r.TipoDocumento @r.NumeroDocumento</td>
                                <td>@(r.TipoProfesional ?? "-")</td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(r.Rol))
                                    {
                                        <span class="prof-badge prof-badge-off">(Sin rol)</span>
                                    }
                                    else
                                    {
                                        <span class="prof-badge prof-badge-rol">@r.Rol</span>
                                    }
                                </td>
                                <td>
                                    @if (r.Sedes.Count == 0)
                                    {
                                        <span class="prof-badge prof-badge-off">(Sin sedes)</span>
                                    }
                                    else
                                    {
                                        <div class="prof-sedes">
                                            @foreach (var s in r.Sedes)
                                            {
                                                <span class="prof-badge prof-badge-sede">@s</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (r.TieneFirma)
                                    {
                                        <span class="prof-firma-si" title="Este profesional tiene firma cargada">&#10004; Si</span>
                                    }
                                    else
                                    {
                                        <span class="prof-firma-no" title="No hay firma cargada">&#10006; No</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-outline-primary btn-sm"
                                            title="Abrir ficha para editar"
                                            @onclick="() => AbrirFichaDesdeTabla(r.Id)">
                                        &#9998; Ficha
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
else
{
@* ===================== TAB FICHAS (vista actual) ===================== *@
<div class="ase-grid">
    <div class="ase-card ase-list">
        <div class="ase-card-h">Profesionales (@_lista.Count)</div>
        <input class="form-control form-control-sm mb-2" placeholder="Buscar..." value="@_filtro" @oninput="OnFiltro" />
        @foreach (var p in _lista)
        {
            <button class="ase-li @(p.Id == _id ? "sel" : "")" @onclick="() => Select(p.Id)">
                <div class="ase-li-name">@p.NombreCompleto</div>
                <div class="ase-li-sub">@p.NumeroDocumento &middot; @(p.TipoProfesional ?? "-") &middot; @(p.Ciudad ?? "-")</div>
            </button>
        }
        @if (_lista.Count == 0) { <div class="ase-empty">Sin profesionales.</div> }
    </div>

    <div class="ase-detail">
        @if (!_showForm)
        {
            <div class="ase-card"><div class="ase-empty">Selecciona o crea un profesional.</div></div>
        }
        else
        {
            <div class="ase-card">
                <div class="ase-card-h">Datos</div>
                <div class="ase-form">
                    <div class="ase-f"><label>Numero Documento *</label><input class="form-control form-control-sm" @bind="_doc" /></div>
                    <div class="ase-f"><label>Tipo documento</label>
                        <select class="form-select form-select-sm" @bind="_tipoDoc">
                            <option>CC</option><option>CE</option><option>TI</option><option>PA</option><option>NIT</option>
                        </select>
                    </div>
                    <div class="ase-f ase-f-wide"><label>Nombre Completo</label><input class="form-control form-control-sm" @bind="_nombreCompleto" placeholder="(se arma con los nombres si lo dejas vacio)" /></div>
                    <div class="ase-f"><label>Primer Nombre</label><input class="form-control form-control-sm" @bind="_pNombre" /></div>
                    <div class="ase-f"><label>Segundo Nombre</label><input class="form-control form-control-sm" @bind="_sNombre" /></div>
                    <div class="ase-f"><label>Primer Apellido</label><input class="form-control form-control-sm" @bind="_pApellido" /></div>
                    <div class="ase-f"><label>Segundo Apellido</label><input class="form-control form-control-sm" @bind="_sApellido" /></div>
                    <div class="ase-f"><label>Tipo Profesional</label>
                        <select class="form-select form-select-sm" @bind="_tipoProfId">
                            <option value="">Seleccione...</option>
                            @foreach (var t in _tipos)
                            {
                                <option value="@t.Id">@t.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="ase-f"><label>Registro Medico</label><input class="form-control form-control-sm" @bind="_registro" /></div>
                    <div class="ase-f"><label>Ciudad</label><input class="form-control form-control-sm" @bind="_ciudad" /></div>
                    <div class="ase-f"><label>Celular</label><input class="form-control form-control-sm" @bind="_celular" /></div>
                </div>

                <div class="ase-subcats">
                    <label class="ase-subcats-lbl">Sub Categoria</label>
                    <div class="ase-subcats-grid">
                        @foreach (var s in _subcats)
                        {
                            <label class="ase-chk">
                                <input type="checkbox" checked="@_subSel.Contains(s.Id)" @onchange="e => ToggleSub(s.Id, e)" />
                                <span>@s.Nombre</span>
                            </label>
                        }
                        @if (_subcats.Count == 0) { <span class="ase-empty">No hay subcategorias. Configuralas en el catalogo.</span> }
                    </div>
                </div>

                <div class="ase-actions">
                    <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@_busy">Guardar profesional</button>
                    @if (_id is not null)
                    {
                        <button class="btn btn-outline-success btn-sm" @onclick="OpenCrearUsuario" title="Crear usuario de login para este profesional">&#128100; Crear usuario</button>
                        @if (!_confirmingDelete)
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="StartConfirmDelete">Eliminar</button>
                        }
                        else
                        {
                            <div class="cfg-prof-confirm">
                                <span>Escribe <strong>ELIMINAR</strong> para confirmar:</span>
                                <input class="form-control form-control-sm" style="width: 130px;" @bind="_confirmText" @bind:event="oninput" @onkeyup="OnConfirmKey" placeholder="ELIMINAR" autocomplete="off" />
                                <button class="btn btn-danger btn-sm" @onclick="Delete" disabled="@(_confirmText != "ELIMINAR" || _busy)">Confirmar</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelConfirmDelete">Cancelar</button>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Sedes / agencias activas: select con sedes del tenant -->
            <div class="ase-card">
                <div class="ase-card-h">Sedes de atencion <button class="btn btn-outline-primary btn-sm ms-2" @onclick="AddAgencia" disabled="@(_sedes.Count == 0)">+ Sede</button></div>
                @if (_sedes.Count == 0)
                {
                    <div class="ase-empty">No hay sedes activas en el tenant. Crea sedes en Configuracion de Empresa primero.</div>
                }
                else
                {
                    @for (var i = 0; i < _agencias.Count; i++)
                    {
                        var idx = i;
                        var val = _agencias[idx] ?? "";
                        <div class="ase-ag-row">
                            <select class="form-select form-select-sm" value="@val"
                                    @onchange="e => _agencias[idx] = e.Value?.ToString() ?? string.Empty">
                                <option value="">Seleccione sede...</option>
                                @* Si el valor actual NO esta en la lista de sedes activas (legado),
                                   lo mostramos arriba para preservarlo y que el usuario lo cambie. *@
                                @if (!string.IsNullOrWhiteSpace(val) && !_sedes.Any(s => string.Equals(s.Nombre, val, StringComparison.OrdinalIgnoreCase)))
                                {
                                    <option value="@val">@val (legado)</option>
                                }
                                @foreach (var s in _sedes)
                                {
                                    <option value="@s.Nombre">@s.Nombre@(string.IsNullOrWhiteSpace(s.Ciudad) ? "" : " - " + s.Ciudad)</option>
                                }
                            </select>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => _agencias.RemoveAt(idx)">&times;</button>
                        </div>
                    }
                    @if (_agencias.Count == 0) { <div class="ase-empty">Sin sedes asignadas. Agrega una y guarda el profesional.</div> }
                }
            </div>

            <!-- Rol de acceso predeterminado. Se persiste en el profesional y se
                 replica al TenantUser vinculado al guardar. Si aun no existe usuario,
                 queda listo para aplicarse al momento de crearlo. -->
            <div class="ase-card">
                <div class="ase-card-h">Rol de acceso al sistema</div>
                <select class="form-select form-select-sm" @bind="_rolPredeterminadoId">
                    <option value="">(sin rol)</option>
                    @foreach (var r in _roles)
                    {
                        <option value="@r.Id">@r.Nombre</option>
                    }
                </select>
                <div class="ase-hint">
                    Al guardar, este rol y las sedes de arriba se aplican
                    automaticamente al usuario de acceso del profesional. Si aun no
                    existe usuario, quedan guardados y se aplicaran al crearlo.
                </div>
            </div>

            <!-- Firma + usuario -->
            <div class="ase-card">
                <div class="ase-card-h">Firma del profesional</div>
                @if (!string.IsNullOrWhiteSpace(_firmaUrl))
                {
                    <div class="ase-firma"><img src="@_firmaUrl" alt="firma" /></div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _firmaUrl = null">Quitar firma</button>
                }
                else
                {
                    <InputFile class="form-control form-control-sm" accept="image/*" OnChange="OnFirmaSelected" />
                    <div class="ase-hint">Sube la imagen de la firma (PNG/JPG, max 4 MB).</div>
                }

                <div class="ase-card-h" style="margin-top:16px;">Usuario de acceso</div>
                @if (_usuarioVinculado is not null)
                {
                    <div class="usu-info">
                        <div><strong>Correo:</strong> @_usuarioVinculado.Email</div>
                        <div><strong>Rol:</strong> @(_usuarioVinculado.RolNombre ?? "(sin rol)")</div>
                        <div><strong>Estado:</strong> @_usuarioVinculado.Estado</div>
                    </div>
                    <div style="margin-top:8px; display:flex; gap:8px; flex-wrap:wrap;">
                        <button class="btn btn-outline-warning btn-sm" @onclick="ReiniciarClaveUsuario" disabled="@_busy">&#128274; Reiniciar clave</button>
                        <a class="btn btn-outline-secondary btn-sm" href="/cfg-usuarios">Editar rol y sedes en /cfg-usuarios</a>
                    </div>
                }
                else
                {
                    <div class="usu-info">
                        Si este profesional necesita acceder al modulo de atencion para ver sus turnos asignados,
                        presiona "Crear usuario" arriba. El usuario heredara los datos personales del profesional.
                    </div>
                }
            </div>
        }
    </div>
</div>
}

@* ===== Modal Importar desde Excel ===== *@
@if (_showImportModal)
{
    <div class="usu-modal-backdrop" @onclick="CloseImport"></div>
    <div class="usu-modal usu-modal-wide">
        <div class="usu-modal-h">
            <h3>Importar profesionales desde Excel</h3>
            <button class="usu-modal-close" @onclick="CloseImport">&times;</button>
        </div>
        <div class="usu-modal-body">
            @if (_importError is not null) { <div class="ase-alert">@_importError</div> }
            <div class="imp-grid">
                <div class="ase-f">
                    <label>Archivo Excel (.xlsx)</label>
                    <div style="display:flex; gap:8px; align-items:flex-start;">
                        <InputFile class="form-control form-control-sm" accept=".xlsx" OnChange="OnExcelSelected" disabled="@_importing" />
                        <a class="btn btn-outline-secondary btn-sm" href="/api/profesionales/plantilla.xlsx" download="plantilla-profesionales.xlsx" title="Descargar plantilla en blanco">&#128229; Plantilla</a>
                    </div>
                    <div class="ase-hint">Columnas esperadas (fila 1): Nº documento, Tipo doc, Primer/Segundo Nombre, Primer/Segundo Apellido, Tipo Profesional, Registro, Ciudad, Celular, SubCategoria, Firma (imagen embebida col 12).</div>
                </div>
                <div class="ase-f">
                    <label>Sede a asignar</label>
                    <select class="form-select form-select-sm" @bind="_importSede" disabled="@_importing">
                        @if (_sedes.Count == 0)
                        {
                            <option value="">No hay sedes activas</option>
                        }
                        else
                        {
                            <option value="">Seleccione...</option>
                            @foreach (var s in _sedes)
                            {
                                <option value="@s.Nombre">@s.Nombre@(string.IsNullOrWhiteSpace(s.Ciudad) ? "" : " - " + s.Ciudad)</option>
                            }
                        }
                    </select>
                </div>
                <div class="ase-f">
                    <label class="form-check-label" style="display:flex; align-items:center; gap:8px;">
                        <input type="checkbox" class="form-check-input" @bind="_importCrearUsuario" disabled="@_importing" />
                        Crear usuario de acceso por cada profesional
                    </label>
                    <div class="ase-hint">Usuario de login: el <strong>documento</strong> del profesional (o el email <code>{documento}@@visal.travels</code>). Clave: <strong>igual al documento</strong>.</div>
                </div>
            </div>

            @if (_importing || _importTotal > 0)
            {
                <div style="margin-top:14px;">
                    <div class="imp-progress">
                        <div class="imp-progress-bar" style="width:@($"{_importProgress:0}%");"></div>
                    </div>
                    <div class="ase-hint" style="margin-top:6px;">
                        @if (_importing) { <span>Procesando fila @_importCurrent de @_importTotal&hellip;</span> }
                        else { <span>Listo: @_importOk OK, @_importErr errores.</span> }
                    </div>
                </div>
                <div class="imp-log">
                    @foreach (var line in _importLog.TakeLast(40))
                    {
                        <div class="imp-log-line @(line.StartsWith("[OK]") ? "ok" : line.StartsWith("[ERR]") ? "err" : "info")">@line</div>
                    }
                </div>
            }
        </div>
        <div class="usu-modal-footer">
            <button class="btn btn-secondary btn-sm" @onclick="CloseImport" disabled="@_importing">Cerrar</button>
        </div>
    </div>
}

@* ===== Modal Crear/Actualizar usuario para profesional =====
   Modo dual: si el profesional ya tiene un TenantUser vinculado, el modal
   se comporta como "Actualizar" (rol + clave, y las sedes se propagan
   desde el card de arriba). Si no existe, comportamiento clasico "Crear". *@
@if (_showCrearUsuModal)
{
    var esActualizacion = _usuarioVinculado is not null;
    <div class="usu-modal-backdrop" @onclick="CloseCrearUsuario"></div>
    <div class="usu-modal">
        <div class="usu-modal-h">
            <h3>@(esActualizacion ? "Actualizar usuario de" : "Crear usuario para") @_nombreCompleto</h3>
            <button class="usu-modal-close" @onclick="CloseCrearUsuario">&times;</button>
        </div>
        <div class="usu-modal-body">
            @if (_modalError is not null) { <div class="ase-alert">@_modalError</div> }
            <div class="ase-form">
                <div class="ase-f ase-f-wide">
                    <label>Correo @(esActualizacion ? "" : "*")</label>
                    <input class="form-control form-control-sm" @bind="_nuevoEmail"
                           placeholder="profesional@ips.com" disabled="@esActualizacion" />
                    @if (esActualizacion)
                    {
                        <small class="text-muted">El correo no se puede cambiar aqui. Editalo desde /cfg-usuarios.</small>
                    }
                </div>
                <div class="ase-f ase-f-wide">
                    <label>Clave temporal @(esActualizacion ? "(opcional)" : "*")</label>
                    <input type="password" class="form-control form-control-sm" @bind="_nuevoPwd"
                           placeholder="@(esActualizacion ? "Deja vacio para no cambiarla" : "Minimo 6 caracteres")" />
                    <small class="text-muted">
                        @if (esActualizacion)
                        {
                            <span>Si escribes una nueva clave, la actual se reemplaza. Deja vacio para conservarla.</span>
                        }
                        else
                        {
                            <span>El profesional la cambiara en su primer ingreso.</span>
                        }
                    </small>
                </div>
                <div class="ase-f ase-f-wide">
                    <label>Rol *</label>
                    <select class="form-select form-select-sm" @bind="_nuevoRolId">
                        <option value="">Selecciona un rol...</option>
                        @foreach (var r in _roles)
                        {
                            <option value="@r.Id">@r.Nombre</option>
                        }
                    </select>
                    <small class="text-muted">Los permisos del rol determinan que modulos vera el usuario en el menu.</small>
                </div>
                <div class="ase-f ase-f-wide">
                    <small class="usu-info">
                        @if (esActualizacion)
                        {
                            <span>
                                Al guardar se actualizan: <strong>rol</strong>, <strong>clave</strong> (si la cambias) y las
                                <strong>sedes</strong> asignadas arriba en el card "Sedes de atencion".
                            </span>
                        }
                        else
                        {
                            <span>
                                Se creara un usuario heredando documento, nombre, apellidos, celular y ciudad
                                de <strong>@_nombreCompleto</strong>. Quedara vinculado a este profesional para
                                ver sus turnos en el modulo de Atencion.
                            </span>
                        }
                    </small>
                </div>
            </div>
        </div>
        <div class="usu-modal-f">
            <button class="btn btn-secondary btn-sm" @onclick="CloseCrearUsuario">Cancelar</button>
            <button class="btn btn-primary btn-sm" @onclick="CrearOActualizarUsuario" disabled="@_busyCrearUsu">
                @(_busyCrearUsu
                    ? (esActualizacion ? "Actualizando..." : "Creando...")
                    : (esActualizacion ? "Actualizar usuario" : "Crear usuario"))
            </button>
        </div>
    </div>
}

<style>
    .usu-modal-backdrop { position: fixed; inset: 0; background: rgba(15,23,42,.45); z-index: 950; }
    .usu-modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 520px; max-width: 95vw; max-height: 90vh; background: #fff; border-radius: 12px; box-shadow: 0 20px 60px rgba(15,23,42,.25); z-index: 951; display: flex; flex-direction: column; }
    .usu-modal-h { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid #e2e8f0; }
    .usu-modal-h h3 { margin: 0; font-size: 15px; font-weight: 700; color: #0f172a; }
    .usu-modal-close { background: none; border: none; font-size: 22px; line-height: 1; cursor: pointer; color: #64748b; }
    .usu-modal-body { padding: 18px; overflow: auto; }
    .usu-modal-f { padding: 12px 18px; border-top: 1px solid #e2e8f0; display: flex; gap: 8px; justify-content: flex-end; }
    .usu-info { font-size: 12px; color: #475569; padding: 8px 10px; background: #f1f5f9; border-radius: 8px; }

    /* Tabs */
    .prof-tabs { display: flex; gap: 4px; margin-bottom: 14px; border-bottom: 2px solid #e2e8f0; }
    .prof-tab { background: none; border: none; padding: 10px 16px; font-size: 13px; font-weight: 600; color: #64748b; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: color .15s, border-color .15s; }
    .prof-tab:hover { color: #1565c0; }
    .prof-tab.sel { color: #1565c0; border-bottom-color: #1565c0; }

    /* Tab Listado */
