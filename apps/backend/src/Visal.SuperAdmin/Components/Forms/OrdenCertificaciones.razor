@* Diseño basado en ctrlOrdenCertificaciones.ascx del legacy. Solo layout. *@

<div class="od-bar">
    <div class="od-bar-left">
        <label>Orden de Certificacion Numero:</label>
        <select class="form-select form-select-sm od-w-220" disabled>
            <option>(sin ordenes)</option>
        </select>
    </div>
    <div class="od-bar-right">
        <button class="btn btn-outline-secondary btn-sm" disabled>+ Agregar</button>
        <button class="btn btn-outline-secondary btn-sm" disabled>&#128190; Guardar</button>
        <button class="btn btn-outline-secondary btn-sm" disabled>&#128424; Imprimir</button>
        <button class="btn btn-outline-secondary btn-sm" disabled>&#128193; Historico</button>
    </div>
</div>

<div class="od-card">
    <div class="od-row">
        <div class="od-f od-c-12">
            <label>Descripcion de la Certificacion</label>
            <textarea class="form-control form-control-sm" rows="15" placeholder="Escriba la certificacion aqui..."></textarea>
        </div>
    </div>
</div>

