@code {
    private enum Tab { Vigentes, Archivados }

    private Tab _tab = Tab.Vigentes;
    private bool _cargando;
    private string? _error;
    private string? _ok;
    private List<FacturacionSnapshotDto> _lista = new();
    private int _conteoVigentes = -1;
    private int _conteoArchivados = -1;
    private List<TipoSnapshot> _tiposDisponibles = new();
    private bool _puedeArchivar;

    // Filtros del listado.
    private string _filtroTipo = "";
    private string _filtroAseguradora = "";
    private DateOnly? _filtroDesde;
    private DateOnly? _filtroHasta;

    // Modal Nuevo.
    private bool _showNuevo;
    private TipoSnapshot _nuevoTipo = TipoSnapshot.RelacionFacturas;
    private string _nuevoNombre = "";
    private string _nuevoFiltrosJson = "{}";
    private bool _generando;
    private string? _nuevoErr;

    // Filtros visuales Relacion de Facturas (F4b).
    private List<AseguradoraDto> _relAseguradoras = new();
    private List<SucursalDto> _relSucursales = new();
    private HashSet<Guid> _relAseguradoraIds = new();
    private HashSet<Guid> _relSucursalIds = new();
    private DateOnly? _relFechaInicio;
    private DateOnly? _relFechaFin;
    // Filtro opcional pensado para pruebas: nombre o identificacion del paciente
    // (contiene, case+tildes insensitive). Vacio = no filtra.
    private string _relPacienteQuery = string.Empty;

    // Modal Ver.
    private bool _showVer;
    private bool _verCargando;
    private FacturacionSnapshotDetalleDto? _verDetalle;
    private List<IReadOnlyDictionary<string, object?>> _verFilas = new();
    private Guid _verSnapshotId;
    private int _verPagina = 1;
    private const int VerTamano = 50;
    private int _verTotal;
    private int _verTotalPaginas = 1;
    private string _verBuscar = "";
    private int _verFijar = 0;
    private string? _verOrden;
    private bool _verOrdenDesc;
    private CancellationTokenSource? _verBuscarCts;

    // Modal Archivar.
    private bool _showArchivar;
    private Guid _archivarId;
    private string _archivarNombre = "";
    private string _archivarMotivo = "";
    private bool _archivando;
    private string? _archivarErr;

    // Modal Configurar columnas (aplica al archivo Excel/CSV de salida).
    private bool _showColConfig;
    private TipoSnapshot _colConfigTipo = TipoSnapshot.RelacionFacturas;
    private List<ColumnaConfigItemDto> _colConfigItems = new();
    private bool _colConfigCargando;
    private bool _colConfigGuardando;
    private string? _colConfigErr;

    // Usuario / permisos.
    private Guid _actorId;
    private bool _esAdminAgencia;

    protected override async Task OnInitializedAsync()
    {
        _tiposDisponibles = Builders.Select(b => b.TipoAplicable).Distinct().ToList();
        await ResolverPermisosAsync();
        await CargarLista();
    }

    private async Task ResolverPermisosAsync()
    {
        if (AuthState is null) { return; }
        var state = await AuthState.GetAuthenticationStateAsync();
        var sub = state.User.FindFirst("sub")?.Value ?? state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(sub, out var g)) { _actorId = g; }

        var isPlatformOperator = state.User.FindFirst("platform_role") is not null;
        var rol = state.User.FindFirst("tenant_role")?.Value ?? "";
        _esAdminAgencia = isPlatformOperator
            || rol.Equals("Owner", StringComparison.OrdinalIgnoreCase)
            || rol.Equals("Admin", StringComparison.OrdinalIgnoreCase);

        var perms = state.User.FindFirst("perms")?.Value;
        var tienePermArchivar = !string.IsNullOrEmpty(perms)
            && perms.Split(',', StringSplitOptions.RemoveEmptyEntries)
                    .Any(p => string.Equals(p.Trim(), "facturacion.snapshots.archivar", StringComparison.OrdinalIgnoreCase));
        _puedeArchivar = _esAdminAgencia || tienePermArchivar;
    }

    private async Task CargarLista()
    {
        _cargando = true; _error = null; _ok = null;
        try
        {
            var estado = _tab == Tab.Vigentes ? EstadoSnapshot.Vigente : EstadoSnapshot.Archivado;
            TipoSnapshot? tipo = null;
            if (!string.IsNullOrWhiteSpace(_filtroTipo) && Enum.TryParse<TipoSnapshot>(_filtroTipo, out var t)) { tipo = t; }
            Guid? asegFiltro = null;
            if (!string.IsNullOrWhiteSpace(_filtroAseguradora) && Guid.TryParse(_filtroAseguradora, out var af)) { asegFiltro = af; }
            var filtros = new FiltrosListaSnapshotDto(null, _filtroDesde, _filtroHasta, asegFiltro);
            _lista = (await Svc.ListarAsync(estado, tipo, filtros)).ToList();

            // Refrescamos ambos contadores en paralelo para el tab.
            var vigCount = await Svc.ListarAsync(EstadoSnapshot.Vigente, null, null);
            var arcCount = await Svc.ListarAsync(EstadoSnapshot.Archivado, null, null);
            _conteoVigentes = vigCount.Count;
            _conteoArchivados = arcCount.Count;
        }
        catch (Exception ex) { _error = "Error al listar snapshots: " + ex.Message; }
        finally { _cargando = false; }
    }

    private async Task CambiarTab(Tab t)
    {
        if (_tab == t) { return; }
        _tab = t;
        await CargarLista();
    }

    // ---- Modal Nuevo ----

    private async Task AbrirNuevo()
    {
        if (_tiposDisponibles.Count == 0) { return; }
        _nuevoTipo = _tiposDisponibles[0];
        _nuevoNombre = "";
        _nuevoFiltrosJson = "{}";
        _nuevoErr = null;
        // Precarga catalogos para el formulario visual del tipo Relacion de Facturas.
        // El motor filtra por tenant activo — lo que aparece aca ya esta scoped.
        _relAseguradoras = (await AseSvc.ListAseguradorasAsync()).OrderBy(a => a.Nombre).ToList();
        _relSucursales = (await SucSvc.ListAsync(soloActivas: true)).OrderBy(s => s.Nombre).ToList();
        _relAseguradoraIds = new();
        _relSucursalIds = new();
        var hoy = DateOnly.FromDateTime(DateTime.Today);
        _relFechaInicio = new DateOnly(hoy.Year, hoy.Month, 1);
        _relFechaFin = hoy;
        _relPacienteQuery = string.Empty;
        _showNuevo = true;
    }

    private void ToggleSucursal(Guid id, bool selected)
    {
        if (selected) { _relSucursalIds.Add(id); }
        else { _relSucursalIds.Remove(id); }
    }

    private void ToggleAseguradora(Guid id, bool selected)
    {
        if (selected) { _relAseguradoraIds.Add(id); }
        else { _relAseguradoraIds.Remove(id); }
    }

    private void MarcarTodasAseguradoras()
    {
        _relAseguradoraIds = _relAseguradoras.Select(a => a.Id).ToHashSet();
    }

    private void QuitarTodasAseguradoras()
    {
        _relAseguradoraIds.Clear();
    }

    private void CerrarNuevo()
    {
        if (_generando) { return; }
        _showNuevo = false;
    }

    private async Task ConfirmarNuevo()
    {
        _nuevoErr = null;
        if (string.IsNullOrWhiteSpace(_nuevoNombre))
        {
            _nuevoErr = "El nombre es obligatorio.";
            return;
        }

        // Rama tipo RelacionFacturas: multi-EPS -> N snapshots (uno por aseguradora).
        // Los otros tipos usan el JSON crudo y siguen siendo 1 snapshot.
        if (_nuevoTipo == TipoSnapshot.RelacionFacturas)
        {
            if (_relAseguradoraIds.Count == 0)
            {
                _nuevoErr = "Marca al menos una aseguradora."; return;
            }
            if (_relFechaInicio is null || _relFechaFin is null)
            {
                _nuevoErr = "Las fechas de inicio y fin son obligatorias."; return;
            }
            if (_relFechaFin < _relFechaInicio)
            {
                _nuevoErr = "La fecha fin debe ser mayor o igual a la fecha inicio."; return;
            }

            _generando = true;
            try
            {
                var nombreBase = _nuevoNombre.Trim();
                var seleccionadas = _relAseguradoras
                    .Where(a => _relAseguradoraIds.Contains(a.Id))
                    .OrderBy(a => a.Nombre)
                    .ToList();
                var esMulti = seleccionadas.Count > 1;
                Guid? primerId = null;
                var okCount = 0;
                var errores = new List<string>();

                var vacios = 0;
                foreach (var a in seleccionadas)
                {
                    // El nombre queda tal cual lo puso el usuario — la EPS ahora es un
                    // campo estructurado (columna Aseguradora + filtro), asi que ya no
                    // se necesita sufijarla al nombre para distinguir los snapshots.
                    var pq = string.IsNullOrWhiteSpace(_relPacienteQuery) ? null : _relPacienteQuery.Trim();
                    var payload = new
                    {
                        aseguradoraId = a.Id.ToString(),
                        sucursalIds = _relSucursalIds.Select(x => x.ToString()).ToArray(),
                        fechaInicio = _relFechaInicio!.Value.ToString("yyyy-MM-dd"),
                        fechaFin = _relFechaFin!.Value.ToString("yyyy-MM-dd"),
                        pacienteQuery = pq,
                    };
                    var filtrosJson = JsonSerializer.Serialize(payload);
                    try
                    {
                        var cmd = new GenerarSnapshotCmd(_nuevoTipo, nombreBase, filtrosJson);
                        var id = await Svc.GenerarAsync(cmd, _actorId);
                        // Guid.Empty = el servicio descarto el snapshot por 0 filas
                        // (regla "no basura" — no persistimos combinaciones sin datos).
                        if (id == Guid.Empty) { vacios++; }
                        else { okCount++; primerId ??= id; }
                    }
                    catch (Exception ex)
                    {
                        errores.Add($"{a.Nombre}: {ex.Message}");
                    }
                }

                _showNuevo = false;
                var resumen = esMulti
                    ? $"Se generaron {okCount} snapshots (uno por aseguradora)."
                    : $"Snapshot generado: {nombreBase}.";
                if (vacios > 0) { resumen += $" {vacios} EPS sin datos (no se guardaron)."; }
                _ok = resumen;
                if (errores.Count > 0)
                {
                    _error = "Algunos snapshots fallaron: " + string.Join(" | ", errores);
                }
                await CargarLista();
                // Cuando es una sola EPS, abrir el detalle. Con multiples, dejar
                // al usuario en la lista para que revise cada uno por separado.
                if (!esMulti && primerId is Guid onlyId)
                {
                    await AbrirVer(onlyId);
                }
            }
            catch (Exception ex) { _nuevoErr = ex.Message; }
            finally { _generando = false; }
            return;
        }

        // Otros tipos: JSON manual, 1 snapshot.
        string filtrosJsonOtro;
        try { using var _ = JsonDocument.Parse(_nuevoFiltrosJson); }
        catch (Exception ex)
        {
            _nuevoErr = "Los filtros no son JSON valido: " + ex.Message;
            return;
        }
        filtrosJsonOtro = _nuevoFiltrosJson.Trim();

        _generando = true;
        try
        {
            var cmd = new GenerarSnapshotCmd(_nuevoTipo, _nuevoNombre.Trim(), filtrosJsonOtro);
            var id = await Svc.GenerarAsync(cmd, _actorId);
            _showNuevo = false;
            if (id == Guid.Empty)
            {
                _ok = $"El snapshot '{_nuevoNombre.Trim()}' no se genero porque no hubo datos para los filtros aplicados.";
                await CargarLista();
            }
            else
            {
                _ok = $"Snapshot generado: {_nuevoNombre.Trim()}.";
                await CargarLista();
                await AbrirVer(id);
            }
        }
        catch (Exception ex) { _nuevoErr = ex.Message; }
        finally { _generando = false; }
    }

    // ---- Modal Ver ----

    private async Task AbrirVer(Guid id)
    {
        _verSnapshotId = id;
        _verPagina = 1;
        _verBuscar = "";
        _verOrden = null;
        _verOrdenDesc = false;
        _verFijar = 0;
        _showVer = true;
        _verCargando = true;
        try
        {
            _verDetalle = await Svc.ObtenerAsync(id);
            await CargarPaginaVer();
        }
        catch (Exception ex) { _error = "Error al abrir snapshot: " + ex.Message; _showVer = false; }
        finally { _verCargando = false; }
    }

    private async Task CargarPaginaVer()
    {
        if (_verDetalle is null) { return; }
        _verCargando = true;
        try
        {
            var buscar = string.IsNullOrWhiteSpace(_verBuscar) ? null : _verBuscar.Trim();
            var page = await Svc.ListarFilasAsync(_verSnapshotId, _verPagina, VerTamano,
                _verOrden, _verOrdenDesc, buscar);
            _verFilas = page.Items.ToList();
            _verTotal = page.Total;
            _verTotalPaginas = Math.Max(1, (int)Math.Ceiling(_verTotal / (double)VerTamano));
        }
        finally { _verCargando = false; }
    }

    private void CerrarVer() => _showVer = false;

    private async Task IrPagina(int p)
    {
        if (p < 1 || p > _verTotalPaginas) { return; }
        _verPagina = p;
        await CargarPaginaVer();
    }

    private async Task Ordenar(string col)
    {
        if (_verOrden == col) { _verOrdenDesc = !_verOrdenDesc; }
        else { _verOrden = col; _verOrdenDesc = false; }
        await CargarPaginaVer();
    }

    private async Task OnBuscarKey(KeyboardEventArgs e)
    {
        // Debounce simple para no consultar en cada tecla.
        _verBuscarCts?.Cancel();
        _verBuscarCts = new CancellationTokenSource();
        var ct = _verBuscarCts.Token;
        try
        {
            await Task.Delay(300, ct);
            if (ct.IsCancellationRequested) { return; }
            _verPagina = 1;
            await CargarPaginaVer();
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    // ---- Modal Archivar ----

    private void AbrirArchivar(Guid id, string nombre)
    {
        _archivarId = id;
        _archivarNombre = nombre;
        _archivarMotivo = "";
        _archivarErr = null;
        _showArchivar = true;
    }

    private void CerrarArchivar()
    {
        if (_archivando) { return; }
        _showArchivar = false;
    }

    private async Task ConfirmarArchivar()
    {
        _archivarErr = null;
        _archivando = true;
        try
        {
            await Svc.ArchivarAsync(_archivarId, _archivarMotivo, _actorId);
            _showArchivar = false;
            _ok = $"Snapshot '{_archivarNombre}' archivado.";
            await CargarLista();
        }
        catch (Exception ex) { _archivarErr = ex.Message; }
        finally { _archivando = false; }
    }

    // ---- Helpers ----

    private static string Truncar(string? s, int max) =>
        string.IsNullOrEmpty(s) || s.Length <= max ? (s ?? "") : s[..max] + "...";

    private static string FormatearDuracion(int? ms)
    {
        if (ms is not int m) { return "-"; }
        if (m < 1000) { return $"{m}ms"; }
        if (m < 60000) { return $"{m / 1000.0:0.0}s"; }
        var mins = m / 60000;
        var secs = (m % 60000) / 1000;
        return $"{mins}m {secs}s";
    }

    // ---- Configurar columnas ----

    private static string NombreTipoSnapshot(TipoSnapshot t) => t switch
    {
        TipoSnapshot.RelacionFacturas => "Relacion de Facturas",
        _ => t.ToString()
    };

    private async Task AbrirConfigColumnas()
    {
        _colConfigErr = null;
        // Preselecciona el primer tipo disponible (hoy solo RelacionFacturas).
        _colConfigTipo = _tiposDisponibles.FirstOrDefault();
        _showColConfig = true;
        await CargarConfigColumnasAsync();
    }

    private void CerrarColConfig()
    {
        _showColConfig = false;
        _colConfigItems = new();
        _colConfigErr = null;
    }

    private async Task OnCambiarTipoColConfig(ChangeEventArgs e)
    {
        if (Enum.TryParse<TipoSnapshot>(e.Value?.ToString(), out var t))
        {
            _colConfigTipo = t;
            await CargarConfigColumnasAsync();
        }
    }

    private async Task CargarConfigColumnasAsync()
    {
        _colConfigErr = null;
        _colConfigCargando = true;
        try
        {
            var items = await ColSvc.ListarAsync(_colConfigTipo);
            // Renumeramos orden secuencial para simplificar el drag & drop en memoria.
            _colConfigItems = items
                .Select((it, i) => new ColumnaConfigItemDto(it.ColumnaOriginal, i, it.Visible, it.Alias, it.Descripcion, it.RutaOrigen))
                .ToList();
        }
        catch (Exception ex) { _colConfigErr = ex.Message; }
        finally { _colConfigCargando = false; }
    }

    private void SubirColConfig(int idx)
    {
        if (idx <= 0) { return; }
        (_colConfigItems[idx], _colConfigItems[idx - 1]) = (_colConfigItems[idx - 1], _colConfigItems[idx]);
        Renumerar();
    }

    private void BajarColConfig(int idx)
    {
        if (idx >= _colConfigItems.Count - 1) { return; }
        (_colConfigItems[idx], _colConfigItems[idx + 1]) = (_colConfigItems[idx + 1], _colConfigItems[idx]);
        Renumerar();
    }

    private void ToggleColConfig(int idx, bool visible)
    {
        var it = _colConfigItems[idx];
        _colConfigItems[idx] = it with { Visible = visible };
    }

    private void SetAliasColConfig(int idx, string? alias)
    {
        var it = _colConfigItems[idx];
        _colConfigItems[idx] = it with { Alias = string.IsNullOrWhiteSpace(alias) ? null : alias };
    }

    private void SetDescripcionColConfig(int idx, string? descripcion)
    {
        var it = _colConfigItems[idx];
        _colConfigItems[idx] = it with { Descripcion = string.IsNullOrWhiteSpace(descripcion) ? null : descripcion };
    }

    private void SetRutaOrigenColConfig(int idx, string? ruta)
    {
        var it = _colConfigItems[idx];
        _colConfigItems[idx] = it with { RutaOrigen = string.IsNullOrWhiteSpace(ruta) ? null : ruta };
    }

    private void Renumerar()
    {
        for (var i = 0; i < _colConfigItems.Count; i++)
        {
            _colConfigItems[i] = _colConfigItems[i] with { Orden = i };
        }
    }

    private async Task GuardarColConfig()
    {
        _colConfigErr = null;
        _colConfigGuardando = true;
        try
        {
            Renumerar();
            await ColSvc.GuardarAsync(_colConfigTipo, _colConfigItems, _actorId);
            _ok = "Configuracion de columnas guardada.";
            _showColConfig = false;
        }
        catch (Exception ex) { _colConfigErr = ex.Message; }
        finally { _colConfigGuardando = false; }
    }

    private async Task ResetColConfig()
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", "Esto elimina todos los overrides guardados y vuelve al orden natural del builder. Continuar?");
        if (!confirmado) { return; }
        _colConfigGuardando = true;
        try
        {
            await ColSvc.ResetAsync(_colConfigTipo, _actorId);
            await CargarConfigColumnasAsync();
            _ok = "Configuracion restaurada a defaults.";
        }
        catch (Exception ex) { _colConfigErr = ex.Message; }
        finally { _colConfigGuardando = false; }
    }

    // ---------- Edicion inline de celdas (Tanda C) ----------

    /// <summary>
    /// Columnas que se pueden editar inline desde el modal Ver. Por ahora solo
    /// "Archivo json" (AC/AP/AT/AM) — el usuario puede ampliar despues por
    /// config. Otras columnas son readonly para evitar romper la traza EPS.
    /// </summary>
    private static readonly HashSet<string> _colsEditablesRelFact = new(StringComparer.Ordinal)
    {
        "Archivo json"
    };

    private static bool _esColumnaEditable(string col) => _colsEditablesRelFact.Contains(col);

    private bool _showHistorial;
    private List<CambioCeldaDto> _historial = new();

    private async Task EditarCeldaAsync(Guid filaId, string columna, string? valorNuevo)
    {
        if (_verDetalle is null) { return; }
        try
        {
            var cambio = await Svc.ActualizarValorCeldaAsync(
                _verDetalle.Metadata.Id, filaId, columna, valorNuevo, _actorId);
            if (cambio)
            {
                _ok = $"Celda actualizada — {columna}";
                // Refrescar la pagina actual para reflejar el nuevo valor.
                await CargarPaginaVer();
            }
        }
        catch (Exception ex)
        {
            _error = "No se pudo actualizar la celda: " + ex.Message;
        }
    }

    private async Task AbrirHistorial()
    {
        if (_verDetalle is null) { return; }
        try
        {
            _historial = (await Svc.ListarCambiosAsync(_verDetalle.Metadata.Id)).ToList();
            _showHistorial = true;
        }
        catch (Exception ex) { _error = "No se pudo cargar el historial: " + ex.Message; }
    }

    private void CerrarHistorial() => _showHistorial = false;
