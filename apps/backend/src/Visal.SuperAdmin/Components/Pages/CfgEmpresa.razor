@page "/cfg-empresa"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Visal.Application.Tenancy
@inject ISucursalService Svc
@inject IConfiguracionClinicaService ClinicaSvc

<PageTitle>Configuracion de Empresa - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion de la Entidad</div>
        <h1 class="ase-title">Configuracion de Empresa</h1>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-card">
    <div class="ase-card-h">Sucursales / sedes que maneja el sistema
        <button class="btn btn-outline-primary btn-sm ms-2" @onclick="Add">+ Sucursal</button>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead><tr><th>Codigo</th><th>Nombre</th><th>Ciudad</th><th>Direccion</th><th>Telefono</th><th title="Codigo de habilitacion REPS de la sede (Fase 4 Facturacion, 12 digitos)">Cod. habilitacion</th><th>Activa</th><th title="Exige codigo MIPRES al entregar medicamentos e insumos">MIPRES obligatorio</th><th title="Cuando esta marcado, el snapshot Relacion de Facturas excluye sesiones cuya HC no este Aprobada por revision clinica">HC revisada obligatoria</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in _items)
                {
                    <tr>
                        <td><input class="form-control form-control-sm mono" style="width:110px" @bind="s.Codigo" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Nombre" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Ciudad" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Direccion" /></td>
                        <td><input class="form-control form-control-sm" style="width:120px" @bind="s.Telefono" /></td>
                        <td><input class="form-control form-control-sm mono" style="width:140px" maxlength="20" @bind="s.CodigoHabilitacion" placeholder="730010353101" /></td>
                        <td class="text-center"><input type="checkbox" class="form-check-input" @bind="s.Activo" /></td>
                        <td class="text-center" title="Cuando esta marcado, la HC bloquea Agregar medicamentos/insumos sin URL MIPRES">
                            <input type="checkbox" class="form-check-input" @bind="s.MipresObligatorio" />
                        </td>
                        <td class="text-center" title="Cuando esta marcado, el snapshot Relacion de Facturas excluye pacientes de esta sede cuya HC no este revisada (Aprobada / Archivada)">
                            <input type="checkbox" class="form-check-input" @bind="s.ExigirHcRevisadaParaFacturar" />
                        </td>
                        <td class="ase-row-actions">
                            <button class="btn btn-primary btn-sm" @onclick="() => Save(s)">&#10003;</button>
                            @if (s.Id is not null)
                            {
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(s)">&times;</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_items.Count == 0) { <div class="ase-empty">Sin sucursales. Agrega la primera.</div> }
    </div>
</div>

@* ===== Configuracion clinica ===== *@
<div class="ase-card">
    <div class="ase-card-h">Configuracion clinica</div>
    <div class="ase-form">
        <div class="ase-f">
            <label>Validez de historia clinica (meses)</label>
            <div class="ase-input-row">
                <input type="number" min="1" max="120" class="form-control form-control-sm" @bind="_mesesHC" />
                <button class="btn btn-primary btn-sm" @onclick="SaveClinica" disabled="@_busyClinica">
                    @(_busyClinica ? "Guardando..." : "Guardar")
                </button>
            </div>
            <small class="text-muted">
                El modulo del profesional valida que el paciente tenga una historia clinica registrada
                en los ultimos N meses antes de permitir nuevas notas. Default 3.
            </small>
        </div>
    </div>
</div>

@* ===== Configuracion de turnos ===== *@
<div class="ase-card">
    <div class="ase-card-h">Configuracion de turnos</div>
    <div class="ase-form">
        <div class="ase-f">
            <label class="ase-chk">
                <input type="checkbox" @bind="_bloquearOverload" />
                <span>Bloquear guardado cuando un dia supere 24 h sumando todos los turnos</span>
            </label>
            <div class="ase-input-row" style="margin-top:6px;">
                <button class="btn btn-primary btn-sm" @onclick="SaveOverload" disabled="@_busyOverload">
                    @(_busyOverload ? "Guardando..." : "Guardar")
                </button>
            </div>
            <small class="text-muted">
                Con el toggle apagado (default) el editor de programaciones solo muestra un aviso visual;
                con el toggle encendido el servicio rechaza el guardado si algun dia acumula mas de 24 h
                de reloj entre todos los turnos apilados.
            </small>
        </div>
    </div>
</div>

<style>
    .ase-input-row { display: flex; gap: 6px; align-items: center; }
    .ase-input-row > input { max-width: 120px; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private List<Row> _items = new();
    private string? _error, _ok;
    private int _mesesHC = 3;
    private bool _busyClinica;
    private bool _bloquearOverload;
    private bool _busyOverload;

    protected override async Task OnInitializedAsync()
    {
        await Load();
        _mesesHC = await ClinicaSvc.GetMesesValidezHistoriaClinicaAsync();
        _bloquearOverload = await ClinicaSvc.GetBloquearOverloadTurnosAsync();
    }
    private async Task Load() => _items = (await Svc.ListAsync()).Select(Row.From).ToList();

    private async Task SaveClinica()
    {
        _error = _ok = null; _busyClinica = true;
        try
        {
            await ClinicaSvc.SetMesesValidezHistoriaClinicaAsync(_mesesHC, await Actor());
            _ok = $"Validez de historia clinica actualizada a {_mesesHC} meses.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _busyClinica = false; }
    }

    private async Task SaveOverload()
    {
        _error = _ok = null; _busyOverload = true;
        try
        {
            await ClinicaSvc.SetBloquearOverloadTurnosAsync(_bloquearOverload, await Actor());
            _ok = _bloquearOverload
                ? "Bloqueo de overload activado: las programaciones con dias > 24h no podran guardarse."
                : "Bloqueo de overload desactivado: se permite guardar aunque un dia supere 24h.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _busyOverload = false; }
    }
    private void Add() => _items.Add(new Row { Activo = true });

    private async Task Save(Row r)
    {
        _error = _ok = null;
        try
        {
            var saved = await Svc.SaveAsync(new SaveSucursalRequest(r.Id, r.Codigo, r.Nombre, r.Direccion, r.Ciudad, r.Telefono, r.Activo, r.MipresObligatorio, r.CodigoHabilitacion, r.ExigirHcRevisadaParaFacturar), await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            r.Id = saved.Id; _ok = "Sucursal guardada.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Delete(Row r)
    {
        if (r.Id is Guid id) { await Svc.DeleteAsync(id, await Actor()); }
        await Load();
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private sealed class Row
    {
        public Guid? Id { get; set; }
        public string Codigo { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string? Direccion { get; set; }
        public string? Ciudad { get; set; }
        public string? Telefono { get; set; }
        public bool Activo { get; set; } = true;
        public bool MipresObligatorio { get; set; }
        public string? CodigoHabilitacion { get; set; }
        public bool ExigirHcRevisadaParaFacturar { get; set; }
        public static Row From(SucursalDto d) => new() { Id = d.Id, Codigo = d.Codigo, Nombre = d.Nombre, Direccion = d.Direccion, Ciudad = d.Ciudad, Telefono = d.Telefono, Activo = d.Activo, MipresObligatorio = d.MipresObligatorio, CodigoHabilitacion = d.CodigoHabilitacion, ExigirHcRevisadaParaFacturar = d.ExigirHcRevisadaParaFacturar };
    }
}
