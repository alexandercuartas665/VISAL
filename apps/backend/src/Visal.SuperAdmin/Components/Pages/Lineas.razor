@page "/lineas"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Visal.Application.Tenancy
@using Visal.Application.Tenancy.WhatsApp
@using Visal.Domain.Enums
@implements IDisposable
@inject IWhatsAppLineService LinesSvc
@inject IWhatsAppConnectorService ConnectorSvc
@inject IWebhookAdminService WebhookSvc
@inject IGupshupConfigService GupshupSvc
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Lineas WhatsApp - Visal</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
            </div>
            <span>Infraestructura & IA</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Lineas <span>WhatsApp</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Conecta tus numeros de WhatsApp via Evolution API: escanea el QR y opera tus lineas.</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenNewLine" disabled="@(_server is { MasterReady: false, UseMasterServer: true })">+ Conectar linea</button>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    @* ===== Servidor Evolution (plataforma / propio) ===== *@
    <div class="card" style="max-width:1040px;padding:20px 22px;margin-bottom:22px;">
        <div style="font-weight:700;margin-bottom:4px;">Servidor de WhatsApp</div>
        <div class="text-muted" style="font-size:12px;margin-bottom:14px;">Usa el servidor de la plataforma o conecta tu propio servidor Evolution API.</div>

        <div style="display:flex;flex-direction:column;gap:8px;max-width:620px;">
            <label class="cfg-row" style="cursor:pointer;gap:10px;">
                <input type="radio" name="srv" checked="@_useMaster" @onchange="@(() => _useMaster = true)" />
                <div class="grow">
                    <div style="font-weight:600;font-size:13px;">Servidor de la plataforma (VISAL)</div>
                    <div class="text-muted" style="font-size:11px;">
                        @if (_server?.MasterReady == true) { <text>Listo: @_server.MasterBaseUrl</text> }
                        else { <text>El operador aun no ha configurado el servidor maestro.</text> }
                    </div>
                </div>
            </label>
            <label class="cfg-row" style="cursor:pointer;gap:10px;">
                <input type="radio" name="srv" checked="@(!_useMaster)" @onchange="@(() => _useMaster = false)" />
                <div class="grow">
                    <div style="font-weight:600;font-size:13px;">Mi propio servidor Evolution</div>
                    <div class="text-muted" style="font-size:11px;">Configura la URL y la API key de tu servidor.</div>
                </div>
            </label>
        </div>

        @if (!_useMaster)
        {
            <div class="field-row" style="max-width:620px;margin-top:12px;">
                <div class="field">
                    <label class="form-label">URL del servidor</label>
                    <input class="form-control" @bind="_ownUrl" placeholder="https://mi-evolution.com" autocomplete="off" />
                </div>
                <div class="field">
                    <label class="form-label">API key</label>
                    <input class="form-control" type="password" @bind="_ownToken" autocomplete="new-password" placeholder="@(_server?.HasOwnToken == true ? "Dejar vacio para conservar" : "")" />
                </div>
            </div>
        }

        @if (_serverMsg is not null)
        {
            <div class="@(_serverOk ? "text-success" : "text-danger")" style="font-size:12px;margin-top:10px;">@_serverMsg</div>
        }
        <button class="btn btn-outline-secondary" style="margin-top:12px;" @onclick="SaveServerAsync" disabled="@_busy">Guardar servidor</button>
    </div>

    @* ===== Webhook entrante (mensajes en caliente) ===== *@
    @if (_webhook is not null)
    {
        <div class="card" style="max-width:1040px;padding:20px 22px;margin-bottom:22px;">
            <div style="font-weight:700;margin-bottom:4px;">Mensajes entrantes (webhook)</div>
            <div class="text-muted" style="font-size:12px;margin-bottom:14px;">Para recibir respuestas de los clientes en vivo. En desarrollo se levanta un tunel; en produccion se usa la URL de tu dominio.</div>

            <div style="display:flex;flex-direction:column;gap:8px;max-width:620px;">
                <label class="cfg-row" style="cursor:pointer;gap:10px;">
                    <input type="radio" name="whmode" checked="@(_whMode == "Development")" @onchange="@(() => _whMode = "Development")" />
                    <div class="grow">
                        <div style="font-weight:600;font-size:13px;">Modo desarrollo (tunel)</div>
                        <div class="text-muted" style="font-size:11px;">La app levanta un tunel cloudflared y expone el webhook temporalmente.</div>
                    </div>
                </label>
                <label class="cfg-row" style="cursor:pointer;gap:10px;">
                    <input type="radio" name="whmode" checked="@(_whMode == "Production")" @onchange="@(() => _whMode = "Production")" />
                    <div class="grow">
                        <div style="font-weight:600;font-size:13px;">Produccion (URL fija)</div>
                        <div class="text-muted" style="font-size:11px;">Usa la URL publica de tu dominio (ej. https://app.visal.com.co).</div>
                    </div>
                </label>
            </div>

            <div class="field-row" style="max-width:620px;margin-top:12px;">
                @if (_whMode == "Production")
                {
                    <div class="field">
                        <label class="form-label">URL publica</label>
                        <input class="form-control" @bind="_whPublicUrl" placeholder="https://app.visal.com.co" autocomplete="off" />
                    </div>
                }
                <div class="field">
                    <label class="form-label">Token del webhook</label>
                    <input class="form-control" @bind="_whToken" placeholder="Se genera si lo dejas vacio" autocomplete="off" />
                </div>
            </div>

            <div style="display:flex;gap:8px;align-items:center;margin-top:12px;flex-wrap:wrap;">
                <button class="btn btn-outline-secondary" @onclick="SaveWebhookAsync" disabled="@_busy">Guardar webhook</button>
                @if (_whMode == "Development")
                {
                    @if (_webhook.TunnelRunning)
                    {
                        <button class="btn btn-outline-danger" @onclick="StopTunnelAsync" disabled="@_busy">Detener tunel</button>
                    }
                    else
                    {
                        <button class="btn btn-primary" @onclick="StartTunnelAsync" disabled="@_busy">Iniciar tunel</button>
                    }
                }
                @if (!string.IsNullOrWhiteSpace(_webhook.EffectiveUrl))
                {
                    <span class="badge bg-success">Escuchando</span>
                }
                else
                {
                    <span class="badge bg-secondary">Sin URL activa</span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_webhook.EffectiveUrl))
            {
                <div class="text-muted" style="font-size:11px;margin-top:8px;word-break:break-all;">Webhook activo: @_webhook.EffectiveUrl</div>
            }
            @if (_whMsg is not null)
            {
                <div class="@(_whOk ? "text-success" : "text-danger")" style="font-size:12px;margin-top:8px;">@_whMsg</div>
            }
        </div>
    }

    @* ===== KPIs ===== *@
    <div class="kpi-grid" style="margin-bottom:22px;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));max-width:820px;">
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2"/><path d="M12 18h.01"/></svg></div></div>
            <div class="kpi-label">Lineas</div>
            <div class="kpi-value">@_lines.Count</div>
            <div class="kpi-hint">Total registradas</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-success"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg></div></div>
            <div class="kpi-label">Conectadas</div>
            <div class="kpi-value">@_lines.Count(l => l.Status == WhatsAppLineStatus.Connected)</div>
            <div class="kpi-hint">En linea</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-gold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div></div>
            <div class="kpi-label">Pendientes</div>
            <div class="kpi-value">@_lines.Count(l => l.Status is WhatsAppLineStatus.Connecting or WhatsAppLineStatus.Created)</div>
            <div class="kpi-hint">Por conectar</div>
        </div>
    </div>

    @if (_lines.Count == 0)
    {
        <p class="text-muted">No tienes lineas todavia. Usa "Conectar linea" para escanear un WhatsApp.</p>
    }
    else
    {
        <div class="card" style="max-width:1180px;padding:6px 16px;">
            <table class="table table-hover align-middle" style="margin-bottom:0;">
                <thead>
                    <tr><th>Linea</th><th>Proveedor</th><th>Telefono</th><th>Estado</th><th>Ultima conexion</th><th class="text-end">Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var l in _lines)
                    {
                        <tr>
                            <td style="font-weight:600;">@l.InstanceName</td>
                            <td>
                                @if (l.Provider == WhatsAppProvider.Gupshup)
                                {
                                    <span class="badge" style="background:#7c3aed;color:#fff;">Gupshup</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#0ea5e9;color:#fff;">Evolution</span>
                                }
                            </td>
                            <td style="font-size:12px;color:var(--muted-foreground);">@(string.IsNullOrWhiteSpace(l.PhoneNumber) ? "—" : l.PhoneNumber)</td>
                            <td><span class="badge bg-@StatusColor(l.Status)">@StatusText(l.Status)</span></td>
                            <td style="font-size:12px;color:var(--muted-foreground);">@(l.LastConnectedAt is { } c ? c.LocalDateTime.ToString("dd MMM HH:mm") : "Nunca")</td>
                            <td class="text-end" style="white-space:nowrap;">
                                @if (l.Provider == WhatsAppProvider.Gupshup)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditGupshupAppOfLineAsync(l)" disabled="@_busy" title="Editar credenciales de la App Gupshup (apikey, numero, etc.)">Editar App</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenWebhookAsync(l)" disabled="@_busy" title="Ver URL del webhook para pegar en Gupshup">Webhook</button>
                                }
                                @if (l.Status == WhatsAppLineStatus.Connected)
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="() => OpenTest(l)" disabled="@_busy">Probar envio</button>
                                    @if (l.Provider == WhatsAppProvider.Evolution)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => RefreshAsync(l.Id)" disabled="@_busy">Actualizar</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DisconnectAsync(l.Id)" disabled="@_busy">Desconectar</button>
                                    }
                                }
                                else if (l.Provider == WhatsAppProvider.Evolution)
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="() => ConnectAsync(l)" disabled="@_busy">Conectar / QR</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => RefreshAsync(l.Id)" disabled="@_busy">Actualizar</button>
                                }
                                else
                                {
                                    @* Gupshup no requiere QR: el estado lo maneja Meta. Un boton para
                                       marcar como Connected una vez validado; en G6.2 lo cablearemos. *@
                                    <button class="btn btn-sm btn-primary" @onclick="() => MarkGupshupConnectedAsync(l.Id)" disabled="@_busy" title="Marcar linea Gupshup como Conectada">Activar</button>
                                }
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => AskDeleteLine(l)" disabled="@_busy" title="Eliminar linea">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@* ===== Modal: nueva linea (multi-provider) ===== *@
@if (_newOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:560px;">
            <div class="modal-head">
                <h3>Conectar nueva linea</h3>
                <button class="modal-close" @onclick="() => _newOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Proveedor *</label>
                    <div style="display:flex; gap:16px;">
                        <label style="flex:1;display:flex;gap:8px;align-items:flex-start;padding:10px 12px;border:1px solid var(--border);border-radius:8px;cursor:pointer;">
                            <input type="radio" name="prov" value="Evolution" checked="@(_newProvider == WhatsAppProvider.Evolution)"
                                   @onchange="() => _newProvider = WhatsAppProvider.Evolution" />
                            <span><strong>Evolution API</strong><br /><small>Baileys / QR / servidor propio o maestro.</small></span>
                        </label>
                        <label style="flex:1;display:flex;gap:8px;align-items:flex-start;padding:10px 12px;border:1px solid var(--border);border-radius:8px;cursor:pointer;">
                            <input type="radio" name="prov" value="Gupshup" checked="@(_newProvider == WhatsAppProvider.Gupshup)"
                                   @onchange="OnPickGupshupProviderAsync" />
                            <span><strong>Gupshup</strong><br /><small>BSP oficial Meta / WABA verificada.</small></span>
                        </label>
                    </div>
                </div>

                <div class="field">
                    <label class="form-label">Nombre visible de la linea *</label>
                    <input class="form-control" @bind="_newName" autocomplete="off" placeholder="Ventas, Soporte, etc." />
                </div>

                @if (_newProvider == WhatsAppProvider.Gupshup)
                {
                    <div class="field">
                        <label class="form-label">App Gupshup *</label>
                        <select class="form-control" @bind="_newGupshupAppId">
                            <option value="">— Selecciona una App configurada —</option>
                            @foreach (var app in _gupshupApps)
                            {
                                <option value="@app.Id">@app.AppName @(string.IsNullOrEmpty(app.PhoneNumber) ? "" : $"({app.PhoneNumber})")</option>
                            }
                        </select>
                        <div style="display:flex; gap:8px; margin-top:6px;">
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="OpenNewGupshupAppFromLine">+ Nueva App Gupshup</button>
                        </div>
                        <small class="text-muted">Cada App vive en tu dashboard Gupshup y trae su propio numero WABA + apikey.</small>
                    </div>
                }

                @if (_newError is not null)
                {
                    <div class="text-danger small">@_newError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _newOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="CreateAndConnectAsync"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(_newName) || (_newProvider == WhatsAppProvider.Gupshup && string.IsNullOrEmpty(_newGupshupAppId)))">
                    @(_newProvider == WhatsAppProvider.Gupshup ? "Crear linea Gupshup" : "Crear y conectar")
                </button>
            </div>
        </div>
    </div>
}

@* ===== Modal: Webhook URL de una linea Gupshup ===== *@
@if (_webhookOpen && _webhookLine is { } wl)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:640px;">
            <div class="modal-head">
                <h3>Webhook de "@wl.InstanceName"</h3>
                <button class="modal-close" @onclick="() => _webhookOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <p class="text-muted" style="margin-top:0;">
                    Pega esta URL en el dashboard Gupshup: <strong>Callback URL</strong> de la App.
                    Cada linea tiene su propio token opaco: si se filtra, regeneralo aca sin tocar Gupshup.
                </p>
                <div class="field">
                    <label class="form-label">URL del webhook</label>
                    <div style="display:flex; gap:6px;">
                        <input class="form-control" readonly value="@WebhookUrlFor(wl.InboundToken)" />
                        <button class="btn btn-outline-secondary" @onclick="() => CopyWebhookAsync(wl.InboundToken)" title="Copiar al portapapeles">Copiar</button>
                    </div>
                    @if (_webhookCopied)
                    {
                        <div class="text-success small" style="margin-top:4px;">Copiado.</div>
                    }
                </div>
                <div class="field">
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RegenerateTokenAsync(wl.Id)" disabled="@_busy">
                        Regenerar token
                    </button>
                    <small class="text-muted" style="margin-left:8px;">La URL vieja deja de funcionar al instante.</small>
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _webhookOpen = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: alta/edicion de App Gupshup ===== *@
@if (_gupshupAppOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:560px;">
            <div class="modal-head">
                <h3>@(_gupshupApp.Id == Guid.Empty ? "Nueva App Gupshup" : "Editar App Gupshup")</h3>
                <button class="modal-close" @onclick="() => _gupshupAppOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">App ID (GUID) *</label>
                    <input class="form-control" @bind="_gupshupApp.AppIdText" placeholder="7bdba1f4-d014-48da-b6a8-6a5c7a5030d4" />
                </div>
                <div class="field">
                    <label class="form-label">App Name *</label>
                    <input class="form-control" @bind="_gupshupApp.AppName" placeholder="Nombre exacto de la app en Gupshup" />
                </div>
                <div class="field">
                    <label class="form-label">WABA ID</label>
                    <input class="form-control" @bind="_gupshupApp.WabaId" placeholder="1845528306425202" />
                </div>
                <div class="field">
                    <label class="form-label">Numero WhatsApp (E.164) *</label>
                    <input class="form-control" @bind="_gupshupApp.PhoneNumber" placeholder="15559799304 (sin +)" />
                </div>
                <div class="field">
                    <label class="form-label">Nombre de visualizacion (Meta)</label>
                    <input class="form-control" @bind="_gupshupApp.DisplayName" placeholder="VisalRT SAS" />
                </div>
                <div class="field">
                    <label class="form-label">apikey @(_gupshupApp.Id == Guid.Empty ? "*" : "(dejar vacio para no cambiar)")</label>
                    <input class="form-control" type="password" @bind="_gupshupApp.ApiKey"
                           placeholder="@(_gupshupApp.Id == Guid.Empty ? "sk_..." : _gupshupApp.ApiKeyMasked ?? "sk_...")" />
                    <small class="text-muted">Se cifra con Data Protection y NUNCA se muestra en pantalla ni en logs.</small>
                </div>
                <div class="field">
                    <label class="form-label">Partner token (opcional, para dashboards)</label>
                    <input class="form-control" type="password" @bind="_gupshupApp.PartnerToken" placeholder="Solo si vas a gestionar plantillas via Partner API" />
                </div>
                @if (_gupshupAppError is not null)
                {
                    <div class="text-danger small">@_gupshupAppError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _gupshupAppOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveGupshupAppAsync" disabled="@_busy">Guardar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: QR ===== *@
@if (_qrOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:420px;">
            <div class="modal-head">
                <h3>Escanea el codigo QR</h3>
                <button class="modal-close" @onclick="CloseQr">&times;</button>
            </div>
            <div class="modal-body" style="text-align:center;">
                <p class="text-muted" style="font-size:12px;margin-top:0;">Abre WhatsApp &gt; Dispositivos vinculados &gt; Vincular dispositivo, y escanea este codigo.</p>
                @if (_qr is { } qr)
                {
                    <img src="@QrSrc(qr)" alt="QR" style="width:260px;height:260px;object-fit:contain;border:1px solid var(--border);border-radius:12px;" />
                }
                else
                {
                    <p class="text-muted">Generando QR...</p>
                }
                <div style="margin-top:12px;font-size:12px;color:var(--muted-foreground);">Estado: <strong>@(_qrLine is { } ql ? StatusText(ql.Status) : "—")</strong> · se actualiza solo</div>
                @if (_qrError is not null)
                {
                    <div class="text-danger small" style="margin-top:8px;">@_qrError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => RefreshAsync(_qrLineId)">Actualizar estado</button>
                <button class="btn btn-primary" @onclick="CloseQr">Listo</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: probar envio ===== *@
@if (_testOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>Probar envio &mdash; @_testLineName</h3>
                <button class="modal-close" @onclick="() => _testOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Numero de destino *</label>
                    <input class="form-control" @bind="_testPhone" autocomplete="off" placeholder="573001234567" />
                    <div class="text-muted" style="font-size:11px;margin-top:4px;">Con codigo de pais, sin signos (ej: 57 + numero).</div>
                </div>
                <div class="field">
                    <label class="form-label">Mensaje</label>
                    <textarea class="form-control" rows="3" @bind="_testText"></textarea>
                </div>
                @if (_testMsg is not null)
                {
                    <div class="@(_testOk ? "text-success" : "text-danger")" style="font-size:0.85rem;">@_testMsg</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _testOpen = false">Cerrar</button>
                <button class="btn btn-primary" @onclick="SendTestAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_testPhone))">Enviar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: confirmar eliminar linea ===== *@
@if (_deleteLineId is not null)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:420px;">
            <div class="modal-head">
                <h3>Eliminar linea</h3>
                <button class="modal-close" @onclick="() => _deleteLineId = null">&times;</button>
            </div>
            <div class="modal-body">
                <p>Vas a eliminar la linea <strong>@_deleteLineName</strong>. Se cerrara su sesion en WhatsApp y se quitara de la lista. Esta accion no se puede deshacer.</p>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _deleteLineId = null">Cancelar</button>
                <button class="btn btn-outline-danger" @onclick="ConfirmDeleteLineAsync" disabled="@_busy">Eliminar</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private List<WhatsAppLineDto> _lines = new();
    private EvolutionServerSettingDto? _server;

    private bool _useMaster = true;
    private string? _ownUrl;
    private string? _ownToken;
    private string? _serverMsg;
    private bool _serverOk;

    private bool _newOpen;
    private string? _newName;
    private string? _newError;
    private WhatsAppProvider _newProvider = WhatsAppProvider.Evolution;
    // El select devuelve string; solo lo casteamos a Guid al submit.
    private string _newGupshupAppId = string.Empty;
    private List<GupshupConfigDto> _gupshupApps = new();

    private bool _gupshupAppOpen;
    private GupshupAppForm _gupshupApp = new();
    private string? _gupshupAppError;

    private bool _webhookOpen;
    private WhatsAppLineDto? _webhookLine;
    private bool _webhookCopied;

    /// <summary>Formulario simple para el modal de App Gupshup. AppIdText es
    /// string para tolerar guiones y validar al submit; el resto son strings
    /// planos que se copian al SaveRequest.</summary>
    private sealed class GupshupAppForm
    {
        public Guid Id { get; set; }
        public string AppIdText { get; set; } = string.Empty;
        public string AppName { get; set; } = string.Empty;
        public string? WabaId { get; set; }
        public string? PhoneNumber { get; set; }
        public string? DisplayName { get; set; }
        public string? ApiKey { get; set; }
        public string? PartnerToken { get; set; }
        public string? ApiKeyMasked { get; set; }
    }

    private bool _qrOpen;
    private string? _qr;
    private string? _qrError;
    private Guid _qrLineId;
    private WhatsAppLineDto? _qrLine;
    private Timer? _pollTimer;

    private bool _testOpen;
    private Guid _testLineId;
    private string? _testLineName;
    private string? _testPhone;
    private string _testText = "Hola! Mensaje de prueba desde Visal.";
    private string? _testMsg;
    private bool _testOk;

    private Guid? _deleteLineId;
    private string? _deleteLineName;

    private WebhookConfigDto? _webhook;
    private string _whMode = "Development";
    private string? _whPublicUrl;
    private string? _whToken;
    private string? _whMsg;
    private bool _whOk;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        _server = await ConnectorSvc.GetServerAsync();
        _useMaster = _server.UseMasterServer;
        _ownUrl = _server.OwnBaseUrl;
        _lines = (await LinesSvc.ListAsync()).ToList();
        await LoadWebhookAsync();
    }

    private async Task LoadWebhookAsync()
    {
        _webhook = await WebhookSvc.GetAsync();
        _whMode = _webhook.Mode;
        _whPublicUrl = _webhook.PublicUrl;
        _whToken = _webhook.Token;
    }

    private async Task SaveWebhookAsync()
    {
        _whMsg = null;
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            _webhook = await WebhookSvc.SaveAsync(_whMode, _whPublicUrl, _whToken, actor);
            _whToken = _webhook.Token;
            _whOk = true;
            _whMsg = "Configuracion de webhook guardada.";
        }
        finally { _busy = false; }
    }

    private async Task StartTunnelAsync()
    {
        _whMsg = null;
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            _webhook = await WebhookSvc.StartTunnelAsync(actor);
            _whToken = _webhook.Token;
            if (string.IsNullOrWhiteSpace(_webhook.ActiveUrl))
            {
                _whOk = false;
                _whMsg = "No se pudo iniciar el tunel (cloudflared no disponible).";
            }
            else
            {
                _whOk = true;
                _whMsg = $"Tunel activo: {_webhook.ActiveUrl}. Webhook aplicado a las lineas conectadas.";
            }
        }
        finally { _busy = false; }
    }

    private async Task StopTunnelAsync()
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            _webhook = await WebhookSvc.StopTunnelAsync(actor);
            _whOk = true;
            _whMsg = "Tunel detenido.";
        }
        finally { _busy = false; }
    }

    private async Task SaveServerAsync()
    {
        _serverMsg = null;
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var res = await ConnectorSvc.SetServerAsync(new SetEvolutionServerRequest(_useMaster, _ownUrl, _ownToken), actor);
            if (res is null) { _serverMsg = "No se pudo guardar."; _serverOk = false; return; }
            _server = res;
            _ownToken = null;
            _serverOk = true;
            _serverMsg = "Servidor guardado.";
        }
        finally { _busy = false; }
    }

    private async void OpenNewLine()
    {
        _newError = null;
        _newName = null;
        _newProvider = WhatsAppProvider.Evolution;
        _newGupshupAppId = string.Empty;
        // Pre-cargamos la lista para que el select este listo si el usuario elige Gupshup.
        _gupshupApps = (await GupshupSvc.ListAsync()).ToList();
        _newOpen = true;
        StateHasChanged();
    }

    private async Task OnPickGupshupProviderAsync()
    {
        _newProvider = WhatsAppProvider.Gupshup;
        _gupshupApps = (await GupshupSvc.ListAsync()).ToList();
    }

    private async Task CreateAndConnectAsync()
    {
        _newError = null;
        if (string.IsNullOrWhiteSpace(_newName)) { _newError = "Escribe un nombre."; return; }
        Guid? gupshupAppId = null;
        if (_newProvider == WhatsAppProvider.Gupshup)
        {
            if (!Guid.TryParse(_newGupshupAppId, out var gid)) { _newError = "Selecciona una App Gupshup."; return; }
            gupshupAppId = gid;
        }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var line = await LinesSvc.CreateAsync(
                new CreateWhatsAppLineRequest(_newName!.Trim(), Provider: _newProvider, GupshupAppId: gupshupAppId),
                actor);
            if (line is null) { _newError = "No se pudo crear la linea."; return; }
            _newOpen = false;
            await ReloadAsync();
            // Solo Evolution tiene flujo QR: para Gupshup mostramos el modal
            // Webhook para que el usuario copie la URL a Gupshup.
            if (line.Provider == WhatsAppProvider.Evolution)
            {
                await ConnectAsync(line);
            }
            else
            {
                _webhookLine = line;
                _webhookCopied = false;
                _webhookOpen = true;
            }
        }
        finally { _busy = false; }
    }

    private void OpenNewGupshupAppFromLine()
    {
        // Precarga vacio para creacion.
        _gupshupAppError = null;
        _gupshupApp = new GupshupAppForm();
        _gupshupAppOpen = true;
    }

    /// <summary>Abre el modal de edicion pre-poblado con la App Gupshup que
    /// esta linea tiene asignada. Los campos AppId/AppName/etc quedan
    /// listos y el usuario solo pega la apikey nueva.</summary>
    private async Task EditGupshupAppOfLineAsync(WhatsAppLineDto line)
    {
        _gupshupAppError = null;
        if (line.GupshupAppId is not Guid gid)
        {
            _gupshupAppError = "Esta linea no tiene App Gupshup asignada.";
            return;
        }
        var app = await GupshupSvc.GetAsync(gid);
        if (app is null)
        {
            _gupshupAppError = "La App no se encontro.";
            return;
        }
        _gupshupApp = new GupshupAppForm
        {
            Id = app.Id,
            AppIdText = app.AppId.ToString(),
            AppName = app.AppName,
            WabaId = app.WabaId,
            PhoneNumber = app.PhoneNumber,
            DisplayName = app.DisplayName,
            ApiKey = null, // Vacio para no re-mostrarla; el placeholder muestra el mask.
            ApiKeyMasked = app.ApiKeyMasked,
        };
        _gupshupAppOpen = true;
    }

    private async Task SaveGupshupAppAsync()
    {
        _gupshupAppError = null;
        if (!Guid.TryParse(_gupshupApp.AppIdText, out var appGuid))
        {
            _gupshupAppError = "AppId invalido: debe ser un GUID.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_gupshupApp.AppName)) { _gupshupAppError = "Falta el AppName."; return; }
        if (string.IsNullOrWhiteSpace(_gupshupApp.PhoneNumber)) { _gupshupAppError = "Falta el numero."; return; }
        if (_gupshupApp.Id == Guid.Empty && string.IsNullOrWhiteSpace(_gupshupApp.ApiKey))
        {
            _gupshupAppError = "La apikey es obligatoria para crear.";
            return;
        }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var req = new SaveGupshupConfigRequest(
                AppId: appGuid,
                AppName: _gupshupApp.AppName.Trim(),
                WabaId: _gupshupApp.WabaId,
                PhoneNumber: _gupshupApp.PhoneNumber,
                DisplayName: _gupshupApp.DisplayName,
                ApiKey: _gupshupApp.ApiKey,
                PartnerToken: _gupshupApp.PartnerToken);
            var saved = await GupshupSvc.UpsertAsync(_gupshupApp.Id == Guid.Empty ? null : _gupshupApp.Id, req, actor);
            if (saved is null) { _gupshupAppError = "No se pudo guardar."; return; }
            _gupshupApps = (await GupshupSvc.ListAsync()).ToList();
            // Auto-selecciona la recien creada si estamos en el modal de linea nueva.
            _newGupshupAppId = saved.Id.ToString();
            _gupshupAppOpen = false;
        }
        finally { _busy = false; }
    }

    private void OpenWebhookAsync(WhatsAppLineDto line)
    {
        _webhookLine = line;
        _webhookCopied = false;
        _webhookOpen = true;
    }

    private async Task CopyWebhookAsync(string? token)
    {
        if (string.IsNullOrEmpty(token)) { return; }
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", WebhookUrlFor(token));
            _webhookCopied = true;
        }
        catch (TaskCanceledException) { _webhookCopied = true; }
        catch { /* algunos navegadores bloquean clipboard sin HTTPS; el usuario puede copiar a mano */ }
    }

    private async Task RegenerateTokenAsync(Guid lineId)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var newToken = await GupshupSvc.RegenerateInboundTokenAsync(lineId, actor);
            if (newToken is null) { return; }
            await ReloadAsync();
            _webhookLine = _lines.FirstOrDefault(l => l.Id == lineId);
            _webhookCopied = false;
        }
        finally { _busy = false; }
    }

    private async Task MarkGupshupConnectedAsync(Guid lineId)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            await LinesSvc.ChangeStatusAsync(lineId, WhatsAppLineStatus.Connected, actor);
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    /// <summary>URL absoluta a copiar en el dashboard Gupshup. Detecta host
    /// dinamicamente para funcionar en dev/staging/prod sin config.</summary>
    private string WebhookUrlFor(string? token)
    {
        if (string.IsNullOrEmpty(token)) { return "(sin token)"; }
        var baseUri = new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority);
        return $"{baseUri}/webhooks/gupshup/{token}";
    }

    private async Task ConnectAsync(WhatsAppLineDto line)
    {
        _qrError = null;
        _qr = null;
        _qrLineId = line.Id;
        _qrLine = line;
        _qrOpen = true;
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var res = await ConnectorSvc.ConnectLineAsync(line.Id, actor);
            if (!res.Ok) { _qrError = res.Error; }
            _qr = res.QrBase64;
            await ReloadAsync();
            _qrLine = _lines.FirstOrDefault(l => l.Id == line.Id);
            StartPolling();
        }
        finally { _busy = false; }
    }

    private void StartPolling()
    {
        _pollTimer?.Dispose();
        _pollTimer = new Timer(async _ => await PollAsync(), null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    private async Task PollAsync()
    {
        if (!_qrOpen) { return; }
        var actor = await ActorAsync();
        var updated = await ConnectorSvc.RefreshAsync(_qrLineId, actor);
        if (updated is not null)
        {
            _qrLine = updated;
            var i = _lines.FindIndex(l => l.Id == updated.Id);
            if (i >= 0) { _lines[i] = updated; }
            if (updated.Status == WhatsAppLineStatus.Connected)
            {
                _pollTimer?.Dispose();
                _pollTimer = null;
            }
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshAsync(Guid lineId)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var updated = await ConnectorSvc.RefreshAsync(lineId, actor);
            if (updated is not null)
            {
                var i = _lines.FindIndex(l => l.Id == updated.Id);
                if (i >= 0) { _lines[i] = updated; }
                if (_qrLineId == lineId) { _qrLine = updated; }
            }
        }
        finally { _busy = false; }
    }

    private async Task DisconnectAsync(Guid lineId)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            await ConnectorSvc.DisconnectAsync(lineId, actor);
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private void AskDeleteLine(WhatsAppLineDto line)
    {
        _deleteLineId = line.Id;
        _deleteLineName = line.InstanceName;
    }

    private async Task ConfirmDeleteLineAsync()
    {
        if (_deleteLineId is not Guid id) { return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            await ConnectorSvc.DeleteLineAsync(id, actor);
            _deleteLineId = null;
            _deleteLineName = null;
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private void CloseQr()
    {
        _qrOpen = false;
        _pollTimer?.Dispose();
        _pollTimer = null;
    }

    private void OpenTest(WhatsAppLineDto line)
    {
        _testMsg = null;
        _testLineId = line.Id;
        _testLineName = line.InstanceName;
        _testPhone = string.IsNullOrWhiteSpace(line.PhoneNumber) ? null : line.PhoneNumber;
        _testOpen = true;
    }

    private async Task SendTestAsync()
    {
        _testMsg = null;
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var res = await ConnectorSvc.SendTestAsync(_testLineId, _testPhone ?? "", _testText, actor);
            _testOk = res.Ok;
            _testMsg = res.Ok ? "Mensaje enviado." : $"No se pudo enviar: {res.Error}";
        }
        finally { _busy = false; }
    }

    public void Dispose() => _pollTimer?.Dispose();

    private static string QrSrc(string qr) =>
        qr.StartsWith("data:", StringComparison.OrdinalIgnoreCase) ? qr : $"data:image/png;base64,{qr}";

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string StatusText(WhatsAppLineStatus s) => s switch
    {
        WhatsAppLineStatus.Connected => "Conectada",
        WhatsAppLineStatus.Connecting => "Conectando",
        WhatsAppLineStatus.Disconnected => "Desconectada",
        WhatsAppLineStatus.Failed => "Error",
        WhatsAppLineStatus.Disabled => "Deshabilitada",
        _ => "Creada"
    };

    private static string StatusColor(WhatsAppLineStatus s) => s switch
    {
        WhatsAppLineStatus.Connected => "success",
        WhatsAppLineStatus.Connecting => "warning",
        WhatsAppLineStatus.Failed => "danger",
        _ => "secondary"
    };
}
