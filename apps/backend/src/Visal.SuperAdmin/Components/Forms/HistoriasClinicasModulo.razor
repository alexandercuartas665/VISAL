    /// ocultan las pestanas marcadas como no visibles. Vacio = todas visibles.
    /// Viene del contexto de la asignacion en /atencion.
    /// </summary>
    [Parameter] public string? TipoServicio { get; set; }

    /// <summary>Set con los identificadores (PestanaKey) actualmente ocultos para
    /// el TipoServicio activo. Se recarga al cambiar el parametro. Vacio =
    /// mostrar todas.</summary>
