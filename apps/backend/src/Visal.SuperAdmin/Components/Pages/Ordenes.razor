@page "/ordenes"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Authorization
@using Visal.Application.Tenancy
@using Visal.Application.Revision
@using Visal.Domain.Entities
@inject IOrdenesClinicasService OcSvc
@inject IRevisionKanbanService KanbanSvc
@inject Visal.Application.Revision.Ia.IPreRevisionIaService PreIaSvc
@inject IRevisionDashboardService DashboardSvc
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

@*
   Modulo "Ordenes Clinicas". Vista de consulta + reimpresion (sin edicion).
   Filtros: paciente (texto), rango de fechas (cierre), especialista (dropdown).
   Ahora incluye HC Abiertas ademas de Cerradas — las abiertas se marcan con un
   tag y sus botones Consultar/Imprimir quedan deshabilitados (no se pueden
   consultar ni imprimir hasta que el profesional las cierre definitivamente).
   Listado ordenado alfabeticamente por paciente, secundario por fecha desc.
   Cada fila muestra los conteos de cada tipo de orden ligado a esa HC.
   El boton "Imprimir" abre un modal con checkboxes de todos los documentos
   disponibles para que el usuario elija cuales imprimir.
*@

<PageTitle>Ordenes Clinicas - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Operacion Clinica</div>
        <h1 class="ase-title">Ordenes Clinicas</h1>
        <small class="text-muted">Consulta, revision y reimpresion de historias clinicas.</small>
    </div>
</div>

@* Tabs secundarios de /ordenes — Ola 2 Capa 08 Revision Clinica.
   Lista: vista original con 2 columnas nuevas (Estado revision + Pre-revision agente).
   Kanban: tablero drag&drop de 4 columnas para el ciclo de revision (RC2c).
   Archivo: HCs con revision terminal (ArchivadaOk / Inactivada) (RC2d). *@
<div class="oc-tabs" role="tablist">
    <button type="button" class="oc-tab @(_tabActivo == "lista" ? "activo" : "")"
            @onclick='() => SeleccionarTab("lista")'>Lista</button>
    <button type="button" class="oc-tab @(_tabActivo == "kanban" ? "activo" : "")"
            @onclick='() => SeleccionarTab("kanban")'>Kanban revision</button>
    <button type="button" class="oc-tab @(_tabActivo == "archivo" ? "activo" : "")"
            @onclick='() => SeleccionarTab("archivo")'>Archivo</button>
    <button type="button" class="oc-tab @(_tabActivo == "dashboard" ? "activo" : "")"
            @onclick='() => SeleccionarTab("dashboard")'>Dashboard</button>
</div>

@if (_tabActivo == "kanban")
{
    <div class="ase-card">
        @if (_board is null)
        {
            <div class="ase-empty" style="padding:24px;">Cargando tablero...</div>
        }
        else
        {
            @* KPIs del header *@
            <div class="oc-kpis">
                <div class="oc-kpi"><span class="oc-kpi-n">@_board.Kpis.TotalCards</span> Total</div>
                <div class="oc-kpi oc-kpi-a"><span class="oc-kpi-n">@_board.Kpis.Abiertas</span> Abiertas</div>
                <div class="oc-kpi oc-kpi-c"><span class="oc-kpi-n">@_board.Kpis.Cerradas</span> Cerradas</div>
                <div class="oc-kpi oc-kpi-r"><span class="oc-kpi-n">@_board.Kpis.Rechazadas</span> Rechazadas</div>
                <div class="oc-kpi oc-kpi-ap"><span class="oc-kpi-n">@_board.Kpis.Aprobadas</span> Aprobadas</div>
                @if (_board.Kpis.PorcentajeRechazadas is double p)
                {
                    <div class="oc-kpi"><span class="oc-kpi-n">@p.ToString("0")%</span> Tasa rechazo</div>
                }
                @if (_board.Kpis.TiempoMedioEnCerradas is TimeSpan ts && ts.TotalMinutes > 0)
                {
                    <div class="oc-kpi" title="Tiempo promedio que las HCs pasan en la columna Cerradas antes de ser tomadas">
                        <span class="oc-kpi-n">@FormatearDuracion(ts)</span> T. medio Cerradas
                    </div>
                }
                <div class="oc-kpi-actions">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="RefrescarKanban" disabled="@_cargandoKanban">
                        @(_cargandoKanban ? "Recargando..." : "🔄 Recargar")
                    </button>
                </div>
            </div>

            @* Ola 7 RC7d — Toolbar de filtros del Kanban. AND entre filtros. *@
            <div class="oc-kb-filtros" style="display:flex;gap:12px;flex-wrap:wrap;align-items:end;padding:12px 0;border-bottom:1px solid #e5e7eb;margin-bottom:12px;">
                <div style="min-width:200px;">
                    <label style="font-size:12px;color:#666;display:block;">Especialista</label>
                    <select class="form-select form-select-sm" @bind="_kbFiltroEspecialista">
                        <option value="">(Todos)</option>
                        @foreach (var esp in _especialistas)
                        {
                            <option value="@esp">@esp</option>
                        }
                    </select>
                </div>
                <div>
                    <label style="font-size:12px;color:#666;display:block;">Fecha desde</label>
                    <input type="date" class="form-control form-control-sm" @bind="_kbFiltroDesde" />
                </div>
                <div>
                    <label style="font-size:12px;color:#666;display:block;">Fecha hasta</label>
                    <input type="date" class="form-control form-control-sm" @bind="_kbFiltroHasta" />
                </div>
                <div style="display:flex;gap:6px;">
                    <button class="btn btn-primary btn-sm" @onclick="AplicarFiltrosKanban" disabled="@_cargandoKanban">🔍 Aplicar</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarFiltrosKanban" disabled="@_cargandoKanban">Limpiar</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(_kbFiltroEspecialista) || _kbFiltroDesde is not null || _kbFiltroHasta is not null)
                {
                    <div style="margin-left:auto;display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                        <span style="font-size:12px;color:#666;">Filtros activos:</span>
                        @if (!string.IsNullOrWhiteSpace(_kbFiltroEspecialista))
                        {
                            <span class="oc-kpi" style="background:#e0e7ff;color:#4338ca;">👤 @_kbFiltroEspecialista</span>
                        }
                        @if (_kbFiltroDesde is DateTime dd)
                        {
                            <span class="oc-kpi" style="background:#e0e7ff;color:#4338ca;">📅 desde @dd.ToString("yyyy-MM-dd")</span>
                        }
                        @if (_kbFiltroHasta is DateTime dh)
                        {
                            <span class="oc-kpi" style="background:#e0e7ff;color:#4338ca;">📅 hasta @dh.ToString("yyyy-MM-dd")</span>
                        }
                    </div>
                }
            </div>

            @if (_kanbanError is not null)
            {
                <div class="oc-kanban-err">@_kanbanError</div>
            }

            @* 4 columnas del tablero *@
            <div class="oc-kb-board">
                @foreach (var col in new[] { RevisionKanbanColumna.Abiertas, RevisionKanbanColumna.Cerradas,
                                             RevisionKanbanColumna.Rechazadas, RevisionKanbanColumna.Aprobadas })
                {
                    var cards = _board.Cards.Where(c => c.Columna == col).ToList();
                    <div class="oc-kb-col oc-kb-col-@(col.ToString().ToLower())"
                         ondragover="event.preventDefault();"
                         @ondrop="() => OnDropColumnaAsync(col)">
                        <div class="oc-kb-colh">
                            <span>@ColumnaLabel(col)</span>
                            <span class="oc-kb-count">@cards.Count</span>
                        </div>
                        <div class="oc-kb-cards">
                            @foreach (var card in cards)
                            {
                                <div class="oc-kb-card"
                                     draggable="true"
                                     @ondragstart="() => OnDragStart(card)"
                                     @ondragend="OnDragEnd"
                                     title="@(card.UltimoMotivo ?? card.UltimoResumenAgente ?? "")">
                                    <div class="oc-kb-p">@card.PacienteNombre</div>
                                    <div class="oc-kb-fm">@card.FormatoNombre</div>
                                    <div class="oc-kb-meta">
                                        <span>📅 @(card.FechaCierre?.ToLocalTime().ToString("dd/MM/yy") ?? card.FechaApertura.ToLocalTime().ToString("dd/MM/yy"))</span>
                                        @if (card.EspecialistaNombre is not null)
                                        {
                                            <span>👤 @card.EspecialistaNombre</span>
                                        }
                                    </div>
                                    <div class="oc-kb-badges">
                                        @if (card.Iteracion > 1)
                                        {
                                            <span class="oc-kb-badge oc-kb-badge-iter" title="Iteracion actual">iter @card.Iteracion</span>
                                        }
                                        @if (card.EstadoAgente is RevisionResultado ea)
                                        {
                                            var (agTxt, agCls, _) = AgenteBadge(ea);
                                            <span class="oc-kb-badge @agCls" title="Veredicto del agente IA">@agTxt</span>
                                        }
                                    </div>
                                    @if (col == RevisionKanbanColumna.Aprobadas)
                                    {
                                        <div class="oc-kb-card-actions">
                                            <button class="btn btn-sm btn-outline-success"
                                                    @onclick="() => AbrirModalArchivar(card)"
                                                    title="Archivar con permiso final (ArchivarOk / Inactivar)">
                                                📦 Archivar
                                            </button>
                                        </div>
                                    }
                                    else if (_puedeRevisar
                                             && (col == RevisionKanbanColumna.Cerradas || col == RevisionKanbanColumna.Rechazadas))
                                    {
                                        <div class="oc-kb-card-actions">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => EjecutarPreRevisionIa(card)"
                                                    disabled="@_procesando"
                                                    title="Ejecutar REVISOR CLINICO IA sobre esta HC (registra veredicto en la bitacora)">
                                                🤖 Pre-revision IA
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                            @if (cards.Count == 0)
                            {
                                <div class="oc-kb-empty">Sin cards</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
else if (_tabActivo == "archivo")
{
    <div class="ase-card">
        <div class="oc-filtros" style="grid-template-columns:1.5fr 1fr 1fr 1fr auto;">
            <div class="oc-f oc-f-wide">
                <label>Paciente</label>
                <input class="form-control form-control-sm"
                       placeholder="Nombre o documento..."
                       @bind="_archPaciente" @bind:event="oninput" />
            </div>
            <div class="oc-f">
                <label>Sabor</label>
                <select class="form-select form-select-sm" @bind="_archSabor">
                    <option value="">(Todos)</option>
                    <option value="ArchivadaOk">Archivadas OK</option>
                    <option value="Inactivada">Inactivadas</option>
                </select>
            </div>
            <div class="oc-f">
                <label>Fecha desde</label>
                <input type="date" class="form-control form-control-sm" @bind="_archDesde" />
            </div>
            <div class="oc-f">
                <label>Fecha hasta</label>
                <input type="date" class="form-control form-control-sm" @bind="_archHasta" />
            </div>
            <div class="oc-f oc-f-acts">
                <button class="btn btn-primary btn-sm" @onclick="RefrescarArchivo" disabled="@_cargandoArchivo">
                    @(_cargandoArchivo ? "Cargando..." : "🔍 Buscar")
                </button>
                @* Ola 7 RC7b — Export CSV del archivo con los mismos filtros actuales. *@
                <button class="btn btn-outline-secondary btn-sm" @onclick="DescargarArchivoCsv"
                        title="Descarga el listado actual del tab Archivo como CSV (UTF-8 con BOM).">
                    📥 CSV
                </button>
            </div>
        </div>

        @if (_kanbanError is not null)
        {
            <div class="oc-kanban-err">@_kanbanError</div>
        }

        <div class="oc-grid-h">
            Archivo de revisiones (@_archivo.Count)
        </div>

        @if (_cargandoArchivo && _archivo.Count == 0)
        {
            <div class="ase-empty" style="padding:20px;">Cargando...</div>
        }
        else if (_archivo.Count == 0)
        {
            <div class="ase-empty" style="padding:30px;">
                No hay revisiones archivadas. Los ciclos terminales aparecen aca.
            </div>
        }
        else
        {
            <div class="oc-tbl-wrap">
                <table class="table table-sm oc-tbl">
                    <thead>
                        <tr>
                            <th style="min-width:220px">Paciente</th>
                            <th style="width:160px">Documento</th>
                            <th>Formato HC</th>
                            <th style="width:180px">Especialista</th>
                            <th class="text-center" style="width:130px">Sabor</th>
                            <th class="text-center" style="width:150px">Fecha archivo</th>
                            <th class="text-center" style="width:80px">Iter</th>
                            <th style="min-width:220px">Motivo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in _archivo)
                        {
                            <tr>
                                <td>
                                    <div class="oc-pname">@a.PacienteNombre</div>
                                </td>
                                <td class="mono">@a.PacienteTipoDoc @a.PacienteDoc</td>
                                <td>@a.FormatoNombre</td>
                                <td>@(a.EspecialistaNombre ?? "-")</td>
                                <td class="text-center">
                                    @if (a.Sabor == RevisionEstadoAgregado.ArchivadaOk)
                                    {
                                        <span class="oc-rv-chip oc-rv-arch" title="Archivada OK">📦 OK</span>
                                    }
                                    else
                                    {
                                        <span class="oc-rv-chip oc-rv-inac" title="Inactivada">⊘ Inactivada</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @a.FechaArchivo.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="text-center">@a.IteracionesTotales</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(a.Motivo))
                                    {
                                        <div class="oc-arch-motivo">@a.Motivo</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
else if (_tabActivo == "dashboard")
{
    @* Ola 7 RC7a: Dashboard con KPIs Kanban (tiempo por columna, tasa rechazo, adopcion agente). *@
    <div class="ase-card oc-dashboard">
        @if (_dashboard is null)
        {
            <div class="ase-empty" style="padding:24px;">
                @(_cargandoDashboard ? "Cargando metricas..." : "Sin datos.")
            </div>
        }
        else
        {
            <div class="oc-dash-actions" style="display:flex;justify-content:flex-end;margin-bottom:12px;">
                <button class="btn btn-outline-secondary btn-sm" @onclick="RefrescarDashboard" disabled="@_cargandoDashboard">
                    @(_cargandoDashboard ? "Recargando..." : "🔄 Recargar")
                </button>
            </div>

            @* Resumen — KPI cards principales *@
            <div class="oc-kpis oc-dash-resumen">
                <div class="oc-kpi"><span class="oc-kpi-n">@_dashboard.Resumen.TotalCiclos</span> Total ciclos</div>
                <div class="oc-kpi oc-kpi-a"><span class="oc-kpi-n">@_dashboard.Resumen.CiclosActivos</span> Activos</div>
                <div class="oc-kpi"><span class="oc-kpi-n">@_dashboard.Resumen.CiclosTerminales</span> Terminales</div>
                <div class="oc-kpi oc-kpi-ap"><span class="oc-kpi-n">@_dashboard.Resumen.Aprobadas</span> Aprobadas</div>
                <div class="oc-kpi oc-kpi-r"><span class="oc-kpi-n">@_dashboard.Resumen.Rechazadas</span> Rechazadas</div>
                <div class="oc-kpi"><span class="oc-kpi-n">@_dashboard.Resumen.PorcentajeRechazoGlobal.ToString("0.0")%</span> Tasa rechazo global</div>
            </div>

            @* Grid de 2 columnas: adopcion agente + tiempo por columna Kanban *@
            <div class="oc-dash-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px;">
                <div class="oc-dash-card">
                    <h3>🤖 Adopcion automatica del agente</h3>
                    <div class="oc-dash-big" style="font-size:28px;font-weight:700;">
                        @_dashboard.AdopcionAgente.PorcentajeAdopcion.ToString("0.0")%
                    </div>
                    <div class="oc-dash-sub" style="color:#666;font-size:13px;">
                        @_dashboard.AdopcionAgente.AprobacionesAutomaticas de @_dashboard.AdopcionAgente.TotalAprobaciones aprobaciones fueron automaticas (agente con confianza >= umbral).
                    </div>
                </div>
                <div class="oc-dash-card">
                    <h3>⏱ Tiempo promedio en columna Kanban</h3>
                    <table class="oc-dash-tabla" style="width:100%;font-size:13px;">
                        <thead>
                            <tr><th style="text-align:left;">Columna</th><th style="text-align:right;">Muestras</th><th style="text-align:right;">Promedio</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var t in _dashboard.TiemposMediosPorColumna)
                            {
                                <tr>
                                    <td>@t.Columna</td>
                                    <td style="text-align:right;">@t.Muestras</td>
                                    <td style="text-align:right;">@(t.PromedioPermanencia is TimeSpan ts ? FormatearDuracion(ts) : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* Top 10 rechazos por profesional *@
            <div class="oc-dash-card" style="margin-top:16px;">
                <h3>🚨 Top rechazos por profesional</h3>
                @if (_dashboard.TopRechazosPorProfesional.Count == 0)
                {
                    <div class="ase-empty" style="padding:16px;color:#666;">Aun no hay rechazos registrados.</div>
                }
                else
                {
                    <table class="oc-dash-tabla" style="width:100%;font-size:13px;">
                        <thead>
                            <tr>
                                <th style="text-align:left;">#</th>
                                <th style="text-align:left;">Especialista</th>
                                <th style="text-align:right;">Total ciclos</th>
                                <th style="text-align:right;">Rechazados</th>
                                <th style="text-align:right;">% rechazo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var idx = 1; }
                            @foreach (var r in _dashboard.TopRechazosPorProfesional)
                            {
                                <tr>
                                    <td>@(idx++)</td>
                                    <td>@r.EspecialistaNombre</td>
                                    <td style="text-align:right;">@r.TotalCiclos</td>
                                    <td style="text-align:right;">@r.Rechazados</td>
                                    <td style="text-align:right;">@r.PorcentajeRechazo.ToString("0.0")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
    </div>
}
else
{
<div class="ase-card">
    <div class="oc-filtros">
        <div class="oc-f oc-f-wide">
            <label>Paciente</label>
            <input class="form-control form-control-sm"
                   placeholder="Nombre o documento del paciente..."
                   @bind="_filtroPaciente" @bind:event="oninput" @onkeyup="OnKeyup" />
        </div>
        <div class="oc-f">
            <label>Fecha desde</label>
            <input type="date" class="form-control form-control-sm" @bind="_desde" />
        </div>
        <div class="oc-f">
            <label>Fecha hasta</label>
            <input type="date" class="form-control form-control-sm" @bind="_hasta" />
        </div>
        <div class="oc-f oc-f-wide">
            <label>Especialista</label>
            <select class="form-select form-select-sm" @bind="_especialista">
                <option value="">(Todos)</option>
                @foreach (var e in _especialistas)
                {
                    <option value="@e">@e</option>
                }
            </select>
        </div>
        <div class="oc-f">
            <label>Estado</label>
            <select class="form-select form-select-sm" @bind="_estadoFiltro">
                <option value="">(Todas)</option>
                <option value="Cerrada">Solo Cerradas</option>
                <option value="Abierta">Solo Abiertas</option>
            </select>
        </div>
        <div class="oc-f oc-f-acts">
            <button class="btn btn-primary btn-sm" @onclick="Buscar" disabled="@_buscando">
                @(_buscando ? "Buscando..." : "🔍 Buscar")
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="Limpiar" disabled="@_buscando">
                Limpiar
            </button>
        </div>
    </div>

    <div class="oc-grid-h">
        Historias clinicas (@_rows.Count)
        @if (_rows.Count >= 500)
        {
            <span class="oc-warn">- mostrando primeros 500. Refina los filtros para ver mas.</span>
        }
    </div>

    @if (_buscando && _rows.Count == 0)
    {
        <div class="ase-empty">Cargando...</div>
    }
    else if (_rows.Count == 0)
    {
        <div class="ase-empty" style="padding:30px;">
            No hay historias clinicas que coincidan con los filtros.
        </div>
    }
    else
    {
        <div class="oc-tbl-wrap">
            <table class="table table-sm oc-tbl">
                <thead>
                    <tr>
                        <th style="min-width:220px">Paciente</th>
                        <th style="width:160px">Documento</th>
                        <th>Formato HC</th>
                        <th style="width:180px">Especialista</th>
                        <th class="text-center" style="width:110px">Estado</th>
                        <th class="text-center" style="width:130px">Fecha</th>
                        <th class="text-center" style="width:320px">Documentos</th>
                        <th class="text-center" style="width:130px" title="Estado del ciclo de revision (Capa 08)">Revision</th>
                        <th class="text-center" style="width:130px" title="Ultimo veredicto del agente IA">Pre-revision agente</th>
                        <th class="text-end" style="width:280px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _rows)
                    {
                        var cerrada = string.Equals(r.Estado, "Cerrada", StringComparison.OrdinalIgnoreCase);
                        var abierta = string.Equals(r.Estado, "Abierta", StringComparison.OrdinalIgnoreCase);
                        var fechaMostrar = r.FechaCierre ?? r.FechaApertura;
                        <tr class="@(abierta ? "oc-row-abierta" : "")">
                            <td>
                                <div class="oc-pname">@r.PacienteNombre</div>
                                <div class="oc-pmeta">
                                    @if (cerrada) { <text>HC cerrada el @(r.FechaCierre?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</text> }
                                    else if (abierta) { <text>HC abierta el @(r.FechaApertura.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</text> }
                                    else { <text>HC @r.Estado.ToLower() el @(fechaMostrar.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</text> }
                                </div>
                            </td>
                            <td class="mono">@r.PacienteTipoDoc @r.PacienteDoc</td>
                            <td>@r.FormatoNombre</td>
                            <td>@(r.EspecialistaNombre ?? "-")</td>
                            <td class="text-center">
                                @if (cerrada)
                                {
                                    <span class="oc-est oc-est-cerrada" title="Cerrada definitivamente">&#10004; Cerrada</span>
                                }
                                else if (abierta)
                                {
                                    <span class="oc-est oc-est-abierta" title="La historia sigue abierta — el profesional aun no la ha cerrado">&#128276; Abierta</span>
                                }
                                else
                                {
                                    <span class="oc-est oc-est-inactiva" title="@(r.Estado)">@r.Estado</span>
                                }
                            </td>
                            <td class="text-center">
                                @fechaMostrar.ToLocalTime().ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-center">
                                <div class="oc-pills">
                                    <span class="oc-pill" title="Historia clinica">HC</span>
                                    @if (r.MedicamentosCount > 0)   { <span class="oc-pill oc-pill-med"  title="@r.MedicamentosCount medicamento(s)">MED @r.MedicamentosCount</span> }
                                    @if (r.ServiciosCount > 0)      { <span class="oc-pill oc-pill-srv"  title="@r.ServiciosCount servicio(s)">SRV @r.ServiciosCount</span> }
                                    @if (r.InsumosCount > 0)        { <span class="oc-pill oc-pill-ins"  title="@r.InsumosCount insumo(s)">INS @r.InsumosCount</span> }
                                    @if (r.RemisionesCount > 0)     { <span class="oc-pill oc-pill-rem"  title="@r.RemisionesCount remision(es)">REM @r.RemisionesCount</span> }
                                    @if (r.IncapacidadesCount > 0)  { <span class="oc-pill oc-pill-inc"  title="@r.IncapacidadesCount incapacidad(es)">INC @r.IncapacidadesCount</span> }
                                    @if (r.CertificacionesCount > 0){ <span class="oc-pill oc-pill-cert" title="@r.CertificacionesCount certificacion(es)">CRT @r.CertificacionesCount</span> }
                                    @if (r.RxImagCount > 0)         { <span class="oc-pill oc-pill-rx"   title="@r.RxImagCount rx/imagenologia">RX @r.RxImagCount</span> }
                                    @if (r.LabExtCount > 0)         { <span class="oc-pill oc-pill-lab"  title="@r.LabExtCount laboratorio(s)">LAB @r.LabExtCount</span> }
                                    @if (r.InsExtCount > 0)         { <span class="oc-pill oc-pill-inx"  title="@r.InsExtCount insumo(s) externo(s)">INX @r.InsExtCount</span> }
                                    @if (r.EscalasCount > 0)        { <span class="oc-pill oc-pill-esc"  title="@r.EscalasCount escala(s) diligenciada(s)">ESC @r.EscalasCount</span> }
                                    @if (r.EvolucionesCount > 0)    { <span class="oc-pill oc-pill-evo"  title="@r.EvolucionesCount evolucion(es)">EVO @r.EvolucionesCount</span> }
                                    @if (r.ConsentimientosCount > 0){ <span class="oc-pill oc-pill-con"  title="@r.ConsentimientosCount consentimiento(s)">CON @r.ConsentimientosCount</span> }
                                </div>
                            </td>
                            <td class="text-center">
                                @{
                                    var (chipTxt, chipCls, chipTitle) = ChipRevisionEstado(r);
                                }
                                <span class="oc-rv-chip @chipCls" title="@chipTitle">@chipTxt</span>
                                @if (r.RevisionIteracion is int it && it > 1)
                                {
                                    <div class="oc-rv-iter" title="Iteracion actual del ciclo">iter @it</div>
                                }
                            </td>
                            <td class="text-center">
                                @{
                                    var (aChipTxt, aChipCls, aChipTitle) = ChipAgente(r);
                                }
                                @if (aChipTxt is not null)
                                {
                                    <span class="oc-ag-chip @aChipCls" title="@aChipTitle">@aChipTxt</span>
                                }
                                else
                                {
                                    <span class="oc-rv-chip oc-rv-none" title="El agente IA aun no ha revisado esta HC">—</span>
                                }
                            </td>
                            <td class="text-end">
                                @{
                                    var revisableEstado = r.RevisionEstado is RevisionEstadoAgregado.SinRevisar
                                                                             or RevisionEstadoAgregado.PreRevision
                                                                             or RevisionEstadoAgregado.EnRevision
                                                                             or null; // null = crea revision on-demand
                                    var puedeAprobar = cerrada && _puedeRevisar && revisableEstado;
                                    var puedeRechazar = cerrada && _puedeRevisar && revisableEstado;
                                    var esteAbierto = _kebabRowId == r.HistoriaClinicaId;
                                }
                                <div class="oc-kebab-wrap">
                                    <button type="button" class="oc-kebab-btn @(esteAbierto ? "open" : "")"
                                            title="Acciones"
                                            @onclick="() => ToggleKebab(r.HistoriaClinicaId)">
                                        &#8942;
                                    </button>
                                    @if (esteAbierto)
                                    {
                                        <div class="oc-kebab-menu" @onclick:stopPropagation>
                                            @if (cerrada)
                                            {
                                                <button class="oc-kebab-item" @onclick="() => KebabRun(() => Consultar(r))">
                                                    <span class="oc-kebab-ico">👁</span> Consultar
                                                </button>
                                                <button class="oc-kebab-item" @onclick="() => KebabRun(() => AbrirModalImprimir(r))">
                                                    <span class="oc-kebab-ico">🖨</span> Imprimir
                                                </button>
                                                <button class="oc-kebab-item" @onclick="() => KebabRun(() => AbrirRevision(r))">
                                                    <span class="oc-kebab-ico">🔍</span> Ver revision
                                                </button>
                                                @if (puedeAprobar || puedeRechazar) { <div class="oc-kebab-sep"></div> }
                                                @if (puedeAprobar)
                                                {
                                                    <button class="oc-kebab-item oc-kebab-ok" @onclick="() => KebabRunAsync(() => AprobarDesdeTablaAsync(r))">
                                                        <span class="oc-kebab-ico">✓</span> Aprobar
                                                    </button>
                                                }
                                                @if (puedeRechazar)
                                                {
                                                    <button class="oc-kebab-item oc-kebab-danger" @onclick="() => KebabRun(() => RechazarDesdeTabla(r))">
                                                        <span class="oc-kebab-ico">✗</span> Rechazar
                                                    </button>
                                                }
                                            }
                                            else
                                            {
                                                <button class="oc-kebab-item" disabled title="La HC debe estar cerrada">
                                                    <span class="oc-kebab-ico">👁</span> Consultar
                                                </button>
                                                <button class="oc-kebab-item" disabled title="La HC debe estar cerrada">
                                                    <span class="oc-kebab-ico">🖨</span> Imprimir
                                                </button>
                                                <button class="oc-kebab-item" disabled title="La HC debe estar cerrada para entrar al ciclo de revision">
                                                    <span class="oc-kebab-ico">🔍</span> Ver revision
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
}

@* =========================================================================
   Modal "Motivo de rechazo": aparece al hacer drop en Rechazadas o al
   confirmar rechazo desde una card. Motivo es obligatorio.
   ========================================================================= *@
@if (_showRechazoModal && _cardEnAccion is not null)
{
    <div class="oc-backdrop" @onclick="CerrarRechazoModal"></div>
    <div class="oc-modal" style="width:520px;">
        <div class="oc-modal-h">
            <h3>Rechazar revision</h3>
            <button class="oc-modal-close" @onclick="CerrarRechazoModal">&times;</button>
        </div>
        <div class="oc-modal-body">
            <div class="oc-modal-meta">
                <div><b>Paciente:</b> @_cardEnAccion.PacienteNombre</div>
                <div><b>Formato HC:</b> @_cardEnAccion.FormatoNombre</div>
            </div>
            <label class="oc-form-lbl">Motivo <span style="color:#dc2626">*</span></label>
            <textarea class="form-control" rows="4" placeholder="Explica por que se rechaza esta HC..."
                      @bind="_rechazoMotivo"></textarea>
            <label class="oc-form-lbl mt-2">Nota adicional (opcional)</label>
            <textarea class="form-control" rows="2" @bind="_rechazoNota"></textarea>
        </div>
        <div class="oc-modal-foot">
            @if (_kanbanError is not null)
            {
                <div class="oc-modal-err">@_kanbanError</div>
            }
            <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarRechazoModal">Cancelar</button>
            <button class="btn btn-danger btn-sm" @onclick="ConfirmarRechazoAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_rechazoMotivo) || _procesando)">
                @(_procesando ? "Rechazando..." : "Rechazar")
            </button>
        </div>
    </div>
}

@* =========================================================================
   Modal "Archivar" — solo para cards Aprobadas. Radios OK / Inactivar.
   ========================================================================= *@
@if (_showArchivarModal && _cardEnAccion is not null && _cardEnAccion.RevisionId is Guid archivarRid)
{
    <div class="oc-backdrop" @onclick="CerrarArchivarModal"></div>
    <div class="oc-modal" style="width:520px;">
        <div class="oc-modal-h">
            <h3>📦 Archivar revision</h3>
            <button class="oc-modal-close" @onclick="CerrarArchivarModal">&times;</button>
        </div>
        <div class="oc-modal-body">
            <div class="oc-modal-meta">
                <div><b>Paciente:</b> @_cardEnAccion.PacienteNombre</div>
                <div><b>Formato HC:</b> @_cardEnAccion.FormatoNombre</div>
            </div>
            <p class="oc-modal-lead">Elige el sabor de archivo. Ambos sacan la HC del Kanban al tab Archivo.</p>
            <div class="oc-arch-opt">
                <label>
                    <input type="radio" name="arch-sabor" value="ok" checked="@(_archivarSabor == ArchivarSabor.Ok)"
                           @onchange='() => _archivarSabor = ArchivarSabor.Ok' />
                    <b>Archivar OK</b> — la revision quedo aprobada sin novedades.
                </label>
            </div>
            <div class="oc-arch-opt">
                <label>
                    <input type="radio" name="arch-sabor" value="in" checked="@(_archivarSabor == ArchivarSabor.Inactivar)"
                           @onchange='() => _archivarSabor = ArchivarSabor.Inactivar' />
                    <b>Inactivar</b> — la HC no debe conservarse (duplicada, error de captura).
                </label>
            </div>
            <label class="oc-form-lbl mt-2">
                Motivo @if (_archivarSabor == ArchivarSabor.Inactivar) { <span style="color:#dc2626">*</span> }
            </label>
            <textarea class="form-control" rows="3"
                      placeholder="@(_archivarSabor == ArchivarSabor.Inactivar ? "Explica por que se inactiva..." : "Nota opcional...")"
                      @bind="_archivarMotivo"></textarea>
        </div>
        <div class="oc-modal-foot">
            @if (_kanbanError is not null)
            {
                <div class="oc-modal-err">@_kanbanError</div>
            }
            <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarArchivarModal">Cancelar</button>
            <button class="btn btn-primary btn-sm" @onclick="() => ConfirmarArchivarAsync(archivarRid)"
                    disabled="@(_procesando || (_archivarSabor == ArchivarSabor.Inactivar && string.IsNullOrWhiteSpace(_archivarMotivo)))">
                @(_procesando ? "Archivando..." : "Confirmar")
            </button>
        </div>
    </div>
}

@* =========================================================================
   Modal "Elegir documentos a imprimir": checkboxes por tipo de documento.
   Solo aparecen los tipos que la HC realmente tiene (count > 0). El
   documento principal HC siempre se ofrece marcado por defecto.
   Al confirmar abre /imprimir-paquete con los tipos seleccionados en la
   query string y dispara window.print() al cargar (#print=1).
   ========================================================================= *@
@if (_showImprimirModal && _rowSel is not null)
{
    <div class="oc-backdrop" @onclick="CerrarModalImprimir"></div>
    <div class="oc-modal">
        <div class="oc-modal-h">
            <h3>🖨 Imprimir documentos</h3>
            <button class="oc-modal-close" @onclick="CerrarModalImprimir">&times;</button>
        </div>
        <div class="oc-modal-body">
            <div class="oc-modal-meta">
                <div><b>Paciente:</b> @_rowSel.PacienteNombre</div>
                <div><b>Documento:</b> @_rowSel.PacienteTipoDoc @_rowSel.PacienteDoc</div>
                <div><b>Formato HC:</b> @_rowSel.FormatoNombre</div>
            </div>
            <p class="oc-modal-lead">Selecciona los documentos que deseas imprimir. Solo aparecen los que tienen items registrados en esta historia.</p>

            <div class="oc-impr-opt">
                <label>
                    <input type="checkbox" @bind="_selHc" />
                    <span><b>Historia clinica</b></span>
                </label>
                <small>Documento principal del formato de la HC.</small>
            </div>
            @if (_rowSel.MedicamentosCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selMed" />
                        <span><b>Orden de Medicamentos</b> <em>(@_rowSel.MedicamentosCount item@(_rowSel.MedicamentosCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.ServiciosCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selSrv" />
                        <span><b>Orden a Servicios</b> <em>(@_rowSel.ServiciosCount item@(_rowSel.ServiciosCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.InsumosCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selIns" />
                        <span><b>Orden de Insumos</b> <em>(@_rowSel.InsumosCount item@(_rowSel.InsumosCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.RemisionesCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selRem" />
                        <span><b>Remisiones</b> <em>(@_rowSel.RemisionesCount item@(_rowSel.RemisionesCount == 1 ? "" : "es"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.RxImagCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selRxExt" />
                        <span><b>Orden RX Imagenologia</b> <em>(@_rowSel.RxImagCount item@(_rowSel.RxImagCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.LabExtCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selLabExt" />
                        <span><b>Orden Laboratorios</b> <em>(@_rowSel.LabExtCount item@(_rowSel.LabExtCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.InsExtCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selInsExt" />
                        <span><b>Orden Insumos Externos</b> <em>(@_rowSel.InsExtCount item@(_rowSel.InsExtCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.IncapacidadesCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selInc" />
                        <span><b>Orden de Incapacidad</b> <em>(@_rowSel.IncapacidadesCount item@(_rowSel.IncapacidadesCount == 1 ? "" : "es"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.CertificacionesCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selCert" />
                        <span><b>Certificacion Medica</b> <em>(@_rowSel.CertificacionesCount item@(_rowSel.CertificacionesCount == 1 ? "" : "es"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.EscalasCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selEsc" />
                        <span><b>Escalas diligenciadas</b> <em>(@_rowSel.EscalasCount escala@(_rowSel.EscalasCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.EvolucionesCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selEvo" />
                        <span><b>Evoluciones diligenciadas</b> <em>(@_rowSel.EvolucionesCount evolucion@(_rowSel.EvolucionesCount == 1 ? "" : "es"))</em></span>
                    </label>
                </div>
            }
            @if (_rowSel.ConsentimientosCount > 0)
            {
                <div class="oc-impr-opt">
                    <label>
                        <input type="checkbox" @bind="_selCon" />
                        <span><b>Consentimientos diligenciados</b> <em>(@_rowSel.ConsentimientosCount consentimiento@(_rowSel.ConsentimientosCount == 1 ? "" : "s"))</em></span>
                    </label>
                </div>
            }
        </div>
        <div class="oc-modal-foot">
            @if (_modalErr is not null)
            {
                <div class="oc-modal-err">@_modalErr</div>
            }
            <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarModalImprimir">Cancelar</button>
            <button class="btn btn-primary btn-sm" @onclick="ConfirmarImprimir">🖨 Imprimir seleccion</button>
        </div>
    </div>
}

@* =========================================================================
   Modal grande "Ver revision": iframe con la impresion completa de la HC
   a la izquierda + panel de revision (bitacora + aprobar/rechazar) a la
   derecha. Reutiliza HcRevisionPanel, el mismo componente que ya se usa
   en el menu lateral del modal HC.
   ========================================================================= *@
@if (_showRevisionModal && _revisionModalHcId is Guid rmHcId)
{
    <div class="oc-rv-backdrop" @onclick="CerrarRevisionModalAsync"></div>
    <div class="oc-rv-modal" @onclick:stopPropagation>
        <div class="oc-rv-h">
            <div>
                <div class="oc-rv-eyebrow">Ordenes clinicas</div>
                <h3 class="oc-rv-title">Ver revision de la HC</h3>
            </div>
            <button class="oc-rv-close" @onclick="CerrarRevisionModalAsync" title="Cerrar">&times;</button>
        </div>
        <div class="oc-rv-body">
            <div class="oc-rv-left">
                <iframe class="oc-rv-iframe"
                        src="@($"/imprimir-paquete/{rmHcId}?docs={_revisionModalDocs}")"
                        title="Impresion HC">
                </iframe>
            </div>
            <div class="oc-rv-right">
                <Visal.SuperAdmin.Components.Forms.HcRevisionPanel
                    HistoriaClinicaId="@rmHcId"
                    HcCerrada="true" />
            </div>
        </div>
    </div>
}

