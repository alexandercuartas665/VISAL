    .cd-cal-lg-sw { width: 14px; height: 14px; border-radius: 3px; display: inline-block; }
</style>

@* ============ Modal Aplicar programacion ============ *@
@if (_progOpen)
{
    <div class="cie-modal-overlay" @onclick="CerrarModalProgramacion"></div>
    <div class="cie-modal cd-prog-modal">
        <div class="cie-modal-h">
            <div>Aplicar programacion @(_solicitudSel is not null ? "- " + _solicitudSel.PacienteNombre : "")</div>
            <button class="cie-modal-close" @onclick="CerrarModalProgramacion">&times;</button>
        </div>
        <div class="cie-modal-body">
            @if (_progList.Count == 0)
            {
                <div class="ase-empty">
                    No hay programaciones activas para el (anio, mes, sede, tipo servicio)
                    de esta solicitud. Crea una en <a href="cfg-turnos" target="_blank">/cfg-turnos</a>.
                </div>
            }
            else
            {
                <div class="small text-muted mb-1">1. Elige la programacion a aplicar:</div>
                <div class="cd-prog-grid">
                    @foreach (var p in _progList)
                    {
                        <div class="cd-prog-card @(p.Id == _progSelId ? "sel" : "")"
                             @onclick="() => SeleccionarProgramacion(p)">
                            <div class="cd-prog-card-title">@p.Nombre</div>
                            <div class="cd-prog-card-meta">
                                @MesNombre(p.Mes) @p.Anio ·
                                @(p.SedeNombre ?? "Sin sede") ·
                                @(p.TipoServicio ?? "Todos") ·
                                @p.NumTurnos turno(s)
                            </div>
                        </div>
                    }
                </div>

                @if (_progSelId is Guid && _progFilas.Count > 0)
                {
                    <hr />
                    <div class="small text-muted mb-1">2. Dia de arranque (dentro del mes de la programacion):</div>
                    <input type="number" min="1" max="31" class="form-control form-control-sm" style="max-width:120px"
                           @bind="_progDiaArranque" />

                    <div class="small text-muted mt-3 mb-1">3. Asigna un profesional a cada fila del grid:</div>
                    @foreach (var fila in _progFilas)
                    {
                        <div class="cd-prog-row-picker">
                            <div>@fila</div>
                            <select class="form-select form-select-sm"
                                    value="@(_progProfPorFila.GetValueOrDefault(fila) is Guid gp ? gp.ToString() : "")"
                                    @onchange="e => SetProfesionalFila(fila, e.Value?.ToString())">
                                <option value="">-- Elegir profesional --</option>
                                @foreach (var e in _especialistas)
                                {
                                    <option value="@e.Id">@e.NombreCompleto</option>
                                }
                            </select>
                        </div>
                    }
                }
            }
            @if (_progError is not null) { <div class="text-danger small mt-2">@_progError</div> }
        </div>
        <div class="cie-modal-foot" style="justify-content:flex-end;gap:8px;">
            <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarModalProgramacion">Cancelar</button>
            <button class="btn btn-primary btn-sm" @onclick="AplicarProgramacionAsync"
                    disabled="@(_progBusy || _progSelId is null || _progProfPorFila.Count == 0)">
                @(_progBusy ? "Aplicando..." : "Programar")
            </button>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private readonly string[] _tabs = new[] { "Solicitudes", "Kanban", "Calendario", "Modificacion", "Consultas Historicas", "Documentos Externos", "RIPS", "Historias" };
    private string _tabSel = "Solicitudes";
    private static readonly HashSet<string> _tabsActivos = new(StringComparer.OrdinalIgnoreCase) { "Solicitudes", "Kanban", "Calendario" };

    // Permisos del usuario logueado (que modulos puede coordinar).
    private List<string> _modulos = new();

    /// <summary>Nombre de la sucursal con la que el usuario logueo. Cuando NO es
    /// null, el grid de "Servicios no asignados" filtra a asignaciones de esa
    /// sede. Si el usuario entro con SEDE=GLOBAL (admin), queda null y ve todo.</summary>
    private string? _miSucursalNombre;

    // Filtros.
    private string _tipoSel = "";
    private AsignacionEstadoFiltro _estado = AsignacionEstadoFiltro.Pendientes;
    private int _anio = DateTime.Now.Year;
    // 0 = "(Todos los meses)" — sin filtro. Es el default para que el coordinador
    // no se le escapen asignaciones de meses anteriores al abrir la pagina.
    private int _mes = 0;
    private string _noOrden = "";
    private string _doc = "";

    private List<AsignacionPendienteDto> _pendientes = new();
    private AsignacionPendienteDto? _solicitudSel;

    // ============ Tablero Kanban ============
    private List<KanbanCardVm> _kbCards = new();
    private readonly List<KanbanColumnaVm> _kbColumnas = new()
    {
        new(EstadoTablero.Asignado, "Asignado", "#fee2e2", "#991b1b"),
        new(EstadoTablero.Coordinado, "Coordinado", "#e0e7ff", "#3730a3"),
        new(EstadoTablero.Programado, "Programado", "#fef3c7", "#92400e"),
        new(EstadoTablero.Atendido, "Atendido", "#dbeafe", "#1d4ed8"),
        new(EstadoTablero.EnProgreso, "En progreso", "#fde68a", "#92400e"),
        new(EstadoTablero.Terminado, "Terminado", "#dcfce7", "#166534"),
    };

    // ============ Tablero Calendario ============
    private int _mesCalendario = DateTime.Now.Month;
    private List<SesionCalendarioDto> _calChips = new();
    private List<DateOnly> _calDias = new();

    private sealed record KanbanColumnaVm(EstadoTablero Estado, string Titulo, string Bg, string Fg);
    private sealed record KanbanCardVm(
        Guid Id, EstadoTablero Estado,
        string PacienteNombre, string PacienteTipoOrDoc,
        string NombreServicio, string TipoServicio,
        int Cantidad, int SesionesTotales, int NotasDefinitivas,
        int TurnosCoordinados, string? EspecialistasNombres);

    // Panel derecho (coordinacion - editable).
    private string _idProfAsig = "";
    private string _profesionalPred = "";
    private string _observaciones = "";
    private DateOnly? _fechaInicio;
    private int _mesAsignar;
    private decimal? _horasPorTurno;
    /// <summary>Tarifa editable por el coordinador. Se pre-llena al seleccionar la
    /// solicitud con la tarifa del ServicioContrato (contratoCodigo + codigoServicio)
    /// pero el coordinador puede ajustarla manualmente.</summary>
    private decimal? _tarifa;
    // Lista de profesionales filtrada por el modulo del servicio elegido.
    private List<EspecialistaDto> _especialistas = new();
    private string _especialistaSel = "";
    private int _turnosAAgregarN = 1;

    // Carrito de turnos en memoria (lo que se va a guardar al pulsar "Asignar el servicio").
    private List<CartTurno> _carritoTurnos = new();
    // Turnos ya persistidos (los que ya estan en BD para esa asignacion).
    private List<TurnoCoordinadoDto> _turnosGuardados = new();

    private int _turnosUsados => _turnosGuardados.Sum(t => t.Cantidad) + _carritoTurnos.Sum(t => t.Cantidad);
    private int _turnosFaltan => _solicitudSel is null ? 0 : Math.Max(0, _solicitudSel.Cantidad - _turnosUsados);

    private bool _busy;
    private string? _error, _ok;

    // Modal Aplicar programacion. Se abre desde el boton "Programar" junto a
    // "Asignar el servicio". El modal no persiste — al confirmar, agrega
    // CartTurno sinteticos con TurnoProgramacionId + fila + diaArranque; la
    // persistencia real ocurre al pulsar "Asignar el servicio".
    private bool _progOpen;
    private bool _progBusy;
    private string? _progError;
    private List<TurnoProgramacionCardDto> _progList = new();
    private Guid? _progSelId;
    private List<string> _progFilas = new();
    private Dictionary<string, Guid> _progProfPorFila = new();
    private int _progDiaArranque = 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (AuthState is null) { _error = "Sesion no detectada."; return; }
            var st = await AuthState;
            if (!Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var puId))
            {
                _error = "No se pudo identificar al usuario.";
                return;
            }
            _modulos = (await UsuSvc.GetModulosCoordinacionAsync(puId)).ToList();

            // Resolver el nombre de la sucursal del claim sucursal_id. Si no hay
            // claim (admin con SEDE=GLOBAL) o no se resuelve, dejamos null para
            // que el usuario vea todas las sedes.
            var sucClaim = st.User.FindFirst("sucursal_id")?.Value;
            if (Guid.TryParse(sucClaim, out var sucId))
            {
                var sedes = await SucSvc.ListAsync();
                _miSucursalNombre = sedes.FirstOrDefault(s => s.Id == sucId)?.Nombre;
            }
        }
        catch (Exception ex) { _error = "Error inicial: " + ex.Message; }
    }

    private void OnTipoChanged(ChangeEventArgs e)
    {
        _tipoSel = e.Value?.ToString() ?? "";
        _pendientes = new();
        _solicitudSel = null;
    }

    private void MesActual()
    {
        _mes = DateTime.Now.Month;
        _anio = DateTime.Now.Year;
    }

    private async Task Cargar()
    {
        _error = _ok = null; _busy = true;
        try
        {
            var modulos = string.IsNullOrEmpty(_tipoSel) ? _modulos : new List<string> { _tipoSel };
            // _mes == 0 significa "todos los meses" -> no enviamos filtro al servicio.
            int? mesFiltro = _mes >= 1 && _mes <= 12 ? _mes : null;
            _pendientes = (await Svc.ListarPendientesAsync(modulos, _estado, _anio, mesFiltro,
                string.IsNullOrWhiteSpace(_noOrden) ? null : _noOrden,
                string.IsNullOrWhiteSpace(_doc) ? null : _doc,
                _miSucursalNombre)).ToList();
            _solicitudSel = null;
            _especialistas = new();
            if (_pendientes.Count == 0) { _ok = "Sin servicios para esta combinacion."; }
        }
        catch (Exception ex) { _error = "Error consultando: " + ex.Message; }
        finally { _busy = false; }
    }

    private void LimpiarFiltros()
    {
        _tipoSel = ""; _noOrden = ""; _doc = "";
        _estado = AsignacionEstadoFiltro.Pendientes;
        // Volvemos al default ancho: ano actual + todos los meses (no esconder nada).
        _anio = DateTime.Now.Year; _mes = 0;
        _pendientes = new(); _solicitudSel = null; _especialistas = new();
    }

    private async Task CargarSolicitud(AsignacionPendienteDto p)
    {
        _error = _ok = null;
        _solicitudSel = p;
        _observaciones = p.Observaciones ?? "";
        _fechaInicio = p.FechaInicio;
        _mesAsignar = 0;
        _horasPorTurno = null;
        _tarifa = null;
        _idProfAsig = "";
        _profesionalPred = "";
        _especialistaSel = "";
        _carritoTurnos = new();
        _turnosAAgregarN = 1;
        // Cargar profesionales del tipo correspondiente al modulo del servicio + turnos ya guardados.
        try
        {
            _especialistas = (await Svc.ListarEspecialistasPorModuloAsync(p.TipoServicio)).ToList();
            _turnosGuardados = (await Svc.ListarTurnosAsync(p.Id)).ToList();
            // Pre-llenar TARIFA con la pactada en el ServicioContrato. El coordinador
            // puede ajustarla manualmente despues si necesita (negociacion puntual,
            // tarifa especial, etc.) — el input no es readonly.
            _tarifa = await Svc.ObtenerTarifaServicioAsync(p.ContratoCodigo, p.CodigoServicio);
            // Si ya hay turnos faltantes, sugerir turnosAAgregar = lo que falta.
            if (_turnosFaltan > 0) { _turnosAAgregarN = _turnosFaltan; }
        }
        catch (Exception ex)
        {
            _error = "Error cargando coordinacion: " + ex.Message;
            _especialistas = new();
            _turnosGuardados = new();
        }
    }

    private void AgregarTurno()
    {
        _error = null;
        if (_solicitudSel is null) { return; }
        if (!Guid.TryParse(_especialistaSel, out var profId) || profId == Guid.Empty)
        {
            _error = "Selecciona un especialista antes de agregar el turno."; return;
        }
        if (_turnosAAgregarN <= 0)
        {
            _error = "La cantidad de turnos a agregar debe ser mayor a cero."; return;
        }
        if (_turnosAAgregarN > _turnosFaltan)
        {
            _error = $"Solo faltan {_turnosFaltan} turnos por asignar."; return;
        }
        var prof = _especialistas.FirstOrDefault(e => e.Id == profId);
        if (prof is null)
        {
            _error = "Especialista no encontrado en el catalogo."; return;
        }
        _carritoTurnos.Add(new CartTurno
        {
            ProfesionalId = profId,
            ProfesionalNombre = prof.NombreCompleto,
            Cantidad = _turnosAAgregarN,
            HorasPorTurno = _horasPorTurno,
            FechaInicio = _fechaInicio,
            MesAsignar = _mesAsignar > 0 ? (short)_mesAsignar : (short?)null,
            Tarifa = _tarifa
        });
        // Reset para el siguiente turno; sugerir lo que aun falta.
        _especialistaSel = "";
        _turnosAAgregarN = _turnosFaltan > 0 ? _turnosFaltan : 0;
    }

    private void QuitarTurno(CartTurno t) => _carritoTurnos.Remove(t);

    private async Task AsignarServicio()
    {
        _error = _ok = null;
        if (_solicitudSel is null || _carritoTurnos.Count == 0) { return; }
        _busy = true;
        try
        {
            var req = new AsignarServicioRequest(
                _solicitudSel.Id,
                _carritoTurnos.Select(c => new TurnoCoordinadoRequest(
                    c.ProfesionalId, c.Cantidad, c.HorasPorTurno, c.FechaInicio, c.MesAsignar, c.Tarifa,
                    c.TurnoProgramacionId, c.TurnoRowNombre, c.DiaArranque)).ToList());
            var n = await Svc.AsignarServicioAsync(req, Guid.Empty);
            _ok = $"Servicio coordinado: {n} turno(s) guardados.";
            // Refrescar grilla y limpiar panel.
            _carritoTurnos = new();
            await Cargar();
            _solicitudSel = null;
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        catch (Exception ex) { _error = "Error tecnico: " + ex.Message; }
        finally { _busy = false; }
    }

    private void LimpiarPanel()
    {
        _solicitudSel = null;
        _observaciones = ""; _fechaInicio = null; _mesAsignar = 0;
        _horasPorTurno = null;
        _tarifa = null;
        _idProfAsig = ""; _profesionalPred = "";
        _especialistas = new(); _especialistaSel = ""; _turnosAAgregarN = 1;
        _carritoTurnos = new(); _turnosGuardados = new();
        CerrarModalProgramacion();
    }

    // ---------------- Modal Aplicar programacion ----------------

    private async Task AbrirModalProgramacion()
    {
        if (_solicitudSel is null) { return; }
        _progError = null;
        _progBusy = true;
        try
        {
            _progList = (await Svc.ListarProgramacionesElegiblesAsync(_solicitudSel.Id)).ToList();
            _progSelId = null;
            _progFilas = new();
            _progProfPorFila = new();
            _progDiaArranque = 1;
            _progOpen = true;
        }
        catch (Exception ex) { _progError = ex.Message; _progOpen = true; }
        finally { _progBusy = false; }
    }

    private void CerrarModalProgramacion()
    {
        _progOpen = false;
        _progSelId = null;
        _progFilas = new();
        _progProfPorFila = new();
        _progError = null;
    }

    private void SeleccionarProgramacion(TurnoProgramacionCardDto p)
    {
        _progSelId = p.Id;
        _progError = null;
        // Extraer las filas del grid JSON para armar los pickers de profesional.
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(p.GridDataJson);
            if (doc.RootElement.TryGetProperty("turnos", out var arr) &&
                arr.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                _progFilas = arr.EnumerateArray()
                    .Select(x => x.GetString() ?? "")
                    .Where(s => s.Length > 0)
                    .ToList();
            }
        }
        catch { _progFilas = new(); }
        _progProfPorFila = new();
    }

    private void SetProfesionalFila(string fila, string? profIdRaw)
    {
        if (Guid.TryParse(profIdRaw, out var pid)) { _progProfPorFila[fila] = pid; }
        else { _progProfPorFila.Remove(fila); }
    }

    /// <summary>Aplica la programacion: en vez de persistir al backend, genera CartTurno
    /// sinteticos (uno por fila del grid con profesional) y los agrega al carrito. El
    /// coordinador puede revisarlos y pulsar "Asignar el servicio" para guardarlos. Politica
    /// "reemplazar una a la vez": borra cualquier CartTurno de programacion previa antes
    /// de agregar los nuevos.</summary>
    private void AplicarProgramacionAsync()
    {
        if (_progSelId is not Guid pid || _solicitudSel is null) { return; }
        if (_progProfPorFila.Count == 0)
        {
            _progError = "Asigna al menos un profesional a una fila del grid antes de programar.";
            return;
        }
        var prog = _progList.FirstOrDefault(p => p.Id == pid);
        if (prog is null)
        {
            _progError = "Programacion no encontrada en la lista cargada.";
            return;
        }
        int diasEnMes = DateTime.DaysInMonth(prog.Anio, prog.Mes);
        if (_progDiaArranque < 1 || _progDiaArranque > diasEnMes)
        {
            _progError = $"Dia de arranque fuera del mes ({diasEnMes} dias).";
            return;
        }
        _progError = null;

        // Politica: reemplazar programacion previa. Borrar CartTurno con TurnoProgramacionId.
        _carritoTurnos.RemoveAll(c => c.TurnoProgramacionId is not null);

        var fechaInicioProg = new DateOnly(prog.Anio, prog.Mes, _progDiaArranque);
        foreach (var kv in _progProfPorFila)
        {
            var fila = kv.Key;
            var profId = kv.Value;
            var prof = _especialistas.FirstOrDefault(e => e.Id == profId);
            int sesiones = ContarSesionesEnFila(prog.GridDataJson, fila, _progDiaArranque, diasEnMes);
            _carritoTurnos.Add(new CartTurno
            {
                ProfesionalId = profId,
                ProfesionalNombre = prof?.NombreCompleto ?? "?",
                Cantidad = 1,
                HorasPorTurno = null,
                FechaInicio = fechaInicioProg,
                MesAsignar = (short)prog.Mes,
                Tarifa = _tarifa,
                TurnoProgramacionId = pid,
                TurnoRowNombre = fila,
                DiaArranque = _progDiaArranque,
                SesionesEstimadas = sesiones
            });
        }
        _ok = $"Programacion cargada al carrito: {_progProfPorFila.Count} fila(s). Revisa y pulsa 'Asignar el servicio' para guardar.";
        CerrarModalProgramacion();
    }

    /// <summary>Cuenta cuantas celdas pintadas hay en la fila del grid a partir del dia de
    /// arranque. Debe coincidir con la logica de <c>AsignacionService.CrearTurnoDesdeGrid</c>
    /// para que el chip del carrito muestre el numero real de sesiones que se generaran.</summary>
    private static int ContarSesionesEnFila(string gridJson, string rowNombre, int diaArranque, int diasEnMes)
    {
        try
        {
            var root = System.Text.Json.JsonDocument.Parse(gridJson).RootElement;
            if (!root.TryGetProperty("dias", out var diasProp)
                || diasProp.ValueKind != System.Text.Json.JsonValueKind.Object
                || !diasProp.TryGetProperty(rowNombre, out var celdasRow)
                || celdasRow.ValueKind != System.Text.Json.JsonValueKind.Object)
            {
                return 0;
            }
            int n = 0;
            for (int d = diaArranque; d <= diasEnMes; d++)
            {
                if (!celdasRow.TryGetProperty(d.ToString(), out var celda)) { continue; }
                var tipo = celda.TryGetProperty("tipo", out var t) ? t.GetString() : null;
                if (!string.IsNullOrEmpty(tipo)) { n++; }
            }
            return n;
        }
        catch { return 0; }
    }

    private sealed class CartTurno
    {
        public Guid ProfesionalId { get; set; }
        public string ProfesionalNombre { get; set; } = "";
        public int Cantidad { get; set; }
        public decimal? HorasPorTurno { get; set; }
        public DateOnly? FechaInicio { get; set; }
        public short? MesAsignar { get; set; }
        public decimal? Tarifa { get; set; }

        /// <summary>Cuando el turno viene del modal "Programar", lleva la referencia
        /// a la TurnoProgramacion y la fila del grid. Al hacer "Asignar el servicio"
        /// se envian al backend y este genera las sesiones desde el grid.</summary>
        public Guid? TurnoProgramacionId { get; set; }
        public string? TurnoRowNombre { get; set; }
        public int? DiaArranque { get; set; }
        /// <summary>Sesiones aproximadas que se van a generar. Solo display.</summary>
        public int SesionesEstimadas { get; set; }
    }

    private static string MesNombre(int m) => m switch
    {
        1 => "Enero", 2 => "Febrero", 3 => "Marzo", 4 => "Abril", 5 => "Mayo", 6 => "Junio",
        7 => "Julio", 8 => "Agosto", 9 => "Septiembre", 10 => "Octubre", 11 => "Noviembre", 12 => "Diciembre",
        _ => "--"
    };

    // Calcula (etiqueta, cssClass) para la pill de estado del grid:
    //   Pendiente   -> sin turnos coordinados y estado=Pendiente
    //   Parcial     -> con turnos coordinados pero estado=Pendiente (no completa todavia)
    //   Asignado    -> estado=Asignado (sum turnos == Cantidad)
    //   Cerrado     -> estado=Cerrado (terminado / facturado)
    private static (string label, string css) EstadoTag(AsignacionPendienteDto p)
    {
        if (string.Equals(p.EstadoTexto, "Asignado", StringComparison.OrdinalIgnoreCase))
        { return ("Asignado", "cd-est-asignado"); }
        if (string.Equals(p.EstadoTexto, "Cerrado", StringComparison.OrdinalIgnoreCase))
        { return ("Cerrado", "cd-est-cerrado"); }
        if (p.TurnosCoordinados > 0 && p.TurnosCoordinados < p.Cantidad)
        { return ($"Parcial ({p.TurnosCoordinados}/{p.Cantidad})", "cd-est-parcial"); }
        return ("Pendiente", "cd-est-pendiente");
    }

    // ============ Handlers Tablero ============
    private async Task OnTabSeleccionado(string tab)
    {
        if (!_tabsActivos.Contains(tab)) { return; }
        _tabSel = tab;
        _error = null; _ok = null;
        if (tab == "Kanban" && _kbCards.Count == 0) { await CargarKanban(); }
        else if (tab == "Calendario" && _calChips.Count == 0) { await CargarCalendario(); }
    }

    private async Task CargarKanban()
    {
        if (_modulos.Count == 0) { return; }
        _busy = true; _error = null; _ok = null;
        try
        {
            int? mes = _mes == 0 ? null : _mes;
            var raw = await Svc.ListarTableroKanbanAsync(_modulos, _anio, mes,
                string.IsNullOrWhiteSpace(_doc) ? null : _doc.Trim(),
                _miSucursalNombre);
            _kbCards = raw.Select(x => new KanbanCardVm(
                x.Id, x.Estado,
                x.PacienteNombre, $"{x.PacienteDocumento}",
                x.NombreServicio, x.TipoServicio,
                x.Cantidad, x.SesionesTotales, x.NotasDefinitivas,
                x.TurnosCoordinados, x.EspecialistasNombres)).ToList();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CargarCalendario()
    {
        if (_modulos.Count == 0) { return; }
        _busy = true; _error = null; _ok = null;
        try
        {
            var raw = await Svc.ListarTableroCalendarioAsync(_modulos, _anio, _mesCalendario, _miSucursalNombre);
            _calChips = raw.ToList();
            _calDias = BuildCalendarioDias(_anio, _mesCalendario);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    /// <summary>Genera la lista de dias del mes rellenando los slots vacios al inicio y fin
    /// para completar semanas Lunes..Domingo. Los dias de otros meses van con opacity baja.</summary>
    private static List<DateOnly> BuildCalendarioDias(int anio, int mes)
    {
        var first = new DateOnly(anio, mes, 1);
        var last = first.AddMonths(1).AddDays(-1);
        // Alinear al lunes: DayOfWeek.Monday = 1, Sunday = 0.
        int prepend = ((int)first.DayOfWeek + 6) % 7;
        int append = 6 - ((int)last.DayOfWeek + 6) % 7;
        var lista = new List<DateOnly>();
        for (int i = prepend; i > 0; i--) { lista.Add(first.AddDays(-i)); }
        for (var d = first; d <= last; d = d.AddDays(1)) { lista.Add(d); }
        for (int i = 1; i <= append; i++) { lista.Add(last.AddDays(i)); }
        return lista;
    }

