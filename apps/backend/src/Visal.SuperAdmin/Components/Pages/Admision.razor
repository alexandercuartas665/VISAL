    // Se dispara cuando el usuario elige una fecha de nacimiento (input type=date).
    // Calcula la edad y la asigna al campo readonly. Si la fecha es invalida
    // (futuro, mayor a 130 anios, o null) deja la edad en null.
    private void RecalcularEdad()
    {
        _edad = CalcularEdad(_fnac);
    }

    /// <summary>
    /// Calcula edad en anios cumplidos entre fechaNacimiento y hoy. Retorna null
    /// si la fecha es nula, futura, o el resultado esta fuera de rango (0..130).
    /// </summary>
    /// <remarks>
    /// Casos verificados:
    /// - fn=1964-05-21, hoy=2026-07-02 -> 62 (cumpleanos ya paso)
    /// - fn=1964-08-21, hoy=2026-07-02 -> 61 (aun no cumple este anio)
    /// - fn=hoy -> 0
    /// - fn=hoy+1 dia -> null (futuro)
    /// - fn=hoy-1 anio exacto -> 1
    /// - fn=hoy-1 anio+1 dia -> 0 (aun no cumple 1)
    /// - fn=1890-01-01 -> null (>130 anios)
    /// - fn=null -> null
    /// </remarks>
    private static int? CalcularEdad(DateOnly? fechaNacimiento)
    {
        if (fechaNacimiento is not DateOnly fn) { return null; }
        var hoy = DateOnly.FromDateTime(DateTime.Today);
        if (fn > hoy) { return null; }
        var edad = hoy.Year - fn.Year;
        if (fn > hoy.AddYears(-edad)) { edad--; }
        return edad < 0 || edad > 130 ? null : edad;
    }

