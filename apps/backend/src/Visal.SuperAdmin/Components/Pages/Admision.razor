        _fnac = d.FechaNacimiento;
        // Recalculamos siempre: la edad guardada en BD puede haber quedado
        // vieja (cumpleanos pasado sin re-guardado). Fallback al valor de BD
        // si la fecha no permite calcular.
        _edad = CalcularEdad(_fnac) ?? d.Edad;
