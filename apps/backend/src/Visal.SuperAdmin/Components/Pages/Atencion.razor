@page "/atencion"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Visal.Application.Tenancy
@using Visal.Domain.Entities
@using Visal.SuperAdmin.Components.Forms
@inject IAtencionProfesionalService Svc
@inject IAsignacionService AsigSvc
@inject IHistoriaClinicaService HcSvc
@inject INotaMedicaService NotaSvc
@inject IAtencionColumnaConfigService ColSvc
@inject IJSRuntime JS

<PageTitle>Mis Servicios Asignados - Visal</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Operacion Clinica</div>
        <h1 class="ase-title">Atencion</h1>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

@if (_modulos.HasValue && !_modulos.Value)
{
    <div class="ase-card">
        <div class="ase-empty at-no-prof">
            @if (_esAdmin)
            {
                <text>No hay turnos coordinados en la agencia todavia. Cuando el coordinador programe turnos desde el modulo <code>Coordinacion</code>, apareceran aqui.</text>
            }
            else if (_tieneProfesionalVinculado)
            {
                <text>No tienes servicios asignados todavia. Pide al coordinador que te asigne turnos desde el modulo <code>Coordinacion</code>.</text>
            }
            else
            {
                <text>Tu usuario no esta vinculado a un profesional. El modulo de atencion solo aplica para usuarios creados desde el modulo de <code>Profesionales</code>.</text>
            }
        </div>
    </div>
}
else
{
    <div class="ase-card">
        <div class="at-tabs">
            <button class="at-tab sel">Pacientes</button>
        </div>

        <div class="ase-form at-filtros">
            <div class="ase-f"><label>Profesional</label><input class="form-control form-control-sm asg-ro" readonly value="@_nombreProf" /></div>
            <div class="ase-f"><label>Especialidad</label><input class="form-control form-control-sm asg-ro" readonly value="@_especialidad" /></div>
        </div>

        @* Toolbar de filtros al estilo pipeline CUBOT: busqueda + orden + boton
           Filtros con popover de chips. Los chips son multi-select por dimension
           (tipo servicio, estado, servicio, profesional, paquete, fecha). El
           estado vive en memoria — no se persiste. *@
        <div class="at-fbar">
            <div class="at-fbar-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input placeholder="Buscar paciente por documento o nombre..." @bind="_filtroPac" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(_filtroPac))
                {
                    <button class="at-fbar-search-clear" @onclick="() => _filtroPac = string.Empty" title="Limpiar">&times;</button>
                }
            </div>
            <div class="at-fbar-sort">
                <span class="at-fbar-sort-lbl">Ordenar:</span>
                <select @bind="_sortBy">
                    <option value="recent">Mas recientes primero</option>
                    <option value="oldest">Mas antiguos primero</option>
                    <option value="paciente">Paciente (A-Z)</option>
                    <option value="servicio">Servicio (A-Z)</option>
                    <option value="profesional">Profesional (A-Z)</option>
                </select>
            </div>
            <div class="at-fbar-filt-anchor">
                <button class="btn btn-outline-secondary @(FiltrosActivos ? "at-fbar-filt-on" : "")" @onclick="() => _filtrosOpen = !_filtrosOpen">
                    Filtros@(FiltrosActivos ? $" ({CuentaFiltrosActivos})" : "")
                </button>
                @if (_filtrosOpen)
                {
                    <div class="at-fbar-filters">
                        <div class="at-fbar-filters-head">
                            <span>Filtros avanzados</span>
                            <button class="at-fbar-link" @onclick="LimpiarFiltros">Limpiar</button>
                        </div>

                        <div class="at-fbar-filt-group">
                            <div class="at-fbar-filt-lbl">Tipo de servicio</div>
                            <div class="at-fbar-chips">
                                @foreach (var t in TiposServicioDisponibles)
                                {
                                    <button class="at-fbar-fchip @(_filTipos.Contains(t) ? "on" : "")" @onclick="() => ToggleTipo(t)">@t</button>
                                }
                            </div>
                        </div>

                        <div class="at-fbar-filt-group">
                            <div class="at-fbar-filt-lbl">Estado</div>
                            <div class="at-fbar-chips">
                                <button class="at-fbar-fchip @(_filEstado == "pendientes" ? "on" : "")" @onclick='() => SetEstado("pendientes")'>Pendientes</button>
                                <button class="at-fbar-fchip @(_filEstado == "completados" ? "on" : "")" @onclick='() => SetEstado("completados")'>Completados</button>
                            </div>
                            <label class="at-fbar-toggle" style="margin-top:6px;">
                                <input type="checkbox" checked="@_mostrarVencidas" @onchange="OnVencidasChanged" />
                                <span>Mostrar notas vencidas</span>
                            </label>
                        </div>

                        @if (ServiciosDisponibles.Count > 0)
                        {
                            <div class="at-fbar-filt-group">
                                <div class="at-fbar-filt-lbl">Servicio</div>
                                <div class="at-fbar-chips">
                                    @foreach (var s in ServiciosDisponibles)
                                    {
                                        <button class="at-fbar-fchip @(_filServicios.Contains(s) ? "on" : "")" @onclick="() => ToggleServicio(s)">@s</button>
                                    }
                                </div>
                            </div>
                        }

                        @if (_esAdmin && ProfesionalesDisponibles.Count > 0)
                        {
                            <div class="at-fbar-filt-group">
                                <div class="at-fbar-filt-lbl">Profesional</div>
                                <div class="at-fbar-chips">
                                    @foreach (var p in ProfesionalesDisponibles)
                                    {
                                        <button class="at-fbar-fchip @(_filProfesionales.Contains(p) ? "on" : "")" @onclick="() => ToggleProfesional(p)">@p</button>
                                    }
                                </div>
                            </div>
                        }

                        <div class="at-fbar-filt-group">
                            <div class="at-fbar-filt-lbl">Paquete</div>
                            <div class="at-fbar-chips">
                                <button class="at-fbar-fchip @(_filPaquete == "con" ? "on" : "")" @onclick='() => SetPaquete("con")'>Con paquete</button>
                                <button class="at-fbar-fchip @(_filPaquete == "sin" ? "on" : "")" @onclick='() => SetPaquete("sin")'>Sin paquete</button>
                                @foreach (var c in PaquetesCodigosDisponibles)
                                {
                                    <button class="at-fbar-fchip @(_filPaquetesCodigos.Contains(c) ? "on" : "")" @onclick="() => TogglePaqueteCodigo(c)">@c</button>
                                }
                            </div>
                        </div>

                        <div class="at-fbar-filt-group">
                            <div class="at-fbar-filt-lbl">Fecha asignacion</div>
                            <div class="at-fbar-chips">
                                <button class="at-fbar-fchip @(_filFecha == "hoy" ? "on" : "")" @onclick='() => SetFecha("hoy")'>Hoy</button>
                                <button class="at-fbar-fchip @(_filFecha == "7d" ? "on" : "")" @onclick='() => SetFecha("7d")'>Ultimos 7 dias</button>
                                <button class="at-fbar-fchip @(_filFecha == "30d" ? "on" : "")" @onclick='() => SetFecha("30d")'>Ultimos 30 dias</button>
                                <button class="at-fbar-fchip @(_filFecha == "rango" ? "on" : "")" @onclick='() => SetFecha("rango")'>Rango...</button>
                            </div>
                            @if (_filFecha == "rango")
                            {
                                <div style="display:flex;gap:8px;margin-top:8px;">
                                    <input type="date" class="form-control form-control-sm" @bind="_filFechaDesde" />
                                    <input type="date" class="form-control form-control-sm" @bind="_filFechaHasta" />
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="at-grid-h">
            <span>MIS SERVICIOS ASIGNADOS (@_visibles.Count)</span>
            @* El boton "Columnas" abre el modal para elegir columnas visibles,
               orden y alias. Antes estaba gated a admin, pero el config aplica
               a todo el tenant (no es per-user), asi que cualquier usuario del
               tenant que entra a /atencion debe poder abrirlo. *@
            <button class="btn btn-outline-secondary btn-sm at-cfg-btn" @onclick="AbrirConfigColumnas" title="Configurar columnas (visibles, orden, alias)">
                &#9881; Columnas
            </button>
        </div>
        <div class="at-grid-wrap">
            @if (_visibles.Count == 0)
            {
                <div class="ase-empty">No tienes servicios asignados pendientes.</div>
            }
            else
            {
                <table class="table table-sm at-tbl">
                    <thead>
                        <tr>
                            @foreach (var col in _columnasVisibles)
                            {
                                <th>@((MarkupString)col.Titulo)</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _visibles)
                        {
                            <tr class="@(s.Completado ? "at-row-done" : "")">
                                @foreach (var col in _columnasVisibles)
                                {
                                    @RenderCelda(col.Key, s)
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@* ===== Modal: Configurar columnas de la tabla ===== *@
@if (_showConfigCols)
{
    <div class="usu-modal-backdrop" @onclick="CerrarConfigColumnas"></div>
    <div class="usu-modal">
        <div class="usu-modal-h">
            <h3>Configurar columnas</h3>
            <button class="usu-modal-close" @onclick="CerrarConfigColumnas">&times;</button>
        </div>
        <div class="usu-modal-body">
            <p class="text-muted" style="font-size:12px;margin-bottom:12px;">
                Aplica a todos los usuarios del tenant. Usa las flechas para reordenar las columnas.
                Deja Alias vacio para usar el titulo por defecto. Desmarca Visible para ocultarla.
            </p>
            <table class="table table-sm at-cfg-tbl">
                <thead>
                    <tr>
                        <th style="width:70px;">Mover</th>
                        <th style="width:60px;">Visible</th>
                        <th>Columna</th>
                        <th style="width:200px;">Alias (opcional)</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < _cfgEdicion.Count; i++)
                    {
                        var idx = i;
                        var row = _cfgEdicion[idx];
                        <tr>
                            <td class="text-center at-mov-cell">
                                <button type="button" class="btn btn-sm at-mov-btn" title="Subir"
                                        disabled="@(idx == 0)" @onclick="() => MoverArriba(idx)">&#9650;</button>
                                <button type="button" class="btn btn-sm at-mov-btn" title="Bajar"
                                        disabled="@(idx == _cfgEdicion.Count - 1)" @onclick="() => MoverAbajo(idx)">&#9660;</button>
                            </td>
                            <td class="text-center">
                                <input type="checkbox" @bind="row.Visible" />
                            </td>
                            <td>@row.TituloDefault</td>
                            <td>
                                <input type="text" class="form-control form-control-sm" @bind="row.Alias" placeholder="@row.TituloDefault" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="usu-modal-f">
            <button class="btn btn-outline-secondary" @onclick="CerrarConfigColumnas">Cancelar</button>
            <button class="btn btn-primary" @onclick="GuardarConfigColumnas" disabled="@_cfgGuardando">
                @(_cfgGuardando ? "Guardando..." : "Guardar")
            </button>
        </div>
    </div>
}

@* ===== Modal full-screen: Historias Clinicas ===== *@
@if (_showHistoriaSel is MiServicioAsignadoDto hs)
{
    <div class="at-fs-backdrop" @onclick="CerrarHistoria"></div>
    <div class="at-fs-modal">
        <div class="at-fs-h">
            <div>
                <h3>Historias Clinicas - @hs.NombrePaciente</h3>
                <small>@hs.TipoDocPaciente @hs.NumeroDocPaciente</small>
            </div>
            <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarHistoria">&#10006; Cerrar</button>
        </div>
        <div class="at-fs-body">
            @* Pasamos el codigo del formato de historia que ya viene configurado en
               el servicio asignado (Asignacion.FormatoHistoria <- ServicioContrato.
               Historia). El profesional NO elige formato: si esta presente, lo
               usamos para todas las historias nuevas que inicie desde aqui. *@
            <HistoriasClinicasModulo PacienteContexto="@_pacienteCtx"
                                     FormatoForzadoCodigo="@hs.FormatoHistoria"
                                     TipoServicio="@hs.TipoServicio"
                                     AsignacionId="@hs.AsignacionId" />
        </div>
    </div>
}

@* ===== Modal full-screen: Notas Medicas ===== *@
@if (_showNotaSel is MiServicioAsignadoDto sel)
{
    <div class="at-fs-backdrop" @onclick="CerrarNotas"></div>
    <div class="at-fs-modal">
        <div class="at-fs-h">
            <div>
                <h3>Notas Medicas - Sesion @sel.NumeroSesionMostrar / @sel.TotalSesionesAsignacion</h3>
                <small>@sel.NombrePaciente - @sel.TipoDocPaciente @sel.NumeroDocPaciente - @sel.NombreServicio</small>
            </div>
            <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarNotas">&#10006; Cerrar</button>
        </div>
        <div class="at-fs-body at-fs-body-with-chat
                    @(_notasWaColapsado ? "wa-colapsado" : "")
                    @(_notasMonitorColapsado ? "mon-colapsado" : "")">
            <div class="at-fs-notas">
                <NotasMedicasModulo NombrePacienteCtx="@sel.NombrePaciente"
                                    DocumentoPacienteCtx="@sel.NumeroDocPaciente"
                                    SessionNoCtx="@sel.SessionNo"
                                    AsignacionTurnoIdCtx="@sel.AsignacionTurnoId"
                                    PacienteId="@sel.PacienteId"
                                    HistoriaClinicaId="@_hcIdParaNotas"
                                    @bind-ContenidoNotaActual="_contenidoNotaActual"
                                    OnNotaGuardada="OnNotaGuardadaAsync" />
            </div>

            @* ===== Columna WhatsApp del paciente (mismo componente que usa HC) ===== *@
            <div class="at-fs-whatsapp @(_notasWaColapsado ? "is-colapsado" : "")">
                @if (_notasWaColapsado)
                {
                    <button class="at-side-strip" @onclick="() => _notasWaColapsado = false" title="Abrir WhatsApp">
                        <span class="at-side-strip-ico">&#128172;</span>
                        <span class="at-side-strip-text">WhatsApp</span>
                    </button>
                }
                else
                {
                    @* CodigoPais + Telefono para E.164 completo — Gupshup no
                       enruta numeros nacionales de 10 digitos. *@
                    <WhatsAppChatPanel Telefono="@Visal.SuperAdmin.Components.Forms.PhoneFormatHelper.BuildFullDigits(_pacienteCtxNotas?.CodigoPaisTelefono, Visal.Application.Common.PacienteTelefonoHelper.Principal(_pacienteCtxNotas?.Telefono))"
                                       NombreContacto="@sel.NombrePaciente"
                                       Cedula="@sel.NumeroDocPaciente"
                                       PacienteId="@sel.PacienteId"
                                       Colapsable="true"
                                       @bind-Colapsado="_notasWaColapsado" />
                }
            </div>

            @* ===== Columna Monitor de Notas IA (colapsable) ===== *@
            <div class="at-fs-aichat @(_notasMonitorColapsado ? "is-colapsado" : "")">
                @if (_notasMonitorColapsado)
                {
                    <button class="at-side-strip at-side-strip-monitor" @onclick="() => _notasMonitorColapsado = false" title="Abrir monitor de notas IA">
                        <span class="at-side-strip-ico">&#129302;</span>
                        <span class="at-side-strip-text">Monitor IA</span>
                    </button>
                }
                else
                {
                    <div class="at-monitor-head">
                        <span>Monitor de Notas IA</span>
                        <button class="at-monitor-toggle" @onclick="() => _notasMonitorColapsado = true" title="Ocultar">&raquo;</button>
                    </div>
                    <AsistenteChatNotas @ref="_chatRef"
                                        PacienteId="@sel.PacienteId"
                                        HistoriaClinicaId="@_hcIdParaNotas"
                                        ContenidoNota="@_contenidoNotaActual"
                                        UltimoGuardado="@_ultimoGuardadoSignal" />
                }
            </div>
        </div>
    </div>
}

<style>
    .at-tabs { display: flex; border-bottom: 1px solid #e2e8f0; }
    .at-tab { padding: 10px 18px; background: none; border: none; border-bottom: 2px solid #1565c0; color: #1565c0; font-weight: 600; cursor: default; }
    .at-tab.sel { background: #f8fafc; }
    .at-filtros { padding: 14px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .at-filtros .ase-f-wide { grid-column: span 2; }
    .at-filtros label { font-size: 11px; color: #475569; font-weight: 600; text-transform: uppercase; }
    .ase-chk { display: inline-flex; align-items: center; gap: 6px; padding: 6px 0; font-size: 13px; }

    /* Toolbar de filtros al estilo pipeline CUBOT: busqueda + orden + boton
       Filtros con popover de chips. Renombrados de .pl-* a .at-fbar-* para
       no chocar con la nomenclatura del pipeline si algun dia se ports. */
    .at-fbar { display: flex; align-items: center; gap: 12px; padding: 12px 14px; flex-wrap: wrap; border-top: 1px solid #e2e8f0; background: #fff; }
    .at-fbar-search { position: relative; flex: 1; min-width: 240px; display: flex; align-items: center; }
    .at-fbar-search svg { position: absolute; left: 12px; width: 16px; height: 16px; color: #94a3b8; }
    .at-fbar-search input { width: 100%; padding: 9px 32px 9px 36px; border: 1px solid #cbd5e1; border-radius: 10px; background: #fff; font-size: 13px; }
    .at-fbar-search input:focus { border-color: #1565c0; outline: none; }
    .at-fbar-search-clear { position: absolute; right: 8px; border: none; background: none; font-size: 18px; line-height: 1; color: #94a3b8; cursor: pointer; }
    .at-fbar-sort { display: flex; align-items: center; gap: 6px; }
    .at-fbar-sort-lbl { font-size: 12px; color: #64748b; }
    .at-fbar-sort select { border: 1px solid #cbd5e1; border-radius: 8px; padding: 8px 10px; font-size: 12.5px; background: #fff; max-width: 230px; }
    .at-fbar-filt-anchor { position: relative; flex-shrink: 0; }
    .btn.at-fbar-filt-on { border-color: #1565c0; color: #1565c0; }
    .at-fbar-filters { position: absolute; right: 0; top: calc(100% + 8px); z-index: 40; width: 620px; max-width: 88vw; border: 1px solid #e2e8f0; border-radius: 12px; background: #fff; padding: 16px 18px; box-shadow: 0 20px 60px rgba(15,23,42,.18); }
    .at-fbar-filters-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .at-fbar-filters-head > span { font-weight: 700; font-size: 13px; color: #0f172a; }
    .at-fbar-link { border: none; background: none; color: #1565c0; font-size: 12px; cursor: pointer; }
    .at-fbar-filt-group { margin-bottom: 12px; }
    .at-fbar-filt-lbl { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; color: #64748b; margin-bottom: 7px; }
    .at-fbar-chips { display: flex; flex-wrap: wrap; gap: 7px; }
    .at-fbar-fchip { display: inline-flex; align-items: center; gap: 6px; padding: 5px 11px; border-radius: 999px; border: 1px solid #cbd5e1; background: #fff; font-size: 12px; cursor: pointer; color: #334155; }
    .at-fbar-fchip:hover { border-color: #1565c0; }
    .at-fbar-fchip.on { background: #dbeafe; border-color: #1565c0; color: #1565c0; font-weight: 600; }
    .at-fbar-toggle { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; color: #334155; }
    .at-grid-h { padding: 10px 14px; font-size: 12px; font-weight: 700; color: #334155; text-transform: uppercase; letter-spacing: 0.5px; border-top: 1px solid #e2e8f0; background: #f1f5f9; display: flex; align-items: center; justify-content: space-between; }
    .at-cfg-btn { text-transform: none; font-weight: 600; letter-spacing: 0; }
    .at-grid-wrap { overflow: auto; background: #fff; max-height: 600px; }
    .at-tbl { margin: 0; font-size: 12px; min-width: 100%; }
    .at-tbl thead th { position: sticky; top: 0; z-index: 3; background: #f1f5f9; color: #334155; font-size: 11px; font-weight: 700; border-bottom: 1px solid #cbd5e1; white-space: nowrap; padding: 8px 10px; text-align: center; line-height: 1.15; }
    .at-tbl td { vertical-align: middle; padding: 8px 10px; }
    .at-cfg-tbl input[type="text"], .at-cfg-tbl input[type="number"] { font-size: 12px; padding: 4px 6px; }
    .at-mov-cell { white-space: nowrap; }
    .at-mov-btn { background: #f1f5f9; border: 1px solid #cbd5e1; color: #334155; padding: 2px 6px; font-size: 10px; line-height: 1; margin: 0 1px; }
    .at-mov-btn:hover:not(:disabled) { background: #dbeafe; border-color: #1565c0; color: #1565c0; }
    .at-mov-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .at-row-done { opacity: 0.6; background: #f8fafc; }
    .at-pill-done { background: #dcfce7; color: #166534; padding: 2px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; }
    .at-pill-no { background: #fef3c7; color: #92400e; padding: 2px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; }
    .at-no-prof { padding: 30px; }
    .at-no-prof code { background:#f1f5f9; padding:1px 6px; border-radius:3px; }
    .asg-ro { background: #f1f5f9; }
    .at-paciente-meta { padding: 10px 12px; background: #eff6ff; border-radius: 8px; margin-bottom: 14px; font-size: 13px; }

    /* Overlay full-screen para submodulos (Historias / Notas) */
    .at-fs-backdrop { position: fixed; inset: 0; background: rgba(15,23,42,.55); z-index: 1000; }
    .at-fs-modal { position: fixed; top: 24px; left: 24px; right: 24px; bottom: 24px; background: #f8fafc; border-radius: 12px; box-shadow: 0 30px 80px rgba(15,23,42,.35); z-index: 1001; display: flex; flex-direction: column; overflow: hidden; }
    .at-fs-h { display: flex; align-items: center; justify-content: space-between; padding: 14px 22px; background: #fff; border-bottom: 1px solid #e2e8f0; }
    .at-fs-h h3 { margin: 0; font-size: 16px; font-weight: 700; color: #0f172a; }
    .at-fs-h small { color: #64748b; font-size: 11.5px; }
    .at-fs-body { flex: 1; overflow: auto; padding: 16px 22px; }
    /* Grid de 3 columnas: notas (fluida) | WhatsApp (320px) | Monitor IA (360px).
       Cada auxiliar puede colapsarse a 44px (franja vertical con boton para expandir),
       devolviendo todo el ancho extra a la columna de notas. */
    .at-fs-body-with-chat { display: grid; grid-template-columns: minmax(0, 1fr) 320px 360px; gap: 0; padding: 0; overflow: hidden; }
    .at-fs-body-with-chat.wa-colapsado { grid-template-columns: minmax(0, 1fr) 44px 360px; }
    .at-fs-body-with-chat.mon-colapsado { grid-template-columns: minmax(0, 1fr) 320px 44px; }
    .at-fs-body-with-chat.wa-colapsado.mon-colapsado { grid-template-columns: minmax(0, 1fr) 44px 44px; }
    .at-fs-notas { overflow: auto; padding: 16px 22px; }
    .at-fs-whatsapp { display: flex; flex-direction: column; min-width: 0; border-left: 1px solid #e2e8f0; background: #f8fafc; overflow: hidden; }
    .at-fs-whatsapp.is-colapsado { padding: 8px 4px; align-items: center; background: #f1f5f9; }
    .at-fs-aichat { overflow: hidden; display: flex; flex-direction: column; border-left: 1px solid #e2e8f0; }
    .at-fs-aichat.is-colapsado { padding: 8px 4px; align-items: center; background: #f1f5f9; }
    /* Header del monitor IA con boton de colapso. */
    .at-monitor-head { display: flex; justify-content: space-between; align-items: center; padding: 8px 12px; background: #f1f5f9; border-bottom: 1px solid #e2e8f0; font-size: 11px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: .04em; flex-shrink: 0; }
    .at-monitor-toggle { background: none; border: 1px solid #cbd5e1; color: #475569; padding: 0 7px; border-radius: 4px; cursor: pointer; font-size: 14px; line-height: 22px; }
    .at-monitor-toggle:hover { background: #fff; color: #1565c0; }
    /* Franja vertical cuando una columna esta colapsada. */
    .at-side-strip { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 10px 4px; border: 1px solid #cbd5e1; background: #fff; border-radius: 8px; cursor: pointer; min-width: 36px; }
    .at-side-strip:hover { background: #eef6ff; border-color: #25d366; }
    .at-side-strip.at-side-strip-monitor:hover { border-color: #1565c0; }
    .at-side-strip-ico { font-size: 16px; }
    .at-side-strip-text { font-size: 9px; font-weight: 700; color: #475569; writing-mode: vertical-rl; transform: rotate(180deg); letter-spacing: .04em; text-transform: uppercase; }
    @@media (max-width: 1300px) {
        /* En pantallas chicas dejamos el grid en 2 columnas (notas + monitor) y ocultamos
           el WhatsApp por defecto. El usuario puede colapsarlo/expandirlo con el chip. */
        .at-fs-body-with-chat { grid-template-columns: minmax(0, 1fr) 44px 360px; }
        .at-fs-body-with-chat.wa-colapsado { grid-template-columns: minmax(0, 1fr) 44px 360px; }
    }
    .usu-modal-backdrop { position: fixed; inset: 0; background: rgba(15,23,42,.45); z-index: 950; }
    .usu-modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 720px; max-width: 95vw; max-height: 90vh; background: #fff; border-radius: 12px; box-shadow: 0 20px 60px rgba(15,23,42,.25); z-index: 951; display: flex; flex-direction: column; }
    .usu-modal-h { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid #e2e8f0; }
    .usu-modal-h h3 { margin: 0; font-size: 15px; font-weight: 700; color: #0f172a; }
    .usu-modal-close { background: none; border: none; font-size: 22px; line-height: 1; cursor: pointer; color: #64748b; }
    .usu-modal-body { padding: 18px; overflow: auto; }
    .usu-modal-f { padding: 12px 18px; border-top: 1px solid #e2e8f0; display: flex; gap: 8px; justify-content: flex-end; }

    /* Chip columna Revision (Ola 3 Capa 08) */
    .at-rv-chip { display:inline-block; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:700; white-space:nowrap; }
    .at-rv-none   { background:#f1f5f9; color:#94a3b8; }
    .at-rv-sinrev { background:#e5e7eb; color:#475569; }
    .at-rv-prerev { background:#dbeafe; color:#1e40af; }
    .at-rv-enrev  { background:#fef3c7; color:#92400e; }
    .at-rv-aprob  { background:#d1fae5; color:#065f46; }
    .at-rv-rech   { background:#fee2e2; color:#991b1b; cursor:help; }
    .at-rv-arch   { background:#a7f3d0; color:#064e3b; }
    .at-rv-inac   { background:#374151; color:#f9fafb; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<MiServicioAsignadoDto> _todos = new();
    private string _filtroPac = "";
    private bool _mostrarVencidas = true;

    // Estado del toolbar de filtros (portado del pipeline CUBOT). Solo vive en
    // memoria de la sesion; si el usuario recarga la pagina, se pierde.
    private bool _filtrosOpen;
    private string _sortBy = "recent";
    private HashSet<string> _filTipos = new(StringComparer.OrdinalIgnoreCase);
    private string _filEstado = "";              // "" = ambos, "pendientes", "completados"
    private HashSet<string> _filServicios = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _filProfesionales = new(StringComparer.OrdinalIgnoreCase);
    private string _filPaquete = "";             // "" = ambos, "con", "sin"
    private HashSet<string> _filPaquetesCodigos = new(StringComparer.OrdinalIgnoreCase);
    private string _filFecha = "";               // "" | "hoy" | "7d" | "30d" | "rango"
    private DateOnly? _filFechaDesde, _filFechaHasta;

    private static readonly string[] TiposServicioDisponibles = new[] { "CONSULTA", "TERAPIA", "ENFERMERIA", "EQUIPOS", "INSUMOS" };
    private List<string> ServiciosDisponibles => _todos.Select(x => x.NombreServicio).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
    private List<string> ProfesionalesDisponibles => _todos.Select(x => x.NombreProfesional).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
    private List<string> PaquetesCodigosDisponibles => _todos.Where(x => !string.IsNullOrWhiteSpace(x.PaqueteCodigo)).Select(x => x.PaqueteCodigo!).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();

    private string _nombreProf = "";
    private string _especialidad = "";
    private bool? _modulos;
    /// <summary>True si el claim "profesional_id" esta presente: el usuario es
    /// un profesional. Permite diferenciar "no estas vinculado" vs "vinculado
    /// pero sin turnos asignados" cuando _modulos = false.</summary>
    private bool _tieneProfesionalVinculado;

    private MiServicioAsignadoDto? _showHistoriaSel;
    private MiServicioAsignadoDto? _showNotaSel;
    private Guid? _hcIdParaNotas;
    /// <summary>Contenido en vivo de la nota — espejado desde NotasMedicasModulo via @@bind para que el chat IA lo lea sin tener que pegarlo manualmente.</summary>
    private string? _contenidoNotaActual;
    /// <summary>Ref al chat IA — kept for back-compat pero ya no es el camino principal de la auto-revision.</summary>
    private Visal.SuperAdmin.Components.Forms.AsistenteChatNotas? _chatRef;
    /// <summary>
    /// Senal reactiva del guardado de la nota. Cada guardado bumpea un tick y el
    /// chat reacciona via OnParametersSetAsync. Mas robusto que @ref porque
    /// funciona aun si el chat no estaba completamente renderizado.
    /// </summary>
    private Visal.SuperAdmin.Components.Forms.AsistenteChatNotas.AutoRevisarSignal? _ultimoGuardadoSignal;
    private long _tickGuardado;

    /// <summary>Handler del evento OnNotaGuardada del modulo de notas — bumpea el signal para que el chat decida si auto-revisa segun la config de la regla.</summary>
    private void OnNotaGuardadaAsync(bool definitivo)
    {
        _tickGuardado++;
        _ultimoGuardadoSignal = new Visal.SuperAdmin.Components.Forms.AsistenteChatNotas.AutoRevisarSignal(_tickGuardado, definitivo);
        StateHasChanged();
    }
    private PacienteAsignacionDto? _pacienteCtx;
    /// <summary>Paciente cargado al abrir el modal de Notas (para que el panel WhatsApp
    /// tenga acceso a Telefono y datos del paciente sin tener que consultarlo el solo).</summary>
    private PacienteAsignacionDto? _pacienteCtxNotas;

    /// <summary>Estado de colapso de la columna WhatsApp dentro del modal de notas.
    /// Inicia en true (colapsado) para no tapar el espacio de notas al abrir el modal.
    /// El operador lo expande con un click si necesita escribirle al paciente.</summary>
    private bool _notasWaColapsado = true;
    /// <summary>Estado de colapso del monitor IA dentro del modal de notas.</summary>
    private bool _notasMonitorColapsado;

    private string? _error, _ok;

    /// <summary>Filas visibles: pasa <see cref="_todos"/> por el pipeline de
    /// filtros configurado en la toolbar y despues aplica el orden elegido.
    /// Recomputa en cada render (client-side, sin round-trip).</summary>
    private List<MiServicioAsignadoDto> _visibles
    {
        get
        {
            IEnumerable<MiServicioAsignadoDto> q = _todos;

            if (!string.IsNullOrWhiteSpace(_filtroPac))
            {
                var t = _filtroPac.Trim();
                q = q.Where(s => s.NumeroDocPaciente.Contains(t, StringComparison.OrdinalIgnoreCase)
                              || s.NombrePaciente.Contains(t, StringComparison.OrdinalIgnoreCase));
            }
            if (_filTipos.Count > 0) { q = q.Where(s => _filTipos.Contains(s.TipoServicio)); }
            if (_filEstado == "pendientes") { q = q.Where(s => !s.Completado); }
            else if (_filEstado == "completados") { q = q.Where(s => s.Completado); }
            if (_filServicios.Count > 0) { q = q.Where(s => _filServicios.Contains(s.NombreServicio)); }
            if (_filProfesionales.Count > 0) { q = q.Where(s => _filProfesionales.Contains(s.NombreProfesional)); }
            if (_filPaquete == "con") { q = q.Where(s => !string.IsNullOrWhiteSpace(s.PaqueteCodigo)); }
            else if (_filPaquete == "sin") { q = q.Where(s => string.IsNullOrWhiteSpace(s.PaqueteCodigo)); }
            if (_filPaquetesCodigos.Count > 0) { q = q.Where(s => s.PaqueteCodigo != null && _filPaquetesCodigos.Contains(s.PaqueteCodigo)); }
            var hoy = DateOnly.FromDateTime(DateTime.Today);
            if (_filFecha == "hoy") { q = q.Where(s => s.FechaAsignacion == hoy); }
            else if (_filFecha == "7d") { var d = hoy.AddDays(-7); q = q.Where(s => s.FechaAsignacion >= d); }
            else if (_filFecha == "30d") { var d = hoy.AddDays(-30); q = q.Where(s => s.FechaAsignacion >= d); }
            else if (_filFecha == "rango")
            {
                if (_filFechaDesde is DateOnly d1) { q = q.Where(s => s.FechaAsignacion >= d1); }
                if (_filFechaHasta is DateOnly d2) { q = q.Where(s => s.FechaAsignacion <= d2); }
            }

            q = _sortBy switch
            {
                "oldest"      => q.OrderBy(s => s.FechaAsignacion).ThenBy(s => s.NombrePaciente),
                "paciente"    => q.OrderBy(s => s.NombrePaciente, StringComparer.OrdinalIgnoreCase),
                "servicio"    => q.OrderBy(s => s.NombreServicio, StringComparer.OrdinalIgnoreCase),
                "profesional" => q.OrderBy(s => s.NombreProfesional, StringComparer.OrdinalIgnoreCase),
                _             => q.OrderByDescending(s => s.FechaAsignacion).ThenBy(s => s.NombrePaciente),
            };
            return q.ToList();
        }
    }

    private bool FiltrosActivos => _filTipos.Count > 0 || !string.IsNullOrEmpty(_filEstado)
                                   || _filServicios.Count > 0 || _filProfesionales.Count > 0
                                   || !string.IsNullOrEmpty(_filPaquete) || _filPaquetesCodigos.Count > 0
                                   || !string.IsNullOrEmpty(_filFecha) || !_mostrarVencidas;

    private int CuentaFiltrosActivos
    {
        get
        {
            var n = 0;
            if (_filTipos.Count > 0) { n++; }
            if (!string.IsNullOrEmpty(_filEstado)) { n++; }
            if (_filServicios.Count > 0) { n++; }
            if (_filProfesionales.Count > 0) { n++; }
            if (!string.IsNullOrEmpty(_filPaquete) || _filPaquetesCodigos.Count > 0) { n++; }
            if (!string.IsNullOrEmpty(_filFecha)) { n++; }
            if (!_mostrarVencidas) { n++; }
            return n;
        }
    }

    private void ToggleTipo(string t) { if (!_filTipos.Add(t)) { _filTipos.Remove(t); } }
    private void ToggleServicio(string s) { if (!_filServicios.Add(s)) { _filServicios.Remove(s); } }
    private void ToggleProfesional(string p) { if (!_filProfesionales.Add(p)) { _filProfesionales.Remove(p); } }
    private void TogglePaqueteCodigo(string c) { if (!_filPaquetesCodigos.Add(c)) { _filPaquetesCodigos.Remove(c); } }
    private void SetEstado(string v) => _filEstado = _filEstado == v ? "" : v;
    private void SetPaquete(string v) => _filPaquete = _filPaquete == v ? "" : v;
    private void SetFecha(string v) => _filFecha = _filFecha == v ? "" : v;

    private async Task OnVencidasChanged(ChangeEventArgs e)
    {
        _mostrarVencidas = e.Value is bool b && b;
        await Cargar();
    }

    private void LimpiarFiltros()
    {
        _filTipos.Clear();
        _filServicios.Clear();
        _filProfesionales.Clear();
        _filPaquetesCodigos.Clear();
        _filEstado = "";
        _filPaquete = "";
        _filFecha = "";
        _filFechaDesde = _filFechaHasta = null;
        _filtroPac = "";
    }

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _error = _ok = null;
        try
        {
            if (AuthState is null) { _error = "Sesion no detectada."; return; }
            var st = await AuthState;
            if (!Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var puId))
            {
                _error = "No se pudo identificar al usuario.";
                return;
            }
            // Si el claim "profesional_id" existe, el usuario SI es un
            // profesional. Lo usamos para distinguir "no vinculado" de
            // "vinculado sin turnos" cuando _todos.Count == 0.
            _tieneProfesionalVinculado = !string.IsNullOrEmpty(st.User.FindFirst("profesional_id")?.Value);
            // Admin: Owner o rol Administrador. Solo admin ve el boton "Columnas".
            var rol = st.User.FindFirst(ClaimTypes.Role)?.Value ?? "";
            var tenantRole = st.User.FindFirst("tenant_role")?.Value ?? "";
            _esAdmin = string.Equals(tenantRole, "Owner", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(rol, "Administrador", StringComparison.OrdinalIgnoreCase);
            _todos = (await Svc.GetMisServiciosAsync(puId, incluirCompletados: _mostrarVencidas)).ToList();
            // Config de columnas (overrides del tenant). Nulos = usar default.
            try { _configColumnas = (await ColSvc.ListarAsync()).ToList(); }
            catch { _configColumnas = new(); }
            // Llenar header con el primer registro (todos comparten profesional).
            if (_todos.Count > 0)
            {
                _nombreProf = "(profesional vinculado)";
                _especialidad = _todos[0].TipoServicio;
                _modulos = true;
            }
            else
            {
                _modulos = false;
            }
        }
        catch (Exception ex) { _error = "Error: " + ex.Message; }
    }

    private async Task AbrirNotas(MiServicioAsignadoDto s)
    {
        _error = null; _ok = null;
        // Regla de negocio: para crear notas, el paciente debe tener una HC vigente
        // del formato que pide el servicio (FormatoHistoria) y la vigencia se mide
        // contra la "Validez de Historia Clinica (Meses)" configurada en la empresa.
        // Si no cumple, no abrimos el modal de notas y mostramos un mensaje claro.
        var val = await NotaSvc.ValidarHcParaNotaAsync(s.PacienteId, s.FormatoHistoria);
        if (!val.Ok)
        {
            _error = val.Mensaje;
            return;
        }
        // Cargar el paciente PRIMERO para tener Telefono disponible en el panel
        // WhatsApp del modal de notas. Mismo patron defensivo que AbrirHistoria:
        // si seteamos _showNotaSel antes, los submodulos arrancan a consultar la
        // BD en paralelo y el DbContext scoped revienta.
        try { _pacienteCtxNotas = await AsigSvc.GetPacienteAsync(s.PacienteId); }
        catch { _pacienteCtxNotas = null; }
        _hcIdParaNotas = val.HistoriaId;
        _showNotaSel = s;
    }
    private void CerrarNotas() { _showNotaSel = null; _hcIdParaNotas = null; _pacienteCtxNotas = null; }

    private async Task AbrirHistoria(MiServicioAsignadoDto s)
    {
        // OJO: primero cargamos el paciente y SOLO despues montamos el modal.
        // Si se setea _showHistoriaSel antes, el HistoriasClinicasModulo empieza
        // a consultar la BD en paralelo con esta llamada y el DbContext scoped
        // explota con "A second operation was started on this context instance".
        try
        {
            _pacienteCtx = await AsigSvc.GetPacienteAsync(s.PacienteId);
        }
        catch
        {
            _pacienteCtx = null;
        }
        _showHistoriaSel = s;
    }

    private void CerrarHistoria() { _showHistoriaSel = null; _pacienteCtx = null; }

    // ===== Config de columnas de la tabla MIS SERVICIOS ASIGNADOS =====
    // Nivel tenant: el admin decide que columnas se ven, con que alias y en que orden.
    // Cada usuario del tenant ve exactamente la misma configuracion.

    private bool _esAdmin;

    /// <summary>
    /// Config default de columnas. El orden aqui es el orden por defecto.
    /// El "TituloHtml" permite forzar saltos de linea (por ejemplo "HISTORIA
    /// MEDICA" en 2 lineas para que la columna sea mas angosta).
    /// </summary>
    private sealed record ColDef(string Key, string TituloDefault, string TituloHtml, int OrdenDefault);
    private static readonly ColDef[] _columnasDefault = new[]
    {
        new ColDef("chk",           "",                "",                                       1),
        new ColDef("historia",      "Historia Medica", "Historia<br/>Medica",                     2),
        new ColDef("notas",         "Notas",           "Notas",                                   3),
        new ColDef("cod_int",       "CodInt",          "CodInt",                                  4),
        new ColDef("cod_asig",      "CodAsig",         "CodAsig",                                 5),
        new ColDef("fec_asig",      "FechaAsig",       "Fecha<br/>Asig",                          6),
        new ColDef("orden",         "Orden",           "Orden",                                   7),
        new ColDef("tipo",          "Tipo",            "Tipo",                                    8),
        new ColDef("servicio",      "Servicio",        "Servicio",                                9),
        new ColDef("pkg_cod",       "PaqueteCod",      "Paquete<br/>Cod",                        10),
        new ColDef("pkg_nom",       "PaqueteNombre",   "Paquete<br/>Nombre",                     11),
        new ColDef("session_no",    "SessionNo",       "Sesion",                                 12),
        new ColDef("completado",    "Completado",     "Completado",                              13),
        new ColDef("tipo_doc_pac",  "TipoDocPac",      "Tipo<br/>DocPac",                        14),
        new ColDef("no_doc_pac",    "NoDocPac",        "NoDocPac",                                15),
        new ColDef("nom_paciente",  "NomPaciente",     "Paciente",                                16),
        new ColDef("profesional",   "Profesional",     "Profesional",                             17),
        new ColDef("fec_nota",      "FecNota",         "Fecha<br/>Nota",                          18),
        // Capa 08 Ola 3 — chip del estado del ciclo de revision de la HC del paciente.
        new ColDef("revision_estado","Revision",        "Revision",                                19),
    };

    private List<AtencionColumnaConfigDto> _configColumnas = new();

    /// <summary>Columnas visibles ya mezcladas con overrides y ordenadas.</summary>
    private IReadOnlyList<(string Key, string Titulo)> _columnasVisibles
    {
        get
        {
            var cfgDict = _configColumnas.ToDictionary(c => c.ColumnaKey, c => c);
            var items = _columnasDefault.Select(d =>
            {
                cfgDict.TryGetValue(d.Key, out var ov);
                var visible = ov?.Visible ?? true;
                var titulo = string.IsNullOrWhiteSpace(ov?.Alias) ? d.TituloHtml : System.Net.WebUtility.HtmlEncode(ov!.Alias!);
                var orden = ov?.Orden ?? d.OrdenDefault;
                return new { d.Key, Titulo = titulo, Visible = visible, Orden = orden };
            });
            return items.Where(x => x.Visible).OrderBy(x => x.Orden).Select(x => (x.Key, x.Titulo)).ToList();
        }
    }

    /// <summary>Render de la celda de la fila segun el key de la columna.</summary>
    private RenderFragment RenderCelda(string key, MiServicioAsignadoDto s) => __b =>
    {
        var seq = 0;
        switch (key)
        {
            case "chk":
                __b.OpenElement(seq++, "td");
                __b.OpenElement(seq++, "input");
                __b.AddAttribute(seq++, "type", "checkbox");
                __b.AddAttribute(seq++, "disabled", s.Completado);
                __b.CloseElement();
                __b.CloseElement();
                break;
            case "historia":
                __b.OpenElement(seq++, "td");
                __b.OpenElement(seq++, "button");
                __b.AddAttribute(seq++, "class", "btn btn-outline-secondary btn-sm");
                __b.AddAttribute(seq++, "title", "Abrir Historias Clinicas del paciente");
                __b.AddAttribute(seq++, "onclick", Microsoft.AspNetCore.Components.EventCallback.Factory.Create(this, () => AbrirHistoria(s)));
                __b.AddMarkupContent(seq++, "&#9998;");
                __b.CloseElement();
                __b.CloseElement();
                break;
            case "notas":
                __b.OpenElement(seq++, "td");
                __b.OpenElement(seq++, "button");
                __b.AddAttribute(seq++, "class", "btn btn-outline-primary btn-sm");
                __b.AddAttribute(seq++, "title", "Abrir Notas Medicas (registrar atencion)");
                __b.AddAttribute(seq++, "disabled", s.Completado);
                __b.AddAttribute(seq++, "onclick", Microsoft.AspNetCore.Components.EventCallback.Factory.Create(this, () => AbrirNotas(s)));
                __b.AddMarkupContent(seq++, "&#9998;");
                __b.CloseElement();
                __b.CloseElement();
                break;
            case "cod_int":
                __b.OpenElement(seq++, "td");
                __b.AddAttribute(seq++, "class", "mono");
                __b.AddContent(seq++, s.CodigoAsignacionInterna);
                __b.CloseElement();
                break;
            case "cod_asig":
                __b.OpenElement(seq++, "td");
                __b.AddAttribute(seq++, "class", "mono");
                __b.AddContent(seq++, s.CodigoAutorizacion);
                __b.CloseElement();
                break;
            case "fec_asig":
                __b.OpenElement(seq++, "td");
                __b.AddContent(seq++, s.FechaAsignacion.ToString("dd/MM/yyyy"));
                __b.CloseElement();
                break;
            case "orden":
                __b.OpenElement(seq++, "td");
                __b.AddAttribute(seq++, "class", "text-center");
                __b.AddContent(seq++, s.Orden);
                __b.CloseElement();
                break;
            case "tipo":
                __b.OpenElement(seq++, "td");
                __b.AddContent(seq++, s.TipoServicio);
                __b.CloseElement();
                break;
            case "servicio":
                __b.OpenElement(seq++, "td");
                __b.AddContent(seq++, s.NombreServicio);
                __b.CloseElement();
                break;
            case "pkg_cod":
                __b.OpenElement(seq++, "td");
                __b.AddAttribute(seq++, "class", "mono");
                __b.AddContent(seq++, s.PaqueteCodigo);
                __b.CloseElement();
                break;
            case "pkg_nom":
                __b.OpenElement(seq++, "td");
                __b.AddContent(seq++, s.PaqueteNombre);
                __b.CloseElement();
                break;
            case "session_no":
                __b.OpenElement(seq++, "td");
                __b.AddAttribute(seq++, "class", "text-center");
                __b.AddContent(seq++, s.NumeroSesionMostrar);
                __b.CloseElement();
                break;
            case "completado":
                __b.OpenElement(seq++, "td");
                __b.OpenElement(seq++, "span");
                __b.AddAttribute(seq++, "class", s.Completado ? "at-pill-done" : "at-pill-no");
                __b.AddContent(seq++, s.Completado ? "COMPLETO" : "NO");
                __b.CloseElement();
                __b.CloseElement();
                break;
            case "tipo_doc_pac":
                __b.OpenElement(seq++, "td");
                __b.AddAttribute(seq++, "class", "mono");
                __b.AddContent(seq++, s.TipoDocPaciente);
                __b.CloseElement();
                break;
            case "no_doc_pac":
                __b.OpenElement(seq++, "td");
                __b.AddAttribute(seq++, "class", "mono");
                __b.AddContent(seq++, s.NumeroDocPaciente);
                __b.CloseElement();
                break;
            case "nom_paciente":
                __b.OpenElement(seq++, "td");
                __b.AddContent(seq++, s.NombrePaciente);
                __b.CloseElement();
                break;
            case "profesional":
                __b.OpenElement(seq++, "td");
                __b.AddContent(seq++, s.NombreProfesional);
                __b.CloseElement();
                break;
            case "fec_nota":
                __b.OpenElement(seq++, "td");
                __b.AddContent(seq++, s.FechaAtencion is DateOnly fa ? fa.ToString("dd/MM/yyyy") : "");
                __b.CloseElement();
                break;
            case "revision_estado":
                {
                    // Capa 08 Ola 3 — chip del ciclo de revision. Rojo lleva tooltip con
                    // el motivo del ultimo rechazo (viene resuelto en el service).
                    var (txt, cls, tip) = ChipRevisionAt(s);
                    __b.OpenElement(seq++, "td");
                    __b.AddAttribute(seq++, "class", "text-center");
                    __b.OpenElement(seq++, "span");
                    __b.AddAttribute(seq++, "class", "at-rv-chip " + cls);
                    if (!string.IsNullOrWhiteSpace(tip)) { __b.AddAttribute(seq++, "title", tip); }
                    __b.AddContent(seq++, txt);
                    __b.CloseElement();
                    __b.CloseElement();
                }
                break;
            default:
                __b.OpenElement(seq++, "td");
                __b.CloseElement();
                break;
        }
    };

    /// <summary>
    /// Chip de la columna Revision (Capa 08 Ola 3). Devuelve texto, clase CSS y tooltip.
    /// Segun el plan: gris (Sin/Sin solicitar) / azul (Pre-revision) / amarillo (En revision)
    /// / verde (Aprobada) / rojo (Rechazada con tooltip motivo) / verde oscuro (ArchivadaOk)
    /// / negro (Inactivada).
    /// </summary>
    private static (string txt, string cls, string title) ChipRevisionAt(MiServicioAsignadoDto s)
    {
        if (s.RevisionEstado is null)
        {
            return ("—", "at-rv-none", "HC del paciente aun no entra al ciclo de revision");
        }
        return s.RevisionEstado switch
        {
            RevisionEstadoAgregado.SinRevisar => ("Sin revisar", "at-rv-sinrev", "Revision solicitada, aun sin revisor"),
            RevisionEstadoAgregado.PreRevision => ("Pre-revision", "at-rv-prerev", "El agente IA ya opino — falta revisor humano"),
            RevisionEstadoAgregado.EnRevision => ("En revision", "at-rv-enrev", "Un revisor humano tomo esta HC"),
            RevisionEstadoAgregado.Aprobada => ("Aprobada", "at-rv-aprob", "Aprobada por el revisor"),
            RevisionEstadoAgregado.Rechazada => ("Rechazada", "at-rv-rech",
                string.IsNullOrWhiteSpace(s.RevisionMotivoRechazo)
                    ? "Rechazada — espera reenvio"
                    : "Rechazada: " + s.RevisionMotivoRechazo),
            RevisionEstadoAgregado.ArchivadaOk => ("Archivada", "at-rv-arch", "Ciclo cerrado — archivada OK"),
            RevisionEstadoAgregado.Inactivada => ("Inactivada", "at-rv-inac", "Revision inactivada — captura invalida"),
            _ => ("—", "at-rv-none", ""),
        };
    }

    // ===== Modal configurar columnas =====

    private bool _showConfigCols;
    private bool _cfgGuardando;

    private sealed class CfgFila
    {
        public string Key { get; set; } = "";
        public string TituloDefault { get; set; } = "";
        public bool Visible { get; set; } = true;
        public string? Alias { get; set; }
        public int? Orden { get; set; }
    }
    private List<CfgFila> _cfgEdicion = new();

    private void AbrirConfigColumnas()
    {
        var cfgDict = _configColumnas.ToDictionary(c => c.ColumnaKey, c => c);
        _cfgEdicion = _columnasDefault.Select(d =>
        {
            cfgDict.TryGetValue(d.Key, out var ov);
            return new CfgFila
            {
                Key = d.Key,
                TituloDefault = d.TituloDefault,
                Visible = ov?.Visible ?? true,
                Alias = ov?.Alias,
                Orden = ov?.Orden ?? d.OrdenDefault
            };
        }).OrderBy(x => x.Orden ?? int.MaxValue).ToList();
        _showConfigCols = true;
    }

    private void CerrarConfigColumnas()
    {
        _showConfigCols = false;
    }

    private void MoverArriba(int idx)
    {
        if (idx <= 0 || idx >= _cfgEdicion.Count) { return; }
        (_cfgEdicion[idx - 1], _cfgEdicion[idx]) = (_cfgEdicion[idx], _cfgEdicion[idx - 1]);
    }

    private void MoverAbajo(int idx)
    {
        if (idx < 0 || idx >= _cfgEdicion.Count - 1) { return; }
        (_cfgEdicion[idx + 1], _cfgEdicion[idx]) = (_cfgEdicion[idx], _cfgEdicion[idx + 1]);
    }

    private async Task GuardarConfigColumnas()
    {
        if (_cfgGuardando) { return; }
        _cfgGuardando = true;
        try
        {
            // El orden se toma de la posicion actual en la lista tras el drag con
            // flechas. Asi el usuario no pisa numeros a mano y el orden es siempre
            // consistente con lo que ve en el modal.
            for (var i = 0; i < _cfgEdicion.Count; i++) { _cfgEdicion[i].Orden = i + 1; }
            var reqs = _cfgEdicion.Select(f => new GuardarAtencionColumnaRequest(
                f.Key,
                f.Visible,
                string.IsNullOrWhiteSpace(f.Alias) ? null : f.Alias.Trim(),
                f.Orden)).ToList();
            await ColSvc.GuardarLoteAsync(reqs);
            // Recargar overrides para que _columnasVisibles refleje inmediato.
            _configColumnas = (await ColSvc.ListarAsync()).ToList();
            _showConfigCols = false;
            _ok = "Configuracion guardada.";
        }
        catch (Exception ex) { _error = "Error guardando columnas: " + ex.Message; }
        finally { _cfgGuardando = false; }
    }
}
