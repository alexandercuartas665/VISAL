@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Forms
@using Visal.Application.Tenancy
@inject INotaMedicaService NotaSvc
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

@*
   Modulo reutilizable de Notas Medicas. Se invoca como submodulo desde
   /atencion recibiendo paciente + sesion + HistoriaClinicaId como contexto.
*@

<div class="nm-header">
    <div>
        <h1 class="nm-title">&#9994; Notas Medicas</h1>
        <div class="nm-subtitle">Modulo Profesional</div>
    </div>
    <div class="nm-header-right">
        @if (_borrador is not null && !string.IsNullOrEmpty(_borrador.Id?.ToString()))
        {
            <small class="text-muted">Editando: @_borrador.CodigoUnico</small>
        }
    </div>
</div>

<div class="nm-tabs">
    @foreach (var t in _tabs)
    {
        <button class="nm-tab @(t == _tabSel ? "sel" : "")" @onclick="() => _tabSel = t">
            @t
            @if (t == "Notas")
            {
                <span class="nm-tab-badge">@_conteo.Definitivas/@_conteo.Parciales</span>
            }
        </button>
    }
</div>

@* =================== TAB DILIGENCIAMIENTO =================== *@
@if (_tabSel == "Diligenciamiento")
{
    if (HistoriaClinicaId is null || PacienteId is null)
    {
        <div class="ase-card nm-panel"><div class="ase-empty">Selecciona o inicia una historia para registrar notas.</div></div>
    }
    else
    {
        <div class="ase-card nm-panel">
            @if (_error is not null) { <div class="ase-alert">@_error</div> }
            @if (_ok is not null) { <div class="ase-ok">@_ok</div> }

            <div class="nm-row">
                <div class="ase-f">
                    <label>Seleccionar Fecha Nota</label>
                    <input type="date" class="form-control form-control-sm" @bind="_borrador.FechaNota" />
                </div>
                <div class="ase-f nm-col-2">
                    <label>Nombre Paciente</label>
                    <input class="form-control form-control-sm asg-ro" readonly value="@NombrePacienteCtx" />
                </div>
                <div class="ase-f">
                    <label>Documento Paciente</label>
                    <input class="form-control form-control-sm asg-ro mono" readonly value="@DocumentoPacienteCtx" />
                </div>
            </div>
            <div class="nm-row">
                <div class="ase-f">
                    <label>Codigo Unico Nota</label>
                    <input class="form-control form-control-sm asg-ro mono" readonly value="@_borrador.CodigoUnico" />
                </div>
                <div class="ase-f">
                    <label>Hora Nota</label>
                    <select class="form-select form-select-sm" @bind="_borrador.HoraNotaStr">
                        <option value="">Selecciona...</option>
                        @for (int h = 6; h <= 20; h++)
                        {
                            <option value="@($"{h:00}:00")">@($"{h:00}:00")</option>
                            <option value="@($"{h:00}:30")">@($"{h:00}:30")</option>
                        }
                    </select>
                </div>
                <div class="ase-f">
                    <label>Criticidad</label>
                    <select class="form-select form-select-sm" @bind="_borrador.Criticidad">
                        <option value="Estable">Estable</option>
                        <option value="Vigilancia">Vigilancia</option>
                        <option value="Alerta">Alerta</option>
                        <option value="Critico">Critico</option>
                    </select>
                </div>
                <div class="ase-f">
                    <label>Sesion No</label>
                    <input class="form-control form-control-sm mono" @bind="_borrador.SessionNoStr" />
                </div>
            </div>
            <div class="ase-f ase-f-wide nm-row-full">
                <label>Contenido de la Nota</label>
                <textarea class="form-control form-control-sm" rows="12" @bind="_borrador.Contenido"
                          placeholder="Describe la atencion, hallazgos, plan, recomendaciones..."></textarea>
            </div>
            <div class="nm-acciones-center">
                <button class="btn btn-outline-secondary" @onclick="() => GuardarAsync(false)" disabled="@_busy">
                    @(_busy && !_guardandoDef ? "Guardando..." : "Guardado Parcial")
                </button>
                <button class="btn btn-primary nm-btn-gradient" @onclick="() => GuardarAsync(true)" disabled="@_busy">
                    @(_busy && _guardandoDef ? "Guardando..." : "Guardado Definitivo")
                </button>
                <button class="btn btn-outline-danger" @onclick="NuevoBorrador" disabled="@_busy">Cancelar</button>
            </div>
        </div>
    }
}

@* =================== TAB NOTAS (antes "Notas Completadas") =================== *@
else if (_tabSel == "Notas")
{
    <div class="ase-card nm-panel">
        <div class="nm-row-inline">
            <span class="nm-counts">
                <strong>@_conteo.Definitivas</strong> definitivas
                <span class="nm-sep">/</span>
                <strong>@_conteo.Parciales</strong> parciales
            </span>
            <span class="ms-auto"></span>
            <button class="btn btn-outline-primary btn-sm" @onclick="RefrescarNotas" disabled="@_busy">&#128260; Refrescar</button>
        </div>

        @if (_notas.Count == 0)
        {
            <div class="ase-empty">Aun no hay notas registradas para esta historia.</div>
        }
        else
        {
            <div class="nm-cards-grid">
                @foreach (var n in _notas)
                {
                    <div class="nm-card-mini @CritClass(n.Criticidad)">
                        <div class="nm-card-h">
                            <span class="nm-card-fecha">@n.FechaNota.ToString("dd/MM/yyyy") @(n.HoraNota is TimeOnly h ? h.ToString("HH:mm") : "")</span>
                            @if (n.Estado == "Definitivo")
                            {
                                <span class="nm-pill nm-pill-def">DEFINITIVO</span>
                            }
                            else
                            {
                                <span class="nm-pill nm-pill-par">PARCIAL</span>
                            }
                        </div>
                        <div class="nm-card-cod">@n.CodigoUnico @if (n.SessionNo is int s) { <span class="nm-sess">Sesion @s</span> }</div>
                        <div class="nm-card-body">@(n.Contenido.Length > 220 ? n.Contenido.Substring(0,220) + "..." : n.Contenido)</div>
                        <div class="nm-card-f">
                            <small>@n.EspecialistaNombre</small>
                            <small class="nm-card-crit">@n.Criticidad</small>
                        </div>
                        @if (n.Estado == "Parcial")
                        {
                            <button class="btn btn-link btn-sm nm-card-edit" @onclick="() => CargarEnBorrador(n)">Editar</button>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@* =================== TAB SEGUIMIENTO (KANBAN) =================== *@
else if (_tabSel == "Seguimiento")
{
    <div class="ase-card nm-panel">
        <div class="nm-row-inline">
            <strong>Seguimiento por criticidad</strong>
            <span class="ms-auto"></span>
            <small class="text-muted">Cambia el dropdown de cada nota para moverla de columna.</small>
        </div>
        <div class="nm-kanban">
            @foreach (var col in _kanbanCols)
            {
                var items = _notas.Where(n => n.Criticidad == col).ToList();
                <div class="nm-kanban-col">
                    <div class="nm-kanban-h @CritClass(col)">
                        <span>@col</span>
                        <span class="nm-kanban-count">@items.Count</span>
                    </div>
                    <div class="nm-kanban-body">
                        @if (items.Count == 0)
                        {
                            <div class="nm-kanban-empty">Sin notas</div>
                        }
                        @foreach (var n in items)
                        {
                            <div class="nm-kanban-card @CritClass(n.Criticidad)">
                                <div class="nm-card-fecha">@n.FechaNota.ToString("dd/MM/yyyy")</div>
                                <div class="nm-kanban-prev">@(n.Contenido.Length > 90 ? n.Contenido.Substring(0,90) + "..." : n.Contenido)</div>
                                <select class="form-select form-select-sm" value="@n.Criticidad"
                                        @onchange="@(e => MoverEnKanban(n, e.Value?.ToString()))">
                                    @foreach (var c in _kanbanCols) { <option value="@c">@c</option> }
                                </select>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@* =================== TAB FIRMA =================== *@
else if (_tabSel == "Firma")
{
    <div class="ase-card nm-panel nm-firma">
        <h6 class="nm-firma-h">Ingrese Firma Paciente:</h6>
        <div class="nm-firma-canvas">
            <div class="nm-firma-placeholder">Area de firma 450 x 175 (pendiente de cableado JS).</div>
        </div>
        <div class="nm-firma-acciones">
            <button class="btn btn-primary nm-btn-gradient" disabled>&#128190; Guardar</button>
            <button class="btn btn-outline-danger" disabled>Cancelar</button>
        </div>
    </div>
}

@* =================== TAB DOCUMENTOS EXTERNOS =================== *@
else if (_tabSel == "Documentos Externos")
{
    <div class="ase-card nm-panel">
        @if (_borrador?.Id is null)
        {
            <div class="ase-empty">Para subir documentos primero guarda la nota como parcial o definitiva.</div>
        }
        else
        {
            <div class="nm-row-inline">
                <label class="nm-lbl-inline">Categoria:</label>
                <select class="form-select form-select-sm nm-w-280" @bind="_docCategoria">
                    <option value="">Seleccione...</option>
                    <option>Lista de firmas</option>
                    <option>Escala</option>
                    <option>Formato</option>
                    <option>Examen</option>
                    <option>Otros</option>
                </select>
            </div>
            <div class="nm-row-inline">
                <label class="nm-lbl-inline">Tipo de Terapia:</label>
                <select class="form-select form-select-sm nm-w-280" @bind="_docTipoTerapia">
                    <option value="">Selecciona...</option>
                    <option>FISIOTERAPEUTA</option>
                    <option>FONOAUDIOLOGIA</option>
                    <option>TERAPIAOCUPACIONAL</option>
                    <option>TERAPIARESPIRATORIA</option>
                    <option>NEBULIZACION</option>
                    <option>TRAQUEOSTOMIA</option>
                </select>
                <label class="nm-lbl-inline">Mes:</label>
                <select class="form-select form-select-sm nm-w-150" @bind="_docMes">
                    <option value="">Selecciona...</option>
                    @foreach (var m in new[] { "ENERO","FEBRERO","MARZO","ABRIL","MAYO","JUNIO","JULIO","AGOSTO","SEPTIEMBRE","OCTUBRE","NOVIEMBRE","DICIEMBRE" })
                    {
                        <option>@m</option>
                    }
                </select>
            </div>
            <div class="nm-doc-grid">
                <div class="nm-doc-card">
                    <div class="nm-doc-h">Subir archivo</div>
                    <textarea class="form-control form-control-sm" rows="3" placeholder="Anotaciones del archivo..." @bind="_docAnotaciones"></textarea>
                    <hr />
                    <InputFile OnChange="OnDocSeleccionado" class="form-control form-control-sm" accept=".pdf,.png,.jpg,.jpeg,.webp,.docx,.xlsx" />
                    @if (_docSubiendo) { <div class="text-muted small">Subiendo...</div> }
                </div>
                <div class="nm-doc-card nm-doc-list">
                    <div class="nm-doc-h">Archivos adjuntos (@_documentos.Count)</div>
                    @if (_documentos.Count == 0)
                    {
                        <div class="nm-doc-empty">Sin archivos.</div>
                    }
                    else
                    {
                        @foreach (var d in _documentos)
                        {
                            <div class="nm-doc-row">
                                <a href="@d.RutaArchivo" target="_blank" class="nm-doc-nm">&#128206; @d.NombreOriginal</a>
                                <div class="nm-doc-meta">
                                    @if (!string.IsNullOrEmpty(d.Categoria)) { <span class="nm-doc-badge">@d.Categoria</span> }
                                    @if (!string.IsNullOrEmpty(d.TipoTerapia)) { <span class="nm-doc-badge">@d.TipoTerapia</span> }
                                    @if (!string.IsNullOrEmpty(d.Mes)) { <span class="nm-doc-badge">@d.Mes</span> }
                                    <small>@FormatBytes(d.Tamano)</small>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(d.Anotaciones)) { <small class="text-muted">@d.Anotaciones</small> }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
}

@* =================== TAB VER HISTORIAL (notas anteriores del paciente) =================== *@
else if (_tabSel == "Ver Historial")
{
    <div class="ase-card nm-panel">
        <div class="nm-row-inline">
            <strong>Notas previas de @NombrePacienteCtx</strong>
            <span class="ms-auto"></span>
            <button class="btn btn-outline-primary btn-sm" @onclick="RefrescarHistorial" disabled="@_busy">&#128260; Refrescar</button>
        </div>
        @if (_historialPaciente.Count == 0)
        {
            <div class="ase-empty">No hay notas previas registradas para este paciente.</div>
        }
        else
        {
            <div class="nm-cards-grid">
                @foreach (var n in _historialPaciente)
                {
                    <div class="nm-card-mini @CritClass(n.Criticidad)">
                        <div class="nm-card-h">
                            <span class="nm-card-fecha">@n.FechaNota.ToString("dd/MM/yyyy") @(n.HoraNota is TimeOnly h ? h.ToString("HH:mm") : "")</span>
                            @if (n.Estado == "Definitivo")
                            {
                                <span class="nm-pill nm-pill-def">DEFINITIVO</span>
                            }
                            else
                            {
                                <span class="nm-pill nm-pill-par">PARCIAL</span>
                            }
                        </div>
                        <div class="nm-card-cod">@n.CodigoUnico @if (n.SessionNo is int s) { <span class="nm-sess">Sesion @s</span> }</div>
                        @if (!string.IsNullOrWhiteSpace(n.FormatoCodigo))
                        {
                            <div class="nm-card-fmt">@n.FormatoNombre (@n.FormatoCodigo)</div>
                        }
                        <div class="nm-card-body">@n.ContenidoPreview</div>
                        <div class="nm-card-f">
                            <small><strong>@n.EspecialistaNombre</strong></small>
                            <small class="nm-card-crit">@n.Criticidad</small>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

<style>
    .nm-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 18px; background: rgba(255,255,255,.7); border: 1px solid #e2e8f0; border-radius: 12px; margin-bottom: 16px; }
    .nm-title { margin: 0; font-size: 22px; font-weight: 700; color: #2c3e50; }
    .nm-subtitle { font-size: 11px; color: #7f8c8d; text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }
    .nm-btn-gradient { background: linear-gradient(135deg, #4a90e2, #00d2ff); border: none; color: #fff; padding: 8px 18px; border-radius: 8px; font-weight: 600; }

    .nm-tabs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
    .nm-tab { padding: 10px 18px; background: rgba(255,255,255,.7); border: 1px solid rgba(255,255,255,.3); border-radius: 12px; color: #7f8c8d; font-size: 13px; font-weight: 500; cursor: pointer; transition: all .3s; display:inline-flex; align-items:center; gap:8px; }
    .nm-tab:hover { background: rgba(255,255,255,.9); transform: translateY(-1px); }
    .nm-tab.sel { background: linear-gradient(135deg, #4a90e2, #00d2ff); color: #fff; border-color: transparent; }
    .nm-tab-badge { background:rgba(255,255,255,.25); color:#fff; padding:1px 8px; border-radius:999px; font-size:11px; font-weight:700; }
    .nm-tab:not(.sel) .nm-tab-badge { background:#e2e8f0; color:#1565c0; }

    .nm-panel { padding: 22px; }
    .nm-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 18px; }
    .nm-col-2 { grid-column: span 2; }
    .nm-row label { font-size: 11px; color: #7f8c8d; text-transform: uppercase; letter-spacing: .5px; font-weight: 600; }
    .nm-row-full { margin-bottom: 18px; }
    .nm-row-full > label { display: block; font-size: 11px; color: #7f8c8d; text-transform: uppercase; letter-spacing: .5px; font-weight: 600; margin-bottom: 6px; }
    .nm-acciones-center { display: flex; justify-content: center; gap: 12px; margin-top: 18px; }

    .nm-row-inline { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
    .nm-lbl-inline { font-size: 11px; color: #7f8c8d; font-weight: 600; text-transform: uppercase; margin: 0; }
    .nm-sep { color: #cbd5e1; margin: 0 6px; }
    .nm-w-150 { max-width: 150px; }
    .nm-w-280 { min-width: 220px; max-width: 320px; }
    .nm-counts { font-size:13px; color:#0f172a; }
    .nm-counts strong { font-size:18px; color:#1565c0; }

    /* Cards reusables para Notas y Ver Historial */
    .nm-cards-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:14px; }
    .nm-card-mini { background:#fff; border:1px solid #e2e8f0; border-left:4px solid #cbd5e1; border-radius:10px; padding:12px 14px; position:relative; }
    .nm-card-h { display:flex; justify-content:space-between; align-items:center; margin-bottom:4px; }
    .nm-card-fecha { font-size:12px; font-weight:700; color:#0f172a; }
    .nm-card-cod { font-family:'JetBrains Mono','Consolas',monospace; font-size:11px; color:#64748b; margin-bottom:6px; }
    .nm-sess { background:#eff6ff; color:#1565c0; padding:1px 6px; border-radius:4px; margin-left:6px; }
    .nm-card-fmt { font-size:11px; color:#1565c0; font-style:italic; margin-bottom:6px; }
    .nm-card-body { font-size:12.5px; color:#334155; line-height:1.4; max-height:5.6em; overflow:hidden; }
    .nm-card-f { display:flex; justify-content:space-between; margin-top:8px; padding-top:6px; border-top:1px solid #f1f5f9; }
    .nm-card-crit { font-weight:700; color:#475569; }
    .nm-card-edit { position:absolute; top:6px; right:6px; padding:0 6px; font-size:11px; }

    /* Pills de estado */
    .nm-pill { font-size:10px; font-weight:800; padding:2px 8px; border-radius:999px; letter-spacing:.04em; }
    .nm-pill-def { background:#dcfce7; color:#166534; }
    .nm-pill-par { background:#fef3c7; color:#92400e; }

    /* Colores por criticidad (borde izquierdo) */
    .nm-crit-Estable { border-left-color:#10b981; }
    .nm-crit-Vigilancia { border-left-color:#f59e0b; }
    .nm-crit-Alerta { border-left-color:#f97316; }
    .nm-crit-Critico { border-left-color:#dc2626; }

    /* Kanban */
    .nm-kanban { display:grid; grid-template-columns:repeat(4, 1fr); gap:14px; }
    .nm-kanban-col { background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; display:flex; flex-direction:column; min-height:300px; }
    .nm-kanban-h { padding:10px 12px; background:#fff; border-bottom:1px solid #e2e8f0; border-radius:10px 10px 0 0; display:flex; justify-content:space-between; align-items:center; font-weight:700; font-size:13px; border-left:4px solid #cbd5e1; }
    .nm-kanban-h.nm-crit-Estable { border-left-color:#10b981; color:#065f46; }
    .nm-kanban-h.nm-crit-Vigilancia { border-left-color:#f59e0b; color:#92400e; }
    .nm-kanban-h.nm-crit-Alerta { border-left-color:#f97316; color:#9a3412; }
    .nm-kanban-h.nm-crit-Critico { border-left-color:#dc2626; color:#7f1d1d; }
    .nm-kanban-count { background:#1565c0; color:#fff; font-size:11px; padding:1px 8px; border-radius:999px; }
    .nm-kanban-body { padding:10px; display:flex; flex-direction:column; gap:8px; flex:1; }
    .nm-kanban-card { background:#fff; border-radius:8px; padding:10px; border:1px solid #e2e8f0; border-left:3px solid #cbd5e1; }
    .nm-kanban-prev { font-size:11.5px; color:#475569; margin:4px 0 6px; }
    .nm-kanban-empty { font-size:11px; color:#94a3b8; font-style:italic; text-align:center; padding:12px; }

    /* Documentos */
    .nm-doc-grid { display:grid; grid-template-columns:280px 1fr; gap:14px; margin-top:16px; }
    .nm-doc-card { background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:14px; }
    .nm-doc-h { font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.5px; margin-bottom:10px; }
    .nm-doc-empty { color:#94a3b8; font-style:italic; padding:20px 0; text-align:center; }
    .nm-doc-list { max-height:480px; overflow:auto; }
    .nm-doc-row { padding:8px 0; border-bottom:1px solid #f1f5f9; }
    .nm-doc-nm { display:block; font-weight:700; color:#1565c0; text-decoration:none; font-size:13px; margin-bottom:2px; }
    .nm-doc-meta { display:flex; gap:6px; flex-wrap:wrap; align-items:center; }
    .nm-doc-badge { font-size:10px; background:#eff6ff; color:#1565c0; padding:2px 7px; border-radius:999px; font-weight:600; }

    .nm-firma { text-align:center; }
    .nm-firma-h { text-align:left; font-weight:700; color:#0f172a; margin-bottom:12px; }
    .nm-firma-canvas { border:2px solid #cbd5e1; border-radius:8px; background:#fff; padding:60px 0; max-width:480px; margin:0 auto; }
    .nm-firma-placeholder { color:#94a3b8; font-style:italic; }
    .nm-firma-acciones { display:flex; justify-content:space-between; margin-top:20px; max-width:480px; margin:auto; }
    .asg-ro { background:#f1f5f9; }
</style>

@code {
    [Parameter] public string? NombrePacienteCtx { get; set; }
    [Parameter] public string? DocumentoPacienteCtx { get; set; }
    [Parameter] public int? SessionNoCtx { get; set; }
    [Parameter] public Guid? AsignacionTurnoIdCtx { get; set; }
    [Parameter] public Guid? HistoriaClinicaId { get; set; }
    [Parameter] public Guid? PacienteId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private readonly string[] _tabs = new[] {
        "Notas", "Diligenciamiento", "Firma", "Seguimiento", "Documentos Externos", "Ver Historial"
    };
    private readonly string[] _kanbanCols = new[] { "Estable", "Vigilancia", "Alerta", "Critico" };
    private string _tabSel = "Diligenciamiento";

    private NotaBorrador _borrador = new();
    private NotaConteoDto _conteo = new(0, 0);
    private List<NotaMedicaDto> _notas = new();
    private List<NotaMedicaTarjetaDto> _historialPaciente = new();
    private List<NotaDocumentoDto> _documentos = new();
    private bool _busy;
    private bool _guardandoDef;
    private bool _docSubiendo;
    private string? _error;
    private string? _ok;

    private string _docCategoria = "";
    private string _docTipoTerapia = "";
    private string _docMes = "";
    private string _docAnotaciones = "";

    private Guid? _ultimoHcId;

    protected override async Task OnParametersSetAsync()
    {
        if (HistoriaClinicaId != _ultimoHcId)
        {
            _ultimoHcId = HistoriaClinicaId;
            NuevoBorrador();
            await Refrescar();
        }
    }

    private async Task Refrescar()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        _busy = true; _error = null;
        try
        {
            _conteo = await NotaSvc.ContarPorHistoriaAsync(hid);
            _notas = (await NotaSvc.ListarPorHistoriaAsync(hid)).ToList();
            if (PacienteId is Guid pid)
            {
                _historialPaciente = (await NotaSvc.ListarHistorialPacienteAsync(pid)).ToList();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task RefrescarNotas() => await Refrescar();
    private async Task RefrescarHistorial() => await Refrescar();

    private void NuevoBorrador()
    {
        _borrador = new NotaBorrador
        {
            FechaNota = DateOnly.FromDateTime(DateTime.Today),
            SessionNoStr = SessionNoCtx?.ToString() ?? "",
            CodigoUnico = "",
            Criticidad = "Estable",
            Contenido = ""
        };
        _error = _ok = null;
    }

    private void CargarEnBorrador(NotaMedicaDto n)
    {
        _borrador = new NotaBorrador
        {
            Id = n.Id,
            FechaNota = n.FechaNota,
            HoraNotaStr = n.HoraNota is TimeOnly t ? t.ToString("HH:mm") : "",
            SessionNoStr = n.SessionNo?.ToString() ?? "",
            CodigoUnico = n.CodigoUnico,
            Criticidad = n.Criticidad,
            Contenido = n.Contenido
        };
        _tabSel = "Diligenciamiento";
        _ok = null;
        _error = null;
    }

    private async Task GuardarAsync(bool definitivo)
    {
        if (HistoriaClinicaId is not Guid hid || PacienteId is not Guid pid)
        {
            _error = "Falta paciente o historia."; return;
        }
        if (string.IsNullOrWhiteSpace(_borrador.Contenido))
        {
            _error = "El contenido es obligatorio."; return;
        }

        _busy = true; _guardandoDef = definitivo; _error = _ok = null;
        try
        {
            TimeOnly? hora = TimeOnly.TryParse(_borrador.HoraNotaStr, out var hh) ? hh : null;
            int? sesion = int.TryParse(_borrador.SessionNoStr, out var ss) ? ss : (int?)SessionNoCtx;
            var req = new GuardarNotaRequest(
                _borrador.Id, hid, pid, AsignacionTurnoIdCtx, sesion,
                _borrador.FechaNota ?? DateOnly.FromDateTime(DateTime.Today),
                hora, _borrador.Contenido!,
                definitivo ? "Definitivo" : "Parcial",
                _borrador.Criticidad ?? "Estable",
                null);
            var saved = await NotaSvc.GuardarAsync(req, Guid.Empty);
            _ok = definitivo ? "Nota guardada como DEFINITIVA." : "Nota guardada como PARCIAL.";
            _borrador.Id = saved.Id;
            _borrador.CodigoUnico = saved.CodigoUnico;
            await Refrescar();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _guardandoDef = false; }
    }

    private async Task MoverEnKanban(NotaMedicaDto n, string? nuevaCritStr)
    {
        if (string.IsNullOrWhiteSpace(nuevaCritStr) || nuevaCritStr == n.Criticidad) { return; }
        await NotaSvc.ActualizarCriticidadAsync(n.Id, nuevaCritStr, Guid.Empty);
        var idx = _notas.FindIndex(x => x.Id == n.Id);
        if (idx >= 0) { _notas[idx] = n with { Criticidad = nuevaCritStr }; }
    }

    private async Task OnDocSeleccionado(InputFileChangeEventArgs e)
    {
        if (_borrador.Id is not Guid notaId) { _error = "Guarda la nota primero."; return; }
        _docSubiendo = true; _error = null;
        try
        {
            var f = e.File;
            var ext = Path.GetExtension(f.Name);
            var nombreEnDisco = $"{Guid.NewGuid()}{ext}";
            var dir = Path.Combine(Env.WebRootPath, "uploads", "notas");
            Directory.CreateDirectory(dir);
            var rutaDisco = Path.Combine(dir, nombreEnDisco);
            await using (var fs = File.Create(rutaDisco))
            await using (var rs = f.OpenReadStream(20L * 1024 * 1024))
            {
                await rs.CopyToAsync(fs);
            }
            var rutaWeb = $"/uploads/notas/{nombreEnDisco}";

            var d = await NotaSvc.AdjuntarDocumentoAsync(new AdjuntarDocumentoRequest(
                notaId, f.Name, rutaWeb, f.ContentType, f.Size,
                _docCategoria, _docTipoTerapia, _docMes, _docAnotaciones), Guid.Empty);
            _documentos.Insert(0, d);
            _docAnotaciones = "";
        }
        catch (Exception ex) { _error = "No se pudo subir el archivo: " + ex.Message; }
        finally { _docSubiendo = false; }
    }

    private static string CritClass(string crit) => $"nm-crit-{crit}";

    private static string FormatBytes(long b)
    {
        if (b < 1024) return $"{b} B";
        if (b < 1024 * 1024) return $"{b / 1024} KB";
        return $"{b / (1024 * 1024)} MB";
    }

    private sealed class NotaBorrador
    {
        public Guid? Id { get; set; }
        public DateOnly? FechaNota { get; set; }
        public string HoraNotaStr { get; set; } = "";
        public string SessionNoStr { get; set; } = "";
        public string CodigoUnico { get; set; } = "";
        public string Criticidad { get; set; } = "Estable";
        public string? Contenido { get; set; } = "";
    }
}
