@using Visal.Application.Tenancy
@using Visal.Domain.Enums
@inject IRemisionService RemSvc
@inject ICatalogoServicioService CatSvc
@inject IJSRuntime JS

@*
   Pestana "Remisiones" de la HC. Autocomplete unico sobre
   CatalogoServicioReferencia con Tipo=ServicioGeneral. El profesional
   escribe 2+ letras en Descripcion, elige del catalogo (codigo + nombre)
   y define Cantidad + Motivo. Persiste atado a HistoriaClinicaId.
*@

<div class="or-bar">
    <div class="or-bar-left">
        <label>Orden de Remision Numero:</label>
        <span class="or-bar-count">@_items.Count item(s)</span>
    </div>
    <div class="or-bar-right">
        <button class="btn btn-outline-primary btn-sm" title="Imprimir orden"
                disabled="@(HistoriaClinicaId is null || _items.Count == 0)"
                @onclick="ImprimirAsync">&#128424; Imprimir</button>
    </div>
</div>

@if (HistoriaClinicaId is null)
{
    <div class="or-card or-empty-hc">
        Selecciona o inicia una historia para registrar remisiones.
    </div>
}
else
{
    <div class="or-card">
        <div class="or-row">
            <div class="or-f or-c-3">
                <label>Codigo</label>
                <input class="form-control form-control-sm"
                       placeholder="Opcional"
                       @bind="_borrador.Codigo" @bind:event="oninput" />
            </div>
            <div class="or-f or-c-9 or-autocomplete">
                <label>Descripcion</label>
                <input class="form-control form-control-sm"
                       placeholder="Escribe para buscar en el catalogo de servicios (min 2 caracteres)..."
                       @bind="_borrador.Descripcion"
                       @bind:event="oninput"
                       @onkeyup="BuscarSugerenciasAsync"
                       @onblur="() => _mostrarSugerencias = false" />
                @if (_mostrarSugerencias && _sugerencias.Count > 0)
                {
                    <div class="or-sug-list">
                        @foreach (var s in _sugerencias)
                        {
                            <div class="or-sug-item" @onmousedown="() => SeleccionarSugerencia(s)">
                                <span class="or-sug-cod">@s.Codigo</span>
                                <span class="or-sug-nom">@s.Nombre</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        <div class="or-row">
            <div class="or-f or-c-3">
                <label>Cantidad</label>
                <input class="form-control form-control-sm"
                       placeholder="Ej: 1, 3 sesiones, 10 unidades"
                       @bind="_borrador.Cantidad" @bind:event="oninput" />
            </div>
            <div class="or-f or-c-9">
                <label>Motivo / Observaciones</label>
                <textarea class="form-control form-control-sm" rows="2"
                          placeholder="Motivo clinico de la remision..."
                          @bind="_borrador.Motivo" @bind:event="oninput"></textarea>
            </div>
        </div>
        <div class="or-row or-row-action">
            <button class="btn btn-primary btn-sm"
                    @onclick="AgregarAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_borrador.Descripcion) || _agregando)">
                @(_agregando ? "Guardando..." : "+ Agregar remision")
            </button>
        </div>

        <div class="or-grid-wrap">
            <table class="table table-sm or-tbl">
                <thead>
                    <tr>
                        <th style="width:40px">#</th>
                        <th style="width:110px">Codigo</th>
                        <th>Descripcion</th>
                        <th style="width:120px">Cantidad</th>
                        <th>Motivo</th>
                        <th class="text-center" style="width:50px"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_items.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted or-empty-row">Sin remisiones agregadas.</td></tr>
                    }
                    else
                    {
                        @foreach (var it in _items)
                        {
                            <tr>
                                <td class="text-center">@it.Orden</td>
                                <td class="mono">@(it.EspecialidadCodigo ?? "-")</td>
                                <td>@it.EspecialidadNombre</td>
                                <td>@(it.Cantidad ?? "-")</td>
                                <td>@(it.Motivo ?? "-")</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="() => EliminarAsync(it)"
                                            title="Quitar">&#128465;</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<style>
    .or-bar { display:flex; justify-content:space-between; align-items:center; padding:8px 12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; margin-bottom:12px; gap:10px; flex-wrap:wrap; }
    .or-bar-left { display:flex; align-items:center; gap:10px; font-size:13px; font-weight:700; color:#0f172a; }
    .or-bar-count { background:#1565c0; color:#fff; padding:2px 10px; border-radius:999px; font-size:11px; font-weight:700; }
    .or-card { border:1px solid #e2e8f0; border-radius:8px; padding:16px; background:#fff; }
    .or-empty-hc { color:#64748b; text-align:center; padding:30px; font-style:italic; }
    .or-row { display:grid; grid-template-columns:repeat(12, 1fr); gap:12px; margin-bottom:12px; align-items:end; }
    .or-row-action { display:flex; justify-content:flex-end; }
    .or-f label { font-size:11px; font-weight:700; color:#334155; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:4px; display:block; }
    .or-c-3 { grid-column: span 3; }
    .or-c-9 { grid-column: span 9; }
    .or-autocomplete { position: relative; }
    .or-sug-list { position: absolute; top: 100%; left: 0; right: 0; background:#fff; border:1px solid #cbd5e1; border-radius:6px; box-shadow:0 6px 18px rgba(0,0,0,0.12); max-height: 240px; overflow-y:auto; z-index: 30; margin-top: 2px; }
    .or-sug-item { padding: 6px 10px; cursor: pointer; display: grid; grid-template-columns: 100px 1fr; gap: 8px; align-items: baseline; font-size: 12px; border-bottom: 1px solid #f1f5f9; }
    .or-sug-item:last-child { border-bottom: none; }
    .or-sug-item:hover { background: #eff6ff; }
    .or-sug-cod { font-family: 'JetBrains Mono','Consolas',monospace; color:#1565c0; font-weight: 600; }
    .or-sug-nom { color:#0f172a; }
    .or-grid-wrap { margin-top:14px; border:1px solid #e2e8f0; border-radius:6px; overflow:auto; }
    .or-tbl { margin:0; font-size:12.5px; }
    .or-tbl thead th { background:#1565c0; color:#fff; padding:8px 10px; font-size:11px; font-weight:700; text-transform:uppercase; }
    .or-tbl td { padding:8px 10px; border-bottom:1px solid #f1f5f9; vertical-align:middle; }
    .or-empty-row { padding:30px !important; font-style:italic; }
    .mono { font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace; }
</style>

@code {
    [Parameter] public Guid? HistoriaClinicaId { get; set; }
    [Parameter] public EventCallback<int> OnCountChanged { get; set; }
    /// <summary>Refresca el FormViewer del tab Historial tras Agregar/Eliminar.</summary>
    [Parameter] public EventCallback OnItemsChanged { get; set; }

    private async Task NotifyItemsChanged()
    {
        if (OnItemsChanged.HasDelegate) { await OnItemsChanged.InvokeAsync(); }
    }

    private Guid? _ultimoIdCargado;
    private List<RemisionItemDto> _items = new();
    private bool _agregando;

    private Borrador _borrador = new();

    // Autocomplete contra el catalogo de Servicios Generales.
    private List<CatalogoServicioDto> _sugerencias = new();
    private bool _mostrarSugerencias;
    // Serializa las queries al DbContext scoped — en Blazor Server dos
    // busquedas concurrentes rompen EF Core con "second operation started".
    private readonly SemaphoreSlim _busquedaLock = new(1, 1);
    // Contador monotono: cada tecla lo incrementa. Si al terminar la query
    // el contador cambio, descartamos el resultado (llego uno mas nuevo).
    private int _busquedaSeq;

    protected override async Task OnParametersSetAsync()
    {
        if (HistoriaClinicaId != _ultimoIdCargado)
        {
            _ultimoIdCargado = HistoriaClinicaId;
            _borrador = new();
            _sugerencias.Clear();
            _mostrarSugerencias = false;
            await CargarItemsAsync();
        }
    }

    private async Task CargarItemsAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { _items = new(); return; }
        _items = (await RemSvc.ListarPorHistoriaAsync(hid)).ToList();
        await NotifyCount();
    }

    private async Task NotifyCount()
    {
        if (OnCountChanged.HasDelegate) { await OnCountChanged.InvokeAsync(_items.Count); }
    }

    /// <summary>
    /// Busca contra el catalogo de servicios generales
    /// (CatalogoServicioReferencia con Tipo=ServicioGeneral) en cuanto el
    /// usuario escribe 2 o mas caracteres. Debounce 220ms + semaforo + secuencia
    /// para evitar "second operation started" con teclas rapidas.
    /// </summary>
    private async Task BuscarSugerenciasAsync()
    {
        var q = _borrador.Descripcion;
        if (string.IsNullOrWhiteSpace(q) || q.Length < 2)
        {
            _sugerencias.Clear();
            _mostrarSugerencias = false;
            return;
        }
        var mySeq = ++_busquedaSeq;
        try
        {
            await Task.Delay(220);
            if (mySeq != _busquedaSeq) { return; }
            await _busquedaLock.WaitAsync();
            try
            {
                if (mySeq != _busquedaSeq) { return; }
                var (rows, _) = await CatSvc.SearchAsync(TipoCatalogoServicio.ServicioGeneral, q, 0, 15);
                if (mySeq != _busquedaSeq) { return; }
                _sugerencias = rows.Where(r => r.Activo).ToList();
                _mostrarSugerencias = _sugerencias.Count > 0;
                StateHasChanged();
            }
            finally { _busquedaLock.Release(); }
        }
        catch (Exception) { /* silenciar: proxima tecla lo reintenta */ }
    }

    private void SeleccionarSugerencia(CatalogoServicioDto sug)
    {
        _borrador.Codigo = sug.Codigo;
        _borrador.Descripcion = sug.Nombre;
        _sugerencias.Clear();
        _mostrarSugerencias = false;
    }

    private async Task AgregarAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        if (string.IsNullOrWhiteSpace(_borrador.Descripcion)) { return; }
        _agregando = true;
        try
        {
            var creado = await RemSvc.AgregarAsync(hid, new AgregarRemisionRequest(
                _borrador.Codigo,
                _borrador.Descripcion!,
                _borrador.Cantidad,
                _borrador.Motivo), Guid.Empty);
            _items.Add(creado);
            await NotifyCount();
            await NotifyItemsChanged();
            _borrador = new();
            _sugerencias.Clear();
            _mostrarSugerencias = false;
        }
        finally { _agregando = false; }
    }

    private async Task EliminarAsync(RemisionItemDto it)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Quitar la remision \"{Truncate(it.EspecialidadNombre, 40)}\"?");
        if (!ok) { return; }
        await RemSvc.EliminarAsync(it.Id, Guid.Empty);
        _items.RemoveAll(x => x.Id == it.Id);
        await NotifyCount();
        await NotifyItemsChanged();
    }

    private async Task ImprimirAsync()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        await JS.InvokeVoidAsync("open", $"/orden-doc/{hid}/REMISIONES", "_blank");
    }

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s.Substring(0, max) + "...";

    private sealed class Borrador
    {
        public string? Codigo { get; set; }
        public string? Descripcion { get; set; }
        public string? Cantidad { get; set; }
        public string? Motivo { get; set; }
    }
}
