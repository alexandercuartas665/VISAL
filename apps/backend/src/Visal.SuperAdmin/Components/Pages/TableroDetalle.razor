    private List<TaskBoardMemberDto> _boardMembers = new();

    // Drag&drop
    private Guid? _draggingCardId;
    private Guid? _dragOverColumnId;

    // Modal card
    private bool _cardModalOpen;
    private TaskCardDetailDto? _cardDetail;
    private string _editCardTitle = "";
    private string? _editCardDescription;
    private string? _editCardColor;
    private DateTime? _editCardDueDate;
    // Trello-like modal state (title/description inline edit + popovers)
    private bool _editingTitle;
    private string _editTitle = "";
    private bool _editingDesc;
    private string _editDescription = "";
    private bool _showMembersPop, _showTagsPop, _showDatePop, _showColorPop, _showMovePop, _showChecklistAdd, _showAttachAdd;
    private string _newTagName = "";
    private string _newTagColor = "#3b82f6";
    private List<TaskCardTagDto> _boardTags = new();
    // Paleta reusable para el color del titulo de la tarjeta
    private static readonly string[] _colorPalette = new[]
    {
        "#ef4444", "#f97316", "#f59e0b", "#22c55e", "#10b981",
        "#06b6d4", "#3b82f6", "#6366f1", "#8b5cf6", "#a855f7",
        "#ec4899", "#475569",
    };
    private string _newChecklistText = "";
    private string _newCommentText = "";
    private string _newAttUrl = "";
    private string _newAttName = "";

    // Modal Nueva tarjeta
    private bool _newCardOpen;
    private Guid _newCardColumnId;
    private string _newCardTitle = "";
    private string? _newCardDescription;

    // Modal columna
    private bool _newColOpen;
    private string _newColName = "";

    // Modal editar tablero
    private bool _editBoardOpen;
    private string _editBoardName = "";
    private string? _editBoardDescription;
    private string? _editBoardColor;

    // Modal miembros
    private bool _membersOpen;
    private List<TaskBoardMemberDto> _members = new();
    private string _inviteSearch = "";
    private List<TaskBoardInviteCandidateDto> _inviteCandidates = new();

    protected override async Task OnInitializedAsync()
    {
        await ResolveActorAsync();
        await ReloadAllAsync();
        _loading = false;
    }

    private async Task ResolveActorAsync()
    {
        if (AuthState is null) { return; }
        var st = await AuthState;
        var uid = st.User.FindFirst("user_id")?.Value ?? st.User.FindFirst("sub")?.Value;
        _actorId = Guid.TryParse(uid, out var id) ? id : Guid.Empty;
        _actorDisplayName = st.User.FindFirst("display_name")?.Value
            ?? st.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
            ?? "Usuario";
    }

    private async Task ReloadAllAsync()
    {
        _board = await BoardsSvc.GetBoardAsync(BoardId, _actorId);
        if (_board is null) { _accessDenied = true; return; }
        _columns = (await BoardsSvc.ListColumnsAsync(BoardId, _actorId)).ToList();
        _cards = (await BoardsSvc.ListCardsAsync(BoardId, _actorId)).ToList();
        _boardMembers = (await MembersSvc.ListMembersAsync(BoardId, _actorId)).ToList();
        _boardTags = (await BoardsSvc.ListBoardTagsAsync(BoardId, _actorId)).ToList();
    }

    // ---- Drag&drop ----

    private void OnDragOver(Guid columnId) { _dragOverColumnId = columnId; }

    private async Task OnDropAsync(Guid columnId)
    {
        if (_draggingCardId is not Guid cid) { return; }
        var newOrder = _cards.Count(c => c.ColumnId == columnId);
        await BoardsSvc.MoveCardAsync(cid, new MoveTaskCardRequest(columnId, newOrder), _actorId, _actorDisplayName);
        _draggingCardId = null;
        await ReloadAllAsync();
    }

    // ---- Columna ----

    private async Task AddColumnAsync()
    {
        if (string.IsNullOrWhiteSpace(_newColName)) { return; }
        await BoardsSvc.CreateColumnAsync(new CreateTaskColumnRequest(BoardId, _newColName, null, false), _actorId);
        _newColOpen = false;
        _newColName = "";
        await ReloadAllAsync();
    }

    // ---- Editar tablero ----

    private void OpenEditBoard()
    {
        if (_board is null) { return; }
        _editBoardName = _board.Name;
        _editBoardDescription = _board.Description;
        _editBoardColor = _board.Color ?? "#3b82f6";
        _editBoardOpen = true;
    }

    private async Task SaveBoardEditAsync()
    {
        if (_board is null) { return; }
        await BoardsSvc.UpdateBoardAsync(BoardId,
            new UpdateTaskBoardRequest(_editBoardName, _editBoardDescription, _editBoardColor, _board.IsArchived),
            _actorId);
        _editBoardOpen = false;
        await ReloadAllAsync();
    }

    // ---- Nueva tarjeta ----

    private void OpenNewCard(Guid columnId)
    {
        _newCardColumnId = columnId;
        _newCardTitle = "";
        _newCardDescription = null;
        _newCardOpen = true;
    }

    private async Task CreateCardAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCardTitle)) { return; }
        await BoardsSvc.CreateCardAsync(
            new CreateTaskCardRequest(BoardId, _newCardColumnId, _newCardTitle, _newCardDescription),
            _actorId, _actorDisplayName);
        _newCardOpen = false;
        await ReloadAllAsync();
    }

    // ---- Card modal ----

    private async Task OpenCardAsync(Guid cardId)
    {
        _cardDetail = await BoardsSvc.GetCardAsync(cardId, _actorId);
        if (_cardDetail is null) { return; }
        _editCardTitle = _cardDetail.Card.Title;
        _editCardDescription = _cardDetail.Card.Description;
        _editCardColor = _cardDetail.Card.Color ?? "#3b82f6";
        _editCardDueDate = _cardDetail.Card.DueAt?.LocalDateTime;
        _cardModalOpen = true;
        _newChecklistText = "";
        _newCommentText = "";
        _newAttUrl = "";
        _newAttName = "";
    }

    private void CloseCardModal() { _cardModalOpen = false; _cardDetail = null; }

    private async Task SaveCardAsync()
    {
        if (_cardDetail is null) { return; }
        DateTimeOffset? due = _editCardDueDate is DateTime dt ? new DateTimeOffset(dt) : null;
        await BoardsSvc.UpdateCardAsync(_cardDetail.Card.Id,
            new UpdateTaskCardRequest(_editCardTitle, _editCardDescription, due, _editCardColor),
            _actorId, _actorDisplayName);
        await RefreshCardAndListAsync();
    }

    private async Task RefreshCardAndListAsync()
    {
        if (_cardDetail is null) { return; }
        _cardDetail = await BoardsSvc.GetCardAsync(_cardDetail.Card.Id, _actorId);
        _cards = (await BoardsSvc.ListCardsAsync(BoardId, _actorId)).ToList();
    }

    // Checklist
    private async Task AddChecklistAsync()
    {
        if (_cardDetail is null || string.IsNullOrWhiteSpace(_newChecklistText)) { return; }
        await BoardsSvc.AddChecklistItemAsync(new AddChecklistItemRequest(_cardDetail.Card.Id, _newChecklistText), _actorId, _actorDisplayName);
        _newChecklistText = "";
        await RefreshCardAndListAsync();
    }
    private async Task ToggleChecklistAsync(TaskCardChecklistItemDto it, bool val)
    {
        await BoardsSvc.UpdateChecklistItemAsync(it.Id, new UpdateChecklistItemRequest(it.Text, val), _actorId, _actorDisplayName);
        await RefreshCardAndListAsync();
    }
    private async Task DeleteChecklistAsync(TaskCardChecklistItemDto it)
    {
        await BoardsSvc.DeleteChecklistItemAsync(it.Id, _actorId);
        await RefreshCardAndListAsync();
    }

    // Comentario
    private async Task AddCommentAsync()
    {
        if (_cardDetail is null || string.IsNullOrWhiteSpace(_newCommentText)) { return; }
        await BoardsSvc.AddCommentAsync(new AddCommentRequest(_cardDetail.Card.Id, _newCommentText), _actorId, _actorDisplayName);
        _newCommentText = "";
        await RefreshCardAndListAsync();
    }

    // Miembros de la tarjeta
    private async Task AssignMemberAsync(TaskBoardMemberDto candidate)
    {
        if (_cardDetail is null) { return; }
        await BoardsSvc.AssignMemberToCardAsync(new AssignMemberRequest(_cardDetail.Card.Id, candidate.PlatformUserId), _actorId, _actorDisplayName);
        await RefreshCardAndListAsync();
    }
    private async Task UnassignMemberAsync(TaskCardMemberDto mem)
    {
        if (_cardDetail is null) { return; }
        await BoardsSvc.UnassignMemberFromCardAsync(_cardDetail.Card.Id, mem.PlatformUserId, _actorId, _actorDisplayName);
        await RefreshCardAndListAsync();
    }

    // Adjuntos
    private async Task AddAttachmentAsync()
    {
        if (_cardDetail is null || string.IsNullOrWhiteSpace(_newAttUrl)) { return; }
        var name = string.IsNullOrWhiteSpace(_newAttName) ? _newAttUrl : _newAttName;
        await BoardsSvc.AddAttachmentAsync(
            new AddAttachmentRequest(_cardDetail.Card.Id, name, _newAttUrl, null, 0),
            _actorId, _actorDisplayName);
        _newAttUrl = "";
        _newAttName = "";
        await RefreshCardAndListAsync();
    }
    private async Task DeleteAttachmentAsync(TaskCardAttachmentDto att)
    {
        await BoardsSvc.DeleteAttachmentAsync(att.Id, _actorId);
        await RefreshCardAndListAsync();
    }

    // Acciones
    private async Task ArchiveCardAsync()
    {
        if (_cardDetail is null) { return; }
        await BoardsSvc.ArchiveCardAsync(_cardDetail.Card.Id, _actorId, _actorDisplayName);
        CloseCardModal();
        await ReloadAllAsync();
    }
    private async Task DeleteCardAsync()
    {
        if (_cardDetail is null) { return; }
        await BoardsSvc.DeleteCardAsync(_cardDetail.Card.Id, _actorId);
        CloseCardModal();
        await ReloadAllAsync();
    }

    // ---- Miembros del tablero ----

    private async Task OpenMembers()
    {
        _members = (await MembersSvc.ListMembersAsync(BoardId, _actorId)).ToList();
        _inviteSearch = "";
        _inviteCandidates = _board?.IsOwner == true
            ? (await MembersSvc.ListInviteCandidatesAsync(BoardId, _actorId)).Take(20).ToList()
            : new();
        _membersOpen = true;
    }

    private async Task OnInviteSearchKeyupAsync(KeyboardEventArgs e)
    {
        _inviteCandidates = (await MembersSvc.ListInviteCandidatesAsync(BoardId, _actorId, _inviteSearch)).Take(20).ToList();
    }

    private async Task InviteAsync(TaskBoardInviteCandidateDto candidate)
    {
        await MembersSvc.InviteMemberAsync(new InviteMemberRequest(BoardId, candidate.PlatformUserId), _actorId);
        _members = (await MembersSvc.ListMembersAsync(BoardId, _actorId)).ToList();
        _inviteCandidates = (await MembersSvc.ListInviteCandidatesAsync(BoardId, _actorId, _inviteSearch)).Take(20).ToList();
        _boardMembers = _members;
        _board = await BoardsSvc.GetBoardAsync(BoardId, _actorId);
    }

    private async Task RemoveMemberAsync(TaskBoardMemberDto m)
    {
        if (m.IsOwner) { return; }
        await MembersSvc.RemoveMemberAsync(BoardId, m.PlatformUserId, _actorId);
        _members = (await MembersSvc.ListMembersAsync(BoardId, _actorId)).ToList();
        _inviteCandidates = (await MembersSvc.ListInviteCandidatesAsync(BoardId, _actorId, _inviteSearch)).Take(20).ToList();
        _boardMembers = _members;
        _board = await BoardsSvc.GetBoardAsync(BoardId, _actorId);
    }

    // ---- Trello-like modal: inline title/desc + popovers + tags catalogo ----

    private void CloseAllPopovers()
    {
        _showMembersPop = _showTagsPop = _showDatePop = _showColorPop = _showMovePop = false;
    }

    private void TogglePopover(string which)
    {
        var wasMembers = _showMembersPop;
        var wasTags = _showTagsPop;
        var wasDate = _showDatePop;
        var wasColor = _showColorPop;
        var wasMove = _showMovePop;
        CloseAllPopovers();
        _showChecklistAdd = false;
        switch (which)
        {
            case "members": _showMembersPop = !wasMembers; break;
            case "tags":    _showTagsPop    = !wasTags; break;
            case "date":    _showDatePop    = !wasDate; break;
            case "color":   _showColorPop   = !wasColor; break;
            case "move":    _showMovePop    = !wasMove; break;
        }
    }

    private async Task SaveTitleAsync()
    {
        if (_cardDetail is null || string.IsNullOrWhiteSpace(_editTitle)) { return; }
        var due = _cardDetail.Card.DueAt;
        await BoardsSvc.UpdateCardAsync(_cardDetail.Card.Id,
            new UpdateTaskCardRequest(_editTitle, _cardDetail.Card.Description, due, _cardDetail.Card.Color),
            _actorId, _actorDisplayName);
        _editingTitle = false;
        await RefreshCardAndListAsync();
    }

